# kerf-app/.env.local.example — TEMPLATE ONLY. Copy to .env.local and fill in real values.
#
# Per Architecture v3.5 §28.1 W4 (Tier 1 hosting migration to Groq) +
# Charter Patch 002 v0.2 AT-019 + standing rule that Christian writes secrets
# (Claude Code touches consumer code, never the env file itself).
#
# .env.local is GITIGNORED — never commit it. This .example file is tracked
# so future operators / coworkers know what variables the runtime expects.

# ──────────────────────────────────────────────────────────────────────────
# Tier 1 — Groq Llama 4 Scout (primary; replaces stale Mac Studio M4 Max line)
# Approved hosted endpoint per D-023 + Gate #15 — production tenant Decision
# Packets route here. Model: meta-llama/llama-4-scout-17b-16e-instruct.
# ──────────────────────────────────────────────────────────────────────────

# Source the API key from 1Password (Kerf Engineering vault) after standing up
# the Groq account per _docs/operations/Kerf_Groq_Hosting_Setup_Guide.md §1.
# Do NOT paste a real key into this .example file.
GROQ_API_KEY=gsk_REPLACE_ME_WITH_REAL_KEY_FROM_1PASSWORD

# Groq's OpenAI-compatible REST base. Stable; rarely changes.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ──────────────────────────────────────────────────────────────────────────
# Tier 1.5 — GPT-OSS 120B on Groq (escalation tier; replaces deprecated Maverick)
# Same Groq account / API key as Tier 1. Different model id selected at call site.
# ──────────────────────────────────────────────────────────────────────────

# Model id is selected by the model adapter, not env-var. No additional
# env vars needed for Tier 1.5 routing — same GROQ_API_KEY applies.

# ──────────────────────────────────────────────────────────────────────────
# Frontier — Anthropic Claude (V13 escalation trigger; L4 altitude routing)
# Per D-023 + Architecture v3.5 §16. Required when V13 fires. V13 may already
# be wired in the W2 batch; uncomment + supply the key when the first frontier
# escalation actually routes (don't want a runtime failure on first L4 packet).
# Anthropic keys start `sk-ant-`. Source from 1Password Kerf Engineering vault.
# ──────────────────────────────────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME_WITH_REAL_KEY_FROM_1PASSWORD
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────────
# Mac mini dev endpoint (DEV ONLY per Gate #15 — never routes production tenant
# Decision Packets; approved_for_production_tenant_data: false in endpoint config)
# ──────────────────────────────────────────────────────────────────────────

# OpenAI-compatible base for the Mac mini's local Qwen-7B (or successor).
# Default assumes the dev box runs llama.cpp / vllm on its LAN address.
# Leave commented if no Mac mini dev endpoint is in use this session.
# MAC_MINI_DEV_BASE_URL=http://ggr-mac-mini.local:11434/v1
# MAC_MINI_DEV_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Smoke benchmark harness — run_kerf_local_llm_smoke_remote.py
# Pointed at whichever endpoint is being benchmarked (Groq Scout for W4).
# Set inline at script invocation OR exported here when running locally.
# ──────────────────────────────────────────────────────────────────────────

KERF_BENCHMARK_BASE_URL=https://api.groq.com/openai/v1
KERF_BENCHMARK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Paste the same Groq key value here directly. Do NOT use $GROQ_API_KEY
# substitution — only shell-source loaders expand `$VAR`; dotenv-style
# loaders (Node.js, most env libs) treat the value as a literal string.
# Duplicating the raw value avoids the shell-vs-loader ambiguity.
KERF_BENCHMARK_API_KEY=gsk_REPLACE_ME_WITH_REAL_KEY_FROM_1PASSWORD

# ──────────────────────────────────────────────────────────────────────────
# After editing:
# 1. Save as .env.local (drop the .example suffix)
# 2. Verify with: git status                  → .env.local should NOT appear
# 3. Verify with: git check-ignore .env.local → should print '.env.local'
# 4. Run typecheck + tests to confirm consumer code reads vars correctly
# ──────────────────────────────────────────────────────────────────────────
