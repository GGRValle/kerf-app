---
// Right Hand Voice Overlay — global listening overlay (the Speak front door).
//
// Spec: docs/architecture/right_hand_voice_overlay_spec_2026-05-29.md
//   §0  Option B (live realtime caption) locked as V1.
//   §4  bounded window (silence-commit / idle-close / hard-cap / teardown).
//   §9  two-lane consequence gating (LIVE interim navigations · COMMIT durable).
//   §10 consent gating (realtime for consenting tenants · Groq fallback else).
//   §11 realtime safety guardrails.
//
// This component renders ONCE (in Layout.astro). Speak triggers carry
// `data-rh-speak` and open this overlay; their `href="/right-hand"` remains the
// no-JS fallback. The overlay produces the transcript that feeds the Phase 1H
// draft path — it does not itself persist or synthesize anything.
import { createLayoutContext } from '../lib/createLayoutContext.js';
const { t } = createLayoutContext();
---

<div
  class="rhvo"
  id="rh-voice-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="rhvo-title"
  data-state="idle"
  data-title={t('rh_voice.title')}
  data-listening={t('rh_voice.status_listening')}
  data-fallback={t('rh_voice.status_fallback')}
  data-transcribing={t('rh_voice.status_transcribing')}
  data-capped={t('rh_voice.status_capped')}
  data-clarify={t('rh_voice.status_clarify')}
  data-unavailable={t('rh_voice.status_unavailable')}
  data-micdenied={t('rh_voice.status_mic_denied')}
  data-sorting={t('rh_voice.status_sorting')}
  data-retry={t('rh_voice.status_retry')}
  data-head-sorting={t('rh_voice.head_sorting')}
  data-head-confirm={t('rh_voice.head_confirm')}
  data-head-resolved={t('rh_voice.head_resolved')}
  data-resolved-ready={t('rh_voice.resolved_ready_to_save')}
  hidden
>
  <div class="rhvo__backdrop" data-rhvo-dismiss></div>
  <div class="rhvo__panel" role="document">
    <div class="rhvo__indicator" aria-hidden="true">
      <span class="rhvo__pulse"></span>
      <span class="rhvo__mic">
        <svg viewBox="0 0 24 24" aria-hidden="true"
          ><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"></path><path
            d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"
          ></path></svg
        >
      </span>
    </div>

    <div class="rhvo__head">
      <p class="rhvo__eyebrow" id="rhvo-title">{t('rh_voice.title')}</p>
      <span class="rhvo__timer" id="rhvo-timer" aria-hidden="true">0:00</span>
    </div>
    <p class="rhvo__status" id="rhvo-status" aria-live="polite">{t('rh_voice.status_listening')}</p>

    <div class="rhvo__meter" id="rhvo-meter" aria-hidden="true">
      <span class="rhvo__bar"></span><span class="rhvo__bar"></span><span class="rhvo__bar"></span
      ><span class="rhvo__bar"></span><span class="rhvo__bar"></span><span class="rhvo__bar"></span
      ><span class="rhvo__bar"></span>
    </div>

    <div class="rhvo__caption" id="rhvo-caption" aria-live="polite" data-empty="true">
      <span class="rhvo__caption-label">{t('rh_voice.caption_label')}</span>
      <span class="rhvo__caption-text" id="rhvo-caption-text"></span
      ><span class="rhvo__cursor" id="rhvo-cursor" aria-hidden="true"></span>
    </div>

    <div class="rhvo__confirm" id="rhvo-confirm" hidden>
      <div class="rhvo__row">
        <span class="rhvo__k">{t('rh_voice.caption_label')}</span>
        <span class="rhvo__v" id="rhvo-confirm-heard"></span>
      </div>
      <div class="rhvo__row">
        <span class="rhvo__k">{t('rh_voice.confirm_routed_label')}</span>
        <span class="rhvo__v" id="rhvo-confirm-routed">{t('rh_voice.confirm_routed')}</span>
      </div>
      <div class="rhvo__row">
        <span class="rhvo__k">{t('rh_voice.confirm_creating_label')}</span>
        <span class="rhvo__v" id="rhvo-confirm-creating">{t('rh_voice.confirm_creating')}</span>
      </div>
      <div class="rhvo__row">
        <span class="rhvo__k">{t('rh_voice.confirm_needs_label')}</span>
        <span class="rhvo__v rhvo__v--prompt" id="rhvo-confirm-prompt">{t('rh_voice.confirm_prompt')}</span>
      </div>
    </div>

    <div class="rhvo__resolution" id="rhvo-resolution" hidden>
      <p class="rhvo__resolution-prompt">{t('rh_voice.resolved_prompt')}</p>
      <div class="rhvo__moves">
        <button type="button" class="rhvo__move" data-move="add_photo">{t('rh_voice.move_add_photo')}</button>
        <button type="button" class="rhvo__move" data-move="open_job">{t('rh_voice.move_open_job')}</button>
        <button type="button" class="rhvo__move" data-move="review_estimate">{t('rh_voice.move_review_estimate')}</button>
        <button type="button" class="rhvo__move rhvo__move--primary" data-move="go_home">{t('rh_voice.move_go_home')}</button>
      </div>
    </div>

    <p class="rhvo__authority" id="rhvo-authority">{t('rh_voice.authority_deterministic')}</p>

    <div class="rhvo__actions">
      <button type="button" class="rhvo__btn rhvo__btn--ghost" id="rhvo-cancel" data-rhvo-dismiss>
        {t('rh_voice.action_cancel')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--primary" id="rhvo-done">
        {t('rh_voice.action_stop')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--primary" id="rhvo-continue" hidden>
        {t('rh_voice.action_continue')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--ghost" id="rhvo-notthat" hidden>
        {t('rh_voice.action_not_that')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--save" id="rhvo-save" hidden>
        {t('rh_voice.action_save')}
      </button>
    </div>
  </div>
</div>

<script>
  import {
    canRouteFromInterim,
    requiresCommittedTranscript,
    classifyTranscriptIntent,
    liveRouteFor,
    type VoiceIntent,
  } from '../../voice/realtime/voiceActionGate.js';
  import {
    buildTurnResolutionPacket,
    serializeTurnResolution,
    nextMovesFor,
    TURN_RESOLUTION_SESSION_KEY,
    type NextMove,
  } from '../../voice/realtime/turnResolution.js';

  type OverlayState = 'idle' | 'listening' | 'sorting' | 'confirm' | 'resolved' | 'fallback' | 'capped';

  // Operator-facing copy is rendered into data-* on the overlay (resolved via
  // t() at render) so the script stays i18n-correct. The inline English here is
  // a last-resort default only — it is always status, never a fake transcript.
  const overlay = document.getElementById('rh-voice-overlay');
  if (overlay) {
    const titleEl = document.getElementById('rhvo-title');
    const timerEl = document.getElementById('rhvo-timer');
    const statusEl = document.getElementById('rhvo-status');
    const captionWrap = document.getElementById('rhvo-caption');
    const captionEl = document.getElementById('rhvo-caption-text');
    const meterEl = document.getElementById('rhvo-meter');
    const meterBars = meterEl ? Array.from(meterEl.querySelectorAll<HTMLElement>('.rhvo__bar')) : [];
    const confirmHeardEl = document.getElementById('rhvo-confirm-heard');
    const confirmRoutedEl = document.getElementById('rhvo-confirm-routed');
    const confirmCreatingEl = document.getElementById('rhvo-confirm-creating');
    const confirmPromptEl = document.getElementById('rhvo-confirm-prompt');
    const cancelBtn = document.getElementById('rhvo-cancel') as HTMLButtonElement | null;
    const doneBtn = document.getElementById('rhvo-done') as HTMLButtonElement | null;
    const continueBtn = document.getElementById('rhvo-continue') as HTMLButtonElement | null;
    const saveBtn = document.getElementById('rhvo-save') as HTMLButtonElement | null;
    const notThatBtn = document.getElementById('rhvo-notthat') as HTMLButtonElement | null;

    // Bounded-window defaults (§4). Overwritten by the server response when a
    // realtime session is minted, so client and session agree.
    let silenceCommitMs = 2500;
    let idleCloseMs = 12000;
    let hardCapMs = 75000;
    const TRANSCRIBE_TIMEOUT_MS = 12000;

    let state: OverlayState = 'idle';
    let mediaStream: MediaStream | null = null;
    let audioCtx: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let rafId = 0;
    let pc: RTCPeerConnection | null = null;
    let dc: RTCDataChannel | null = null;
    let recorder: MediaRecorder | null = null;
    let recChunks: Blob[] = [];
    let silenceTimer = 0;
    let idleTimer = 0;
    let hardCapTimer = 0;
    let routedLive = false; // a LIVE intent already navigated this turn
    let lastInterim = '';
    let timerId = 0;
    let elapsedSec = 0;
    let awaitingConfirm = false; // durable confirm open — pause STT processing
    let parkedTranscript = ''; // committed durable transcript awaiting Save
    let currentMoves: readonly NextMove[] = []; // resolved-state next moves
    let resolvedSurface = '/'; // default landing after a resolved turn

    const setState = (next: OverlayState) => {
      state = next;
      overlay.dataset.state = next;
    };
    const setHeading = (text: string) => {
      if (titleEl) titleEl.textContent = text;
    };
    const setStatus = (text: string) => {
      if (statusEl) statusEl.textContent = text;
    };
    const setCaption = (text: string) => {
      // REAL transcript only — never invented. Empty until STT produces words.
      if (captionEl) captionEl.textContent = text;
      if (captionWrap) captionWrap.dataset.empty = text.trim().length === 0 ? 'true' : 'false';
    };

    // ── Elapsed timer (mm:ss) — starts on overlay open, ticks every second,
    // cleared in teardown (§4 bounded window is the real guard; this is display).
    const fmtClock = (s: number) => `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
    const startTimer = () => {
      window.clearInterval(timerId);
      elapsedSec = 0;
      if (timerEl) timerEl.textContent = fmtClock(0);
      timerId = window.setInterval(() => {
        elapsedSec += 1;
        if (timerEl) timerEl.textContent = fmtClock(elapsedSec);
      }, 1000);
    };
    const stopTimer = () => {
      window.clearInterval(timerId);
    };

    // ── Action-button visibility per state. Stop is the explicit-commit primary
    // while listening; Save/Not that own the confirm trust loop; Continue owns
    // the capped state. (F-RH1.)
    const showActions = (mode: 'listening' | 'confirm' | 'capped' | 'resolved') => {
      // Resolved owns its own next-move buttons (.rhvo__moves); every standard
      // action button is hidden so there is no competing primary.
      if (cancelBtn) cancelBtn.hidden = mode === 'confirm' || mode === 'resolved';
      if (doneBtn) doneBtn.hidden = mode !== 'listening';
      if (continueBtn) continueBtn.hidden = mode !== 'capped';
      if (saveBtn) saveBtn.hidden = mode !== 'confirm';
      if (notThatBtn) notThatBtn.hidden = mode !== 'confirm';
    };

    const clearTimers = () => {
      window.clearTimeout(silenceTimer);
      window.clearTimeout(idleTimer);
      window.clearTimeout(hardCapTimer);
    };

    const teardown = () => {
      clearTimers();
      stopTimer();
      if (rafId) cancelAnimationFrame(rafId);
      rafId = 0;
      try { dc?.close(); } catch { /* noop */ }
      try { pc?.close(); } catch { /* noop */ }
      try {
        if (recorder && recorder.state !== 'inactive') recorder.stop();
      } catch { /* noop */ }
      try { void audioCtx?.close(); } catch { /* noop */ }
      mediaStream?.getTracks().forEach((track) => track.stop());
      mediaStream = null;
      audioCtx = null;
      analyser = null;
      pc = null;
      dc = null;
      recorder = null;
      recChunks = [];
    };

    const releaseListeningResources = () => {
      clearTimers();
      stopTimer();
      if (rafId) cancelAnimationFrame(rafId);
      rafId = 0;
      try { dc?.close(); } catch { /* noop */ }
      try { pc?.close(); } catch { /* noop */ }
      try { void audioCtx?.close(); } catch { /* noop */ }
      mediaStream?.getTracks().forEach((track) => track.stop());
      mediaStream = null;
      audioCtx = null;
      analyser = null;
      pc = null;
      dc = null;
    };

    const closeOverlay = () => {
      teardown();
      setState('idle');
      overlay.hidden = true;
    };

    // ── Routing (no PII in URLs — enums/ids only; transcript stashed in
    // sessionStorage for the downstream 1H surface to consume). ──────────────
    const stashCommitted = (text: string) => {
      try {
        sessionStorage.setItem('kerf.voiceCommit', JSON.stringify({ text, at: Date.now() }));
      } catch { /* storage may be unavailable; navigation still works */ }
    };

    const navigate = (href: string, options: { resume?: boolean } = {}) => {
      if (options.resume) {
        try {
          sessionStorage.setItem('kerf.voiceResume', JSON.stringify({ at: Date.now(), href }));
        } catch { /* storage may be unavailable; navigation still works */ }
      }
      teardown();
      window.location.href = href;
    };

    const routeLive = (intent: VoiceIntent): boolean => {
      const route = liveRouteFor(intent);
      if (route) {
        navigate(`${route}?src=voice`, { resume: intent !== 'open_field_capture' });
        return true;
      }
      if (intent === 'status_question') {
        // No specific project bound from deterministic keywords — land on the
        // real read-only projects surface rather than guess a project id.
        navigate('/projects?src=voice', { resume: true });
        return true;
      }
      return false;
    };

    // ── Trust loop (F-RH1): durable intents NEVER auto-navigate. They surface a
    // four-question confirmation (heard · routed · creating · needs you) and wait
    // for the operator. The overlay persists NOTHING; Save only stashes the
    // transcript and hands off to the validated Field Capture path. ────────────
    const enterConfirm = (text: string) => {
      awaitingConfirm = true;
      parkedTranscript = text;
      const intent = classifyTranscriptIntent(text);
      const trp = buildTurnResolutionPacket({ heardText: text, intent });
      // Mic off while the operator decides (privacy / bounded window §4). Not that
      // → beginSession() re-acquires from scratch, same as Continue.
      teardown();
      setState('confirm');
      setHeading(overlay.dataset.headConfirm ?? 'Ready for you');
      setStatus('');
      if (timerEl) timerEl.textContent = '';
      if (confirmHeardEl) confirmHeardEl.textContent = text;
      if (confirmRoutedEl) confirmRoutedEl.textContent = trp.context_hypothesis.routed_label;
      if (confirmCreatingEl) confirmCreatingEl.textContent = trp.context_hypothesis.preparing_label;
      if (confirmPromptEl) confirmPromptEl.textContent = trp.context_hypothesis.prompt;
      showActions('confirm');
    };

    const SORTING_BEAT_MS = 700;
    const enterSorting = (text: string) => {
      // Guard immediately so the still-draining session can't re-commit mid-beat.
      awaitingConfirm = true;
      setState('sorting');
      setHeading(overlay.dataset.headSorting ?? 'Heard you');
      setStatus(overlay.dataset.sorting ?? 'Got it. Sorting this…');
      setCaption(text);
      window.setTimeout(() => enterConfirm(text), SORTING_BEAT_MS);
    };

    const routeCommitted = (intent: VoiceIntent, text: string) => {
      const cleanText = text.trim();
      if (requiresCommittedTranscript(intent)) {
        // Durable intent: confirm in-overlay first (trust loop). No navigation,
        // no persistence here — that happens only on Save, via the existing
        // validated capture path.
        enterSorting(cleanText);
        return;
      }
      if (canRouteFromInterim(intent)) {
        if (!routedLive) routeLive(intent);
        return;
      }
      if (cleanText.length > 0) {
        // A useful field note does not need to contain a routing keyword to be
        // worth saving. Default meaningful committed speech into the same
        // operator-confirmed note path instead of dead-ending on "no action."
        enterSorting(cleanText);
        return;
      }
      // Unclassified — keep the overlay open and prompt once.
      setCaption(cleanText);
      setStatus(overlay.dataset.clarify ?? 'I didn’t catch an action — say it once more?');
      armIdleClose();
    };

    const returnToListening = () => {
      // "Not that" — discard the parked transcript, resume listening. No nav.
      awaitingConfirm = false;
      parkedTranscript = '';
      routedLive = false;
      lastInterim = '';
      setCaption('');
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(overlay.dataset.listening ?? 'Listening…');
      showActions('listening');
      startTimer();
      void beginSession();
    };

    // ── Turn resolution (brief 2026-05-31): Save does NOT dump the user into a
    // fresh Field Capture mic page. It closes the turn into a Turn Resolution
    // Packet, shows an honest next-step response, and lands the operator on Home
    // (the attention queue, with the result folded in). The overlay performs NO
    // durable write — so the TRP is `ready_to_save` (session-backed), never a
    // false `handled` (non-negotiable #10). ────────────────────────────────────
    const resolveTurn = (text: string) => {
      const clean = text.trim();
      const intent = classifyTranscriptIntent(clean);
      const trp = buildTurnResolutionPacket({ heardText: clean, intent });
      try {
        sessionStorage.setItem(TURN_RESOLUTION_SESSION_KEY, serializeTurnResolution(trp));
      } catch { /* storage may be unavailable; the next-step buttons still work */ }
      // Stash the transcript too so an explicit "Add a photo" hand-off to Field
      // Capture can pick the note up. This is NOT a durable write.
      stashCommitted(clean);
      currentMoves = nextMovesFor(trp);
      resolvedSurface = trp.next_surface;
      teardown();
      awaitingConfirm = false;
      parkedTranscript = '';
      setState('resolved');
      setHeading(overlay.dataset.headResolved ?? 'Here’s what’s next');
      // Honest result copy: session-backed, durable write not yet run.
      setStatus(trp.attention_artifact.why || overlay.dataset.resolvedReady || 'Ready to route.');
      if (timerEl) timerEl.textContent = '';
      showActions('resolved');
    };

    const routeMove = (id: string | null) => {
      const move = currentMoves.find((m) => m.id === id) ?? null;
      navigate(move ? move.route : resolvedSurface);
    };

    // Backdrop / Escape: in the resolved state this lands Home (the default
    // landing with the result folded in), never a dead stay-on-page.
    const dismissOverlay = () => {
      if (state === 'resolved') {
        navigate(resolvedSurface);
        return;
      }
      closeOverlay();
    };

    // ── Interim words: may ONLY fire reversible LIVE navigations (§9). ───────
    const onInterim = (text: string) => {
      if (awaitingConfirm) return; // confirm trust loop owns the turn
      lastInterim = text;
      setCaption(text);
      armIdleClose();
      if (routedLive) return;
      const intent = classifyTranscriptIntent(text);
      if (canRouteFromInterim(intent)) {
        routedLive = routeLive(intent);
      }
    };

    // ── Committed transcript: the only input allowed to drive durable actions.
    const onCommitted = (text: string) => {
      if (awaitingConfirm) return; // already parked for confirm; ignore stragglers
      const finalText = text.trim().length > 0 ? text : lastInterim;
      setCaption(finalText);
      const intent = classifyTranscriptIntent(finalText);
      routeCommitted(intent, finalText);
    };

    const finishCurrentTurn = () => {
      if (recorder && recorder.state !== 'inactive') {
        setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
        recorder.stop();
        releaseListeningResources();
        return;
      }
      releaseListeningResources();
      const interim = lastInterim.trim();
      if (interim.length === 0) {
        setState('capped');
        setStatus(overlay.dataset.clarify ?? 'I didn’t catch an action — say it once more?');
        showActions('capped');
        return;
      }
      const intent = classifyTranscriptIntent(interim);
      if (canRouteFromInterim(intent)) {
        routedLive = routeLive(intent);
        return;
      }
      setCaption(interim);
      // Durable OR unclassified-but-useful speech → confirm trust loop (Save /
      // Not that), never a Cancel/Stop dead-end. This closes the stale
      // "I didn't catch an action" trap on the Stop path (brief stale-screen fix).
      enterSorting(interim);
    };

    // ── Bounded window timers (§4) ──────────────────────────────────────────
    const armHardCap = () => {
      window.clearTimeout(hardCapTimer);
      hardCapTimer = window.setTimeout(() => {
        setState('capped');
        setStatus(overlay.dataset.capped ?? 'Paused — tap Continue to keep going.');
        showActions('capped');
        // Hard cap reached: fully release the mic + audio graph (bounded-window /
        // privacy rule §4) by reusing the shared teardown() — not a hand-rolled
        // partial copy. Keep the overlay + Continue button visible; Continue →
        // beginSession() re-acquires the mic from scratch via getUserMedia.
        teardown();
      }, hardCapMs);
    };
    const armIdleClose = () => {
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => closeOverlay(), idleCloseMs);
    };

    const recoverVoiceTurn = (message?: string) => {
      awaitingConfirm = false;
      parkedTranscript = '';
      lastInterim = '';
      teardown();
      setState('capped');
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setCaption('');
      setStatus(message ?? overlay.dataset.retry ?? 'I couldn’t finish that. Tap Continue and say it again.');
      showActions('capped');
    };

    // ── VAD via Web Audio AnalyserNode: drive the level meter + silence commit.
    const SPEECH_RMS = 0.025;
    const BAR_WEIGHTS = [0.6, 0.82, 1, 1.18, 1, 0.82, 0.6]; // center-weighted VU
    let speaking = false;
    const startMeter = (onSilenceCommit: () => void) => {
      if (!mediaStream) return;
      audioCtx = new (window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext)();
      const src = audioCtx.createMediaStreamSource(mediaStream);
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 512;
      src.connect(analyser);
      const buf = new Uint8Array(analyser.frequencyBinCount);
      const tick = () => {
        if (!analyser) return;
        analyser.getByteTimeDomainData(buf);
        let sum = 0;
        for (let i = 0; i < buf.length; i += 1) {
          const v = (buf[i]! - 128) / 128;
          sum += v * v;
        }
        const rms = Math.sqrt(sum / buf.length);
        // Discrete field-green VU bars driven by the real rms (F-RH1). Center
        // bars weighted taller; floored so they read as present, not dead.
        const level = Math.min(1, rms * 6);
        for (let b = 0; b < meterBars.length; b += 1) {
          const weight = BAR_WEIGHTS[b] ?? 1;
          const h = Math.max(0.18, Math.min(1, level * weight));
          meterBars[b]!.style.transform = `scaleY(${h})`;
        }
        if (rms >= SPEECH_RMS) {
          speaking = true;
          window.clearTimeout(silenceTimer);
          window.clearTimeout(idleTimer);
        } else if (speaking) {
          window.clearTimeout(silenceTimer);
          silenceTimer = window.setTimeout(() => {
            speaking = false;
            onSilenceCommit();
          }, silenceCommitMs);
        }
        rafId = requestAnimationFrame(tick);
      };
      rafId = requestAnimationFrame(tick);
    };

    // ── Groq record-then-send fallback (no consent / realtime unavailable). ──
    const chooseMime = () => {
      if (!('MediaRecorder' in window)) return '';
      const opts = ['audio/mp4', 'audio/aac', 'audio/webm;codecs=opus', 'audio/webm'];
      return opts.find((o) => MediaRecorder.isTypeSupported(o)) ?? '';
    };
    const startFallback = () => {
      setState('fallback');
      setStatus(overlay.dataset.fallback ?? 'Listening — transcribes when you pause.');
      if (!mediaStream || !('MediaRecorder' in window)) {
        setStatus(overlay.dataset.unavailable ?? 'Voice isn’t available here — open Right Hand to type.');
        return;
      }
      const mime = chooseMime();
      recorder = new MediaRecorder(mediaStream, mime ? { mimeType: mime } : undefined);
      recChunks = [];
      recorder.addEventListener('dataavailable', (e) => {
        if (e.data.size > 0) recChunks.push(e.data);
      });
      recorder.addEventListener('stop', async () => {
        if (recChunks.length === 0) {
          recoverVoiceTurn();
          return;
        }
        const blob = new Blob(recChunks, { type: recorder?.mimeType || 'audio/webm' });
        recChunks = [];
        setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), TRANSCRIBE_TIMEOUT_MS);
        try {
          const res = await fetch('/api/v1/transcribe', {
            method: 'POST',
            headers: { 'Content-Type': blob.type || 'audio/webm' },
            body: blob,
            signal: controller.signal,
          });
          if (!res.ok) {
            recoverVoiceTurn(overlay.dataset.unavailable ?? 'Couldn’t transcribe — open Right Hand to type.');
            return;
          }
          const data = (await res.json()) as { transcript?: string };
          const transcript = (data.transcript ?? '').trim();
          if (transcript.length === 0) {
            recoverVoiceTurn();
            return;
          }
          onCommitted(transcript);
        } catch {
          recoverVoiceTurn();
        } finally {
          window.clearTimeout(timeout);
        }
      });
      recorder.start();
      startMeter(() => {
        // On 2–3s silence: stop the clip → POST → committed transcript.
        if (recorder && recorder.state !== 'inactive') recorder.stop();
      });
    };

    // ── Realtime (consenting tenant): WebRTC transcription-only session. ─────
    const startRealtime = async (clientSecret: string, model: string) => {
      try {
        pc = new RTCPeerConnection();
        if (mediaStream) {
          for (const track of mediaStream.getAudioTracks()) pc.addTrack(track, mediaStream);
        }
        dc = pc.createDataChannel('oai-events');
        dc.addEventListener('message', (e) => {
          try {
            const evt = JSON.parse(e.data as string) as { type?: string; delta?: string; transcript?: string };
            if (evt.type?.includes('input_audio_transcription') && typeof evt.delta === 'string') {
              onInterim(`${lastInterim}${evt.delta}`);
            } else if (
              evt.type?.includes('input_audio_transcription') &&
              evt.type.includes('completed') &&
              typeof evt.transcript === 'string'
            ) {
              onCommitted(evt.transcript);
              lastInterim = '';
            }
          } catch { /* ignore non-JSON frames */ }
        });
        const offer = await pc.createOffer();
        await pc.setLocalDescription(offer);
        const sdpRes = await fetch(`https://api.openai.com/v1/realtime?model=${encodeURIComponent(model)}`, {
          method: 'POST',
          headers: { Authorization: `Bearer ${clientSecret}`, 'Content-Type': 'application/sdp' },
          body: offer.sdp ?? '',
        });
        if (!sdpRes.ok) {
          startFallback();
          return;
        }
        const answer = { type: 'answer' as const, sdp: await sdpRes.text() };
        await pc.setRemoteDescription(answer);
        setState('listening');
        startMeter(() => {
          // Silence after speech: the realtime server VAD commits the final
          // transcript over the data channel. Re-arm idle close so that if no
          // `completed` event ever arrives, the session closes honestly at the
          // idle window instead of sitting open to the hard cap.
          setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
          armIdleClose();
        });
      } catch {
        startFallback();
      }
    };

    const beginSession = async () => {
      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
      } catch {
        setStatus(overlay.dataset.micdenied ?? 'Microphone is off — enable it or open Right Hand to type.');
        return;
      }
      armHardCap();
      armIdleClose();
      // Ask the server whether this tenant gets realtime. Consent + config are
      // server-authoritative; 403/503 → honest Groq fallback.
      try {
        const res = await fetch('/api/v1/realtime/transcription-session', { method: 'POST' });
        if (res.ok) {
          const data = (await res.json()) as {
            client_secret?: string;
            model?: string;
            session?: { bounded_window?: { silenceCommitMs?: number; idleCloseMs?: number; hardCapMs?: number } };
          };
          const bw = data.session?.bounded_window;
          if (bw) {
            silenceCommitMs = bw.silenceCommitMs ?? silenceCommitMs;
            idleCloseMs = bw.idleCloseMs ?? idleCloseMs;
            hardCapMs = bw.hardCapMs ?? hardCapMs;
            armHardCap();
            armIdleClose();
          }
          if (data.client_secret && data.model) {
            await startRealtime(data.client_secret, data.model);
            return;
          }
        }
        // 403 (no consent) / 503 (not configured) / malformed → fallback.
        startFallback();
      } catch {
        startFallback();
      }
    };

    const openOverlay = () => {
      if (!overlay.hidden) return;
      routedLive = false;
      lastInterim = '';
      awaitingConfirm = false;
      parkedTranscript = '';
      setCaption('');
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(overlay.dataset.listening ?? 'Listening…');
      showActions('listening');
      overlay.hidden = false;
      startTimer();
      void beginSession();
    };

    // Wire Speak triggers: intercept, open overlay; href is the no-JS fallback.
    document.querySelectorAll<HTMLElement>('[data-rh-speak]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const speakEvent = new CustomEvent('kerf:rh-speak', { cancelable: true });
        if (!window.dispatchEvent(speakEvent)) return;
        openOverlay();
      });
    });

    overlay.querySelectorAll('[data-rhvo-dismiss]').forEach((el) => {
      el.addEventListener('click', () => dismissOverlay());
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) dismissOverlay();
    });
    doneBtn?.addEventListener('click', finishCurrentTurn);
    continueBtn?.addEventListener('click', () => {
      awaitingConfirm = false;
      parkedTranscript = '';
      lastInterim = '';
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(overlay.dataset.listening ?? 'Listening…');
      showActions('listening');
      startTimer();
      void beginSession();
    });
    // Save: RESOLVE the turn (TRP + honest result + next moves) — it does NOT
    // dump the user onto the Field Capture mic page (brief non-negotiables #1/#2).
    saveBtn?.addEventListener('click', () => {
      resolveTurn(parkedTranscript);
    });
    notThatBtn?.addEventListener('click', returnToListening);
    // Resolved-state next moves: "Add a photo" is the ONLY one that goes to Field
    // Capture, and only because the operator explicitly chose it (brief §8).
    overlay.querySelectorAll<HTMLElement>('[data-move]').forEach((el) => {
      el.addEventListener('click', () => routeMove(el.getAttribute('data-move')));
    });
    try {
      const resumeRaw = sessionStorage.getItem('kerf.voiceResume');
      if (resumeRaw) {
        sessionStorage.removeItem('kerf.voiceResume');
        window.setTimeout(() => {
          if (overlay.hidden) openOverlay();
        }, 450);
      }
    } catch { /* storage may be unavailable; user can tap Speak again */ }
  }
</script>

