---
// Right Hand Voice Overlay — global listening overlay (the Speak front door).
//
// Spec: docs/architecture/right_hand_voice_overlay_spec_2026-05-29.md
//   §0  Option B (live realtime caption) locked as V1.
//   §4  bounded window (silence-commit / idle-close / hard-cap / teardown).
//   §9  two-lane consequence gating (LIVE interim navigations · COMMIT durable).
//   §10 consent gating (realtime for consenting tenants · Groq fallback else).
//   §11 realtime safety guardrails.
//
// This component renders ONCE (in Layout.astro). Speak triggers carry
// `data-rh-speak` and open this overlay; their `href="/right-hand"` remains the
// no-JS fallback. The overlay produces the transcript that feeds the Phase 1H
// draft path — it does not itself persist or synthesize anything.
import { createLayoutContext } from '../lib/createLayoutContext.js';
const { t } = createLayoutContext();
---

<button class="rhvo-bubble" id="rhvo-bubble" type="button" hidden>Back to the conversation</button>
<div
  class="rhvo"
  id="rh-voice-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="rhvo-title"
  data-state="idle"
  data-typed="false"
  data-has-thread="false"
  data-title={t('rh_voice.title')}
  data-listening={t('rh_voice.status_listening')}
  data-fallback={t('rh_voice.status_fallback')}
  data-transcribing={t('rh_voice.status_transcribing')}
  data-capped={t('rh_voice.status_capped')}
  data-clarify={t('rh_voice.status_clarify')}
  data-unavailable={t('rh_voice.status_unavailable')}
  data-micdenied={t('rh_voice.status_mic_denied')}
  data-sorting={t('rh_voice.status_sorting')}
  data-retry={t('rh_voice.status_retry')}
  data-head-sorting={t('rh_voice.head_sorting')}
  data-head-confirm={t('rh_voice.head_confirm')}
  data-head-resolved={t('rh_voice.head_resolved')}
  data-resolved-ready={t('rh_voice.resolved_ready_to_save')}
  data-commit-pending={t('rh_voice.commit_pending')}
  data-commit-failed={t('rh_voice.commit_failed')}
  data-commit-project-needed={t('rh_voice.commit_project_needed')}
  data-commit-project-not-found={t('rh_voice.commit_project_not_found')}
  data-commit-project-mismatch={t('rh_voice.commit_project_mismatch')}
  data-commit-workspace-needed={t('rh_voice.commit_workspace_needed')}
  data-action-correct={t('rh_voice.action_correct')}
  data-action-keep-talking={t('rh_voice.action_keep_talking')}
  data-action-back={t('rh_voice.action_back')}
  data-action-tell-job={t('rh_voice.action_tell_job')}
  data-action-change-job={t('rh_voice.action_change_job')}
  data-action-save={t('rh_voice.action_save')}
  data-action-save-to={t('rh_voice.action_save_to')}
  data-action-start-intake={t('rh_voice.action_start_intake')}
  data-head-filed={t('rh_voice.head_filed')}
  data-head-filed-generic={t('rh_voice.head_filed_generic')}
  data-filed-prompt={t('rh_voice.filed_prompt')}
  data-keep-talking-prompt={t('rh_voice.keep_talking_prompt')}
  data-mic-toggle-label={t('rh_voice.mic_toggle_label')}
  data-correction-prompt={t('rh_voice.correction_prompt')}
  data-correction-routed={t('rh_voice.correction_routed')}
  data-correction-creating={t('rh_voice.correction_creating')}
  data-correction-needs={t('rh_voice.correction_needs')}
  data-speaker-you={t('rh_voice.speaker_you')}
  data-speaker-right-hand={t('rh_voice.speaker_right_hand')}
  data-reply-job-note-known={t('rh_voice.reply_job_note_known')}
  data-reply-job-note-unknown={t('rh_voice.reply_job_note_unknown')}
  data-reply-estimate-known={t('rh_voice.reply_estimate_known')}
  data-reply-estimate-unknown={t('rh_voice.reply_estimate_unknown')}
  data-reply-generic={t('rh_voice.reply_generic')}
  data-reply-correction-needed={t('rh_voice.reply_correction_needed')}
  hidden
>
  <div class="rhvo__backdrop" data-rhvo-dismiss></div>
  <div class="rhvo__panel" role="document">
    <button type="button" class="rhvo__close" data-rhvo-dismiss aria-label={t('rh_voice.action_back')}>
      <span aria-hidden="true">‹</span>
    </button>
    <div class="rhvo__head">
      <p class="rhvo__eyebrow" id="rhvo-title">{t('rh_voice.title')}</p>
      <span class="rhvo__timer" id="rhvo-timer" aria-hidden="true">0:00</span>
    </div>
    <p class="rhvo__status" id="rhvo-status" aria-live="polite">{t('rh_voice.status_listening')}</p>

    <div class="rhvo__meter" id="rhvo-meter" aria-hidden="true">
      <span class="rhvo__bar"></span><span class="rhvo__bar"></span><span class="rhvo__bar"></span
      ><span class="rhvo__bar"></span><span class="rhvo__bar"></span><span class="rhvo__bar"></span
      ><span class="rhvo__bar"></span>
    </div>

    <div class="rhvo__thread" id="rhvo-thread" aria-live="polite"></div>

    <!-- Working-state presence (thinking-state card): the in-thread liveness
         frame between heard and created. Continuous gold motion while real
         work is in flight; honest elapsed-keyed narration; resolves to
         ready/question/snag, never outlives the work. -->
    <div class="rhvo__presence" id="rhvo-presence" hidden aria-live="polite">
      <span class="rhvo__presence-orb" aria-hidden="true"></span>
      <span class="rhvo__presence-text" id="rhvo-presence-text"></span>
    </div>

    <div class="rhvo__caption" id="rhvo-caption" aria-live="polite" data-empty="true">
      <span class="rhvo__caption-label" id="rhvo-caption-label">{t('rh_voice.caption_label')}</span>
      <span class="rhvo__caption-text" id="rhvo-caption-text"></span
      ><span class="rhvo__cursor" id="rhvo-cursor" aria-hidden="true"></span>
    </div>

    <form class="rhvo__composer" id="rhvo-composer">
      <div class="rhvo__composer-row">
        <button type="button" class="rhvo__composer-add" id="rhvo-source-add" aria-label="Attach or paste source">+</button>
        <input
          class="rhvo__source-input"
          id="rhvo-source-input"
          type="file"
          multiple
          hidden
          accept="image/*,video/*,application/pdf,.pdf,.doc,.docx,.xls,.xlsx,.csv,.txt"
        />
        <textarea
          class="rhvo__composer-input"
          id="rhvo-caption-input"
          rows="1"
          aria-label={t('rh_voice.typed_input_label')}
          placeholder={t('rh_voice.typed_input_placeholder')}
        ></textarea>
        <button type="submit" class="rhvo__composer-send" aria-label="Send typed note to Right Hand">Send</button>
      </div>
      <div class="rhvo__dock">
        <span class="rhvo__dock-item" aria-hidden="true">Home</span>
        <span class="rhvo__dock-item" aria-hidden="true">Start</span>
        <button
          type="button"
          class="rhvo__indicator"
          id="rhvo-mic-button"
          aria-label={t('rh_voice.mic_toggle_label')}
        >
          <span class="rhvo__pulse"></span>
          <span class="rhvo__mic">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"></path><path
                d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"
              ></path></svg
            >
          </span>
        </button>
        <span class="rhvo__dock-item" aria-hidden="true">Camera</span>
        <span class="rhvo__dock-item" aria-hidden="true">More</span>
      </div>
    </form>

    <div class="rhvo__confirm" id="rhvo-confirm" hidden>
      <div class="rhvo__turn rhvo__turn--operator">
        <span class="rhvo__speaker" id="rhvo-speaker-operator">{t('rh_voice.speaker_you')}</span>
        <p class="rhvo__said" id="rhvo-confirm-heard"></p>
      </div>
      <div class="rhvo__turn rhvo__turn--right-hand">
        <span class="rhvo__speaker">{t('rh_voice.speaker_right_hand')}</span>
        <p class="rhvo__reply" id="rhvo-confirm-reply">{t('rh_voice.reply_generic')}</p>
      </div>
      <p class="rhvo__confirm-prompt" id="rhvo-confirm-prompt">{t('rh_voice.confirm_prompt')}</p>
    </div>

    <div class="rhvo__resolution" id="rhvo-resolution" hidden aria-hidden="true">
      <p class="rhvo__resolution-prompt">{t('rh_voice.resolved_prompt')}</p>
      <div class="rhvo__moves">
        <button type="button" class="rhvo__move" data-move="add_photo">{t('rh_voice.move_add_photo')}</button>
        <button type="button" class="rhvo__move" data-move="open_job">{t('rh_voice.move_open_job')}</button>
        <button type="button" class="rhvo__move" data-move="review_estimate">{t('rh_voice.move_review_estimate')}</button>
        <button type="button" class="rhvo__move rhvo__move--primary" data-move="go_home">{t('rh_voice.move_go_home')}</button>
      </div>
    </div>

    <div class="rhvo__actions">
      <button type="button" class="rhvo__btn rhvo__btn--ghost" id="rhvo-cancel" data-rhvo-dismiss>
        {t('rh_voice.action_cancel')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--primary" id="rhvo-continue" hidden>
        {t('rh_voice.action_continue')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--save" id="rhvo-save" hidden>
        {t('rh_voice.action_save')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--ghost" id="rhvo-changejob" hidden>
        {t('rh_voice.action_change_job')}
      </button>
      <button type="button" class="rhvo__btn rhvo__btn--ghost" id="rhvo-notthat" hidden>
        {t('rh_voice.action_keep_talking')}
      </button>
    </div>
  </div>
</div>

<script>
  import {
    canRouteFromInterim,
    requiresCommittedTranscript,
    classifyTranscriptIntent,
    liveRouteFor,
    type VoiceIntent,
  } from '../../voice/realtime/voiceActionGate.js';
  import { resolveProposalProjectionFromContext } from '../../voice/realtime/rightHandContextResolver.js';
  import {
    buildTurnResolutionPacket,
    parseTurnResolution,
    serializeTurnResolution,
    nextMovesFor,
    TURN_RESOLUTION_SESSION_KEY,
    type NextMove,
    type TurnResolutionPacket,
  } from '../../voice/realtime/turnResolution.js';
  import type { WorkingDraftFields } from '../../voice/realtime/workingDraft.js';
  import {
    readResumeState,
    writeResumeState,
    bubbleLabelFor,
    shouldNavigateAfterAssembly,
    readPhaseState,
    writePhaseState,
    clearPhaseState,
    phaseAfterAssembly,
    workingNarration,
    bubbleLabelForPhase,
    estimateIdFromSourceRefs,
    WORKING_PHASE_STALE_MS,
  } from '../../voice/realtime/overlayResume.js';
  import { checkTranscript } from '../../voice/realtime/transcriptGuard.js';
  import type { SurfaceContext } from '../lib/surfaceContext.js';

  type OverlayState = 'idle' | 'listening' | 'sorting' | 'reply' | 'confirm' | 'resolved' | 'fallback' | 'capped';

  // Operator-facing copy is rendered into data-* on the overlay (resolved via
  // t() at render) so the script stays i18n-correct. The inline English here is
  // a last-resort default only — it is always status, never a fake transcript.
  const overlay = document.getElementById('rh-voice-overlay');
  if (overlay) {
    const titleEl = document.getElementById('rhvo-title');
    const timerEl = document.getElementById('rhvo-timer');
    const statusEl = document.getElementById('rhvo-status');
    const captionWrap = document.getElementById('rhvo-caption');
    const captionLabelEl = document.getElementById('rhvo-caption-label');
    const captionEl = document.getElementById('rhvo-caption-text');
    const captionInputEl = document.getElementById('rhvo-caption-input') as HTMLTextAreaElement | null;
    const micButton = document.getElementById('rhvo-mic-button') as HTMLButtonElement | null;
    const meterEl = document.getElementById('rhvo-meter');
    const meterBars = meterEl ? Array.from(meterEl.querySelectorAll<HTMLElement>('.rhvo__bar')) : [];
    const threadEl = document.getElementById('rhvo-thread');
    const composerForm = document.getElementById('rhvo-composer') as HTMLFormElement | null;
    const sourceAddBtn = document.getElementById('rhvo-source-add') as HTMLButtonElement | null;
    const sourceInputEl = document.getElementById('rhvo-source-input') as HTMLInputElement | null;
    const confirmSpeakerEl = document.getElementById('rhvo-speaker-operator');
    const confirmHeardEl = document.getElementById('rhvo-confirm-heard');
    const confirmReplyEl = document.getElementById('rhvo-confirm-reply');
    const confirmPromptEl = document.getElementById('rhvo-confirm-prompt');
    const cancelBtn = document.getElementById('rhvo-cancel') as HTMLButtonElement | null;
    const continueBtn = document.getElementById('rhvo-continue') as HTMLButtonElement | null;
    const saveBtn = document.getElementById('rhvo-save') as HTMLButtonElement | null;
    const notThatBtn = document.getElementById('rhvo-notthat') as HTMLButtonElement | null;
    const changeJobBtn = document.getElementById('rhvo-changejob') as HTMLButtonElement | null;

    // Bounded-window defaults (§4). Overwritten by the server response when a
    // realtime session is minted, so client and session agree.
    let silenceCommitMs = 2500;
    let idleCloseMs = 12000;
    let hardCapMs = 75000;
    const TRANSCRIBE_TIMEOUT_MS = 12000;

    let state: OverlayState = 'idle';
    let mediaStream: MediaStream | null = null;
    let micPermissionState: PermissionState | 'unknown' | 'unsupported' = 'unknown';
    let micGrantSeen = false;
    let audioCtx: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let rafId = 0;
    let pc: RTCPeerConnection | null = null;
    let dc: RTCDataChannel | null = null;
    let recorder: MediaRecorder | null = null;
    let recChunks: Blob[] = [];
    let silenceTimer = 0;
    let idleTimer = 0;
    let hardCapTimer = 0;
    let routedLive = false; // a LIVE intent already navigated this turn
    let lastInterim = '';
    let timerId = 0;
    let elapsedSec = 0;
    let awaitingConfirm = false; // durable confirm open — pause STT processing
    let parkedTranscript = ''; // committed durable transcript awaiting Save
    let parkedIntent: VoiceIntent = 'unclassified';
    let parkedTurnResolution: TurnResolutionPacket | null = null;
    let activeSurfaceContext: SurfaceContext | null = null;
    let currentMoves: readonly NextMove[] = []; // resolved-state next moves
    let resolvedSurface = '/'; // default landing after a resolved turn
    let confirmSaveNeedsMoreContext = false;
    type ConversationTurn = {
      speaker: 'operator' | 'right_hand' | 'system';
      text: string;
      tone?: 'normal' | 'consequence' | 'saved';
      at?: number;
    };

    const VOICE_CONVERSATION_SESSION_KEY = 'kerf.voiceConversation';
    const VOICE_CONVERSATION_LOCAL_KEY = VOICE_CONVERSATION_SESSION_KEY;
    const VOICE_CONVERSATION_ID_KEY = 'kerf.voiceConversationId';

    let workingDraftTurns: string[] = [];
    let conversationTurns: ConversationTurn[] = [];
    let attachedSourceNames: string[] = [];
    let conversationDestinationLabel = '';

    const emptyWorkingDraft = (rawText = ''): WorkingDraftFields => ({
      rawText,
      clientName: null,
      projectName: null,
      archetypeHint: null,
      scopeSummary: rawText || null,
      scopeFacts: [],
      needsNewClient: false,
      needsNewProject: false,
      scope: [],
      known_entities: [],
      open_items: [],
      assumptions: [],
      allowances: [],
      next_action: null,
      proposed_artifact: rawText ? 'job_note' : null,
      source_refs: rawText ? ['turn:client_raw'] : [],
    });

    let canonicalWorkingDraft: WorkingDraftFields = emptyWorkingDraft();

    const escapeHtml = (value: string): string => value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const getConversationId = () => {
      try {
        const existing = localStorage.getItem(VOICE_CONVERSATION_ID_KEY) || sessionStorage.getItem(VOICE_CONVERSATION_ID_KEY);
        if (existing) return existing;
        const id = `rh_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
        localStorage.setItem(VOICE_CONVERSATION_ID_KEY, id);
        sessionStorage.setItem(VOICE_CONVERSATION_ID_KEY, id);
        return id;
      } catch {
        return 'default';
      }
    };

    const setMicActive = (active: boolean) => {
      overlay.dataset.micActive = active ? 'true' : 'false';
    };

    const scrollConversationToLatest = (behavior: ScrollBehavior = 'smooth') => {
      const run = () => {
        if (threadEl) threadEl.scrollTo({ top: threadEl.scrollHeight, behavior });
      };
      run();
      requestAnimationFrame(run);
      window.setTimeout(run, 120);
    };

    const renderThread = () => {
      if (!threadEl) return;
      overlay.dataset.hasThread = conversationTurns.length > 0 ? 'true' : 'false';
      threadEl.innerHTML = conversationTurns.map((turn) => {
        const label = turn.speaker === 'operator'
          ? (overlay.dataset.speakerYou ?? 'You')
          : turn.speaker === 'right_hand'
            ? (overlay.dataset.speakerRightHand ?? 'Right Hand')
            : 'Done';
        const speakerClass = turn.speaker.replace('_', '-');
        const speakerIcon = turn.speaker === 'right_hand'
          ? '<span class="rhvo__speaker-shield" aria-hidden="true"></span>'
          : '';
        return `<div class="rhvo__thread-turn rhvo__thread-turn--${speakerClass} rhvo__thread-turn--${turn.tone ?? 'normal'}">
          <span class="rhvo__speaker">${speakerIcon}${escapeHtml(label)}</span>
          <p>${escapeHtml(turn.text)}</p>
        </div>`;
      }).join('');
      threadEl.hidden = conversationTurns.length === 0;
      threadEl.scrollTop = threadEl.scrollHeight;
      scrollConversationToLatest();
    };

    const appendTurn = (speaker: 'operator' | 'right_hand' | 'system', text: string, tone: 'normal' | 'consequence' | 'saved' = 'normal'): number | null => {
      const clean = text.trim();
      if (!clean) return null;
      conversationTurns.push({ speaker, text: clean, tone, at: Date.now() });
      renderThread();
      persistConversation();
      return conversationTurns.length - 1;
    };

    const replaceTurn = (index: number | null, speaker: 'operator' | 'right_hand' | 'system', text: string, tone: 'normal' | 'consequence' | 'saved' = 'normal') => {
      if (index === null) return;
      const clean = text.trim();
      if (!clean || conversationTurns[index]?.speaker !== speaker) return;
      conversationTurns[index] = { speaker, text: clean, tone, at: conversationTurns[index]?.at ?? Date.now() };
      renderThread();
      persistConversation();
    };

    const normalizeStoredReplyText = (value: string): string => value
      .toLowerCase()
      .replace(/[’]/g, "'")
      .replace(/\s+/g, ' ')
      .trim();

    const isRetiredCannedRightHandTurn = (turn: ConversationTurn): boolean => {
      if (turn.speaker !== 'right_hand' || turn.tone === 'consequence' || turn.tone === 'saved') return false;
      const text = normalizeStoredReplyText(turn.text);
      return (
        text.includes('i still need the job before i file it') ||
        text.includes('tell me the job when you know where it belongs') ||
        text.includes("tell me the job and i'll file it there") ||
        text === 'got it — this sounds like a new estimate. i can start it from here. what else?'
      );
    };

    const normalizeStoredConversationTurns = (value: unknown): ConversationTurn[] => {
      if (!Array.isArray(value)) return [];
      return value
        .filter((turn): turn is ConversationTurn => (
          typeof turn === 'object'
          && turn !== null
          && ['operator', 'right_hand', 'system'].includes((turn as ConversationTurn).speaker)
          && typeof (turn as ConversationTurn).text === 'string'
        ))
        .map((turn) => ({
          speaker: turn.speaker,
          text: turn.text.trim(),
          tone: ['consequence', 'saved'].includes(String(turn.tone)) ? turn.tone : 'normal',
          ...(typeof turn.at === 'number' && Number.isFinite(turn.at) ? { at: turn.at } : {}),
        }))
        .filter((turn) => turn.text.length > 0)
        // #302 model-led replies replaced these deterministic placeholders.
        // Scrub persisted old RH bubbles so a stale browser session cannot
        // make the current build look canned after deploy.
        .filter((turn) => !isRetiredCannedRightHandTurn(turn));
    };

    const workingDraftText = () => workingDraftTurns.map((turn) => turn.trim()).filter(Boolean).join('\n\n');

    const currentWorkingDraft = (): WorkingDraftFields => ({
      ...canonicalWorkingDraft,
      rawText: workingDraftText() || canonicalWorkingDraft.rawText,
      scopeSummary: workingDraftText() || canonicalWorkingDraft.scopeSummary,
    });

    const cleanStringArray = (value: unknown): readonly string[] => (
      Array.isArray(value)
        ? value.filter((item): item is string => typeof item === 'string').map((item) => item.trim()).filter(Boolean)
        : []
    );

    const cleanStoredWorkingDraft = (value: unknown, fallbackRawText = ''): WorkingDraftFields => {
      if (!value || typeof value !== 'object' || Array.isArray(value)) return emptyWorkingDraft(fallbackRawText);
      const record = value as Record<string, unknown>;
      const rawText = typeof record.rawText === 'string' && record.rawText.trim()
        ? record.rawText.trim()
        : fallbackRawText;
      const archetype = ['kitchen_remodel', 'bath_refresh', 'adu'].includes(String(record.archetypeHint))
        ? record.archetypeHint as WorkingDraftFields['archetypeHint']
        : null;
      const knownEntities = Array.isArray(record.known_entities)
        ? record.known_entities
          .filter((item): item is Record<string, unknown> => !!item && typeof item === 'object' && !Array.isArray(item))
          .map((item) => {
            const type = ['client', 'project', 'site', 'lead'].includes(String(item.type))
              ? item.type as WorkingDraftFields['known_entities'][number]['type']
              : null;
            const label = typeof item.label === 'string' ? item.label.trim() : '';
            const source = ['operator', 'tenant_context', 'model'].includes(String(item.source))
              ? item.source as WorkingDraftFields['known_entities'][number]['source']
              : 'model';
            if (!type || !label) return null;
            return {
              type,
              kind: type,
              label,
              source,
              ...(typeof item.id === 'string' && item.id.trim() ? { id: item.id.trim() } : {}),
            };
          })
          .filter((item): item is WorkingDraftFields['known_entities'][number] => item !== null)
        : [];
      return {
        rawText,
        clientName: typeof record.clientName === 'string' && record.clientName.trim() ? record.clientName.trim() : null,
        projectName: typeof record.projectName === 'string' && record.projectName.trim() ? record.projectName.trim() : null,
        archetypeHint: archetype,
        scopeSummary: typeof record.scopeSummary === 'string' && record.scopeSummary.trim() ? record.scopeSummary.trim() : rawText || null,
        scopeFacts: cleanStringArray(record.scopeFacts),
        needsNewClient: record.needsNewClient === true,
        needsNewProject: record.needsNewProject === true,
        scope: cleanStringArray(record.scope),
        known_entities: knownEntities,
        open_items: cleanStringArray(record.open_items),
        assumptions: cleanStringArray(record.assumptions),
        allowances: cleanStringArray(record.allowances),
        next_action: typeof record.next_action === 'string' && record.next_action.trim() ? record.next_action.trim() : null,
        proposed_artifact: ['job_note', 'project_intake', 'estimate_draft'].includes(String(record.proposed_artifact))
          ? record.proposed_artifact as WorkingDraftFields['proposed_artifact']
          : rawText ? 'job_note' : null,
        source_refs: cleanStringArray(record.source_refs),
      };
    };

    const conversationSnapshotBody = () => ({
      conversationId: getConversationId(),
      currentPath: window.location.pathname,
      workingDraftTurns,
      conversationTurns,
      attachedSourceNames,
      conversationDestinationLabel,
      workingDraft: currentWorkingDraft(),
    });

    const persistConversation = () => {
      const payload = conversationSnapshotBody();
      try {
        const raw = JSON.stringify({ at: Date.now(), ...payload });
        localStorage.setItem(VOICE_CONVERSATION_LOCAL_KEY, raw);
      } catch { /* storage may be unavailable; the live page still keeps state */ }
      try {
        const tenantId = currentTenantId();
        if (!tenantId) return;
        void fetch('/api/v1/right-hand/conversation', {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        }).catch(() => {});
      } catch { /* server memory is best-effort; local memory still protects the turn */ }
    };

    const restoreConversation = () => {
      try {
        const raw = localStorage.getItem(VOICE_CONVERSATION_LOCAL_KEY);
        if (!raw) return false;
        const parsed = JSON.parse(raw) as {
          at?: unknown;
          workingDraftTurns?: unknown;
          conversationTurns?: unknown;
          attachedSourceNames?: unknown;
          conversationDestinationLabel?: unknown;
          workingDraft?: unknown;
        };
        if (!Array.isArray(parsed.workingDraftTurns) || !Array.isArray(parsed.conversationTurns)) return false;
        workingDraftTurns = parsed.workingDraftTurns
          .filter((turn): turn is string => typeof turn === 'string')
            .map((turn) => turn.trim())
            .filter(Boolean);
        conversationTurns = normalizeStoredConversationTurns(parsed.conversationTurns);
        attachedSourceNames = Array.isArray(parsed.attachedSourceNames)
          ? parsed.attachedSourceNames
            .filter((name): name is string => typeof name === 'string')
            .map((name) => name.trim())
            .filter(Boolean)
          : [];
        conversationDestinationLabel = typeof parsed.conversationDestinationLabel === 'string'
          ? cleanDestinationLabel(parsed.conversationDestinationLabel)
          : '';
        canonicalWorkingDraft = cleanStoredWorkingDraft(parsed.workingDraft, workingDraftText());
        renderThread();
        return conversationTurns.length > 0 || workingDraftTurns.length > 0;
      } catch {
        return false;
      }
    };

    const restoreConversationFromServer = async (): Promise<boolean> => {
      try {
        const tenantId = currentTenantId();
        if (!tenantId) return false;
        const res = await fetch(`/api/v1/right-hand/conversation?conversation_id=${encodeURIComponent(getConversationId())}`, {
          method: 'GET',
          credentials: 'include',
        });
        if (!res.ok) return false;
        const body = await res.json() as { snapshot?: unknown };
        const snapshot = body.snapshot as {
          workingDraftTurns?: unknown;
          working_draft_turns?: unknown;
          conversationTurns?: unknown;
          conversation_turns?: unknown;
          attachedSourceNames?: unknown;
          attached_source_names?: unknown;
          conversationDestinationLabel?: unknown;
          conversation_destination_label?: unknown;
          workingDraft?: unknown;
          working_draft?: unknown;
        } | null;
        if (!snapshot) return false;
        const rawWorkingDraftTurns = snapshot.workingDraftTurns ?? snapshot.working_draft_turns;
        const rawConversationTurns = snapshot.conversationTurns ?? snapshot.conversation_turns;
        const rawAttachedSourceNames = snapshot.attachedSourceNames ?? snapshot.attached_source_names;
        const rawDestinationLabel = snapshot.conversationDestinationLabel ?? snapshot.conversation_destination_label;
        const restoredWorkingDraftTurns = Array.isArray(rawWorkingDraftTurns)
          ? rawWorkingDraftTurns
            .filter((turn): turn is string => typeof turn === 'string')
            .map((turn) => turn.trim())
            .filter(Boolean)
          : [];
        const restoredConversationTurns = normalizeStoredConversationTurns(rawConversationTurns);
        if (restoredWorkingDraftTurns.length === 0 && restoredConversationTurns.length === 0) return false;
        workingDraftTurns = restoredWorkingDraftTurns;
        conversationTurns = restoredConversationTurns;
        attachedSourceNames = Array.isArray(rawAttachedSourceNames)
          ? rawAttachedSourceNames
            .filter((name): name is string => typeof name === 'string')
            .map((name) => name.trim())
            .filter(Boolean)
          : [];
        conversationDestinationLabel = typeof rawDestinationLabel === 'string'
          ? cleanDestinationLabel(rawDestinationLabel)
          : '';
        canonicalWorkingDraft = cleanStoredWorkingDraft(snapshot.workingDraft ?? snapshot.working_draft, workingDraftText());
        renderThread();
        surfaceUnfiledDraftLoop();
        persistConversation();
        return true;
      } catch {
        return false;
      }
    };

    const clearPersistedConversation = (options: { server?: boolean } = {}) => {
      try {
        localStorage.removeItem(VOICE_CONVERSATION_LOCAL_KEY);
      } catch { /* noop */ }
      if (options.server) {
        try {
          const tenantId = currentTenantId();
          if (!tenantId) return;
          void fetch('/api/v1/right-hand/conversation', {
            method: 'DELETE',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: getConversationId() }),
          }).catch(() => {});
        } catch { /* noop */ }
      }
    };

    const resetConversation = (options: { clearStored?: boolean; clearServer?: boolean } = {}) => {
      workingDraftTurns = [];
      conversationTurns = [];
      attachedSourceNames = [];
      conversationDestinationLabel = '';
      canonicalWorkingDraft = emptyWorkingDraft();
      renderThread();
      if (options.clearStored) clearPersistedConversation({ server: options.clearServer });
    };

    const FALSE_LANGUAGE_TRANSCRIPT_RE = /^(?:hvað er þetta|það er hann)\.?\s*$/i;
    const PUNCTUATION_ONLY_TRANSCRIPT_RE = /^[.?!,;:\-\s…]+$/;
    const cleanCommittedTranscript = (value: string): string => {
      const clean = value.replace(/\s+/g, ' ').trim();
      if (!clean || PUNCTUATION_ONLY_TRANSCRIPT_RE.test(clean)) return '';
      if (FALSE_LANGUAGE_TRANSCRIPT_RE.test(clean)) return '';
      return clean;
    };
    const pushWorkingDraftTurn = (value: string) => {
      const clean = value.trim();
      if (!clean) return;
      if (workingDraftTurns.at(-1) !== clean) workingDraftTurns.push(clean);
    };

    const surfaceUnfiledDraftLoop = () => {
      if (workingDraftTurns.length === 0) return;
      const alreadySurfaced = conversationTurns.some((turn) => (
        turn.speaker === 'right_hand'
        && /\b(still holding this|say "save it"|before i file it|ready to file)\b/i.test(turn.text)
      ));
      const alreadyFiled = conversationTurns.some((turn) => turn.tone === 'saved');
      if (alreadySurfaced || alreadyFiled) return;
      appendTurn('right_hand', 'Still holding this. Say "save it" when you want me to file it, or keep going.');
      persistConversation();
    };

    const textRequestsDurableCommit = (text: string): boolean => (
      /\b(save|file|log|submit|send|done|that'?s it|go ahead|looks good)\b/i.test(text)
    );

    const textContainsInlineDurableDraft = (text: string): boolean => (
      /\b(save|file|log)\b[\s\S]{0,32}\b(?:job\s+note|note|daily\s+log|update)\b[\s\S]{0,32}\b(?:that|about|saying|:)\b/i.test(text)
    );

    const textIsDestinationCorrection = (text: string): boolean => (
      /^(?:correction:?\s*)?(?:no|actually|yes|yep|correct|right|it'?s|this is|attach|file|save|put|route)\b/i.test(text.trim())
      && /\b(?:attach|file|save|put|route|job|project|client)\b/i.test(text)
      && /\b(?:job|project|client)\b/i.test(text)
      && text.trim().split(/\s+/).length <= 14
    );

    const cleanDestinationLabel = (raw: string): string => {
      const compact = raw
        .replace(/\b(?:are you able to understand that|do you understand that|can you understand that)\b[\s?.!]*$/i, '')
        .replace(/\b(?:job|project|client|site)\b[\s?.!]*$/i, '')
        .replace(/^(?:the|a|an)\s+/i, '')
        .replace(/[“”]/g, '"')
        .replace(/[’]/g, "'")
        .replace(/[?.!,;:]+$/g, '')
        .replace(/\s+/g, ' ')
        .trim();
      if (!compact || /^(?:it|this|that|there|here|job|project|client|site)$/i.test(compact)) return '';
      const words = compact.split(/\s+/).filter(Boolean);
      if (words.length > 5) return '';
      return words.map((word) => {
        if (/^[A-Z0-9&]+$/.test(word)) return word;
        return `${word.slice(0, 1).toUpperCase()}${word.slice(1)}`;
      }).join(' ');
    };

    const extractDestinationLabel = (text: string): string => {
      const clean = text.trim()
        .replace(/^(?:correction:?\s*)?(?:no|actually|yes|yep|correct|right)[,\s]+/i, '')
        .replace(/\b(?:are you able to understand that|do you understand that|can you understand that)\b[\s?.!]*$/i, '')
        .trim();
      const patterns = [
        /\b(?:this\s+is|it'?s|that'?s)\s+(?:for|on|under|with|to)\s+(?:the\s+)?(.+?)\s+(?:project|job|client|site)\b/i,
        /\b(?:attach|file|save|put|route)(?:\s+(?:it|this|that|the note))?\s+(?:to|under|with|in|on)\s+(?:the\s+)?(.+?)(?:\s+(?:project|job|client|site))?(?:[.?!]|$)/i,
        /\b(?:for|under|with|to)\s+(?:the\s+)?(.+?)\s+(?:project|job|client|site)\b/i,
        /\b(?:the\s+)?([A-Z][A-Za-z0-9&' -]{1,40}?)\s+(?:project|job|client|site)\b/,
      ];
      for (const pattern of patterns) {
        const match = clean.match(pattern);
        const label = cleanDestinationLabel(match?.[1] ?? '');
        if (label) return label;
      }
      return '';
    };

    const setState = (next: OverlayState) => {
      state = next;
      overlay.dataset.state = next;
    };
    const setHeading = (text: string) => {
      if (titleEl) titleEl.textContent = text;
    };
    const setStatus = (text: string) => {
      if (statusEl) statusEl.textContent = text;
    };
    const setCaption = (text: string) => {
      // REAL transcript only — never invented. Empty until STT produces words.
      if (captionEl) captionEl.textContent = text;
      if (captionWrap) captionWrap.dataset.empty = text.trim().length === 0 ? 'true' : 'false';
    };
    const currentCaptionText = () => lastInterim.trim();

    const clearComposer = () => {
      if (!captionInputEl) return;
      captionInputEl.value = '';
      captionInputEl.style.height = '';
      overlay.dataset.typed = 'false';
    };

    const growComposer = () => {
      if (!captionInputEl) return;
      captionInputEl.style.height = 'auto';
      const max = 6 * 22;
      captionInputEl.style.height = `${Math.min(captionInputEl.scrollHeight, max)}px`;
      scrollConversationToLatest('auto');
    };

    // ── Elapsed timer (mm:ss) — starts on overlay open, ticks every second,
    // cleared in teardown (§4 bounded window is the real guard; this is display).
    const fmtClock = (s: number) => `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
    const startTimer = () => {
      window.clearInterval(timerId);
      elapsedSec = 0;
      if (timerEl) timerEl.textContent = fmtClock(0);
      timerId = window.setInterval(() => {
        elapsedSec += 1;
        if (timerEl) timerEl.textContent = fmtClock(elapsedSec);
      }, 1000);
    };
    const stopTimer = () => {
      window.clearInterval(timerId);
    };

    // ── Action-button visibility per state. The mic itself is the start/finish
    // control while listening. Confirm keeps at most one consequence button plus
    // a quiet "keep talking" escape; the back/close affordance owns don't-save.
    const showActions = (mode: 'listening' | 'confirm' | 'capped' | 'resolved') => {
      // Stage-4 consequence bubble (F-RH3): the affordances answer the real
      // question — Save to <job> · Change job · Keep talking. The generic
      // "Don't save" cancel is NOT part of the consequence row (the persistent
      // close ‹ / backdrop still dismisses); it only appears on the capped pause.
      // Resolved owns its own next-move buttons (.rhvo__moves).
      if (cancelBtn) cancelBtn.hidden = mode !== 'capped';
      if (continueBtn) continueBtn.hidden = mode !== 'capped';
      if (saveBtn) saveBtn.hidden = mode !== 'confirm' || confirmSaveNeedsMoreContext;
      if (changeJobBtn) changeJobBtn.hidden = mode !== 'confirm';
      if (notThatBtn) notThatBtn.hidden = mode !== 'confirm';
    };

    const resetConfirmActionCopy = () => {
      if (notThatBtn) notThatBtn.textContent = overlay.dataset.actionKeepTalking ?? 'Keep talking';
      if (changeJobBtn) {
        changeJobBtn.textContent = overlay.dataset.actionChangeJob ?? 'Change job';
        changeJobBtn.disabled = false;
      }
      if (saveBtn) {
        saveBtn.textContent = overlay.dataset.actionSave ?? 'Save';
        saveBtn.disabled = false;
        saveBtn.hidden = true;
      }
    };

    const clearTimers = () => {
      window.clearTimeout(silenceTimer);
      window.clearTimeout(idleTimer);
      window.clearTimeout(hardCapTimer);
    };

    const liveMicTracks = () => mediaStream?.getAudioTracks().filter((track) => track.readyState === 'live') ?? [];
    const hasLiveMicStream = () => liveMicTracks().length > 0;
    const setMicTracksEnabled = (enabled: boolean) => {
      liveMicTracks().forEach((track) => {
        track.enabled = enabled;
      });
      setMicActive(enabled && hasLiveMicStream());
    };
    const stopMicStream = () => {
      mediaStream?.getTracks().forEach((track) => track.stop());
      mediaStream = null;
      setMicActive(false);
    };
    const queryMicPermission = async (): Promise<PermissionState | 'unknown' | 'unsupported'> => {
      const permissions = navigator.permissions;
      if (!permissions?.query) {
        micPermissionState = 'unsupported';
        return micPermissionState;
      }
      try {
        const status = await permissions.query({ name: 'microphone' as PermissionName });
        micPermissionState = status.state;
        status.onchange = () => {
          micPermissionState = status.state;
        };
        return status.state;
      } catch {
        micPermissionState = 'unsupported';
        return micPermissionState;
      }
    };
    const micFailureStatus = (err: unknown): string => {
      const name = err instanceof DOMException ? err.name : '';
      if (micPermissionState === 'denied' || name === 'NotAllowedError' || name === 'SecurityError') {
        return overlay.dataset.micdenied ?? 'Microphone is off — enable it or open Right Hand to type.';
      }
      return overlay.dataset.unavailable ?? 'Voice isn’t available here — open Right Hand to type.';
    };
    const acquireMicStream = async (): Promise<boolean> => {
      if (hasLiveMicStream()) {
        setMicTracksEnabled(true);
        micGrantSeen = true;
        return true;
      }
      if (!navigator.mediaDevices?.getUserMedia) {
        setStatus(overlay.dataset.unavailable ?? 'Voice isn’t available here — open Right Hand to type.');
        setMicActive(false);
        return false;
      }
      const permission = await queryMicPermission();
      if (permission === 'denied') {
        setStatus(overlay.dataset.micdenied ?? 'Microphone is off — enable it or open Right Hand to type.');
        setMicActive(false);
        return false;
      }
      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
        micPermissionState = 'granted';
        micGrantSeen = true;
        setMicActive(true);
        return true;
      } catch (err) {
        const afterFailure = await queryMicPermission();
        if (afterFailure === 'granted' || micGrantSeen) {
          setStatus(overlay.dataset.unavailable ?? 'Voice isn’t available here — open Right Hand to type.');
        } else {
          setStatus(micFailureStatus(err));
        }
        setMicActive(false);
        return false;
      }
    };

    const teardown = () => {
      clearTimers();
      stopTimer();
      if (rafId) cancelAnimationFrame(rafId);
      rafId = 0;
      try { dc?.close(); } catch { /* noop */ }
      try { pc?.close(); } catch { /* noop */ }
      try {
        if (recorder && recorder.state !== 'inactive') recorder.stop();
      } catch { /* noop */ }
      try { void audioCtx?.close(); } catch { /* noop */ }
      stopMicStream();
      audioCtx = null;
      analyser = null;
      pc = null;
      dc = null;
      recorder = null;
      recChunks = [];
    };

    const releaseListeningResources = () => {
      clearTimers();
      stopTimer();
      if (rafId) cancelAnimationFrame(rafId);
      rafId = 0;
      try { dc?.close(); } catch { /* noop */ }
      try { pc?.close(); } catch { /* noop */ }
      try { void audioCtx?.close(); } catch { /* noop */ }
      // Pause normal turn-listening without revoking an already granted mic
      // stream. The same overlay conversation can resume without looking like
      // a fresh permission request. closeOverlay()/hard-cap still call teardown()
      // for a full privacy release.
      setMicTracksEnabled(false);
      setMicActive(false);
      audioCtx = null;
      analyser = null;
      pc = null;
      dc = null;
    };

    const closeOverlay = () => {
      teardown();
      setState('idle');
      persistConversation();
      overlay.hidden = true;
      if (conversationTurns.length > 0) {
        // Parked, not gone — the bubble is the continuity affordance.
        writeResumeState(sessionStorage, { at: Date.now(), href: window.location.pathname });
        showResumeBubble();
      }
    };

    // ── Routing (no PII in URLs — enums/ids only; transcript stashed in
    // sessionStorage for the downstream 1H surface to consume). ──────────────
    const stashCommitted = (text: string) => {
      try {
        sessionStorage.setItem('kerf.voiceCommit', JSON.stringify({ text, at: Date.now() }));
      } catch { /* storage may be unavailable; navigation still works */ }
    };

    const navigate = (href: string, options: { resume?: boolean } = {}) => {
      if (options.resume) {
        try {
          persistConversation();
          writeResumeState(sessionStorage, { at: Date.now(), href });
        } catch { /* storage may be unavailable; navigation still works */ }
      }
      teardown();
      window.location.href = href;
    };

    const routeLive = (intent: VoiceIntent): boolean => {
      const route = liveRouteFor(intent);
      if (route) {
        navigate(`${route}?src=voice`, { resume: intent !== 'open_field_capture' });
        return true;
      }
      if (intent === 'status_question') {
        // No specific project bound from deterministic keywords — land on the
        // real read-only projects surface rather than guess a project id.
        navigate('/projects?src=voice', { resume: true });
        return true;
      }
      return false;
    };

    const template = (text: string | undefined, vars: Record<string, string>) => {
      let out = text ?? '';
      for (const [key, value] of Object.entries(vars)) {
        out = out.replaceAll(`{${key}}`, value);
      }
      return out;
    };

    const likelyEntityLabel = (trp: TurnResolutionPacket): string => {
      const label = trp.context_hypothesis.likely_entity?.label?.trim();
      if (label) return label;
      const routedParts = trp.context_hypothesis.routed_label.split('→');
      const routed = routedParts[routedParts.length - 1]?.trim() ?? '';
      if (/choose job|session review|draft review|daily log|estimate intake|estimate|field capture|read-only review/i.test(routed)) return '';
      return routed;
    };

    const conversationEntityLabel = (trp: TurnResolutionPacket): string => {
      const label = likelyEntityLabel(trp).replace(/\s+/g, ' ').trim();
      if (!label) return '';
      const clientPart = label.split(',')[0]?.trim() || label;
      const routePart = clientPart.split(/[·+]/)[0]?.trim() || clientPart;
      const scopeStripped = routePart
        .replace(/\s+(kitchen|bath(?:room)?|primary|site|project|job|remodel|addition|adu)\b.*$/i, '')
        .trim();
      return scopeStripped || routePart || clientPart || label;
    };

    const conversationDestinationFor = (trp: TurnResolutionPacket, latestText = ''): string => (
      conversationEntityLabel(trp)
      || (textIsDestinationCorrection(latestText) ? extractDestinationLabel(latestText) : '')
      || conversationDestinationLabel
    );

    const replyForTurn = (trp: TurnResolutionPacket): string => {
      const entity = conversationDestinationFor(trp);
      const frame = trp.context_hypothesis.frame;
      if (trp.intent === 'job_note' || trp.intent === 'job_log' || frame === 'field_note') {
        return entity
          ? template(overlay.dataset.replyJobNoteKnown, { entity })
          : (overlay.dataset.replyJobNoteUnknown ?? 'Got it — this looks like a job note. Tell me the job and I’ll file it there.');
      }
      if (trp.intent === 'job_intake' || trp.intent === 'estimate_update' || frame === 'estimate_walk') {
        return entity
          ? template(overlay.dataset.replyEstimateKnown, { entity })
          : (overlay.dataset.replyEstimateUnknown ?? 'Got it — this looks like an estimate walk. Tell me the job and I’ll start the draft.');
      }
      const action = trp.context_hypothesis.preparing_label
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();
      return action
        ? `Got it — I am preparing ${action}. Keep going, or say "save it" when you are ready.`
        : 'Got it — keep going, or say "save it" when you are ready.';
    };

    const latestLooksLikeProductFeedback = (text: string): boolean => (
      /\b(button|screen|scroll|interface|mic|microphone|working correctly|improved|not working|doesn'?t work|response|conversation)\b/i.test(text)
    );
    const latestLooksLikeFieldStatus = (text: string): boolean => (
      /\b(installed|finished|complete|completed|schedule|scheduled|paint|painters|drywall|patch|cabinet|cabinetry|invoice|paperwork|change order|punch(?:less| list)?|cleanup|cleaned up)\b/i.test(text)
    );
    const textExplicitlyRequestsEstimate = (text: string): boolean => (
      /\b(estimate|bid|quote|proposal|pricing|price out|scope for pricing)\b/i.test(text)
    );
    const conversationIntentForTurn = (text: string, draftText: string): VoiceIntent => {
      const classified = classifyTranscriptIntent(text);
      if ((latestLooksLikeFieldStatus(text) || latestLooksLikeProductFeedback(text)) && !textExplicitlyRequestsEstimate(text)) {
        return 'job_note';
      }
      const draftIntent = classifyTranscriptIntent(draftText);
      if (classified === 'unclassified' && requiresCommittedTranscript(draftIntent)) {
        return draftIntent;
      }
      return classified;
    };
    const textRequestsEstimateAssembly = (text: string): boolean => (
      /\b(?:put it together|take me there|take me to (?:the )?(?:estimate|quote|bid)|let'?s build it|build it|build (?:the )?(?:estimate|quote|bid)|assemble(?: it| the (?:estimate|quote|bid))|start (?:the )?(?:estimate|quote|bid)|make (?:the )?(?:estimate|quote|bid)|open (?:the )?(?:estimate|quote|bid)|price it out)\b/i.test(text)
    );

    const textRequestsProposalOrInvoice = (text: string): boolean => (
      /\b(?:(?:make|build|generate|create|draft|open|show|review)\s+(?:the\s+)?proposal(?:\s+draft)?|(?:send|take|route)\s+me\s+to\s+(?:the\s+)?proposal(?:\s+draft)?|(?:generate|make|build|create|draft|open|show|review)\s+(?:the\s+)?(?:down[- ]?payment\s+)?invoice(?:\s+draft)?|bill\s+(?:the\s+)?down[- ]?payment|down[- ]?payment\s+invoice)\b/i.test(text)
    );

    type RightHandProposedAction = 'assemble_estimate' | 'open_proposal_draft' | 'open_invoice_draft' | 'bill_down_payment_invoice';

    const normalizeProposedAction = (value: unknown): RightHandProposedAction | null => {
      if (typeof value !== 'string') return null;
      const clean = value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
      if (clean === 'assemble_estimate') return 'assemble_estimate';
      if (clean === 'open_proposal_draft') return 'open_proposal_draft';
      if (clean === 'open_invoice_draft') return 'open_invoice_draft';
      if (clean === 'bill_down_payment_invoice' || clean === 'bill_down_payment') return 'bill_down_payment_invoice';
      return null;
    };

    const textLooksLikeEstimatePageUpdate = (text: string): boolean => (
      /^\/estimate\/[A-Za-z0-9_-]+/.test(window.location.pathname)
      && /\b(?:add|include|bump|raise|increase|change|swap|allowance|backsplash|flooring|slab|counter|cabinet)\b/i.test(text)
    );

    const pendingReplyText = (): string => {
      const variants = ['Working…', 'On it…', 'I’m checking the draft…'];
      const index = conversationTurns.filter((turn) => turn.speaker === 'right_hand').length % variants.length;
      return variants[index] ?? 'Working…';
    };

    const renderProposalProjectionConfirm = () => {
      activeSurfaceContext = readSurfaceContext() ?? activeSurfaceContext;
      const resolution = resolveProposalProjectionFromContext(activeSurfaceContext);
      confirmSaveNeedsMoreContext = resolution.href === null;
      if (confirmSpeakerEl) confirmSpeakerEl.textContent = operatorName();
      if (confirmReplyEl) {
        confirmReplyEl.textContent = `${resolution.creating}. ${resolution.routed}.`;
      }
      if (confirmPromptEl) {
        confirmPromptEl.innerHTML = `<span class="rhvo__confirm-kicker">Context check</span><span>${escapeHtml(resolution.needs)}</span>`;
      }
      if (saveBtn) {
        saveBtn.textContent = resolution.href ? 'Open proposal' : (overlay.dataset.actionKeepTalking ?? 'Keep talking');
        saveBtn.hidden = confirmSaveNeedsMoreContext;
        saveBtn.disabled = false;
      }
      if (changeJobBtn) changeJobBtn.hidden = true;
      if (notThatBtn) notThatBtn.textContent = overlay.dataset.actionKeepTalking ?? 'Keep talking';
    };

    const renderConfirmTurn = (trp: TurnResolutionPacket) => {
      confirmSaveNeedsMoreContext = turnNeedsProjectBeforeSave(trp);
      const entity = conversationDestinationFor(trp);
      if (confirmSpeakerEl) confirmSpeakerEl.textContent = operatorName();
      if (confirmReplyEl) confirmReplyEl.textContent = replyForTurn(trp);
      if (confirmPromptEl) {
        const prompt = promptForTurn(trp);
        confirmPromptEl.innerHTML = `<span class="rhvo__confirm-kicker">Before I file it</span><span>${escapeHtml(prompt)}</span>`;
      }
      if (notThatBtn) {
        notThatBtn.textContent = overlay.dataset.actionKeepTalking ?? 'Keep talking';
      }
      // Primary affordance is the answer to where-it-goes: "Save to <job>" when
      // the destination is known (F-RH3 stage 4), "Start intake" for a brand-new
      // estimate walk, plain "Save" only when no job is bound yet.
      if (saveBtn) {
        saveBtn.textContent = startNewIntakeTurn(trp)
          ? overlay.dataset.actionStartIntake ?? 'Start intake'
          : entity
            ? template(overlay.dataset.actionSaveTo ?? 'Save to {job}', { job: entity })
            : overlay.dataset.actionSave ?? 'Save';
        saveBtn.hidden = confirmSaveNeedsMoreContext;
        saveBtn.disabled = false;
      }
      // Change job only makes sense once a destination is on the table; with no
      // job bound the operator should Keep talking to name one instead.
      if (changeJobBtn) changeJobBtn.hidden = state !== 'confirm' || !entity;
    };

    type KnownEntityPayload = {
      type: 'project' | 'client' | 'site' | 'lead';
      id?: string;
      label: string;
    };

    const currentTenantId = (): string | undefined => (
      document.querySelector<HTMLElement>('.kerf-shell')?.dataset.tenant?.trim() || undefined
    );

    const parseSurfaceContext = (value: unknown): SurfaceContext | null => {
      if (typeof value !== 'object' || value === null) return null;
      const record = value as Record<string, unknown>;
      if (typeof record.surface !== 'string') return null;
      if (typeof record.tenant !== 'string') return null;
      if (typeof record.role !== 'string') return null;
      return value as SurfaceContext;
    };

    const readSurfaceContext = (): SurfaceContext | null => {
      const globalContext = (window as Window & { __KERF_SURFACE_CONTEXT__?: unknown }).__KERF_SURFACE_CONTEXT__;
      const parsedGlobal = parseSurfaceContext(globalContext);
      if (parsedGlobal) return parsedGlobal;
      const raw = document.getElementById('kerf-surface-context')?.textContent ?? '';
      if (!raw.trim()) return null;
      try {
        return parseSurfaceContext(JSON.parse(raw));
      } catch {
        return null;
      }
    };

    const operatorName = (): string => (
      document.querySelector<HTMLElement>('.kerf-shell')?.dataset.operatorName?.trim() ||
      overlay.dataset.speakerYou ||
      'You'
    );

    const rightHandVoiceProfileSummary = (): string => [
      'Peer altitude: sharp contractor operator talking to a trusted PM/advisor.',
      'Use dense, casual contractor English; no rote re-grounding or repeated confirmation.',
      'Adapt to role and user voice through interaction; unpack only when the operator misses or asks.',
      'Be explicit and pushy only for consequence gates, health/safety/policy, money/send, client-risk, or durable writes.',
      'Deterministic floor: tenant isolation · source validation · durable-write gate · money/send gate · classification/envelope stamping · health/safety/policy gates · humble fallback.',
    ].join(' ');

    const collectKnownEntities = (): KnownEntityPayload[] => {
      const byKey = new Map<string, KnownEntityPayload>();
      const add = (entity: KnownEntityPayload) => {
        const label = entity.label.replace(/\s+/g, ' ').trim();
        if (!label) return;
        const id = entity.id?.trim();
        byKey.set(`${entity.type}:${id ?? label}`, { ...entity, ...(id ? { id } : {}), label });
      };

      if (currentTenantId() === 'tenant_ggr') {
        // Dogfood context visible throughout the current GGR shell. This is
        // tenant-scoped fixture data, not shared platform memory; it gives the
        // model-led resolver the same active-job context the operator sees.
        add({ type: 'project', id: 'proj_wegrzyn_kitchen', label: 'Wegrzyn kitchen + primary bath' });
        add({ type: 'client', id: 'client_wegrzyn', label: 'Wegrzyn, Mark & Grace' });
        add({ type: 'site', id: 'site_wegrzyn_pacifica', label: 'Wegrzyn site · 4287 Pacifica Way' });
      }

      const fieldShell = document.querySelector<HTMLElement>('.field-shell');
      const projectId = fieldShell?.dataset.projectId;
      const destination = document.querySelector<HTMLSelectElement>('#f-e1-destination');
      const selected = destination?.selectedOptions?.[0];
      const activeProject = destination?.dataset.activeProject;
      const activeClient = destination?.dataset.activeClient;
      const activeLocation = destination?.dataset.activeLocation;
      if (projectId && (activeProject || selected?.textContent)) {
        add({ type: 'project', id: projectId, label: activeProject ?? selected?.textContent ?? projectId });
      }
      if (activeClient) add({ type: 'client', label: activeClient });
      if (activeLocation) add({ type: 'site', label: activeLocation });

      return [...byKey.values()].slice(0, 8);
    };

    const normalizeMatchText = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').replace(/\s+/g, ' ').trim();
    const ENTITY_TOKEN_STOP_WORDS = new Set(['kitchen', 'primary', 'bath', 'project', 'job', 'site']);
    const entityMatchTokens = (label: string): string[] => normalizeMatchText(label)
      .split(' ')
      .filter((token) => (token.length >= 4 || /^\d{3,}$/.test(token)) && !ENTITY_TOKEN_STOP_WORDS.has(token));
    const escapeRegExp = (value: string): string => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    const textRejectsEntityAssignment = (text: string, label: string): boolean => {
      const source = normalizeMatchText(text);
      const rejectionCue = '(?:not|wrong|don t|do not|instead of|rather than|isn t|is not|isnt)';
      return entityMatchTokens(label).some((token) => {
        const escaped = escapeRegExp(token);
        const cueBeforeEntity = new RegExp(`\\b${rejectionCue}\\b(?:\\s+[a-z0-9]+){0,8}\\s+${escaped}\\b`);
        const entityBeforeWrong = new RegExp(`\\b${escaped}\\b(?:\\s+[a-z0-9]+){0,5}\\s+\\b(?:wrong|not it|not right)\\b`);
        return cueBeforeEntity.test(source) || entityBeforeWrong.test(source);
      });
    };

    const textMentionsEntity = (text: string, label: string): boolean => {
      const source = normalizeMatchText(text);
      if (textRejectsEntityAssignment(text, label)) return false;
      const tokens = entityMatchTokens(label);
      return tokens.some((token) => source.includes(token));
    };

    const projectIdFromPath = (): string | null => {
      const match = window.location.pathname.match(/^\/(?:projects|estimate)\/([A-Za-z0-9_-]+)(?:\/|$)/);
      return match?.[1] ?? null;
    };

    const knownProjectById = (id: string | null | undefined): KnownEntityPayload | null => {
      if (!id) return null;
      return collectKnownEntities().find((entity) => entity.type === 'project' && entity.id === id) ?? null;
    };

    const likelyProjectIdFor = (trp: TurnResolutionPacket | null): string | null => {
      const likely = trp?.context_hypothesis?.likely_entity;
      if (likely?.type !== 'project' || !likely.id) return null;
      return /^[A-Za-z0-9_-]+$/.test(likely.id) ? likely.id : null;
    };

    const projectEntityHasContextSupport = (id: string, label: string | null | undefined, text: string): boolean => {
      if (projectIdFromPath() === id) return true;
      const knownProject = knownProjectById(id);
      if (knownProject) return textMentionsEntity(text, knownProject.label);
      return Boolean(label && textMentionsEntity(text, label));
    };

    const startNewIntakeTurn = (trp: TurnResolutionPacket | null): boolean => {
      const frame = trp?.context_hypothesis?.frame;
      return (frame === 'estimate_walk' || frame === 'job_intake') && likelyProjectIdFor(trp) === null;
    };

    const turnNeedsProjectBeforeSave = (trp: TurnResolutionPacket | null): boolean => {
      if (!trp || likelyProjectIdFor(trp) !== null || startNewIntakeTurn(trp)) return false;
      const frame = trp.context_hypothesis?.frame;
      return trp.intent === 'job_note' || trp.intent === 'job_log' || frame === 'field_note';
    };

    const promptForTurn = (trp: TurnResolutionPacket): string => {
      if (turnNeedsProjectBeforeSave(trp)) {
        const destination = conversationDestinationFor(trp);
        return destination
          ? `I will keep this with ${destination}. I still need to match it to a job before I file it.`
          : overlay.dataset.correctionNeeds ?? 'Which job should I attach this to?';
      }
      const entity = likelyEntityLabel(trp);
      const conversationalEntity = conversationEntityLabel(trp);
      const frame = trp.context_hypothesis?.frame;
      if (entity && (trp.intent === 'job_note' || trp.intent === 'job_log' || frame === 'field_note')) {
        return `I'll save this to ${conversationalEntity || entity} → today's Daily Log. Good there?`;
      }
      if (entity && (trp.intent === 'job_intake' || trp.intent === 'estimate_update' || frame === 'estimate_walk')) {
        return `Create estimate from this for ${conversationalEntity || entity}?`;
      }
      if (!entity && (trp.intent === 'job_intake' || trp.intent === 'estimate_update' || frame === 'estimate_walk')) {
        return 'Start a new estimate from this?';
      }
      return trp.context_hypothesis.prompt;
    };

    const withKnownEntity = (trp: TurnResolutionPacket): TurnResolutionPacket => {
      const likely = trp.context_hypothesis.likely_entity;
      if (likely?.type === 'project' && likely.id) {
        if (projectEntityHasContextSupport(likely.id, likely.label, trp.heard_text)) return trp;
        return buildTurnResolutionPacket({
          heardText: trp.heard_text,
          intent: trp.intent,
          workArtifact: trp.work_artifact,
          sourceRefs: trp.source_refs,
          memoryCandidates: trp.memory_candidates,
          contextHypothesis: {
            ...trp.context_hypothesis,
            likely_entity: null,
            routed_label: trp.context_hypothesis.frame === 'estimate_walk' || trp.context_hypothesis.frame === 'job_intake'
              ? 'New project → estimate'
              : 'Job note → choose job',
            prompt: trp.context_hypothesis.frame === 'estimate_walk' || trp.context_hypothesis.frame === 'job_intake'
              ? 'Start a new estimate from this?'
              : 'Which job should I attach this to?',
          },
          now: trp.created_at,
        });
      }
      if (likely?.id) return trp;
      const project = collectKnownEntities().find((entity) => entity.type === 'project' && textMentionsEntity(trp.heard_text, entity.label));
      if (!project) return trp;
      const frame = trp.context_hypothesis.frame;
      const entity = {
        type: 'project' as const,
        id: project.id ?? null,
        label: project.label,
        confidence: 'high' as const,
      };
      const contextHypothesis = {
        ...trp.context_hypothesis,
        likely_entity: entity,
        routed_label: frame === 'estimate_walk' || frame === 'job_intake'
          ? `${project.label} → estimate`
          : `${project.label} → job notes`,
        prompt: frame === 'estimate_walk' || frame === 'job_intake'
          ? `Create estimate from this for ${project.label}?`
          : `I'll save this to ${project.label} → today's Daily Log. Good there?`,
        missing_facts: trp.context_hypothesis.missing_facts.filter((fact) => !/\b(job|project|active project)\b/i.test(fact)),
      };
      return buildTurnResolutionPacket({
        heardText: trp.heard_text,
        intent: trp.intent,
        workArtifact: trp.work_artifact,
        sourceRefs: trp.source_refs,
        memoryCandidates: trp.memory_candidates,
        contextHypothesis,
        now: trp.created_at,
      });
    };

    const resolveTurnServerSide = async (text: string, fallback: TurnResolutionPacket): Promise<TurnResolutionPacket> => {
      try {
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        const res = await fetch('/api/v1/right-hand/resolve-turn', {
          method: 'POST',
          credentials: 'include',
          headers,
          body: JSON.stringify({
            heardText: text,
            currentPath: window.location.pathname,
            userRole: 'owner',
            // V1 personalization hook: tenant/user preference orders what Right
            // Hand offers next, but never bypasses durable/money/send gates.
            userPreferenceSummary: rightHandVoiceProfileSummary(),
            knownEntities: collectKnownEntities(),
          }),
        });
        if (!res.ok) return fallback;
        const body = await res.json() as { trp?: unknown };
        const parsed = parseTurnResolution(JSON.stringify(body.trp ?? null));
        return parsed ? withKnownEntity(parsed) : fallback;
      } catch {
        return fallback;
      }
    };

    type ResolveReplyResponse = {
      reply?: string;
      mode?: string;
      authority?: string;
      fallback_reason?: string;
      workingDraft?: unknown;
      working_draft?: unknown;
      proposed_action?: unknown;
      artifact_action?: unknown;
      draft_fabrication_flags?: unknown;
    };

    type EstimateArtifactActionPayload = {
      status?: string;
      route?: string | null;
      operator_message?: string;
    };

    type ResolvedReplyPayload = {
      readonly reply: string;
      readonly workingDraft: WorkingDraftFields;
      readonly proposedAction: RightHandProposedAction | null;
      readonly artifactAction: EstimateArtifactActionPayload | null;
    };

    const resolveReplyServerSide = async (
      latestText: string,
      draftText: string,
      trp: TurnResolutionPacket,
      turnsForModel: ConversationTurn[],
    ): Promise<ResolvedReplyPayload | null> => {
      try {
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        const res = await fetch('/api/v1/right-hand/resolve-reply', {
          method: 'POST',
          credentials: 'include',
          headers,
          body: JSON.stringify({
            latestText,
            draftText,
            trp,
            currentPath: `${window.location.pathname}${window.location.search}`,
            userRole: 'owner',
            userPreferenceSummary: rightHandVoiceProfileSummary(),
            knownEntities: collectKnownEntities(),
            conversationDestinationLabel,
            workingDraft: currentWorkingDraft(),
            conversationId: getConversationId(),
            conversationTurns: turnsForModel.map((turn) => ({
              speaker: turn.speaker,
              text: turn.text,
            })),
          }),
        });
        if (!res.ok) return null;
        const body = await res.json() as ResolveReplyResponse;
        const reply = typeof body.reply === 'string' ? body.reply.trim() : '';
        if (!reply) return null;
        return {
          reply,
          workingDraft: cleanStoredWorkingDraft(body.workingDraft ?? body.working_draft, draftText),
          proposedAction: normalizeProposedAction(body.proposed_action),
          artifactAction: body.artifact_action && typeof body.artifact_action === 'object'
            ? body.artifact_action as EstimateArtifactActionPayload
            : null,
        };
      } catch {
        return null;
      }
    };

    type AssembleEstimateResponse = {
      ok?: boolean;
      status?: string;
      route?: string;
      draft?: unknown;
      working_draft?: unknown;
      workingDraft?: unknown;
    };

    // Hard client bound on the assembly request: ~40s is normal frontier
    // assembly; at 150s something is genuinely wrong and the operator gets an
    // honest snag, never an indicator that outlives the work.
    const ASSEMBLY_TIMEOUT_MS = 150_000;

    const assembleEstimateServerSide = async (
      latestText: string,
      draftText: string,
      turnsForModel: ConversationTurn[],
    ): Promise<{ route: string; workingDraft: WorkingDraftFields; openQuestionCount: number } | null> => {
      const abort = new AbortController();
      const timeoutHandle = window.setTimeout(() => abort.abort(), ASSEMBLY_TIMEOUT_MS);
      try {
        const res = await fetch('/api/v1/right-hand/assemble-estimate', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          signal: abort.signal,
          body: JSON.stringify({
            latestText,
            draftText,
            currentPath: window.location.pathname,
            project_id: projectIdFromPath(),
            userRole: 'owner',
            conversationDestinationLabel,
            workingDraft: currentWorkingDraft(),
            conversationId: getConversationId(),
            conversationTurns: turnsForModel.map((turn) => ({
              speaker: turn.speaker,
              text: turn.text,
            })),
          }),
        });
        if (!res.ok) return null;
        const body = await res.json() as AssembleEstimateResponse;
        const route = typeof body.route === 'string' && body.route.trim() ? body.route.trim() : '';
        if (!route) return null;
        const draftQuestions = (body.draft as { open_questions?: unknown } | undefined)?.open_questions;
        return {
          route,
          workingDraft: cleanStoredWorkingDraft(body.workingDraft ?? body.working_draft, draftText),
          openQuestionCount: Array.isArray(draftQuestions) ? draftQuestions.length : 0,
        };
      } catch {
        return null;
      } finally {
        window.clearTimeout(timeoutHandle);
      }
    };

    // ── Working-state presence (thinking-state card) ─────────────────────
    // One state machine drives the orb, the narration, the bubble label, and
    // the resolution copy. Phases bind to real async edges only.
    const presenceEl = document.getElementById('rhvo-presence');
    const presenceTextEl = document.getElementById('rhvo-presence-text');
    let presenceTimer: number | null = null;

    const showWorkingPresence = () => {
      const startedAt = Date.now();
      writePhaseState(sessionStorage, { phase: 'working', at: startedAt, conversationId: getConversationId() });
      if (presenceEl) presenceEl.hidden = false;
      if (presenceTextEl) presenceTextEl.textContent = workingNarration(0);
      if (presenceTimer !== null) window.clearInterval(presenceTimer);
      // The interval refreshes elapsed-keyed TEXT; it never advances the
      // phase — only a real response/poll result does that.
      presenceTimer = window.setInterval(() => {
        if (presenceTextEl) presenceTextEl.textContent = workingNarration(Date.now() - startedAt);
      }, 5_000);
    };

    const hideWorkingPresence = () => {
      if (presenceTimer !== null) {
        window.clearInterval(presenceTimer);
        presenceTimer = null;
      }
      if (presenceEl) presenceEl.hidden = true;
    };

    const SNAG_REPLY = 'Hit a snag building the estimate — nothing was lost. Say it again or tap the mic to retry.';

    /**
     * The one assembly path both call sites share: presence on → real
     * request → exactly one honest ending (ready | question | snag), with
     * the no-yank guard deciding navigate-vs-park.
     */
    const runAssemblyWithPresence = (
      latestText: string,
      draftText: string,
      turnsForModel: ConversationTurn[],
      replyIndex: number,
    ): void => {
      showWorkingPresence();
      void assembleEstimateServerSide(latestText, draftText, turnsForModel).then((payload) => {
        hideWorkingPresence();
        const phase = phaseAfterAssembly({
          ok: payload !== null,
          hasRoute: payload !== null,
          openQuestionCount: payload?.openQuestionCount ?? 0,
        });
        if (phase === 'snag' || payload === null) {
          writePhaseState(sessionStorage, { phase: 'snag', at: Date.now(), conversationId: getConversationId() });
          replaceTurn(replyIndex, 'right_hand', SNAG_REPLY);
          persistConversation();
          return;
        }
        canonicalWorkingDraft = payload.workingDraft;
        const questionDetail = payload.openQuestionCount > 0
          ? `Needs your call: ${payload.openQuestionCount} question${payload.openQuestionCount === 1 ? '' : 's'}`
          : undefined;
        writePhaseState(sessionStorage, {
          phase,
          at: Date.now(),
          conversationId: getConversationId(),
          ...(questionDetail ? { detail: questionDetail } : {}),
        });
        replaceTurn(
          replyIndex,
          'right_hand',
          phase === 'question'
            ? `Estimate draft is open — ${payload.openQuestionCount} question${payload.openQuestionCount === 1 ? '' : 's'} need your call. I'm still here if you want to adjust it.`
            : 'Estimate draft is open. I’m still here if you want to adjust it.',
        );
        persistConversation();
        if (shouldNavigateAfterAssembly({ overlayHidden: overlay.hidden })) {
          clearPhaseState(sessionStorage);
          window.setTimeout(() => navigate(payload.route, { resume: true }), 180);
        } else {
          // Operator moved on mid-assembly — never yank (walk: "popped in and out").
          const bubbleHint = questionDetail ?? 'Estimate draft ready';
          writeResumeState(sessionStorage, { at: Date.now(), href: payload.route, hint: bubbleHint });
          showResumeBubble(bubbleHint);
        }
      });
    };

    // ── Stage 4 consequence bubble (F-RH3): durable intents NEVER auto-navigate.
    // The reply is appended in place (You said · Right Hand reply · where-it-goes
    // prompt) on the same blurred surface — the mic stays available — and the
    // affordances answer the real question: Save to <job> · Change job · Keep
    // talking. The overlay persists NOTHING here; Save commits through the
    // validated server path and only THEN renders the filed (stage 5) state. ────
    const enterConfirm = (text: string) => {
      awaitingConfirm = true;
      parkedTranscript = text;
      const intent = classifyTranscriptIntent(text);
      parkedIntent = intent;
      const trp = withKnownEntity(buildTurnResolutionPacket({ heardText: text, intent }));
      parkedTurnResolution = trp;
      // Mic off while the operator decides (privacy / bounded window §4). Change
      // → beginSession() re-acquires from scratch, same as Continue.
      teardown();
      setState('confirm');
      setHeading(template(overlay.dataset.headConfirm ?? 'Ready for {operator}', { operator: operatorName() }));
      setStatus('');
      if (timerEl) timerEl.textContent = '';
      if (confirmHeardEl) confirmHeardEl.textContent = text;
      resetConfirmActionCopy();
      showActions('confirm');
      // renderConfirmTurn runs AFTER showActions so its entity-gated Change-job
      // visibility (and "Save to <job>" label) win over the default confirm row.
      renderConfirmTurn(trp);
      if (intent === 'proposal_projection') {
        renderProposalProjectionConfirm();
        return;
      }
      void resolveTurnServerSide(text, trp).then((serverTrp) => {
        // Only update if the operator is still deciding on the same turn.
        if (!awaitingConfirm || parkedTranscript !== text || state !== 'confirm') return;
        const resolvedTrp = withKnownEntity(serverTrp);
        parkedTurnResolution = resolvedTrp;
        renderConfirmTurn(resolvedTrp);
      });
    };

    const enterReply = (text: string) => {
      const clean = text.trim();
      if (!clean) return;
      awaitingConfirm = false;
      const isDestinationCorrection = textIsDestinationCorrection(clean);
      const spokenDestination = isDestinationCorrection ? extractDestinationLabel(clean) : '';
      if (spokenDestination) conversationDestinationLabel = spokenDestination;
      pushWorkingDraftTurn(clean);
      const draftText = workingDraftText() || clean;
      const intent = conversationIntentForTurn(clean, draftText);
      const trp = withKnownEntity(buildTurnResolutionPacket({ heardText: draftText, intent }));
      parkedTranscript = workingDraftText();
      parkedIntent = intent;
      parkedTurnResolution = trp;
      teardown();
      setState('reply');
      setHeading('');
      setStatus('');
      if (timerEl) timerEl.textContent = '';
      setCaption('');
      clearComposer();
      {
        const verdict = checkTranscript(clean);
        if (!verdict.ok) {
          // ASR hallucination guard: drop the phantom turn, tell the operator.
          setStatus('Didn\u2019t catch that \u2014 try again.');
          showActions('listening');
          return;
        }
      }
      appendTurn('operator', clean);
      const turnsForModel = [...conversationTurns];
      const wantsArtifactDraft = textRequestsProposalOrInvoice(clean);
      const wantsAssembly = !wantsArtifactDraft && (textRequestsEstimateAssembly(clean) || textLooksLikeEstimatePageUpdate(clean));
      const fallbackReply = wantsAssembly
        ? 'Assembling the estimate draft…'
        : wantsArtifactDraft
          ? 'Checking the estimate gate…'
          : pendingReplyText();
      const replyIndex = appendTurn('right_hand', fallbackReply);
      showActions('listening');
      persistConversation();
      if (wantsAssembly) {
        runAssemblyWithPresence(clean, draftText, turnsForModel, replyIndex);
        return;
      }
      void resolveReplyServerSide(clean, draftText, trp, turnsForModel).then((payload) => {
        if (!payload) return;
        canonicalWorkingDraft = payload.workingDraft;
        if (payload.artifactAction?.route && payload.artifactAction.status === 'ready_for_review') {
          replaceTurn(replyIndex, 'right_hand', payload.reply);
          persistConversation();
          navigate(payload.artifactAction.route, { resume: true });
          return;
        }
        if (payload.proposedAction === 'assemble_estimate') {
          replaceTurn(replyIndex, 'right_hand', 'Assembling the estimate draft…');
          persistConversation();
          runAssemblyWithPresence(clean, draftText, turnsForModel, replyIndex);
          return;
        }
        if (payload.reply === fallbackReply) {
          persistConversation();
          return;
        }
        replaceTurn(replyIndex, 'right_hand', payload.reply);
        persistConversation();
      });
    };

    const SORTING_BEAT_MS = 700;
    const enterSorting = (text: string) => {
      // Guard immediately so the still-draining session can't re-commit mid-beat.
      awaitingConfirm = true;
      setState('sorting');
      setHeading(overlay.dataset.headSorting ?? 'Heard you');
      setStatus(overlay.dataset.sorting ?? 'Got it. Sorting this…');
      setCaption('');
      window.setTimeout(() => enterConfirm(text), SORTING_BEAT_MS);
    };

    const routeCommitted = (intent: VoiceIntent, text: string) => {
      const cleanText = cleanCommittedTranscript(text);
      if (!cleanText) {
        recoverVoiceTurn('I didn’t catch usable speech. Tap Continue and say it again.');
        return;
      }
      const existingDraftText = workingDraftText();
      const draftText = [existingDraftText, cleanText].filter(Boolean).join('\n\n');
      if (cleanText.length > 0 && textRequestsDurableCommit(cleanText) && (draftText.length > 0 || textContainsInlineDurableDraft(cleanText))) {
        const draft = draftText.length > 0 ? draftText : cleanText;
        if (existingDraftText.length === 0) {
          pushWorkingDraftTurn(cleanText);
        }
        appendTurn('operator', cleanText);
        persistConversation();
        enterSorting(draft);
        return;
      }
      const conversationIntent = conversationIntentForTurn(cleanText, draftText || cleanText);
      if (conversationIntent === 'proposal_projection') {
        appendTurn('operator', cleanText);
        persistConversation();
        enterSorting(cleanText);
        return;
      }
      if (requiresCommittedTranscript(conversationIntent)) {
        // Durable-capable speech starts as conversation, not a button gate. A
        // consequence bubble appears only when the operator asks to file/send or
        // taps the explicit save affordance at the end of the thread.
        enterReply(cleanText);
        return;
      }
      if (canRouteFromInterim(intent)) {
        if (!routedLive) routeLive(intent);
        return;
      }
      if (cleanText.length > 0) {
        // A useful field note does not need to contain a routing keyword. Keep
        // it as a conversational turn until the operator asks to file it.
        enterReply(cleanText);
        return;
      }
      // Unclassified — keep the overlay open and prompt once.
      setCaption(cleanText);
      setStatus(overlay.dataset.clarify ?? 'I didn’t catch an action — say it once more?');
      armIdleClose();
    };

    // Both "Keep talking" and "Change job" resume the SAME conversational
    // thread. Prior turns stay in workingDraftTurns; the next spoken/typed turn
    // is appended as its own bubble rather than being spliced into one synthetic
    // transcript. Nothing is persisted or discarded.
    const resumeListeningWithCorrection = (statusText: string) => {
      awaitingConfirm = false;
      confirmSaveNeedsMoreContext = false;
      parkedTranscript = '';
      parkedIntent = 'unclassified';
      parkedTurnResolution = null;
      routedLive = false;
      lastInterim = '';
      setCaption('');
      clearComposer();
      if (captionLabelEl) captionLabelEl.textContent = operatorName();
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(statusText);
      showActions('listening');
      startTimer();
      void beginSession();
    };

    // Keep talking — stay in the turn and add to the note.
    const returnToListening = () => {
      resumeListeningWithCorrection(
        overlay.dataset.keepTalkingPrompt ?? overlay.dataset.correctionPrompt ?? 'Keep talking — I’m listening.',
      );
    };

    // Change job — re-route the same note to a different job. Same resume path,
    // but the prompt asks specifically for the destination.
    const changeJob = () => {
      appendTurn('right_hand', overlay.dataset.correctionNeeds ?? 'Which job should I attach this to?');
      resumeListeningWithCorrection(
        overlay.dataset.correctionNeeds ?? 'Which job should I attach this to?',
      );
    };

    type CommitTurnResponse = {
      ok?: boolean;
      trp?: unknown;
      error?: string;
      reason?: string;
      operator_message?: string;
    };

    const currentProjectId = (): string | undefined => (
      document.querySelector<HTMLElement>('[data-project-id]')?.dataset.projectId?.trim() || undefined
    );

    const friendlyCommitFailure = (body: CommitTurnResponse, status: number): { message: string; projectCorrection: boolean } => {
      const code = body.error ?? `request_failed_${status}`;
      if (body.operator_message && !/tenant-scoped/i.test(body.operator_message)) {
        return {
          message: body.operator_message,
          projectCorrection: code === 'project_required' || code === 'project_not_found' || code === 'tenant_mismatch',
        };
      }
      if (code === 'project_required') {
        return { message: overlay.dataset.commitProjectNeeded ?? 'I need to know which job this belongs to. Tell me the job name. Nothing was filed.', projectCorrection: true };
      }
      if (code === 'project_not_found') {
        return { message: overlay.dataset.commitProjectNotFound ?? 'I couldn’t find that job yet. Tell me the job name again. Nothing was filed.', projectCorrection: true };
      }
      if (code === 'tenant_mismatch') {
        return { message: overlay.dataset.commitProjectMismatch ?? 'I can’t file that to this job from the current workspace. Tell me the right job. Nothing was filed.', projectCorrection: true };
      }
      if (code === 'tenant_required') {
        return { message: overlay.dataset.commitWorkspaceNeeded ?? 'I need your workspace loaded before I can file that. Reload and try again. Nothing was filed.', projectCorrection: false };
      }
      return { message: `${overlay.dataset.commitFailed ?? 'I could not file that yet.'} I kept the note here so you can try again. Nothing was filed.`, projectCorrection: false };
    };

    const commitTurnServerSide = async (trp: TurnResolutionPacket): Promise<{ ok: true; trp: TurnResolutionPacket } | { ok: false; message: string; projectCorrection: boolean }> => {
      try {
        const headers: Record<string, string> = { 'Content-Type': 'application/json' };
        const res = await fetch('/api/v1/right-hand/commit-turn', {
          method: 'POST',
          credentials: 'include',
          headers,
          body: JSON.stringify({
            trp,
            tenant_id: tenantId,
            project_id: currentProjectId(),
            currentPath: window.location.pathname,
            knownEntities: collectKnownEntities(),
            idempotency_key: `${trp.created_at}:${trp.intent}:${trp.heard_text}`,
          }),
        });
        const body = await res.json() as CommitTurnResponse;
        if (!res.ok || body.ok !== true) {
          return { ok: false, ...friendlyCommitFailure(body, res.status) };
        }
        const parsed = parseTurnResolution(JSON.stringify(body.trp ?? null));
        if (!parsed || !parsed.work_artifact || parsed.attention_artifact.kind !== 'handled') {
          return { ok: false, message: `${overlay.dataset.commitFailed ?? 'I could not file that yet.'} I kept the note here so you can try again. Nothing was filed.`, projectCorrection: false };
        }
        return { ok: true, trp: parsed };
      } catch {
        return { ok: false, message: `${overlay.dataset.commitFailed ?? 'I could not file that yet.'} I could not reach the filing service. Nothing was filed.`, projectCorrection: false };
      }
    };

    const routeToNewProjectIntake = (trp: TurnResolutionPacket) => {
      try {
        sessionStorage.setItem(TURN_RESOLUTION_SESSION_KEY, serializeTurnResolution(trp));
      } catch { /* storage may be unavailable; the route still works */ }
      stashCommitted(trp.heard_text);
      const text = trp.heard_text.toLowerCase();
      const archetype = /\b(bath|bathroom|shower|tub|vanity)\b/.test(text)
        ? 'bath_refresh'
        : /\b(kitchen|cabinet|countertop|appliance|island|pantry)\b/.test(text)
          ? 'kitchen_remodel'
          : /\b(adu|addition)\b/.test(text)
            ? 'adu'
            : '';
      const archetypeParam = archetype ? `&archetype=${archetype}` : '';
      const conversationParam = `&conversation_id=${encodeURIComponent(getConversationId())}`;
      persistConversation();
      navigate(`/projects/new?src=voice&intent=estimate_walk${archetypeParam}${conversationParam}`);
    };

    // ── Turn commit (Packet #27): Save asks the server to create a durable
    // artifact through the validator wall. The UI only shows `handled` after the
    // API returns a TRP whose work_artifact came from real persistence.
    const resolveTurn = async (text: string) => {
      const clean = text.trim();
      const intent = classifyTranscriptIntent(clean);
      const baseTrp = parkedTurnResolution?.heard_text === clean
        ? parkedTurnResolution
        : buildTurnResolutionPacket({ heardText: clean, intent });
      if (parkedIntent === 'proposal_projection' || baseTrp.intent === 'proposal_projection') {
        activeSurfaceContext = readSurfaceContext() ?? activeSurfaceContext;
        const resolution = resolveProposalProjectionFromContext(activeSurfaceContext);
        if (!resolution.href) {
          confirmSaveNeedsMoreContext = true;
          if (confirmReplyEl) confirmReplyEl.textContent = resolution.creating;
          if (confirmPromptEl) confirmPromptEl.textContent = resolution.needs;
          if (saveBtn) saveBtn.hidden = true;
          if (notThatBtn) notThatBtn.disabled = false;
          setStatus(resolution.needs);
          return;
        }
        stashCommitted(clean);
        persistConversation();
        navigate(resolution.href, { resume: true });
        return;
      }
      if (turnNeedsProjectBeforeSave(baseTrp)) {
        returnToListening();
        return;
      }
      if (startNewIntakeTurn(baseTrp)) {
        routeToNewProjectIntake(baseTrp);
        return;
      }
      if (saveBtn) saveBtn.disabled = true;
      if (notThatBtn) notThatBtn.disabled = true;
      setStatus(overlay.dataset.commitPending ?? 'Saving through the validated path…');
      const committed = await commitTurnServerSide(baseTrp);
      if (!committed.ok) {
        if (saveBtn) saveBtn.disabled = committed.projectCorrection;
        if (notThatBtn) notThatBtn.disabled = false;
        if (notThatBtn && committed.projectCorrection) {
          notThatBtn.textContent = overlay.dataset.actionTellJob ?? 'Tell me job';
        }
        if (committed.projectCorrection) {
          if (confirmReplyEl) {
            confirmReplyEl.textContent = overlay.dataset.replyCorrectionNeeded
              ?? 'I have the note. Tell me the job and I’ll file it there.';
          }
          if (confirmPromptEl) confirmPromptEl.textContent = overlay.dataset.correctionNeeds ?? 'Which job should I attach this to?';
        }
        setStatus(committed.message);
        return;
      }
      const trp = committed.trp;
      try {
        sessionStorage.setItem(TURN_RESOLUTION_SESSION_KEY, serializeTurnResolution(trp));
      } catch { /* storage may be unavailable; the next-step buttons still work */ }
      // Stash the transcript too so an explicit "Add a photo" hand-off to Field
      // Capture can pick the note up. This is NOT a durable write.
      stashCommitted(clean);
      currentMoves = nextMovesFor(trp);
      resolvedSurface = trp.next_surface;
      releaseListeningResources();
      awaitingConfirm = false;
      parkedTranscript = '';
      parkedIntent = 'unclassified';
      parkedTurnResolution = null;
      if (saveBtn) saveBtn.disabled = false;
      if (notThatBtn) notThatBtn.disabled = false;
      setState('resolved');
      // Stage 5 (F-RH3): the committed state renders ONLY now that the durable
      // write returned — "✓ Filed to <job> · Daily Log · via voice". Never before
      // (honesty floor #5). The conversation stays open with the mic available;
      // the next-move buttons offer "add a photo" etc. without dumping the user.
      const filedEntity = conversationEntityLabel(trp);
      setHeading(filedEntity
        ? template(overlay.dataset.headFiled ?? '✓ Filed to {job} · Daily Log · via voice', { job: filedEntity })
        : overlay.dataset.headFiledGeneric ?? '✓ Filed · Daily Log · via voice');
      setStatus('');
      if (timerEl) timerEl.textContent = '';
      appendTurn('system', filedEntity
        ? template(overlay.dataset.headFiled ?? '✓ Filed to {job} · Daily Log · via voice', { job: filedEntity })
        : overlay.dataset.headFiledGeneric ?? '✓ Filed · Daily Log · via voice', 'saved');
      appendTurn('right_hand', overlay.dataset.filedPrompt ?? 'Anything else, or want to add a photo to it?');
      workingDraftTurns = [];
      persistConversation();
      showActions('resolved');
    };

    const routeMove = (id: string | null) => {
      const move = currentMoves.find((m) => m.id === id) ?? null;
      navigate(move ? move.route : resolvedSurface);
    };

    // Backdrop / Escape: in the resolved state this lands Home (the default
    // landing with the result folded in), never a dead stay-on-page.
    const dismissOverlay = () => {
      if (state === 'resolved') {
        navigate(resolvedSurface);
        return;
      }
      closeOverlay();
    };

    // ── Interim words: may ONLY fire reversible LIVE navigations (§9). ───────
    const onInterim = (text: string) => {
      if (awaitingConfirm) return; // confirm trust loop owns the turn
      lastInterim = text;
      setCaption(text);
      armIdleClose();
      if (routedLive) return;
      const intent = classifyTranscriptIntent(text);
      if (canRouteFromInterim(intent)) {
        routedLive = routeLive(intent);
      }
    };

    // ── Committed transcript: the only input allowed to drive durable actions.
    const onCommitted = (text: string) => {
      if (awaitingConfirm) return; // already parked for confirm; ignore stragglers
      const finalText = cleanCommittedTranscript(text.trim().length > 0 ? text : lastInterim);
      if (!finalText) {
        recoverVoiceTurn('I didn’t catch usable speech. Tap Continue and say it again.');
        return;
      }
      setCaption(finalText);
      const intent = classifyTranscriptIntent(finalText);
      routeCommitted(intent, finalText);
    };

    const finishCurrentTurn = () => {
      if (recorder && recorder.state !== 'inactive') {
        setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
        recorder.stop();
        releaseListeningResources();
        return;
      }
      releaseListeningResources();
      const interim = cleanCommittedTranscript(currentCaptionText());
      if (interim.length === 0) {
        setState('capped');
        setStatus(overlay.dataset.clarify ?? 'I didn’t catch an action — say it once more?');
        showActions('capped');
        return;
      }
      const intent = classifyTranscriptIntent(interim);
      if (canRouteFromInterim(intent)) {
        routedLive = routeLive(intent);
        return;
      }
      setCaption(interim);
      // Useful speech becomes the next conversational turn first. The
      // consequence bubble appears only when the operator asks to file/send or
      // taps the explicit Save affordance.
      routeCommitted(intent, interim);
    };

    // ── Bounded window timers (§4) ──────────────────────────────────────────
    const armHardCap = () => {
      window.clearTimeout(hardCapTimer);
      hardCapTimer = window.setTimeout(() => {
        setState('capped');
        setStatus(overlay.dataset.capped ?? 'Paused — tap Continue to keep going.');
        showActions('capped');
        // Hard cap reached: fully release the mic + audio graph (bounded-window /
        // privacy rule §4) by reusing the shared teardown() — not a hand-rolled
        // partial copy. Keep the overlay + Continue button visible; Continue →
        // beginSession() re-acquires the mic from scratch via getUserMedia.
        teardown();
      }, hardCapMs);
    };
    const armIdleClose = () => {
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => closeOverlay(), idleCloseMs);
    };

    const recoverVoiceTurn = (message?: string) => {
      awaitingConfirm = false;
      parkedTranscript = '';
      parkedIntent = 'unclassified';
      const partial = cleanCommittedTranscript(currentCaptionText());
      if (partial && workingDraftTurns.at(-1) !== partial) {
        pushWorkingDraftTurn(partial);
        appendTurn('operator', partial);
      }
      persistConversation();
      lastInterim = '';
      teardown();
      setState('capped');
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setCaption('');
      setStatus(message ?? overlay.dataset.retry ?? 'I couldn’t finish that. Tap Continue and say it again.');
      showActions('capped');
    };

    // ── VAD via Web Audio AnalyserNode: drive the level meter + silence commit.
    const SPEECH_RMS = 0.025;
    const BAR_WEIGHTS = [0.6, 0.82, 1, 1.18, 1, 0.82, 0.6]; // center-weighted VU
    let speaking = false;
    const startMeter = (onSilenceCommit: () => void) => {
      if (!mediaStream) return;
      audioCtx = new (window.AudioContext || (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext)();
      const src = audioCtx.createMediaStreamSource(mediaStream);
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 512;
      src.connect(analyser);
      const buf = new Uint8Array(analyser.frequencyBinCount);
      const tick = () => {
        if (!analyser) return;
        analyser.getByteTimeDomainData(buf);
        let sum = 0;
        for (let i = 0; i < buf.length; i += 1) {
          const v = (buf[i]! - 128) / 128;
          sum += v * v;
        }
        const rms = Math.sqrt(sum / buf.length);
        // Discrete field-green VU bars driven by the real rms (F-RH1). Center
        // bars weighted taller; floored so they read as present, not dead.
        const level = Math.min(1, rms * 6);
        for (let b = 0; b < meterBars.length; b += 1) {
          const weight = BAR_WEIGHTS[b] ?? 1;
          const h = Math.max(0.18, Math.min(1, level * weight));
          meterBars[b]!.style.transform = `scaleY(${h})`;
        }
        if (rms >= SPEECH_RMS) {
          speaking = true;
          window.clearTimeout(silenceTimer);
          window.clearTimeout(idleTimer);
        } else if (speaking) {
          window.clearTimeout(silenceTimer);
          silenceTimer = window.setTimeout(() => {
            speaking = false;
            onSilenceCommit();
          }, silenceCommitMs);
        }
        rafId = requestAnimationFrame(tick);
      };
      rafId = requestAnimationFrame(tick);
    };

    // ── Groq record-then-send fallback (no consent / realtime unavailable). ──
    const chooseMime = () => {
      if (!('MediaRecorder' in window)) return '';
      const opts = ['audio/mp4', 'audio/aac', 'audio/webm;codecs=opus', 'audio/webm'];
      return opts.find((o) => MediaRecorder.isTypeSupported(o)) ?? '';
    };
    const startFallback = () => {
      setState('fallback');
      setStatus(overlay.dataset.fallback ?? 'Listening — transcribes when you pause.');
      if (!mediaStream || !('MediaRecorder' in window)) {
        setStatus(overlay.dataset.unavailable ?? 'Voice isn’t available here — open Right Hand to type.');
        return;
      }
      const mime = chooseMime();
      recorder = new MediaRecorder(mediaStream, mime ? { mimeType: mime } : undefined);
      recChunks = [];
      recorder.addEventListener('dataavailable', (e) => {
        if (e.data.size > 0) recChunks.push(e.data);
      });
      recorder.addEventListener('stop', async () => {
        if (recChunks.length === 0) {
          recoverVoiceTurn();
          return;
        }
        const blob = new Blob(recChunks, { type: recorder?.mimeType || 'audio/webm' });
        recChunks = [];
        setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), TRANSCRIBE_TIMEOUT_MS);
        try {
          const res = await fetch('/api/v1/transcribe', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': blob.type || 'audio/webm' },
            body: blob,
            signal: controller.signal,
          });
          if (!res.ok) {
            recoverVoiceTurn(overlay.dataset.unavailable ?? 'Couldn’t transcribe — open Right Hand to type.');
            return;
          }
          const data = (await res.json()) as { transcript?: string };
          const transcript = cleanCommittedTranscript(data.transcript ?? '');
          if (transcript.length === 0) {
            recoverVoiceTurn();
            return;
          }
          onCommitted(transcript);
        } catch {
          recoverVoiceTurn();
        } finally {
          window.clearTimeout(timeout);
        }
      });
      recorder.start();
      startMeter(() => {
        // On 2–3s silence: stop the clip → POST → committed transcript.
        if (recorder && recorder.state !== 'inactive') recorder.stop();
      });
    };

    // ── Realtime (consenting tenant): WebRTC transcription-only session. ─────
    const startRealtime = async (clientSecret: string, model: string) => {
      try {
        pc = new RTCPeerConnection();
        if (mediaStream) {
          for (const track of mediaStream.getAudioTracks()) pc.addTrack(track, mediaStream);
        }
        dc = pc.createDataChannel('oai-events');
        dc.addEventListener('message', (e) => {
          try {
            const evt = JSON.parse(e.data as string) as { type?: string; delta?: string; transcript?: string };
            if (evt.type?.includes('input_audio_transcription') && typeof evt.delta === 'string') {
              onInterim(`${lastInterim}${evt.delta}`);
            } else if (
              evt.type?.includes('input_audio_transcription') &&
              evt.type.includes('completed') &&
              typeof evt.transcript === 'string'
            ) {
              onCommitted(evt.transcript);
              lastInterim = '';
            }
          } catch { /* ignore non-JSON frames */ }
        });
        const offer = await pc.createOffer();
        await pc.setLocalDescription(offer);
        const sdpRes = await fetch(`https://api.openai.com/v1/realtime?model=${encodeURIComponent(model)}`, {
          method: 'POST',
          headers: { Authorization: `Bearer ${clientSecret}`, 'Content-Type': 'application/sdp' },
          body: offer.sdp ?? '',
        });
        if (!sdpRes.ok) {
          startFallback();
          return;
        }
        const answer = { type: 'answer' as const, sdp: await sdpRes.text() };
        await pc.setRemoteDescription(answer);
        setState('listening');
        startMeter(() => {
          // Silence after speech: the realtime server VAD commits the final
          // transcript over the data channel. Re-arm idle close so that if no
          // `completed` event ever arrives, the session closes honestly at the
          // idle window instead of sitting open to the hard cap.
          setStatus(overlay.dataset.transcribing ?? 'Transcribing…');
          armIdleClose();
        });
      } catch {
        startFallback();
      }
    };

    const beginSession = async () => {
      if (!(await acquireMicStream())) return;
      armHardCap();
      armIdleClose();
      // Ask the server whether this tenant gets realtime. Consent + config are
      // server-authoritative; 403/503 → honest Groq fallback.
      try {
        const res = await fetch('/api/v1/realtime/transcription-session', { method: 'POST', credentials: 'include' });
        if (res.ok) {
          const data = (await res.json()) as {
            client_secret?: string;
            model?: string;
            session?: { bounded_window?: { silenceCommitMs?: number; idleCloseMs?: number; hardCapMs?: number } };
          };
          const bw = data.session?.bounded_window;
          if (bw) {
            silenceCommitMs = bw.silenceCommitMs ?? silenceCommitMs;
            idleCloseMs = bw.idleCloseMs ?? idleCloseMs;
            hardCapMs = bw.hardCapMs ?? hardCapMs;
            armHardCap();
            armIdleClose();
          }
          if (data.client_secret && data.model) {
            await startRealtime(data.client_secret, data.model);
            return;
          }
        }
        // 403 (no consent) / 503 (not configured) / malformed → fallback.
        startFallback();
      } catch {
        startFallback();
      }
    };

    const resumeBubble = document.getElementById('rhvo-bubble') as HTMLButtonElement | null;
    const showResumeBubble = (label?: string) => {
      if (!resumeBubble) return;
      resumeBubble.textContent = label ?? bubbleLabelFor(readResumeState(sessionStorage));
      resumeBubble.hidden = false;
    };
    const hideResumeBubble = () => { if (resumeBubble) resumeBubble.hidden = true; };

    // ── Parked-recovery poll (thinking-state card, Part 3) ────────────────
    // A full-page navigation kills the in-flight assembly fetch, but the
    // server finishes the work and stamps the conversation snapshot's
    // source_refs with `right-hand-estimate:<id>`. While the bubble wears a
    // parked "working" phase, poll that REAL signal so the bubble resolves to
    // ready/question — and degrade honestly at the stale bound rather than
    // claim work we can no longer confirm.
    let parkedPollTimer: number | null = null;
    const stopParkedRecoveryPoll = () => {
      if (parkedPollTimer !== null) {
        window.clearInterval(parkedPollTimer);
        parkedPollTimer = null;
      }
    };
    const startParkedRecoveryPoll = (workingState: { at: number; conversationId?: string }) => {
      if (parkedPollTimer !== null) return;
      const conversationId = workingState.conversationId ?? getConversationId();
      const tick = async () => {
        if (Date.now() - workingState.at >= WORKING_PHASE_STALE_MS) {
          stopParkedRecoveryPoll();
          clearPhaseState(sessionStorage);
          if (resumeBubble && !resumeBubble.hidden) {
            resumeBubble.textContent = bubbleLabelFor(readResumeState(sessionStorage));
          }
          return;
        }
        try {
          const res = await fetch(`/api/v1/right-hand/conversation?conversation_id=${encodeURIComponent(conversationId)}`, {
            method: 'GET',
            credentials: 'include',
          });
          if (!res.ok) return;
          const body = await res.json() as { snapshot?: { working_draft?: { source_refs?: unknown[] }; workingDraft?: { source_refs?: unknown[] } } | null };
          const workingDraftRefs = body.snapshot?.working_draft?.source_refs ?? body.snapshot?.workingDraft?.source_refs;
          const estimateId = estimateIdFromSourceRefs(workingDraftRefs);
          if (!estimateId) return; // genuinely still working
          stopParkedRecoveryPoll();
          const draftRes = await fetch(`/api/v1/right-hand/estimates/${encodeURIComponent(estimateId)}`, {
            method: 'GET',
            credentials: 'include',
          });
          if (!draftRes.ok) return;
          const draftBody = await draftRes.json() as { draft?: { route?: unknown; open_questions?: unknown } | null };
          const route = typeof draftBody.draft?.route === 'string' ? draftBody.draft.route : '';
          if (!route) return;
          const questionCount = Array.isArray(draftBody.draft?.open_questions) ? draftBody.draft.open_questions.length : 0;
          const phase = phaseAfterAssembly({ ok: true, hasRoute: true, openQuestionCount: questionCount });
          const detail = questionCount > 0
            ? `Needs your call: ${questionCount} question${questionCount === 1 ? '' : 's'}`
            : undefined;
          writePhaseState(sessionStorage, { phase, at: Date.now(), conversationId, ...(detail ? { detail } : {}) });
          writeResumeState(sessionStorage, { at: Date.now(), href: route, hint: detail ?? 'Estimate draft ready' });
          if (resumeBubble && !resumeBubble.hidden) {
            resumeBubble.textContent = detail ?? 'Estimate draft ready';
          }
        } catch {
          /* transient poll failure — the stale bound still ends the claim */
        }
      };
      parkedPollTimer = window.setInterval(() => void tick(), 5_000);
      void tick();
    };

    const openOverlay = (options: { restoreConversation?: boolean } = {}) => {
      if (!overlay.hidden) return;
      hideResumeBubble();
      stopParkedRecoveryPoll();
      {
        // Re-entry consumes a DELIVERED phase (ready/question/snag) — the
        // operator is back in the conversation. A live working phase stays:
        // the in-flight presence picks it up if its request still runs.
        const phaseAtOpen = readPhaseState(sessionStorage);
        if (phaseAtOpen && phaseAtOpen.phase !== 'working') clearPhaseState(sessionStorage);
      }
      setMicActive(false);
      routedLive = false;
      lastInterim = '';
      awaitingConfirm = false;
      parkedTranscript = '';
      parkedIntent = 'unclassified';
      parkedTurnResolution = null;
      activeSurfaceContext = readSurfaceContext();
      setCaption('');
      clearComposer();
      const restored = options.restoreConversation ? restoreConversation() : false;
      if (!restored) {
        resetConversation({ clearStored: false });
      } else {
        surfaceUnfiledDraftLoop();
      }
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(overlay.dataset.listening ?? 'Listening…');
      showActions('listening');
      overlay.hidden = false;
      startTimer();
      scrollConversationToLatest('auto');
      if (options.restoreConversation && !restored) void restoreConversationFromServer();
      void beginSession();
    };

    // Wire Speak triggers through delegation. Astro can execute component
    // scripts before route chrome finishes hydrating; delegation keeps the
    // universal bottom mic alive on every surface without page-level recorders.
    document.addEventListener('click', (e) => {
      const target = e.target instanceof Element ? e.target.closest<HTMLElement>('[data-rh-speak]') : null;
      if (!target) return;
      e.preventDefault();
      const speakEvent = new CustomEvent('kerf:rh-speak', { cancelable: true });
      window.dispatchEvent(speakEvent);
      openOverlay({ restoreConversation: true });
    });

    overlay.querySelectorAll('[data-rhvo-dismiss]').forEach((el) => {
      el.addEventListener('click', () => dismissOverlay());
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) dismissOverlay();
    });
    micButton?.addEventListener('click', () => {
      if (state === 'listening' || state === 'fallback') {
        finishCurrentTurn();
        return;
      }
      if (state === 'reply' || state === 'confirm' || state === 'resolved') {
        returnToListening();
        return;
      }
      if (state === 'capped') {
        awaitingConfirm = false;
        parkedTranscript = '';
        parkedIntent = 'unclassified';
        lastInterim = '';
        setHeading(overlay.dataset.title ?? 'Right Hand is listening');
        setState('listening');
        setStatus(overlay.dataset.listening ?? 'Listening…');
        showActions('listening');
        startTimer();
        void beginSession();
      }
    });
    continueBtn?.addEventListener('click', () => {
      awaitingConfirm = false;
      parkedTranscript = '';
      parkedIntent = 'unclassified';
      lastInterim = '';
      setHeading(overlay.dataset.title ?? 'Right Hand is listening');
      setState('listening');
      setStatus(overlay.dataset.listening ?? 'Listening…');
      showActions('listening');
      startTimer();
      void beginSession();
    });
    captionInputEl?.addEventListener('input', () => {
      growComposer();
      const hasTypedText = captionInputEl.value.trim().length > 0;
      overlay.dataset.typed = hasTypedText ? 'true' : 'false';
      if (hasTypedText) {
        window.clearTimeout(idleTimer);
      }
      scrollConversationToLatest('auto');
    });
    composerForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const typed = captionInputEl?.value.trim() ?? '';
      if (typed.length === 0) return;
      clearComposer();
      setCaption('');
      routeCommitted(classifyTranscriptIntent(typed), typed);
    });
    sourceAddBtn?.addEventListener('click', () => {
      sourceInputEl?.click();
    });
    sourceInputEl?.addEventListener('change', () => {
      const files = Array.from(sourceInputEl.files ?? []);
      if (files.length === 0) return;
      const names = files.map((file) => file.name.trim()).filter(Boolean);
      attachedSourceNames.push(...names);
      const shownNames = names.slice(0, 3).join(', ') || 'that source';
      const more = names.length > 3 ? ` and ${names.length - 3} more` : '';
      appendTurn('system', `Added ${shownNames}${more} to this conversation. I will use it as source while we keep talking.`);
      persistConversation();
      sourceInputEl.value = '';
    });
    // Save: commit the turn through the durable backend path, then render the
    // handled TRP returned by the server. No server artifact, no "saved" state.
    saveBtn?.addEventListener('click', () => {
      void resolveTurn(parkedTranscript);
    });
    notThatBtn?.addEventListener('click', returnToListening);
    // Change job: re-route the parked note to a different job, same turn.
    changeJobBtn?.addEventListener('click', changeJob);
    // Resolved-state next moves: "Add a photo" is the ONLY one that goes to Camera,
    // and only because the operator explicitly chose it (F-CAM1).
    overlay.querySelectorAll<HTMLElement>('[data-move]').forEach((el) => {
      el.addEventListener('click', () => routeMove(el.getAttribute('data-move')));
    });
    try {
      // Persistent re-entry bubble (replaces the one-shot auto-open that read
      // as "the screen popped in and out" and died on reload). State is NOT
      // consumed here — it survives reloads until the conversation ends.
      // The bubble wears the PHASE truth first: a parked working phase shows
      // "Building your estimate…" and starts the recovery poll so it resolves
      // from the real server state, never from a guess.
      const phaseState = readPhaseState(sessionStorage);
      const resumeState = readResumeState(sessionStorage);
      if ((phaseState || resumeState) && overlay.hidden) {
        showResumeBubble(bubbleLabelForPhase(phaseState, resumeState, Date.now()));
      }
      if (phaseState?.phase === 'working' && overlay.hidden) {
        startParkedRecoveryPoll(phaseState);
      }
    } catch { /* storage may be unavailable; user can tap Speak again */ }
    resumeBubble?.addEventListener('click', () => {
      hideResumeBubble();
      openOverlay({ restoreConversation: true });
    });
  }
</script>

