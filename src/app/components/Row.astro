---
export interface Props {
  title: string;
  meta?: string;
  amount?: string;
  state?: string;
  showArrow?: boolean;
}

const { title, meta, amount, state, showArrow = false } = Astro.props;
---

<div class="row">
  <div class="row-leading"><slot name="icon" /></div>
  <div class="row-body">
    <div class="row-title">{title}</div>
    {meta ? <div class="row-meta">{meta}</div> : null}
  </div>
  <div class="row-trailing">
    {amount ? <span class="row-amount">{amount}</span> : null}
    {state ? <span class="row-state">{state}</span> : null}
    {showArrow ? <span class="row-arrow" aria-hidden="true">›</span> : null}
    <slot name="trailing" />
  </div>
</div>

<style>
  .row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border, #d8dee6);
  }
  .row-title { font-weight: 600; }
  .row-meta, .row-state { font-size: 0.85rem; color: var(--text-muted, #5c6670); }
  .row-amount { font-variant-numeric: tabular-nums; font-weight: 600; }
  .row-arrow { color: var(--text-muted, #5c6670); }
</style>
