---
// Right Hand conversation bubble — F-RH3 (bloom-from-heart) + F-RH7 (transitions).
// Importable, testable presentation module. The state machine + invariants live
// in ../lib/rightHandBubble.ts (unit-tested); this renders them. PRESENTATION
// ONLY — no intent seam / estimator / store / gate. Light + dark come free from
// the app's --kerf-* tokens (accents stay constant, bg/surface/text flip).
import {
  micPosition,
  micGlow,
  bloomHeightClass,
  turnClass,
  showsConfirm,
  isMinimizedPill,
  type BubbleState,
  type MicSide,
  type Speaker,
  type Tone,
} from '../lib/rightHandBubble.js';

export interface BubbleTurn {
  readonly speaker: Speaker;
  readonly text: string;
  readonly tone?: Tone;
}

interface Props {
  state?: BubbleState;
  /** Handedness — docks the traveled pill to this side (F-RH7 rule 2). */
  micSide?: MicSide;
  turns?: readonly BubbleTurn[];
  /** Live words shown while listening. */
  transcript?: string;
  /** Artifact/context label shown on the minimized pill. */
  contextLabel?: string;
}

const {
  state = 'idle',
  micSide = 'right',
  turns = [],
  transcript = '',
  contextLabel = 'Right Hand',
} = Astro.props;

const minimized = isMinimizedPill(state);
const mic = micGlow(state);
const micPos = micPosition(state, micSide);
const height = bloomHeightClass(turns.length || 1);
const listening = state === 'listening' || state === 'thinking';
const confirm = showsConfirm(state);
const micLabel = state === 'idle' ? 'Speak' : listening ? 'Stop' : 'Keep going';
---

<div
  class="rhb"
  data-state={state}
  data-mic-side={micSide}
  data-mic-pos={micPos}
  data-testid="right-hand-bubble"
>
  {minimized ? (
    <button class={`rhb-pill rhb-pill--${micSide}`} type="button" data-rhb-action="tap_pill" aria-label="Open Right Hand — tap to talk">
      <span class="rhb-pill-text">tap to talk</span>
      <span class={`rhb-mic rhb-mic--pill rhb-mic--${mic}`} aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 15a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/></svg>
      </span>
    </button>
  ) : (
    <section class={`rhb-bloom rhb-bloom--${height}`} aria-label="Right Hand conversation" role="region">
      {listening ? (
        <div class="rhb-bloom-head">
          <div class="rhb-listening">Right Hand is listening</div>
          <div class="rhb-wave" aria-hidden="true">
            <i style="height:5px"></i><i style="height:11px"></i><i style="height:8px"></i><i style="height:13px"></i><i style="height:6px"></i>
          </div>
        </div>
      ) : null}

      <div class="rhb-thread" data-rhb-thread>
        {turns.map((t) => (
          <div class={turnClass(t.speaker, t.tone)}>
            <span class="rhb-turn-who">{t.speaker === 'you' ? 'You' : 'Right Hand'}</span>
            <span class="rhb-turn-text" set:html={t.text}></span>
          </div>
        ))}
        {listening && transcript ? (
          <div class="rhb-turn rhb-turn--you rhb-turn--live"><span class="rhb-turn-text">{transcript}</span></div>
        ) : null}
      </div>

      {confirm ? (
        <div class="rhb-confirm" role="group" aria-label="Confirm the durable write">
          <button class="rhb-confirm-go" type="button" data-rhb-action="write_returned">Confirm</button>
          <button class="rhb-confirm-cancel" type="button" data-rhb-action="dismiss">Not yet</button>
        </div>
      ) : null}

      <div class="rhb-composer">
        <button class="rhb-plus" type="button" aria-label="Add a PDF, plan, photo, or video">+</button>
        <div class="rhb-field" aria-hidden="true">Just talk, or type… I'll ask before I file.</div>
      </div>

      <!-- The dock IS the base bar; the mic heart is seated in the frame (F-RH3). -->
      <div class="rhb-dock">
        <div class="rhb-dock-grp">
          <span class="rhb-dock-item">Home</span>
          <span class="rhb-dock-item">Create</span>
        </div>
        <div class="rhb-dock-mic">
          <button class={`rhb-mic rhb-mic--${mic}`} type="button" data-rhb-action={state === 'idle' ? 'tap_mic' : 'dismiss'} aria-label={micLabel}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2.5" width="6" height="11" rx="3"/><path d="M5.5 11a6.5 6.5 0 0 0 13 0M12 17.5V21"/></svg>
          </button>
          <span class={`rhb-mic-label ${state === 'idle' ? 'rhb-mic-label--off' : ''}`}>{micLabel}</span>
        </div>
        <div class="rhb-dock-grp">
          <span class="rhb-dock-item">Camera</span>
          <span class="rhb-dock-item">More</span>
        </div>
      </div>
    </section>
  )}
</div>

<script>
  import { nextBubbleState, type BubbleState } from '../lib/rightHandBubble.js';
  // Presentation-only wiring: actions drive the SAME state machine the tests
  // pin. No estimator/store/gate here — that stays in the overlay's intent seam.
  for (const root of document.querySelectorAll<HTMLElement>('.rhb')) {
    root.addEventListener('click', (ev) => {
      const el = (ev.target as HTMLElement).closest<HTMLElement>('[data-rhb-action]');
      if (!el) return;
      const event = el.dataset.rhbAction as Parameters<typeof nextBubbleState>[1];
      const current = (root.dataset.state ?? 'idle') as BubbleState;
      const next = nextBubbleState(current, event);
      if (next !== current) {
        root.dataset.state = next;
        root.dispatchEvent(new CustomEvent('rhb:state', { detail: { state: next }, bubbles: true }));
      }
    });
  }
</script>

<style>
  /* Tokens: --right-hand = RH gold (frame/bubbles); --kerf-amber = the live/
     thinking glow; --field-green = the consequence tone. bg/surface/text flip
     with the app theme automatically. */
  .rhb { --rhb-gold: var(--right-hand, #c9a961); --rhb-live: var(--kerf-amber, #f5b544); --rhb-go: var(--field-green, #38c977); }

  /* THE BLOOM — one continuous gold-framed surface; the mic heart is seated in
     the base. Grows up (s1→s2→smax) then holds. */
  .rhb-bloom {
    display: flex; flex-direction: column; gap: 0.5rem;
    border: 1.5px solid color-mix(in srgb, var(--rhb-gold) 55%, transparent);
    border-radius: 22px; padding: 0.8rem 0.75rem 0.7rem;
    background: color-mix(in srgb, var(--kerf-bg-2, #14181f) 90%, transparent);
    box-shadow: 0 -12px 34px rgba(0, 0, 0, 0.28); color: var(--kerf-text, #e8ecf1);
    transition: min-height 0.28s ease;
  }
  .rhb-bloom--s1 { min-height: 33vh; }
  .rhb-bloom--s2 { min-height: 52vh; }
  .rhb-bloom--smax { min-height: 78vh; }

  .rhb-bloom-head { display: flex; flex-direction: column; align-items: center; gap: 0.35rem; }
  .rhb-listening { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--rhb-live); font-weight: 800; }
  .rhb-wave { display: flex; gap: 2px; align-items: flex-end; height: 14px; }
  .rhb-wave i { width: 2.5px; border-radius: 2px; background: var(--rhb-live); animation: rhb-pulse 1s ease-in-out infinite; }
  .rhb-wave i:nth-child(even) { animation-delay: 0.18s; }
  @keyframes rhb-pulse { 0%, 100% { transform: scaleY(0.6); } 50% { transform: scaleY(1); } }

  .rhb-thread { display: flex; flex-direction: column; gap: 0.45rem; overflow-y: auto; flex: 1; min-height: 0; }
  .rhb-turn { border-radius: 12px; padding: 0.45rem 0.6rem; font-size: 0.8rem; line-height: 1.4; max-width: 90%; }
  .rhb-turn-who { display: block; font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 800; margin-bottom: 2px; }
  /* You — gray, right. RH — gold, left. (F-RH3 rule 4) */
  .rhb-turn--you { align-self: flex-end; background: var(--kerf-surface-2, #232936); border-bottom-right-radius: 4px; }
  .rhb-turn--you .rhb-turn-who { color: var(--kerf-text-mute, #6a7282); }
  .rhb-turn--rh { align-self: flex-start; border-bottom-left-radius: 4px;
    background: color-mix(in srgb, var(--rhb-gold) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--rhb-gold) 30%, transparent); }
  .rhb-turn--rh .rhb-turn-who { color: var(--rhb-gold); }
  /* Consequence (file/send/money) — green; never silent. (F-RH3 rule 5) */
  .rhb-turn--consequence { background: color-mix(in srgb, var(--rhb-go) 13%, transparent); border-color: color-mix(in srgb, var(--rhb-go) 40%, transparent); }
  .rhb-turn--consequence .rhb-turn-who { color: var(--rhb-go); }
  .rhb-turn--live { opacity: 0.7; }

  .rhb-confirm { display: flex; gap: 0.5rem; padding: 0.35rem 0; }
  .rhb-confirm-go { flex: 1; padding: 0.55rem; border: none; border-radius: 12px; font-weight: 800; background: var(--rhb-go); color: #04210f; cursor: pointer; }
  .rhb-confirm-cancel { padding: 0.55rem 0.8rem; border-radius: 12px; border: 1px solid var(--kerf-border, #2a3140); background: transparent; color: var(--kerf-text-dim, #98a1b3); cursor: pointer; }

  .rhb-composer { display: flex; align-items: center; gap: 0.45rem; padding-top: 0.45rem; border-top: 1px solid color-mix(in srgb, var(--kerf-text, #fff) 7%, transparent); }
  .rhb-plus { width: 26px; height: 26px; border-radius: 7px; border: 1px solid var(--kerf-border, #2a3140); background: var(--kerf-bg-2, #14181f); color: var(--rhb-gold); font-size: 1rem; line-height: 1; flex: none; cursor: pointer; }
  .rhb-field { flex: 1; border: 1px solid var(--kerf-border-soft, #1f2530); border-radius: 13px; padding: 0.4rem 0.6rem; font-size: 0.72rem; color: var(--kerf-text-mute, #6a7282); }

  /* The dock = the framed base bar; mic heart center-seated, never floating. */
  .rhb-dock { display: flex; align-items: center; justify-content: space-between; padding-top: 0.35rem; }
  .rhb-dock-grp { display: flex; gap: 0.85rem; opacity: 0.45; }
  .rhb-dock-item { font-size: 0.55rem; color: var(--kerf-text-dim, #98a1b3); font-weight: 600; }
  .rhb-dock-mic { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }

  .rhb-mic { width: 46px; height: 46px; border-radius: 50%; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    background: var(--rhb-gold); color: #241b07; transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .rhb-mic svg { width: 21px; height: 21px; }
  /* The gold thinking-state presence — the live glow. */
  .rhb-mic--live { background: var(--rhb-live); box-shadow: 0 0 0 4px color-mix(in srgb, var(--rhb-live) 28%, transparent), 0 0 16px color-mix(in srgb, var(--rhb-live) 45%, transparent); }
  .rhb-mic--idle { background: var(--kerf-surface-2, #232936); color: var(--rhb-gold); box-shadow: 0 0 0 1px color-mix(in srgb, var(--rhb-gold) 40%, transparent); }
  .rhb-mic--pill { width: 40px; height: 40px; box-shadow: 0 0 0 4px color-mix(in srgb, var(--rhb-live) 24%, transparent); }
  .rhb-mic-label { font-size: 0.55rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; color: var(--rhb-gold); }
  .rhb-mic-label--off { color: var(--kerf-text-mute, #6a7282); }

  /* F-RH7 ④ — the minimized pill, docked to the handedness side, travels with you. */
  .rhb-pill { position: fixed; bottom: 1rem; display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.4rem 0.5rem; border-radius: 24px; cursor: pointer;
    background: linear-gradient(180deg, color-mix(in srgb, var(--rhb-gold) 18%, transparent), color-mix(in srgb, var(--rhb-gold) 8%, transparent));
    border: 1.5px solid color-mix(in srgb, var(--rhb-gold) 55%, transparent); backdrop-filter: blur(3px); }
  .rhb-pill--right { right: 1rem; }
  .rhb-pill--left { left: 1rem; flex-direction: row-reverse; }
  .rhb-pill-text { font-size: 0.6rem; color: var(--rhb-gold); font-weight: 700; }

  @media (prefers-reduced-motion: reduce) {
    .rhb-wave i { animation: none; }
    .rhb-bloom, .rhb-mic { transition: none; }
  }
</style>
