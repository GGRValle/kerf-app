---
import { createLayoutContext } from '../lib/createLayoutContext.js';

const { context } = createLayoutContext();
const operatorName =
  context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner' ? 'Christian' : 'there';

// Background work is a HONEST count of what Right Hand carried, with no fake
// attention rows. Real attention items are projected live in the script below.
const backgroundWork = [
  { label: 'Captured', href: '/projects' },
  { label: 'Drafted', href: '/draft-review' },
  { label: 'Synced', href: '/connections' },
];
---

<section class="rh-home kg-grid" data-grammar="canon" aria-label="Right Hand owner home">
  <form class="route-bar kg-span-12" action="/right-hand" method="get" role="search">
    <a class="icon-btn icon-btn--dark" href="/right-hand" data-rh-speak aria-label="Start voice route">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z" />
        <path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z" />
      </svg>
    </a>
    <label class="sr-only" for="rh-route-anywhere">Find a job, invoice, crew, or log</label>
    <input id="rh-route-anywhere" name="q" type="search" placeholder="Find a job, invoice, crew, or log" />
    <a class="icon-btn" href="/camera" aria-label="Open camera">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8.5 5 7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-1.5-2zM12 17a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm0-2a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
      </svg>
    </a>
  </form>

  <section class="agent-read kg-span-12" aria-label="Right Hand readout">
    <p>Morning, <strong>{operatorName}</strong>.</p>
  </section>

  <section class="rh-section kg-span-12" aria-labelledby="rh-one-title">
    <div class="rh-brain" data-attention-band="one">
      <span class="kg-chip rh-brain__kicker">Needs you</span>
      <h2 id="rh-one-title">The one thing</h2>
    </div>
    <div class="aa-slot" id="rh-one-thing" data-empty="Nothing needs you right now">
      <p class="aa-empty">Nothing needs you right now</p>
    </div>
  </section>

  <section class="rh-section kg-span-12" aria-labelledby="rh-deck-title">
    <div class="rh-section__head">
      <h2 id="rh-deck-title">On deck</h2>
      <span>Across your jobs</span>
    </div>
    <div class="aa-slot aa-slot--deck" id="rh-on-deck" data-empty="No queued decisions">
      <p class="aa-empty">No queued decisions</p>
    </div>
  </section>

  <section class="rh-section kg-span-12" aria-labelledby="rh-pulse-title">
    <div class="rh-section__head">
      <h2 id="rh-pulse-title">The pulse</h2>
      <span>company pulse</span>
    </div>
    <div class="aa-slot aa-slot--pulse" id="rh-pulse" data-empty="No company pulse items yet">
      <p class="aa-empty">No company pulse items yet</p>
    </div>
  </section>

  <section class="rh-section kg-span-12" aria-labelledby="rh-handled-title">
    <div class="rh-section__head">
      <h2 id="rh-handled-title">Right Hand handled</h2>
      <span>background work</span>
    </div>
    <div class="handled-grid">
      {backgroundWork.map((item) => (
        <a class="kg-card handled-card" href={item.href}>
          <span>{item.label}</span>
        </a>
      ))}
    </div>
  </section>
</section>

<script>
  import {
    TURN_RESOLUTION_SESSION_KEY,
    parseTurnResolution,
  } from '../../voice/realtime/turnResolution.js';
  import {
    attentionFromTurnResolution,
    attentionFromRelayCard,
    composeHomeAttentionSections,
    type AttentionProjection,
  } from '../../attention/attentionArtifact.js';
  import { createAttentionArtifactCard } from '../lib/attentionArtifactCard.js';

  // Read the turn the overlay stashed (if any) and project it through the SAME
  // attention artifact card the Office Review surface uses. No fixtures: when
  // nothing is live, the section renders its honest empty state.
  function liveTurnProjection(): AttentionProjection | null {
    try {
      const raw = sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY);
      const trp = parseTurnResolution(raw);
      if (!trp) return null;
      return attentionFromTurnResolution(trp, trp.work_artifact ? 'pulse' : 'one_thing');
    } catch {
      return null;
    }
  }

  function fillSlot(id: string, items: readonly AttentionProjection[], variant: 'one' | 'deck' | 'pulse') {
    const slot = document.getElementById(id);
    if (!(slot instanceof HTMLElement)) return;
    if (!items.length) return; // keep the server-rendered honest empty state
    slot.innerHTML = '';
    for (const item of items) {
      slot.append(createAttentionArtifactCard(item, { variant }));
    }
  }

  function signatureFor(item: AttentionProjection): string {
    return [
      item.source,
      item.headline.trim().toLowerCase(),
      item.detail.trim().toLowerCase(),
      (item.domain || '').trim().toLowerCase(),
    ].join('|');
  }

  function uniqueByContent(items: readonly AttentionProjection[]): AttentionProjection[] {
    const seen = new Set<string>();
    const unique: AttentionProjection[] = [];
    for (const item of items) {
      const signature = signatureFor(item);
      if (seen.has(signature)) continue;
      seen.add(signature);
      unique.push(item);
    }
    return unique;
  }

  function render(live: readonly AttentionProjection[]) {
    const { oneThing, onDeck, pulse } = composeHomeAttentionSections({
      live: uniqueByContent(live),
      onDeckLimit: 3,
      pulseLimit: 4,
    });
    fillSlot('rh-one-thing', oneThing ? [oneThing] : [], 'one');
    fillSlot('rh-on-deck', onDeck, 'deck');
    fillSlot('rh-pulse', pulse, 'pulse');
  }

  function apiUrl(pathname: string): string {
    return new URL(pathname, window.location.origin).toString();
  }

  // Optional enrichment: fold the office-review feed into the same live queue so
  // the pulse reflects real field captures. Failure is silent — the turn
  // projection (and honest empty states) still stand.
  async function loadLive() {
    const turn = liveTurnProjection();
    const live: AttentionProjection[] = turn ? [turn] : [];
    render(live); // paint immediately from local state

    try {
      const res = await fetch(apiUrl('/api/v1/field-daily/relay-feed?tenant_id=tenant_ggr'));
      if (!res.ok) return;
      const body = await res.json();
      const items = Array.isArray(body.items) ? body.items : [];
      for (const item of items) {
        live.push(attentionFromRelayCard(item));
      }
      render(live);
    } catch {
      /* keep the local projection + empty states */
    }
  }

  void loadLive();
</script>

<style>
  /* Canon grammar (F-A1b): question band + red CHIP, never a red row rail. All
     color comes from canon tokens resolved by [data-grammar="canon"] on .rh-home. */
  .rh-home {
    --aa-dot: var(--gold);
    display: grid;
    gap: 0.82rem;
    max-width: 46rem;
    margin: 0 auto;
    color: var(--ink);
  }

  .route-bar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.62rem;
    padding: 0.64rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .icon-btn {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
  }

  .icon-btn--dark {
    background: var(--ink);
    color: var(--panel);
  }

  .icon-btn svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .route-bar input {
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-size: 1.02rem;
    font-weight: 900;
    outline: 0;
  }

  .route-bar input::placeholder {
    color: var(--muted);
    opacity: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .agent-read {
    color: var(--ink);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .agent-read p {
    margin: 0;
    font-weight: 650;
  }

  .agent-read strong {
    color: var(--gold);
    font-weight: 950;
  }

  .rh-section {
    display: grid;
    gap: 0.6rem;
  }

  .rh-brain {
    display: grid;
    gap: 0.18rem;
    padding: 0.72rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--gold-soft);
  }

  .rh-brain__kicker {
    color: var(--amber);
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .rh-brain h2 {
    margin: 0;
    color: var(--ink);
    font-size: 1.2rem;
    line-height: 1.05;
  }

  .rh-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .rh-section__head h2 {
    margin: 0;
    color: var(--gold);
    font-size: 1.05rem;
    line-height: 1;
  }

  .rh-section__head span {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .aa-slot {
    display: grid;
    gap: 0.55rem;
  }

  .aa-empty {
    margin: 0;
    padding: 0.85rem 0.9rem;
    border: 1px dashed var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    color: var(--muted);
    font-weight: 800;
  }

  .handled-grid {
    display: grid;
    gap: 0.55rem;
    grid-auto-flow: column;
    grid-auto-columns: minmax(0, 1fr);
  }

  .handled-card {
    display: grid;
    place-items: center;
    min-height: 3.4rem;
    color: var(--gold);
    font-weight: 950;
    text-decoration: none;
  }

  @media screen and (max-width: 600px) {
    .handled-grid {
      grid-auto-flow: row;
    }
  }
</style>

<!-- Canon overrides for the shared attention card (injected into .rh-home by the
     script above, so these must be global). Red status is a CHIP and the rail uses
     the attention-dot token — there is NO red border-left rail anywhere. -->
<style is:global>
  .rh-home .aa-card__rail {
    background: var(--aa-dot);
  }

  .rh-home .aa-card[data-consequence-tier='durable'] .aa-card__chip {
    font-weight: 850;
  }

  .rh-home .aa-card[data-attention-state='risk_changed'] {
    --aa-dot: var(--red);
    border-color: color-mix(in srgb, var(--red) 32%, var(--line));
  }

  .rh-home .aa-card[data-attention-state='risk_changed'] .aa-card__state {
    background: var(--red-soft);
    color: var(--red);
    border-color: transparent;
  }
</style>
