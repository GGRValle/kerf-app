---
import { createLayoutContext } from '../lib/createLayoutContext.js';

const { context } = createLayoutContext();
const operatorName =
  context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner' ? 'Christian' : 'there';

const proofItems = [
  'Saved at 2:14 PM from Maple Ave jobsite',
  '6 photos attached, supplier quote pulled in',
  'Nothing sends without you',
];

const workAnswers = [
  { label: 'Money', detail: '$12,860 ready once you approve', href: '/money' },
  { label: 'Crew', detail: 'North crew on Maple Ave', href: '/home/field' },
  { label: 'Jobs', detail: '1 blocked by tile edge', href: '/projects' },
  { label: 'Leads', detail: '2 new walks to price', href: '/sales' },
];

const jobScan = [
  {
    tone: 'red',
    job: 'Ramirez bath - blocked',
    detail: 'Tile edge selection needs owner choice · crew idle risk Thursday',
    action: 'Choose',
    href: '/design/proj_ramirez_bath?focus=tile-edge',
  },
  {
    tone: 'amber',
    job: 'Ortiz kitchen - proposal drafted',
    detail: 'Maple Ave · $8,420 · waiting on you',
    action: 'Send',
    href: '/estimate/proj_wegrzyn_kitchen/proposal',
  },
  {
    tone: 'amber',
    job: 'Pearl St ADU - deposit not sent',
    detail: "Signed Sat · can't start Monday without it",
    action: 'Bill',
    href: '/money',
  },
  {
    tone: 'green',
    job: 'Delgado deck - on track',
    detail: '92% · punch list next, then retention',
    action: 'OK',
    href: '/projects',
  },
];

const backgroundWork = [
  { label: 'Captured', value: '9', detail: 'photos, notes, and scans filed or queued' },
  { label: 'Drafted', value: '3', detail: 'customer-ready items held for review' },
  { label: 'Synced', value: '12', detail: 'records updated when signal came back' },
];

---

<section class="rh-home" data-grammar="canon" aria-label="Right Hand owner home">
  <form class="route-bar" action="/right-hand" method="get" role="search">
    <a class="icon-btn icon-btn--dark" href="/right-hand" data-rh-speak aria-label="Start voice route">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z" />
        <path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z" />
      </svg>
    </a>
    <label class="sr-only" for="rh-route-anywhere">Find a job, invoice, crew, or log</label>
    <input id="rh-route-anywhere" name="q" type="search" placeholder="Find a job, invoice, crew, or log" />
    <a class="icon-btn" href="/camera" aria-label="Open camera">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M8.5 5 7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-1.5-2zM12 17a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm0-2a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" />
      </svg>
    </a>
  </form>

  <section class="agent-read" aria-label="Right Hand readout">
    <p>Morning, <strong>{operatorName}</strong>.</p>
  </section>

  <div class="section-kicker">
    <h2>The one thing</h2>
  </div>

  <article class="decision-card" aria-labelledby="rh-home-decision">
    <div class="decision-body">
      <div class="status-row">
        <span class="status status--yellow">Drafted</span>
        <span class="muted-pill">proposal ready</span>
      </div>
      <h1 id="rh-home-decision">Ortiz kitchen proposal</h1>
      <p>
        Priced the black cabinet pull change, matched it to site photos,
        and wrote the customer version in English.
      </p>
      <div class="evidence-strip" aria-label="Field proof">
        <span>Field proof</span>
        <strong>6 photos attached</strong>
        <small>Saved offline, queued to sync</small>
      </div>
      <ul class="proof-list">
        {proofItems.map((item) => (
          <li>
            <span aria-hidden="true">✓</span>
            <strong>{item}</strong>
          </li>
        ))}
      </ul>
      <div class="button-row">
        <a class="action-btn action-btn--primary" href="/estimate/proj_wegrzyn_kitchen/proposal">Review</a>
        <a class="action-btn" href="/right-hand" data-rh-speak>Change</a>
      </div>
    </div>
  </article>

  <section class="answer-grid" aria-label="Key answers">
    {workAnswers.map((item) => (
      <a class="answer-card" href={item.href}>
        <b>{item.label}</b>
        <span>{item.detail}</span>
      </a>
    ))}
  </section>

  <section class="jobs-panel" aria-labelledby="jobs-panel-title">
    <div class="panel-head">
      <h2 id="jobs-panel-title">Across your jobs</h2>
      <span>worst first · 6 active</span>
    </div>
    <div class="jobs-scan">
      {jobScan.map((job) => (
        <a class="scan-row" data-tone={job.tone} href={job.href}>
          <span class="scan-dot" aria-hidden="true"></span>
          <span>
            <b>{job.job}</b>
            <small>{job.detail}</small>
          </span>
          <em>{job.action}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="domain-summary" aria-labelledby="domain-summary-title">
    <div class="panel-head">
      <h2 id="domain-summary-title">Right Hand handled</h2>
      <span>background work</span>
    </div>
    <div class="domain-grid">
      {backgroundWork.map((item) => (
        <a class="domain-card" href={item.label === 'Drafted' ? '/draft-review' : item.label === 'Synced' ? '/connections' : '/projects'}>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <small>{item.detail}</small>
        </a>
      ))}
    </div>
  </section>
</section>

<style>
  .rh-home {
    --home-bg: var(--bg, #f7f6f1);
    --home-panel: var(--surface, #ffffff);
    --home-panel-2: var(--surface-2, #f1efe7);
    --home-ink: var(--text, #181713);
    --home-muted: var(--text-muted, #5d5a50);
    --home-line: var(--border, #d9d4c7);
    --home-gold: var(--right-hand, #d6ad36);
    --home-green: var(--field-green, #0f7a53);
    --home-red: var(--kerf-red, #b84831);
    display: grid;
    gap: 0.82rem;
    max-width: 46rem;
    margin: 0 auto;
    color: var(--home-ink);
  }

  .route-bar {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.62rem;
    padding: 0.64rem;
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel);
    box-shadow: 0 14px 34px rgba(24, 23, 19, 0.08);
  }

  .icon-btn {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel);
    color: var(--home-ink);
    text-decoration: none;
  }

  .icon-btn--dark {
    background: #11100d;
    color: #fff;
  }

  .icon-btn svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .route-bar input {
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--home-ink);
    font: inherit;
    font-size: 1.02rem;
    font-weight: 900;
    outline: 0;
  }

  .route-bar input::placeholder {
    color: var(--home-muted);
    opacity: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .agent-read {
    color: var(--home-ink);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .agent-read p {
    margin: 0;
    font-weight: 650;
  }

  .agent-read strong {
    color: var(--home-gold);
    font-weight: 950;
  }

  .section-kicker {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .section-kicker h2 {
    margin: 0;
    color: var(--home-gold);
    font-size: 1.08rem;
    line-height: 1;
  }

  .section-kicker span {
    color: var(--home-muted);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .decision-card,
  .answer-card,
  .jobs-panel,
  .domain-summary {
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel);
    box-shadow: 0 14px 34px rgba(24, 23, 19, 0.08);
  }

  .decision-card {
    overflow: hidden;
  }

  .decision-body {
    display: grid;
    gap: 0.8rem;
    padding: 1rem;
  }

  .status-row,
  .button-row,
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .status-row {
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .status,
  .muted-pill {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding: 0 0.7rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 950;
    white-space: nowrap;
  }

  .status {
    gap: 0.4rem;
    text-transform: uppercase;
  }

  .status::before {
    content: '';
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: currentColor;
  }

  .status--yellow {
    background: #fff2c4;
    color: #7a5200;
  }

  .muted-pill {
    background: var(--home-panel-2);
    color: var(--home-muted);
  }

  .decision-body h1 {
    margin: 0;
    font-size: clamp(2rem, 9vw, 3.25rem);
    line-height: 0.94;
    letter-spacing: 0;
  }

  .decision-body p {
    margin: 0;
    color: var(--home-muted);
    font-size: 1.02rem;
    font-weight: 900;
    line-height: 1.36;
  }

  .evidence-strip {
    display: grid;
    gap: 0.18rem;
    padding: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--home-green) 28%, var(--home-line));
    border-radius: 8px;
    background: color-mix(in srgb, var(--home-green) 8%, var(--home-panel));
  }

  .evidence-strip span {
    color: var(--home-green);
    font-size: 0.7rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .evidence-strip strong {
    line-height: 1.1;
  }

  .evidence-strip small {
    color: var(--home-muted);
    font-weight: 850;
  }

  .proof-list {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .proof-list li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.62rem;
    align-items: start;
    color: var(--home-muted);
  }

  .proof-list li span {
    width: 1.45rem;
    height: 1.45rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--home-green);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 950;
  }

  .proof-list li strong {
    color: var(--home-muted);
    font-size: 0.96rem;
    line-height: 1.25;
  }

  .action-btn {
    min-height: 3.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 0;
    padding: 0 1rem;
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel);
    color: var(--home-ink);
    font-weight: 950;
    text-decoration: none;
  }

  .action-btn--primary {
    background: #11100d;
    color: #fff;
  }

  .answer-grid,
  .domain-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .answer-card,
  .domain-card {
    display: grid;
    gap: 0.25rem;
    padding: 0.9rem;
    color: var(--home-ink);
    text-decoration: none;
  }

  .answer-card span,
  .domain-card small,
  .panel-head span,
  .scan-row small {
    color: var(--home-muted);
    font-weight: 800;
    line-height: 1.25;
  }

  .answer-card b,
  .domain-card span {
    color: var(--home-gold);
  }

  .jobs-panel,
  .domain-summary {
    display: grid;
    gap: 0.65rem;
    padding: 0.9rem;
  }

  .panel-head h2 {
    margin: 0;
    color: var(--home-gold);
    font-size: 1rem;
  }

  .panel-head span {
    font-size: 0.8rem;
    text-align: right;
  }

  .jobs-scan {
    display: grid;
    gap: 0.45rem;
  }

  .scan-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.65rem;
    align-items: center;
    min-height: 3.8rem;
    padding: 0.62rem;
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel-2);
    color: var(--home-ink);
    text-decoration: none;
  }

  .scan-dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: var(--home-muted);
  }

  .scan-row[data-tone='red'] .scan-dot { background: var(--home-red); }
  .scan-row[data-tone='amber'] .scan-dot { background: var(--home-gold); }
  .scan-row[data-tone='green'] .scan-dot { background: var(--home-green); }

  .scan-row b,
  .scan-row small {
    display: block;
  }

  .scan-row em {
    align-self: center;
    padding: 0.35rem 0.5rem;
    border-radius: 999px;
    background: var(--home-panel);
    color: var(--home-muted);
    font-size: 0.72rem;
    font-style: normal;
    font-weight: 950;
  }

  .domain-card {
    border: 1px solid var(--home-line);
    border-radius: 8px;
    background: var(--home-panel-2);
  }

  .domain-card strong {
    color: var(--home-gold);
    font-size: 1.55rem;
    line-height: 1;
  }

  .domain-card span {
    font-weight: 950;
  }

  @media (min-width: 860px) {
    .rh-home {
      max-width: min(82rem, 100%);
      grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
      align-items: start;
    }

    .route-bar,
    .agent-read,
    .section-kicker,
    .decision-card {
      grid-column: 1;
    }

    .answer-grid,
    .jobs-panel,
    .domain-summary,
    .domain-summary {
      grid-column: 2;
    }

    .answer-grid {
      grid-template-columns: 1fr;
    }

  }

  @media (max-width: 520px) {
    .rh-home {
      gap: 0.72rem;
    }

    .route-bar {
      gap: 0.45rem;
      padding: 0.5rem;
    }

    .icon-btn {
      width: 2.65rem;
      height: 2.65rem;
    }

    .route-bar input {
      font-size: 0.92rem;
    }

    .answer-grid,
    .domain-grid {
      grid-template-columns: 1fr;
    }

    .button-row {
      flex-direction: column;
    }

    .action-btn {
      width: 100%;
    }
  }
</style>
