---
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { composeHomeAttentionSections } from '../../attention/attentionArtifact.js';

const { context } = createLayoutContext();
const operatorName = context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner' ? 'Christian' : 'there';
const homeSections = composeHomeAttentionSections();
const oneThing = homeSections.oneThing;
const onDeck = homeSections.onDeck;
const pulse = homeSections.pulse;
---

<section class="rh-home" aria-label="Right Hand home">
  <div class="rh-home__hello">
    <p class="rh-home__eyebrow">Good morning, {operatorName}</p>
    <h1>The one thing</h1>
  </div>

  {oneThing ? (
    <a
      id="rh-one-slot"
      class:list={['aa-card', 'aa-card--one', `aa-tone-${oneThing.tone}`]}
      href={oneThing.href}
      data-attention-id={oneThing.id}
      data-attention-source={oneThing.source}
      data-attention-state={oneThing.state ?? oneThing.kind}
      data-consequence-tier={oneThing.consequenceTier}
    >
      <span class="aa-card__rail" aria-hidden="true"></span>
      <span class="aa-card__body">
        <span class="aa-card__top">
          <span class="aa-card__domain">{oneThing.domain ?? oneThing.label}</span>
          <span class="aa-card__state">{oneThing.label}</span>
        </span>
        <strong class="aa-card__headline">{oneThing.headline}</strong>
        <span class="aa-card__because">{oneThing.because ?? oneThing.detail}</span>
      </span>
    </a>
  ) : (
    <div id="rh-one-empty" class="rh-empty">
      <strong>Nothing needs you right now.</strong>
      <span>New captures, decisions, and changes will land here.</span>
    </div>
  )}

  <section class="rh-home__section" aria-labelledby="rh-on-deck-title">
    <div class="rh-home__section-head">
      <h2 id="rh-on-deck-title">On deck</h2>
      <span>Next 5</span>
    </div>
    <div class="rh-deck" id="rh-deck-list">
      {onDeck.length > 0 ? (
        onDeck.map((item) => (
          <a
            class:list={['aa-card', 'aa-card--deck', `aa-tone-${item.tone}`]}
            href={item.href}
            data-attention-id={item.id}
            data-attention-source={item.source}
            data-attention-state={item.state ?? item.kind}
            data-consequence-tier={item.consequenceTier}
          >
            <span class="aa-card__rail" aria-hidden="true"></span>
            <span class="aa-card__body">
              <span class="aa-card__top">
                <span class="aa-card__domain">{item.domain ?? item.label}</span>
                <span class="aa-card__state">{item.label}</span>
              </span>
              <strong class="aa-card__headline">{item.headline}</strong>
              <span class="aa-card__because">{item.because ?? item.detail}</span>
            </span>
          </a>
        ))
      ) : (
        <div class="rh-empty rh-empty--small">No queued decisions.</div>
      )}
    </div>
  </section>

  <section class="rh-home__section" aria-labelledby="rh-pulse-title">
    <div class="rh-home__section-head">
      <h2 id="rh-pulse-title">The pulse</h2>
      <span>Company status</span>
    </div>
    <div class="rh-pulse" id="rh-pulse-list">
      {pulse.length > 0 ? (
        pulse.map((item) => (
          <a
            class:list={['aa-card', 'aa-card--pulse', `aa-tone-${item.tone}`]}
            href={item.href}
            data-attention-id={item.id}
            data-attention-source={item.source}
            data-attention-state={item.state ?? item.kind}
            data-consequence-tier={item.consequenceTier}
          >
            <span class="aa-card__rail" aria-hidden="true"></span>
            <span class="aa-card__body">
              <span class="aa-card__top">
                <span class="aa-card__domain">{item.domain ?? item.label}</span>
                <span class="aa-card__state">{item.label}</span>
              </span>
              <strong class="aa-card__headline">{item.headline}</strong>
              <span class="aa-card__because">{item.because ?? item.detail}</span>
            </span>
          </a>
        ))
      ) : (
        <div class="rh-empty rh-empty--small">No company pulse items yet.</div>
      )}
    </div>
  </section>
</section>

<script>
  import {
    attentionFromRelayCard,
    attentionFromTurnResolution,
    composeHomeAttentionSections,
  } from '../../attention/attentionArtifact.js';
  import { createAttentionArtifactCard } from '../lib/attentionArtifactCard.js';
  import {
    parseTurnResolution,
    TURN_RESOLUTION_SESSION_KEY,
  } from '../../voice/realtime/turnResolution.js';

  const deckList = document.getElementById('rh-deck-list');
  const pulseList = document.getElementById('rh-pulse-list');

  function apiUrl(path: string): string {
    return new URL(path, window.location.origin).toString();
  }

  function oneThingEmpty(): HTMLElement {
    const empty = document.createElement('div');
    empty.id = 'rh-one-empty';
    empty.className = 'rh-empty';
    const title = document.createElement('strong');
    title.textContent = 'Nothing needs you right now.';
    const body = document.createElement('span');
    body.textContent = 'New captures, decisions, and changes will land here.';
    empty.append(title, body);
    return empty;
  }

  function listEmpty(message: string): HTMLElement {
    const empty = document.createElement('div');
    empty.className = 'rh-empty rh-empty--small';
    empty.textContent = message;
    return empty;
  }

  function renderOne(item: ReturnType<typeof attentionFromTurnResolution> | null) {
    const existing = document.getElementById('rh-one-slot') ?? document.getElementById('rh-one-empty');
    const next = item
      ? createAttentionArtifactCard(item, { variant: 'one' })
      : oneThingEmpty();
    next.id = item ? 'rh-one-slot' : 'rh-one-empty';
    existing?.replaceWith(next);
  }

  function renderList(
    container: Element | null,
    items: ReturnType<typeof attentionFromTurnResolution>[],
    variant: 'deck' | 'pulse',
    emptyMessage: string,
  ) {
    if (!(container instanceof HTMLElement)) return;
    container.innerHTML = '';
    if (items.length === 0) {
      container.append(listEmpty(emptyMessage));
      return;
    }
    items.forEach((item) => container.append(createAttentionArtifactCard(item, { variant })));
  }

  function renderHomeAttention(live: ReturnType<typeof attentionFromTurnResolution>[]) {
    const sections = composeHomeAttentionSections({
      live,
    });
    renderOne(sections.oneThing);
    renderList(deckList, [...sections.onDeck], 'deck', 'No queued decisions.');
    renderList(pulseList, [...sections.pulse], 'pulse', 'No company pulse items yet.');
  }

  async function loadRelayAttention() {
    try {
      const res = await fetch(apiUrl('/api/v1/field-daily/relay-feed?tenant_id=tenant_ggr'));
      const body = await res.json();
      if (!res.ok || !Array.isArray(body.items)) return [];
      return body.items.map((item: unknown) => attentionFromRelayCard(item));
    } catch {
      return [];
    }
  }

  async function hydrateHomeAttention() {
    const live = [];
    try {
      const trp = parseTurnResolution(sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY));
      if (trp) live.push(attentionFromTurnResolution(trp, trp.work_artifact ? 'pulse' : 'one_thing'));
    } catch { /* storage unavailable — keep the honest empty state */ }
    live.push(...await loadRelayAttention());
    if (live.length > 0) renderHomeAttention(live);
  }

  void hydrateHomeAttention();
</script>

<style>
  .rh-home {
    display: grid;
    gap: 1rem;
  }
  .rh-home__hello {
    display: grid;
    gap: 0.2rem;
  }
  .rh-home__eyebrow {
    margin: 0;
    color: var(--right-hand);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .rh-home h1,
  .rh-home h2 {
    margin: 0;
    color: var(--kerf-text);
    letter-spacing: 0;
  }
  .rh-home h1 {
    font-size: 2.2rem;
    line-height: 0.98;
  }
  .rh-home h2 {
    font-size: 1.35rem;
    line-height: 1.05;
  }
  .rh-empty {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border-radius: 14px;
    border: 1px dashed var(--kerf-border);
    background: color-mix(in srgb, var(--kerf-surface-2) 55%, transparent);
    color: var(--kerf-text-dim);
  }
  .rh-empty strong {
    color: var(--kerf-text);
    font-size: 0.98rem;
  }
  .rh-empty span {
    font-size: 0.88rem;
    line-height: 1.35;
  }
  .rh-empty--small {
    padding: 0.8rem 0.9rem;
    font-size: 0.86rem;
  }
  .rh-one {
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--right-hand) 34%, var(--kerf-border));
    background: color-mix(in srgb, var(--right-hand) 10%, var(--kerf-surface));
    color: inherit;
    text-decoration: none;
  }
  .rh-one__tag {
    color: var(--right-hand);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .rh-one strong {
    font-size: 1.24rem;
    line-height: 1.15;
  }
  .rh-one span:last-child {
    color: var(--kerf-text-dim);
    line-height: 1.42;
  }
  .rh-home__section {
    display: grid;
    gap: 0.6rem;
  }
  .rh-home__section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .rh-home__section-head span {
    color: var(--kerf-text-mute);
    font-size: 0.78rem;
    font-weight: 700;
  }
  .rh-deck,
  .rh-pulse {
    display: grid;
    gap: 0.55rem;
  }
  .rh-deck__item,
  .rh-pulse__row {
    position: relative;
    display: grid;
    gap: 0.18rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--kerf-border-soft);
    background: var(--kerf-surface);
  }
  .rh-deck__item {
    padding: 0.85rem 0.9rem 0.85rem 1rem;
    border-radius: 14px;
  }
  .rh-deck__item::before,
  .rh-pulse__row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.8rem;
    bottom: 0.8rem;
    width: 3px;
    border-radius: 999px;
    background: var(--tone);
  }
  .rh-deck__item span,
  .rh-pulse__row span {
    color: var(--tone);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .rh-deck__item strong {
    font-size: 0.98rem;
    line-height: 1.2;
  }
  .rh-deck__item small {
    color: var(--kerf-text-dim);
    font-size: 0.83rem;
    line-height: 1.35;
  }
  .rh-pulse {
    max-height: 28rem;
    overflow: auto;
    padding-bottom: 0.2rem;
  }
  .rh-pulse__row {
    min-height: 58px;
    padding: 0.7rem 0.8rem 0.7rem 1rem;
    border-radius: 12px;
  }
  .rh-pulse__row p {
    margin: 0;
    color: var(--kerf-text-dim);
    font-size: 0.88rem;
    line-height: 1.35;
  }
  .rh-tone-team { --tone: var(--field-green); }
  .rh-tone-project { --tone: var(--kerf-blue); }
  .rh-tone-money { --tone: var(--kerf-amber); }
  .rh-tone-selection { --tone: var(--kerf-violet); }
  .rh-tone-client { --tone: #67D6E0; }
  /*
   * Red-is-chip-tier on Home (D-046): relay block/warn cards stay neutral;
   * red appears only on the small state chip, never the rail or card surface.
   */
  .rh-home .aa-card[data-attention-state='risk_changed'] {
    --aa-state: var(--kerf-border-soft);
    border-color: var(--kerf-border-soft);
    background: var(--kerf-surface);
  }
  .rh-home .aa-card--one[data-attention-state='risk_changed'] {
    border-color: var(--kerf-border-soft);
    background: var(--kerf-surface);
  }
  .rh-home .aa-card[data-attention-state='risk_changed'] .aa-card__rail {
    background: var(--kerf-border-soft);
  }
  .rh-home .aa-card[data-attention-state='risk_changed'] .aa-card__state {
    border-color: color-mix(in srgb, var(--kerf-red) 38%, var(--kerf-border));
    background: color-mix(in srgb, var(--kerf-red) 12%, transparent);
    color: var(--kerf-red);
  }
  @media (min-width: 760px) {
    .rh-deck {
      grid-template-columns: 1fr 1fr;
    }
    .rh-one {
      padding: 1.15rem 1.25rem;
    }
  }
</style>
