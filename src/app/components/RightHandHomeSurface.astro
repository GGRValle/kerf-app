---
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { composeHomeAttentionSections } from '../../attention/attentionArtifact.js';

const { context } = createLayoutContext();
const operatorName = context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner' ? 'Christian' : 'there';
const homeSections = composeHomeAttentionSections();
const oneThing = homeSections.oneThing;
const onDeck = homeSections.onDeck;
const pulse = homeSections.pulse;
const allHomeItems = [...(oneThing ? [oneThing] : []), ...onDeck, ...pulse];
const loopStages = [
  { label: 'Start', href: '/create', count: '12', note: 'capture / job walk', state: 'live' },
  { label: 'Design', href: '/more#design', count: '3', note: 'selections / plans', state: 'needs setup' },
  { label: 'Sales', href: '/clients', count: '5', note: 'estimate / signed', state: 'needs you' },
  { label: 'Project', href: '/projects', count: '4', note: 'docs / schedule', state: 'live' },
  { label: 'Crew', href: '/home/field', count: '2', note: 'work / proof', state: 'field hand' },
  { label: 'Money', href: '/money', count: '$51k', note: 'invoice / pay', state: 'at risk' },
  { label: 'Success', href: '/reports', count: '7', note: 'client / team', state: 'pulse' },
];
const routeShortcuts = [
  { label: 'Job', hint: 'Wegrzyn daily', href: '/projects/proj_wegrzyn_kitchen' },
  { label: 'Crew', hint: 'where crews are', href: '/home/field' },
  { label: 'Money', hint: 'invoices', href: '/money' },
];
const handledSummaries = [
  { label: 'Captured', value: `${allHomeItems.length}`, note: 'items filed or queued' },
  { label: 'Needs you', value: `${allHomeItems.filter((item) => item.needsUser).length}`, note: 'decisions held' },
  { label: 'Money', value: `${allHomeItems.filter((item) => item.tone === 'money').length}`, note: 'items tied to work' },
];
---

<section class="rh-home kg-grid f-a1b-home" data-grammar="canon" aria-label="Right Hand home">
  <div class="rh-home__hello kg-pagehead kg-span-12">
    <p class="rh-home__eyebrow">Right Hand · From capture to completion</p>
    <h1>Morning, {operatorName}. One thing needs you — the rest is moving.</h1>
    <p class="rh-home__lede">Right Hand drafts, files, and holds the important work for your call.</p>
  </div>

  <div class="rh-home__section-head rh-home__section-head--one kg-span-12">
    <h2>The one thing</h2>
    <span>Needs your call</span>
  </div>

  {oneThing ? (
    <a
      id="rh-one-slot"
      class:list={['aa-card', 'aa-card--one', 'kg-card', `aa-tone-${oneThing.tone}`]}
      href={oneThing.href}
      data-attention-id={oneThing.id}
      data-attention-source={oneThing.source}
      data-attention-state={oneThing.state ?? oneThing.kind}
      data-consequence-tier={oneThing.consequenceTier}
    >
      <span class="aa-card__rail" aria-hidden="true"></span>
      <span class="aa-card__body">
        <span class="aa-card__top">
          <span class="aa-card__domain">{oneThing.domain ?? oneThing.label}</span>
          <span class="aa-card__state">{oneThing.label}</span>
        </span>
        <strong class="aa-card__headline">{oneThing.headline}</strong>
        <span class="aa-card__because">{oneThing.because ?? oneThing.detail}</span>
      </span>
    </a>
  ) : (
    <div id="rh-one-empty" class="rh-empty">
      <strong>Nothing needs you right now.</strong>
      <span>New captures, decisions, and changes will land here.</span>
    </div>
  )}

  <section class="rh-handled kg-card kg-span-12" aria-label="Right Hand handled">
    <div>
      <p class="rh-home__eyebrow">Right Hand handled</p>
      <h2>Small checks, no office trip.</h2>
    </div>
    <div class="rh-handled__grid">
      {handledSummaries.map((item) => (
        <a class="rh-handled__item" href={item.label === 'Money' ? '/money' : item.label === 'Needs you' ? '/on-me' : '/projects'}>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
          <small>{item.note}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="rh-route kg-card kg-span-12" aria-labelledby="rh-route-title">
    <div>
      <p class="rh-home__eyebrow">Route anywhere</p>
      <h2 id="rh-route-title">Say it, type it, or tap it.</h2>
    </div>
    <form class="rh-route__search" action="/right-hand" method="get" role="search">
      <label class="sr-only" for="rh-route-q">Ask Right Hand to route you</label>
      <input id="rh-route-q" name="q" type="search" placeholder="Ask: take me to Wegrzyn daily..." />
      <button type="submit">Ask</button>
    </form>
    <div class="rh-route__chips" aria-label="Common routes">
      {routeShortcuts.map((shortcut) => (
        <a class="kg-chip" href={shortcut.href}>
          <strong>{shortcut.label}</strong>
          <span>{shortcut.hint}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="rh-spine kg-span-12" aria-label="Job spine underneath">
    <div class="rh-home__section-head">
      <h2>Filed underneath</h2>
      <span>Start → Success</span>
    </div>
    <nav class="rh-loop" aria-label="From capture to completion loop">
      {loopStages.map((stage) => (
        <a class="rh-loop__stage kg-card" href={stage.href} data-loop-stage={stage.label.toLowerCase()}>
          <span class="rh-loop__dot" aria-hidden="true"></span>
          <strong>{stage.label}</strong>
          <small>{stage.note}</small>
          <em>{stage.state}</em>
        </a>
      ))}
    </nav>
  </section>

  <section class="rh-home__section kg-span-12" aria-labelledby="rh-on-deck-title">
    <div class="rh-home__section-head">
      <h2 id="rh-on-deck-title">On deck</h2>
      <span>Next 5</span>
    </div>
    <div class="rh-deck" id="rh-deck-list">
      {onDeck.length > 0 ? (
        onDeck.map((item) => (
          <a
            class:list={['aa-card', 'aa-card--deck', 'kg-card', `aa-tone-${item.tone}`]}
            href={item.href}
            data-attention-id={item.id}
            data-attention-source={item.source}
            data-attention-state={item.state ?? item.kind}
            data-consequence-tier={item.consequenceTier}
          >
            <span class="aa-card__rail" aria-hidden="true"></span>
            <span class="aa-card__body">
              <span class="aa-card__top">
                <span class="aa-card__domain">{item.domain ?? item.label}</span>
                <span class="aa-card__state">{item.label}</span>
              </span>
              <strong class="aa-card__headline">{item.headline}</strong>
              <span class="aa-card__because">{item.because ?? item.detail}</span>
            </span>
          </a>
        ))
      ) : (
        <div class="rh-empty rh-empty--small">No queued decisions.</div>
      )}
    </div>
  </section>

  <section class="rh-home__section kg-span-12" aria-labelledby="rh-pulse-title">
    <div class="rh-home__section-head">
      <h2 id="rh-pulse-title">The pulse</h2>
      <span>Company status</span>
    </div>
    <div class="rh-pulse" id="rh-pulse-list">
      {pulse.length > 0 ? (
        pulse.map((item) => (
          <a
            class:list={['aa-card', 'aa-card--pulse', 'kg-card', `aa-tone-${item.tone}`]}
            href={item.href}
            data-attention-id={item.id}
            data-attention-source={item.source}
            data-attention-state={item.state ?? item.kind}
            data-consequence-tier={item.consequenceTier}
          >
            <span class="aa-card__rail" aria-hidden="true"></span>
            <span class="aa-card__body">
              <span class="aa-card__top">
                <span class="aa-card__domain">{item.domain ?? item.label}</span>
                <span class="aa-card__state">{item.label}</span>
              </span>
              <strong class="aa-card__headline">{item.headline}</strong>
              <span class="aa-card__because">{item.because ?? item.detail}</span>
            </span>
          </a>
        ))
      ) : (
        <div class="rh-empty rh-empty--small">No company pulse items yet.</div>
      )}
    </div>
  </section>
</section>

<script>
  import {
    attentionFromRelayCard,
    attentionFromTurnResolution,
    composeHomeAttentionSections,
  } from '../../attention/attentionArtifact.js';
  import { createAttentionArtifactCard } from '../lib/attentionArtifactCard.js';
  import {
    parseTurnResolution,
    TURN_RESOLUTION_SESSION_KEY,
  } from '../../voice/realtime/turnResolution.js';

  const deckList = document.getElementById('rh-deck-list');
  const pulseList = document.getElementById('rh-pulse-list');

  function apiUrl(path: string): string {
    return new URL(path, window.location.origin).toString();
  }

  function oneThingEmpty(): HTMLElement {
    const empty = document.createElement('div');
    empty.id = 'rh-one-empty';
    empty.className = 'rh-empty';
    const title = document.createElement('strong');
    title.textContent = 'Nothing needs you right now.';
    const body = document.createElement('span');
    body.textContent = 'New captures, decisions, and changes will land here.';
    empty.append(title, body);
    return empty;
  }

  function listEmpty(message: string): HTMLElement {
    const empty = document.createElement('div');
    empty.className = 'rh-empty rh-empty--small';
    empty.textContent = message;
    return empty;
  }

  function renderOne(item: ReturnType<typeof attentionFromTurnResolution> | null) {
    const existing = document.getElementById('rh-one-slot') ?? document.getElementById('rh-one-empty');
    const next = item
      ? createAttentionArtifactCard(item, { variant: 'one' })
      : oneThingEmpty();
    next.classList.add('kg-card');
    next.id = item ? 'rh-one-slot' : 'rh-one-empty';
    existing?.replaceWith(next);
  }

  function renderList(
    container: Element | null,
    items: ReturnType<typeof attentionFromTurnResolution>[],
    variant: 'deck' | 'pulse',
    emptyMessage: string,
  ) {
    if (!(container instanceof HTMLElement)) return;
    container.innerHTML = '';
    if (items.length === 0) {
      container.append(listEmpty(emptyMessage));
      return;
    }
    items.forEach((item) => {
      const card = createAttentionArtifactCard(item, { variant });
      card.classList.add('kg-card');
      container.append(card);
    });
  }

  function renderHomeAttention(live: ReturnType<typeof attentionFromTurnResolution>[]) {
    const sections = composeHomeAttentionSections({
      live,
    });
    renderOne(sections.oneThing);
    renderList(deckList, [...sections.onDeck], 'deck', 'No queued decisions.');
    renderList(pulseList, [...sections.pulse], 'pulse', 'No company pulse items yet.');
  }

  async function loadRelayAttention() {
    try {
      const res = await fetch(apiUrl('/api/v1/field-daily/relay-feed?tenant_id=tenant_ggr'));
      const body = await res.json();
      if (!res.ok || !Array.isArray(body.items)) return [];
      return body.items.map((item: unknown) => attentionFromRelayCard(item));
    } catch {
      return [];
    }
  }

  async function hydrateHomeAttention() {
    const live = [];
    try {
      const trp = parseTurnResolution(sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY));
      if (trp) live.push(attentionFromTurnResolution(trp, trp.work_artifact ? 'pulse' : 'one_thing'));
    } catch { /* storage unavailable — keep the honest empty state */ }
    live.push(...await loadRelayAttention());
    if (live.length > 0) renderHomeAttention(live);
  }

  void hydrateHomeAttention();
</script>

<style>
  .rh-home {
    gap: 12px;
  }
  .rh-home > * {
    grid-column: 1 / -1;
  }
  .rh-home__hello {
    display: grid;
    gap: 0.2rem;
  }
  .rh-home__lede {
    max-width: 40rem;
    margin: 0.35rem 0 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.35;
  }
  .rh-home__eyebrow {
    margin: 0;
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .rh-home h1,
  .rh-home h2 {
    margin: 0;
    color: var(--ink);
    letter-spacing: 0;
  }
  .rh-home h1 {
    font-size: 2.2rem;
    line-height: 0.98;
  }
  .rh-home h2 {
    font-size: 1.35rem;
    line-height: 1.05;
  }
  .rh-route {
    display: grid;
    gap: 0.85rem;
    padding: 0.95rem;
    border-color: color-mix(in srgb, var(--gold) 34%, var(--line));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--gold-soft) 40%, transparent), transparent 54%),
      var(--panel);
  }
  .rh-route__search {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
  }
  .rh-route__search .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .rh-route__search input {
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.82rem 0.95rem;
    background: var(--bg);
    color: var(--ink);
    font: inherit;
  }
  .rh-route__search button {
    border: 0;
    border-radius: 999px;
    min-width: 4.1rem;
    padding: 0 0.75rem;
    background: var(--gold);
    color: var(--ink);
    font: inherit;
    font-weight: 800;
  }
  .rh-route__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }
  .rh-route__chips .kg-chip {
    gap: 5px;
    text-decoration: none;
  }
  .rh-route__chips .kg-chip span {
    color: var(--muted);
    font-weight: 700;
  }
  .rh-handled {
    display: grid;
    gap: 0.85rem;
    padding: 0.95rem;
  }
  .rh-handled__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }
  .rh-handled__item {
    display: grid;
    gap: 0.2rem;
    min-height: 5.8rem;
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--line) 16%, transparent);
    color: var(--ink);
    text-decoration: none;
  }
  .rh-handled__item strong {
    color: var(--gold);
    font-size: 1.55rem;
    line-height: 1;
  }
  .rh-handled__item span {
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1;
  }
  .rh-handled__item small {
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 750;
    line-height: 1.2;
  }
  .rh-spine {
    display: grid;
    gap: 0.6rem;
  }
  .rh-loop {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(7.4rem, 1fr);
    gap: 8px;
    overflow-x: auto;
    padding: 2px 2px 8px;
    scroll-snap-type: x proximity;
  }
  .rh-loop__stage {
    position: relative;
    display: grid;
    gap: 0.35rem;
    min-height: 7.1rem;
    padding: 0.78rem;
    color: var(--ink);
    text-decoration: none;
    scroll-snap-align: start;
  }
  .rh-loop__dot {
    width: 0.56rem;
    height: 0.56rem;
    border-radius: 999px;
    background: var(--gold);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--gold-soft) 70%, transparent);
  }
  .rh-loop__stage strong {
    font-size: 1rem;
    line-height: 1;
  }
  .rh-loop__stage small {
    min-height: 2.2em;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.15;
  }
  .rh-loop__stage em {
    align-self: end;
    color: var(--gold);
    font-size: 0.68rem;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .rh-empty {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border-radius: var(--radius);
    border: 1px dashed var(--line);
    background: var(--panel);
    color: var(--muted);
  }
  .rh-empty strong {
    color: var(--ink);
    font-size: 0.98rem;
  }
  .rh-empty span {
    font-size: 0.88rem;
    line-height: 1.35;
  }
  .rh-empty--small {
    padding: 0.8rem 0.9rem;
    font-size: 0.86rem;
  }
  .rh-home__section {
    display: grid;
    gap: 0.6rem;
  }
  .rh-home__section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .rh-home__section-head span {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }
  .rh-deck,
  .rh-pulse {
    display: grid;
    gap: 0.55rem;
  }
  .rh-pulse {
    max-height: 28rem;
    overflow: auto;
    padding-bottom: 0.2rem;
  }
  .rh-home .aa-card {
    --aa-dot: var(--gold);
    --aa-state-home: var(--gold);
    display: grid;
    grid-template-columns: 10px minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    border-color: var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    color: var(--ink);
    text-decoration: none;
  }
  .rh-home .aa-card__rail {
    width: 8px;
    min-height: 8px;
    align-self: start;
    margin-top: 0.32rem;
    border-radius: 999px;
    background: var(--aa-dot);
  }
  .rh-home .aa-card__domain {
    color: var(--aa-dot);
  }
  .rh-home .aa-card__headline {
    color: var(--ink);
  }
  .rh-home .aa-card__because,
  .rh-home .aa-card__chip,
  .rh-home .aa-card__expand {
    color: var(--muted);
  }
  .rh-home .aa-card__state,
  .rh-home .aa-card__chip {
    border-color: var(--line);
    background: var(--panel);
    color: var(--ink);
  }
  .rh-home .aa-card__chip--source {
    border-color: var(--line);
    background: color-mix(in srgb, var(--line) 24%, transparent);
  }
  .rh-home .aa-card--one {
    border-color: color-mix(in srgb, var(--gold) 55%, var(--line));
    background: color-mix(in srgb, var(--gold-soft) 46%, var(--panel));
  }
  .rh-home .aa-card--one[data-attention-state='risk_changed'] {
    border-color: var(--line);
    background: var(--panel);
  }
  .rh-home .aa-tone-team { --aa-dot: var(--green); }
  .rh-home .aa-tone-project { --aa-dot: var(--blue); }
  .rh-home .aa-tone-money { --aa-dot: var(--gold); }
  .rh-home .aa-tone-selection { --aa-dot: var(--blue); }
  .rh-home .aa-tone-client { --aa-dot: var(--green); }
  .rh-home .aa-tone-review { --aa-dot: var(--gold); }
  .rh-home .aa-tone-neutral { --aa-dot: var(--muted); }
  .rh-home .aa-card[data-attention-state='handled'] { --aa-state-home: var(--green); }
  .rh-home .aa-card[data-attention-state='next_options'] { --aa-state-home: var(--gold); }
  .rh-home .aa-card[data-attention-state='needs_you'] { --aa-state-home: var(--blue); }
  .rh-home .aa-card[data-attention-state='risk_changed'] { --aa-state-home: var(--red); }
  .rh-home .aa-card[data-attention-state='review_suggested'] { --aa-state-home: var(--blue); }
  .rh-home .aa-card[data-attention-state='risk_changed'] .aa-card__rail {
    background: var(--aa-dot);
  }
  .rh-home .aa-card[data-attention-state='risk_changed'] .aa-card__state {
    border-color: transparent;
    background: var(--red-soft);
    color: var(--red);
  }
  @media (min-width: 760px) {
    .rh-deck {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 520px) {
    .rh-handled__grid { grid-template-columns: 1fr; }
    .rh-home h1 { font-size: 1.62rem; }
    .rh-route {
      gap: 0.65rem;
      padding: 0.78rem;
    }
    .rh-route__search {
      grid-template-columns: minmax(0, 1fr) auto;
    }
    .rh-route__search input {
      padding: 0.7rem 0.85rem;
    }
  }
</style>
