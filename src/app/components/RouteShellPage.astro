---
import Layout from '../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../components/SurfaceIrreversibilityWrap.astro';
import RhSummary from '../components/RhSummary.astro';
import Card from '../components/Card.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';

export interface Props {
  title: string;
  routeName: string;
  phase?: string;
  irreversibility?: boolean;
  actionContext?: string;
}

const {
  title,
  irreversibility = false,
  actionContext,
} = Astro.props;

const { t } = createLayoutContext();
const kind = irreversibility ? 'irreversibility' : 'daily';
---

<Layout title={title} activeHref={Astro.url.pathname}>
  <SurfaceIrreversibilityWrap kind={kind} actionContext={actionContext ?? null}>
    <RhSummary headline={title} detail={t('route_shell.detail')} />
    <Card eyebrow={t('route_shell.card_eyebrow')} title={title}>
      <p class="route-placeholder">{t('route_shell.body')}</p>
      {irreversibility && actionContext ? (
        <p class="safety-copy">{actionContext}</p>
      ) : null}
      <slot />
    </Card>
  </SurfaceIrreversibilityWrap>
</Layout>

<style>
  .route-placeholder {
    margin: 0;
    color: var(--text-muted, #5c6670);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .safety-copy {
    margin: 0.75rem 0 0;
    color: var(--text-muted, #5c6670);
    font-size: 0.9rem;
    line-height: 1.45;
  }
</style>
