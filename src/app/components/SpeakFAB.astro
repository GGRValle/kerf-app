---
import { createLayoutContext } from '../lib/createLayoutContext.js';
const { t } = createLayoutContext();
---
<a href="/right-hand" data-rh-speak class="speak-fab" aria-label={t('layout.speak_fab.label')} title={t('layout.speak_fab.title')}><span aria-hidden="true">🎙</span></a>
<style>.speak-fab{position:fixed;right:max(1rem,env(safe-area-inset-right));bottom:max(5.5rem,calc(1rem + env(safe-area-inset-bottom,0px)));width:3.25rem;height:3.25rem;border-radius:999px;background:var(--right-hand,#C9A961);color:#0A0D11;box-shadow:0 8px 22px rgba(0,0,0,0.35);z-index:20;display:flex;align-items:center;justify-content:center;text-decoration:none}@media(max-width:1099px){.speak-fab{display:none}}@media(min-width:1100px){.speak-fab{bottom:max(1rem,env(safe-area-inset-bottom))}}</style>
