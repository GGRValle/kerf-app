---
import Card from '../Card.astro';
import Row from '../Row.astro';
import PreviewNotice from './PreviewNotice.astro';
import { formatCentsDisplay, type Lane23ProjectRecord, type ProjectTabId } from '../../lib/lane23Fixtures.js';
import {
  listProjectNotes,
  listProjectSelections,
  listAssignmentsForProject,
} from '../../lib/lane3WorkFixtures.js';
import type { I18nKey } from '../../../i18n/keys.js';

export interface Props {
  project: Lane23ProjectRecord;
  activeTab: ProjectTabId;
  labelFor: (key: I18nKey) => string;
  tenantId: string;
}

const { project, activeTab, labelFor: t, tenantId } = Astro.props;
const previewBadge = t('action.preview.badge');
const selections = listProjectSelections(project.project_id);
const notes = listProjectNotes(project.project_id);
const assignments = listAssignmentsForProject(
  tenantId as 'tenant_ggr' | 'tenant_valle' | 'tenant_hpg',
  project.project_id,
);
---

{activeTab === 'overview' ? (
  <Card title={t('project.tab.overview')}>
    <p>{t('project.panel.overview')}</p>
    {assignments.length > 0 && (
      <>
        <p class="lane23-notice">{t('project.overview.assignments')}</p>
        {assignments.map((a) => (
          <div class="lane3w-assign-row">
            <strong>{a.sub_label}</strong>
            <span>{a.trade} · {a.start_at.slice(0, 10)} · {a.location_label}</span>
            <span>{a.wo_sent_at ? t('project.wo.sent') : t('project.wo.draft')}</span>
          </div>
        ))}
      </>
    )}
  </Card>
) : activeTab === 'selections' ? (
  <Card title={t('project.tab.selections')}>
    <p>{t('project.panel.selections')}</p>
    {selections.length === 0 ? (
      <p class="lane23-notice">{t('project.selections.empty')}</p>
    ) : (
      selections.map((s) => (
        <Row title={s.label} meta={`${s.lifecycle} · ${formatCentsDisplay(s.client_visible_cents)}`} />
      ))
    )}
  </Card>
) : activeTab === 'notes' ? (
  <Card title={t('project.tab.notes')}>
    <p>{t('project.panel.notes')}</p>
    {notes.length === 0 ? (
      <p class="lane23-notice">{t('project.notes.empty')}</p>
    ) : (
      notes.map((n) => (
        <Row title={n.evidence_label} meta={n.body} />
      ))
    )}
  </Card>
) : activeTab === 'portal' ? (
  <Card title={t('project.tab.portal')}>
    <p>{t('project.panel.portal')}</p>
    <a class="lane23-btn-link" href={`/projects/${project.project_id}/portal-preview`}>{t('project.portal.gc_preview')}</a>
    <PreviewNotice badgeLabel={previewBadge} message={t('project.portal.client_login_hint')} />
  </Card>
) : (
  <Card title={t(`project.tab.${activeTab}`)}>
    <p>{t(`project.panel.${activeTab}`)}</p>
  </Card>
)}

<style>
  .lane23-btn-link {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border, #d8dee6);
    color: var(--accent, #0f766e);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
  }
</style>
