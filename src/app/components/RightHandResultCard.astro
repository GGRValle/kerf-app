---
// Home fold-in for a resolved Right Hand turn (brief 2026-05-31 §1).
// After Save, the overlay stashes a Turn Resolution Packet; Home reads it and
// folds the result into the attention queue as an HONEST card — never a
// fabricated "I handled this". The card is generated from the real TRP only.
import { createLayoutContext } from '../lib/createLayoutContext.js';
const { t } = createLayoutContext();
---
<section
  class="rh-result"
  id="rh-result"
  aria-label={t('home.result.ready_to_save')}
  data-ready={t('home.result.ready_to_save')}
  data-heard-label={t('home.result.heard_label')}
  data-prompt={t('home.result.prompt')}
  hidden
>
  <div class="rh-result__head">
    <span class="rh-result__badge" id="rh-result-badge">{t('home.result.ready_to_save')}</span>
    <button type="button" class="rh-result__dismiss" id="rh-result-dismiss">{t('home.result.dismiss')}</button>
  </div>
  <p class="rh-result__heard">
    <span class="rh-result__heard-label">{t('home.result.heard_label')}</span>
    <span class="rh-result__heard-text" id="rh-result-heard"></span>
  </p>
  <p class="rh-result__prompt" id="rh-result-prompt">{t('home.result.prompt')}</p>
  <div class="rh-result__moves">
    <button type="button" class="rh-result__move" data-move="add_photo">{t('home.result.add_photo')}</button>
    <button type="button" class="rh-result__move" data-move="open_job">{t('home.result.open_job')}</button>
    <button type="button" class="rh-result__move" data-move="review_estimate">{t('home.result.review_estimate')}</button>
  </div>
</section>

<script>
  import {
    parseTurnResolution,
    nextMovesFor,
    TURN_RESOLUTION_SESSION_KEY,
  } from '../../voice/realtime/turnResolution.js';
  import { attentionFromTurnResolution } from '../../attention/attentionArtifact.js';

  const card = document.getElementById('rh-result');
  if (card) {
    let raw: string | null = null;
    try {
      raw = sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY);
    } catch { /* storage unavailable — leave the card hidden */ }
    const trp = parseTurnResolution(raw);
    if (trp) {
      const artifact = attentionFromTurnResolution(trp, 'inline_result');
      const badge = document.getElementById('rh-result-badge');
      const heard = document.getElementById('rh-result-heard');
      const prompt = document.getElementById('rh-result-prompt');
      // HONEST: the projection computes durable status from work_artifact, not
      // model/result copy. The card cannot claim handled without a real artifact.
      if (badge) badge.textContent = artifact.headline;
      if (heard) heard.textContent = trp.heard_text;
      if (prompt) prompt.textContent = artifact.detail;
      const moves = nextMovesFor(trp);
      card.querySelectorAll<HTMLElement>('[data-move]').forEach((el) => {
        el.addEventListener('click', () => {
          const move = moves.find((m) => m.id === el.getAttribute('data-move'));
          if (move) window.location.href = move.route;
        });
      });
      const dismiss = document.getElementById('rh-result-dismiss');
      dismiss?.addEventListener('click', () => {
        try { sessionStorage.removeItem(TURN_RESOLUTION_SESSION_KEY); } catch { /* noop */ }
        card.hidden = true;
      });
      card.hidden = false;
    }
  }
</script>

<style>
  .rh-result {
    margin-bottom: 0.85rem;
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--field-green, #38c977) 40%, var(--border, #d8dee6));
    border-radius: 14px;
    background: var(--surface, #fff);
  }
  .rh-result__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .rh-result__badge {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--field-green, #38c977);
  }
  .rh-result__dismiss {
    flex: none;
    border: 0;
    background: none;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted, #6a7282);
    cursor: pointer;
  }
  .rh-result__heard {
    margin: 0.5rem 0 0.4rem;
    font-size: 0.88rem;
    line-height: 1.4;
  }
  .rh-result__heard-label {
    display: block;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted, #6a7282);
    margin-bottom: 0.1rem;
  }
  .rh-result__heard-text { color: var(--text, #1a1f24); }
  .rh-result__prompt {
    margin: 0 0 0.6rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--text-muted, #6a7282);
  }
  .rh-result__moves { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .rh-result__move {
    min-height: 38px;
    padding: 0 0.8rem;
    border-radius: 10px;
    border: 1px solid var(--border, #d8dee6);
    background: var(--surface, #fff);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    color: inherit;
    cursor: pointer;
  }
</style>
