---
import { bottomNavForRole, type ShellNavIcon } from '../lib/shellRoutes.js';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import type { RoleRoot } from '../lib/layout-props.js';
export interface Props { activeHref?: string; roleRoot?: RoleRoot }
const { activeHref = '/', roleRoot = 'owner' } = Astro.props;
const { t } = createLayoutContext();
const slots = bottomNavForRole(roleRoot);
const isActive = (href: string) =>
  href === '/' ? activeHref === '/' : activeHref === href || activeHref.startsWith(href + '/');

// Canon F-A1 / F-C1 monochrome silhouette icons. `more` is the intentional
// 4-color quad exception; `speak` uses the simple canon mic glyph.
const ICONS: Record<ShellNavIcon, string> = {
  home: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 2 12h3v8h5v-6h4v6h5v-8h3z"/></svg>',
  projects:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-9l-2-2H4a1 1 0 0 0-1 1z"/></svg>',
  clients:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1z"/></svg>',
  log:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm0 2h2v6l2-1 2 1V4h6v16H6zM10 13h8v2h-8zm0 4h6v2h-6z"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16zM13 7h-2v6l5 3 1-1.73L13 11.5z"/></svg>',
  speak:
    '<svg class="mbn-mic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/></svg>',
  more:
    '<svg viewBox="0 0 24 24" class="icon-more" aria-hidden="true"><rect x="2" y="2" width="9" height="9" rx="1.5" fill="#A78BFA"/><rect x="13" y="2" width="9" height="9" rx="1.5" fill="#E879A8"/><rect x="2" y="13" width="9" height="9" rx="1.5" fill="#4ADE80"/><rect x="13" y="13" width="9" height="9" rx="1.5" fill="#67D6E0"/></svg>',
};
---
<nav class="mobile-bottom-nav" aria-label={t('shell.mobile_nav.aria')}>
  {slots.map((slot) =>
    slot.speak ? (
      <a
        class="mbn-speak"
        href={slot.href}
        aria-label={t(slot.labelKey)}
        aria-current={isActive(slot.href) ? 'page' : undefined}
      >
        <span class="mbn-fab" set:html={ICONS[slot.icon]} />
        <span class="mbn-speak-label">{t(slot.labelKey)}</span>
      </a>
    ) : (
      <a class="mbn-tab" href={slot.href} aria-current={isActive(slot.href) ? 'page' : undefined}>
        <span class="mbn-icon" set:html={ICONS[slot.icon]} />
        <span class="mbn-label">{t(slot.labelKey)}</span>
      </a>
    ),
  )}
</nav>
<style>
  .mobile-bottom-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 80;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    align-items: end;
    background: var(--kerf-bg-2);
    border-top: 1px solid var(--kerf-border);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .mbn-tab,
  .mbn-speak {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 0.5rem 0.25rem 0.55rem;
    font-size: 0.66rem;
    font-weight: 600;
    color: var(--kerf-text-mute);
    text-decoration: none;
    min-width: 0;
    position: relative;
    z-index: 1;
    pointer-events: auto;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .mbn-icon {
    display: inline-flex;
    width: 22px;
    height: 22px;
  }
  .mbn-icon :global(svg) {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }
  .mbn-icon :global(svg.icon-more) {
    fill: none;
  }
  .mobile-bottom-nav .mbn-tab[aria-current='page'] {
    color: var(--kerf-amber);
  }
  .mobile-bottom-nav .mbn-speak[aria-current='page'] .mbn-speak-label {
    color: var(--kerf-amber);
  }

  /* Center Speak slot — canon lifted mic FAB. */
  .mbn-speak {
    position: relative;
  }
  .mbn-fab {
    position: absolute;
    bottom: 0.6rem;
    left: 50%;
    transform: translateX(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--kerf-amber);
    color: #1a1300;
    border: 3px solid var(--kerf-bg);
    box-shadow: 0 6px 18px rgba(245, 181, 68, 0.4);
    pointer-events: none;
  }
  .mbn-fab :global(svg.mbn-mic) {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }
  .mbn-speak-label {
    margin-top: 34px;
  }
  @media (min-width: 900px) {
    .mobile-bottom-nav {
      display: none;
    }
  }
</style>
