---
import { bottomNavForRole, type ShellNavIcon } from '../lib/shellRoutes.js';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import type { RoleRoot } from '../lib/layout-props.js';
export interface Props { activeHref?: string; roleRoot?: RoleRoot }
const { activeHref = '/', roleRoot = 'owner' } = Astro.props;
const { t } = createLayoutContext();
const slots = bottomNavForRole(roleRoot);
const isActive = (href: string) =>
  href === '/' ? activeHref === '/' : activeHref === href || activeHref.startsWith(href + '/');

// Contractor dock icons: quiet silhouettes, fast to read in the field.
const ICONS: Record<ShellNavIcon, string> = {
  home: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 2 12h3v8h5v-6h4v6h5v-8h3z"/></svg>',
  create:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11 4h2v7h7v2h-7v7h-2v-7H4v-2h7z"/></svg>',
  camera:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.5 5 7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-1.5-2zM12 17a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm0-2a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>',
  projects:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7v12a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-9l-2-2H4a1 1 0 0 0-1 1z"/></svg>',
  clients:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1z"/></svg>',
  log:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm0 2h2v6l2-1 2 1V4h6v16H6zM10 13h8v2h-8zm0 4h6v2h-6z"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16zM13 7h-2v6l5 3 1-1.73L13 11.5z"/></svg>',
  speak:
    '<svg class="mbn-mic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/></svg>',
  more:
    '<svg viewBox="0 0 24 24" class="icon-more" aria-hidden="true"><rect x="3" y="5" width="18" height="2.4" rx="1.2"/><rect x="3" y="10.8" width="18" height="2.4" rx="1.2"/><rect x="3" y="16.6" width="18" height="2.4" rx="1.2"/></svg>',
};
---
<nav class="mobile-bottom-nav" aria-label={t('shell.mobile_nav.aria')} data-role-root={roleRoot}>
  {slots.map((slot) =>
    slot.speak ? (
      <a
        class="mbn-speak"
        href={slot.href}
        data-rh-speak
        aria-label={t(slot.labelKey)}
        aria-current={isActive(slot.href) ? 'page' : undefined}
      >
        <span class="mbn-fab" set:html={ICONS[slot.icon]} />
        <span class="mbn-speak-label">{t(slot.labelKey)}</span>
        <span class="mbn-reengage-hint" aria-hidden="true">Tap to reengage</span>
      </a>
    ) : (
      <a class="mbn-tab" href={slot.href} aria-current={isActive(slot.href) ? 'page' : undefined}>
        <span class="mbn-icon" set:html={ICONS[slot.icon]} />
        <span class="mbn-label">{t(slot.labelKey)}</span>
      </a>
    ),
  )}
</nav>
<style>
  .mobile-bottom-nav {
    position: fixed;
    left: 12px;
    right: 12px;
    bottom: calc(10px + env(safe-area-inset-bottom, 0px));
    z-index: 80;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 5px;
    align-items: stretch;
    padding: 6px;
    border: 1px solid var(--kerf-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--kerf-surface) 94%, transparent);
    box-shadow: 0 18px 38px rgba(24, 23, 19, 0.14);
    backdrop-filter: blur(18px);
  }
  .mbn-tab,
  .mbn-speak {
    display: grid;
    grid-template-rows: 20px auto;
    place-items: center;
    gap: 3px;
    min-width: 0;
    min-height: 50px;
    padding: 6px 2px;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--kerf-text-dim);
    font-size: 0.62rem;
    font-weight: 900;
    line-height: 1;
    text-decoration: none;
    position: relative;
    z-index: 1;
    pointer-events: auto;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  .mbn-icon {
    display: inline-flex;
    width: 20px;
    height: 20px;
  }
  .mbn-icon :global(svg) {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }
  .mbn-icon :global(svg.icon-more) {
    fill: currentColor;
  }
  .mobile-bottom-nav .mbn-tab[aria-current='page'] {
    color: var(--kerf-text);
    border-color: color-mix(in srgb, var(--kerf-amber) 38%, var(--kerf-border));
    background: var(--kerf-surface-2);
  }

  /* Center Speak slot: same dock geometry, stronger action color. */
  .mbn-speak {
    color: #181713;
    background: var(--kerf-amber);
    box-shadow: 0 8px 18px rgba(229, 185, 63, 0.22);
  }
  .mbn-fab {
    display: inline-flex;
    width: 20px;
    height: 20px;
    color: currentColor;
    pointer-events: none;
  }
  .mbn-fab :global(svg.mbn-mic) {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }
  .mbn-speak-label {
    display: block;
  }

  /* Parked conversation (body.rh-reengage, set by the Right Hand overlay on
     close): the center action swaps to "Tap to reengage" + a subtle
     dock glow. This is the MOBILE reengage path; desktop keeps the side
     pill (this nav is hidden >=900px). One affordance per breakpoint. */
  .mbn-reengage-hint {
    display: none;
    white-space: nowrap;
    font-size: 0.58rem;
    font-weight: 900;
    color: currentColor;
  }
  :global(body.rh-reengage) .mbn-speak .mbn-speak-label { display: none; }
  :global(body.rh-reengage) .mbn-speak .mbn-reengage-hint { display: block; }
  :global(body.rh-reengage) .mbn-speak {
    animation: mbn-reengage-glow 2.4s ease-in-out infinite;
  }
  .mobile-bottom-nav[data-role-root='field_hand'] .mbn-speak,
  .mobile-bottom-nav[data-role-root='sub'] .mbn-speak {
    background: var(--field-green);
    color: #fff;
    box-shadow: 0 8px 18px rgba(15, 122, 83, 0.22);
  }
  @keyframes mbn-reengage-glow {
    0%, 100% { box-shadow: 0 8px 18px rgba(229, 185, 63, 0.22); }
    50% { box-shadow: 0 9px 24px rgba(229, 185, 63, 0.52), 0 0 0 4px rgba(229, 185, 63, 0.12); }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(body.rh-reengage) .mbn-speak {
      animation: none;
      box-shadow: 0 9px 24px rgba(229, 185, 63, 0.44);
    }
  }

  @media (min-width: 900px) {
    .mobile-bottom-nav {
      display: none;
    }
  }
</style>
