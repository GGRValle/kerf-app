---
export interface Props {
  headline: string;
  detail?: string;
  tone?: 'neutral' | 'green';
}

const { headline, detail, tone = 'neutral' } = Astro.props;
---

<div class:list={['rh-summary', tone === 'green' && 'rh-green']}>
  <div class="rh-avatar" aria-hidden="true">RH</div>
  <div class="rh-text">
    <strong>{headline}</strong>
    {detail ? <> <em>{detail}</em></> : null}
  </div>
</div>

<style>
  .rh-summary {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #d8dee6);
    border-radius: 12px;
  }
  .rh-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: grid;
    place-items: center;
    font-size: 0.7rem;
    font-weight: 700;
    background: #e4e7ec;
  }
  .rh-text {
    font-size: 0.92rem;
    line-height: 1.45;
  }
  .rh-text em {
    font-style: normal;
    color: var(--text-muted, #5c6670);
  }
  .rh-green .rh-text strong { color: var(--chip-green, #027a48); }
</style>
