---
export interface Props {
  headline: string;
  detail?: string;
  tone?: 'neutral' | 'green';
}

const { headline, detail, tone = 'neutral' } = Astro.props;
---

<div class:list={['rh-summary', tone === 'green' && 'rh-green']}>
  <div class="rh-avatar" aria-hidden="true">RH</div>
  <div class="rh-text">
    <strong>{headline}</strong>
    {detail ? <> <em>{detail}</em></> : null}
  </div>
</div>

<style>
  .rh-summary {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.85rem;
    margin-bottom: 0.85rem;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    box-shadow: 0 12px 28px rgba(24, 23, 19, 0.07);
  }
  .rh-avatar {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--kerf-bg, #f7f6f1);
    background: var(--kerf-text, #181713);
  }
  .rh-text {
    min-width: 0;
    font-size: 0.92rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .rh-text strong {
    display: block;
    line-height: 1.2;
  }
  .rh-text em {
    display: block;
    margin-top: 0.12rem;
    font-style: normal;
    color: var(--text-muted, #5c6670);
  }
  .rh-green .rh-avatar {
    color: #fff;
    background: var(--field-green, #0f7a53);
  }
</style>
