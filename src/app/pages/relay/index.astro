---
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';

const { t } = createLayoutContext();
const relayCopy = {
  title: t('rh.relay.list.title'),
  lead: t('rh.relay.list.lead'),
  loading: t('rh.relay.list.loading'),
  emptySubmit: t('rh.relay.list.empty_submit'),
  errorPrefix: t('rh.relay.list.error_prefix'),
  fallbackHeadline: t('rh.relay.card.fallback_headline'),
  fallbackBody: t('rh.relay.card.fallback_body'),
  transcript: t('rh.relay.card.transcript'),
  severity: {
    block: t('rh.relay.severity.block'),
    warn: t('rh.relay.severity.watch'),
    info: t('rh.relay.severity.info'),
    review: t('rh.relay.severity.review'),
  },
};
---

<Layout titleKey="rh.relay.list.title" activeHref={Astro.url.pathname}>
  <main class="relay-page">
    <header class="relay-header">
      <h1>{relayCopy.title}</h1>
      <p>{relayCopy.lead}</p>
    </header>

    <section class="relay-list" id="relay-list" aria-live="polite">
      <article class="relay-empty">
        <p>{relayCopy.loading}</p>
      </article>
    </section>
  </main>

  <script define:vars={{ relayCopy }}>
  const list = document.querySelector('#relay-list');

  function severityLabel(severity) {
    if (severity === 'block') return relayCopy.severity.block;
    if (severity === 'warn') return relayCopy.severity.warn;
    if (severity === 'info') return relayCopy.severity.info;
    return relayCopy.severity.review;
  }

  function cardHeadline(item) {
    const summary = typeof item.summary === 'string' ? item.summary.trim() : '';
    const description = typeof item.description === 'string' ? item.description.trim() : '';
    const transcript = typeof item.transcript_text === 'string' ? item.transcript_text.trim() : '';
    if (description.length > 0 && summary.length < 16) return description;
    if (summary.length > 0) return summary;
    if (transcript.length > 0) {
      const sentence = transcript.split(/[.!?]/)[0]?.trim() ?? transcript;
      return sentence.length > 72 ? `${sentence.slice(0, 69)}…` : sentence;
    }
    return relayCopy.fallbackHeadline;
  }

  function cardBody(item, headline) {
    const description = typeof item.description === 'string' ? item.description.trim() : '';
    if (description.length > 0 && description !== headline) return description;
    return relayCopy.fallbackBody;
  }

  function renderEmpty(message) {
    if (!(list instanceof HTMLElement)) return;
    list.innerHTML = '';
    const card = document.createElement('article');
    card.className = 'relay-empty';
    const p = document.createElement('p');
    p.textContent = message;
    card.append(p);
    list.append(card);
  }

  function renderItems(items) {
    if (!(list instanceof HTMLElement)) return;
    if (!items.length) {
      renderEmpty(relayCopy.emptySubmit);
      return;
    }
    list.innerHTML = '';
    for (const item of items) {
      const card = document.createElement('article');
      card.className = 'relay-card';
      card.dataset.severity = item.severity ?? 'review';
      const top = document.createElement('div');
      top.className = 'relay-card-top';
      const severity = document.createElement('span');
      severity.className = 'relay-card-severity';
      severity.textContent = severityLabel(item.severity);
      const separator = document.createElement('span');
      separator.className = 'relay-card-sep';
      separator.setAttribute('aria-hidden', 'true');
      separator.textContent = '·';
      const surfacedAt = document.createElement('time');
      surfacedAt.dateTime = item.surfaced_at ?? '';
      surfacedAt.textContent = new Date(item.surfaced_at).toLocaleString();
      top.append(severity, separator, surfacedAt);
      const headline = cardHeadline(item);
      const title = document.createElement('h2');
      title.textContent = headline;
      const description = document.createElement('p');
      description.textContent = cardBody(item, headline);
      const details = document.createElement('details');
      const summary = document.createElement('summary');
      summary.textContent = relayCopy.transcript;
      const transcript = document.createElement('p');
      transcript.textContent = item.transcript_text ?? '—';
      details.append(summary, transcript);
      card.append(top, title, description, details);
      list.append(card);
    }
  }

  async function loadRelay() {
    try {
      const res = await fetch('/api/v1/field-daily/relay-feed?tenant_id=tenant_ggr');
      const body = await res.json();
      if (!res.ok) throw new Error(body.error ?? `relay_failed_${res.status}`);
      renderItems(Array.isArray(body.items) ? body.items : []);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      renderEmpty(`${relayCopy.errorPrefix}: ${msg}`);
    }
  }

  void loadRelay();
  </script>

  <style>
    .relay-page {
      max-width: 860px;
      margin: 0 auto;
      padding: 1.5rem 1rem 4rem;
    }

    .relay-header {
      margin-bottom: 1rem;
    }

    .relay-header h1 {
      margin: 0 0 0.4rem;
      font-size: 1.55rem;
      letter-spacing: 0;
    }

    .relay-header p {
      margin: 0;
      color: var(--text-muted, #5c6670);
      line-height: 1.45;
    }

    .relay-list {
      display: grid;
      gap: 0.8rem;
    }

    :global(.relay-card),
    :global(.relay-empty) {
      border: 1px solid var(--border-soft, #d7dde6);
      border-radius: 8px;
      background: var(--surface, #fff);
      padding: 1rem;
    }

    :global(.relay-card[data-severity='block']) {
      border-left: 4px solid #d92d20;
    }

    :global(.relay-card[data-severity='warn']) {
      border-left: 4px solid #f5b544;
    }

    :global(.relay-card[data-severity='info']) {
      border-left: 4px solid #026aa2;
    }

    :global(.relay-card-top) {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.35rem 0.5rem;
      color: var(--text-muted, #5c6670);
      font-size: 0.78rem;
      margin-bottom: 0.45rem;
    }

    :global(.relay-card-severity) {
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    :global(.relay-card-sep) {
      color: var(--text-muted, #5c6670);
      font-weight: 700;
    }

    :global(.relay-card-top time) {
      margin-left: auto;
      text-align: right;
    }

    :global(.relay-card h2) {
      margin: 0 0 0.4rem;
      font-size: 1rem;
      letter-spacing: 0;
      line-height: 1.35;
    }

    :global(.relay-card p) {
      margin: 0 0 0.65rem;
      color: var(--text-muted, #4f5966);
      line-height: 1.45;
    }

    :global(.relay-card details) {
      color: var(--text-muted, #4f5966);
    }

    :global(.relay-card summary) {
      cursor: pointer;
      font-weight: 700;
      color: var(--text, #0a0d11);
    }
  </style>
</Layout>
