---
import Layout from '../layouts/Layout.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { getApiDeps } from '../../api/lib/deps.js';
import { getProjectBrain, listAssignmentsForProject, listProjectSelections } from '../lib/lane3WorkFixtures.js';
import { listProjectRecordsForTenant } from '../lib/projectRecords.js';
import '../styles/lane3work.css';

const { context } = createLayoutContext();
const { tenantReader } = getApiDeps();
const projects = await listProjectRecordsForTenant(tenantReader, context.tenantId);
const projectRows = projects.map((project) => {
  const assignments = listAssignmentsForProject(
    context.tenantId as 'tenant_ggr' | 'tenant_valle' | 'tenant_hpg',
    project.project_id,
  );
  const selections = listProjectSelections(project.project_id);
  const brain = getProjectBrain(project.project_id);
  const openSelections = selections.filter((selection) => selection.lifecycle !== 'approved');
  return {
    project,
    assignments,
    brain,
    openSelections,
    openWork: project.work_orders.filter((workOrder) => workOrder.status !== 'complete').length,
    doneWork: project.work_orders.filter((workOrder) => workOrder.status === 'complete').length,
  };
});
const activeRow = projectRows.find((row) => row.assignments.length > 0) ?? projectRows[0] ?? null;
const activeProject = activeRow?.project ?? null;
const activeAssignment = activeRow?.assignments[0] ?? null;
const blocker = activeRow?.openSelections[0] ?? null;
const crewMapHref = `/field?return_to=${encodeURIComponent('/schedule')}`;
const formatDate = (iso: string | undefined): string => {
  if (!iso) return 'Unscheduled';
  return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(new Date(iso));
};
const phaseRows = activeProject
  ? [
      {
        group: 'Complete',
        state: 'done',
        title: 'Site protection + demo',
        meta: `${activeProject.project_name} · proof filed`,
        chip: 'Synced',
      },
      {
        group: 'In progress',
        state: 'now',
        title: activeAssignment?.trade ? `${activeAssignment.trade} crew window` : activeRow?.brain?.next_action ?? 'Current field phase',
        meta: activeAssignment
          ? `${formatDate(activeAssignment.start_at)} – ${formatDate(activeAssignment.end_at)} · ${activeAssignment.location_label}`
          : 'Right Hand is holding the current job context.',
        chip: activeAssignment?.wo_sent_at ? 'Sent' : 'This week',
      },
      {
        group: 'Upcoming',
        state: blocker ? 'blocked' : 'future',
        title: blocker ? `${blocker.label} blocks the next phase` : 'Next field phase',
        meta: blocker ? 'Selection needs your call before the schedule moves.' : 'No schedule blockers detected.',
        chip: blocker ? 'Needs you' : 'Clear',
      },
      {
        group: 'Upcoming',
        state: 'future',
        title: 'Finish, punch, and closeout',
        meta: `${activeRow?.openWork ?? 0} open work areas · ${activeRow?.doneWork ?? 0} complete`,
        chip: 'Planned',
      },
    ]
  : [];
const crewRows = projectRows.flatMap((row) =>
  row.assignments.map((assignment) => ({
    ...assignment,
    projectName: row.project.project_name,
    projectHref: `/projects/${row.project.project_id}`,
  })),
);
---

<Layout title="Schedule" activeHref="/schedule">
  <section class="schedule-shell" data-grammar="canon" data-tenant-id={context.tenantId} aria-labelledby="schedule-title">
    <header class="schedule-hero">
      <div>
        <span class="schedule-kicker">Schedule</span>
        <h1 id="schedule-title">Jobs, crews, and blockers.</h1>
        <p>See what is happening now and what needs a call before work moves.</p>
      </div>
      <div class="schedule-mode" aria-label="Schedule view">
        <span class="active">Timeline</span>
        <span>Agenda</span>
        <span>Gantt</span>
      </div>
    </header>

    {activeProject && (
      <section class="schedule-decision" aria-label="Schedule decision">
        <div>
          <span>Needs you</span>
          <h2>{blocker ? `${blocker.label} is holding the next phase.` : 'No schedule blocker is holding the job.'}</h2>
          <p>
            {blocker
              ? 'Right Hand has the project context and can hold a reschedule until you approve it.'
              : 'Crew assignments and project proof are lined up. Nothing moves to client or money without approval.'}
          </p>
        </div>
        <div class="schedule-decision__actions">
          <a href={`/projects/${activeProject.project_id}/selections`}>{blocker ? 'Review selection' : 'Review job'}</a>
          <a class="primary" href={`/projects/${activeProject.project_id}`}>Open project</a>
        </div>
      </section>
    )}

    <section class="schedule-command" aria-label="Tell Right Hand about schedule">
      <a href="/right-hand" data-rh-speak>
        <span class="schedule-wave" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
        <span>Tell Right Hand what changed in the field…</span>
      </a>
      <a href={crewMapHref}>Crew map</a>
    </section>

    <section class="schedule-grid" aria-label="Schedule workspace">
      <div class="schedule-main">
        <section class="schedule-panel">
          <div class="schedule-panel__head">
            <span>Project timeline</span>
            <strong>{activeProject?.project_name ?? 'No active project'}</strong>
          </div>
          <div class="schedule-timeline">
            {phaseRows.map((phase, index) => (
              <article class={`schedule-phase schedule-phase--${phase.state}`}>
                <div class="schedule-phase__rail">
                  <span>{phase.state === 'done' ? '✓' : phase.state === 'now' ? '' : index + 1}</span>
                  {index < phaseRows.length - 1 && <i></i>}
                </div>
                <div class="schedule-phase__body">
                  <small>{phase.group}</small>
                  <strong>{phase.title}</strong>
                  <p>{phase.meta}</p>
                  <span class={`schedule-chip schedule-chip--${phase.state}`}>{phase.chip}</span>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside class="schedule-side">
        <section class="schedule-panel">
          <div class="schedule-panel__head">
            <span>Crews today</span>
            <strong>{crewRows.length} assignments</strong>
          </div>
          <div class="schedule-crew-list">
            {crewRows.map((assignment) => (
              <a class="schedule-crew-row" href={assignment.projectHref}>
                <span>{assignment.sub_label.slice(0, 2).toUpperCase()}</span>
                <div>
                  <strong>{assignment.sub_label}</strong>
                  <p>{assignment.trade} · {assignment.projectName}</p>
                  <small>{formatDate(assignment.start_at)} · {assignment.location_label}</small>
                </div>
              </a>
            ))}
            {crewRows.length === 0 && <p class="schedule-empty">No crew assignments for this tenant yet.</p>}
          </div>
        </section>

        <section class="schedule-panel schedule-gantt">
          <div class="schedule-panel__head">
            <span>Gantt cue</span>
            <strong>Next phases</strong>
          </div>
          <div class="schedule-gantt__months">
            <span>Jun</span><span>Jul</span><span>Aug</span><span>Sep</span>
          </div>
          <div class="schedule-gantt__row">
            <span>Current phase</span>
            <i class="current"></i>
          </div>
          <div class="schedule-gantt__row">
            <span>Selections</span>
            <i class={blocker ? 'blocked' : 'clear'}></i>
          </div>
          <div class="schedule-gantt__row">
            <span>Finish + punch</span>
            <i class="planned"></i>
          </div>
          <p>{blocker ? 'Dashed/amber work is held until the selection is resolved.' : 'No blockers are currently holding the schedule.'}</p>
        </section>
      </aside>
    </section>
  </section>
</Layout>

<style>
  .schedule-shell {
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 0.75rem 1rem 6.5rem;
    color: var(--ink);
  }

  .schedule-shell h1,
  .schedule-shell h2,
  .schedule-shell p {
    margin: 0;
    letter-spacing: 0;
  }

  .schedule-hero,
  .schedule-decision,
  .schedule-command,
  .schedule-panel {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .schedule-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 1rem;
    padding: 0.95rem;
    border-color: color-mix(in srgb, var(--ink) 82%, var(--gold));
    background:
      radial-gradient(circle at 82% 12%, color-mix(in srgb, var(--gold) 24%, transparent), transparent 30%),
      linear-gradient(135deg, color-mix(in srgb, var(--ink) 95%, var(--gold)), var(--ink));
    color: var(--bg);
  }

  .schedule-kicker,
  .schedule-panel__head span,
  .schedule-decision span {
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .schedule-hero h1 {
    margin-top: 0.28rem;
    color: var(--bg);
    font-size: 1.9rem;
    line-height: 1.02;
  }

  .schedule-hero p {
    margin-top: 0.22rem;
    color: color-mix(in srgb, var(--bg) 72%, var(--gold));
    font-weight: 760;
  }

  .schedule-mode {
    display: flex;
    gap: 0.32rem;
    padding: 0.28rem;
    border: 1px solid color-mix(in srgb, var(--bg) 16%, transparent);
    border-radius: 9px;
    background: color-mix(in srgb, var(--bg) 8%, transparent);
  }

  .schedule-mode span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.58rem;
    border-radius: 7px;
    color: color-mix(in srgb, var(--bg) 78%, var(--gold));
    font-size: 0.8rem;
    font-weight: 900;
  }

  .schedule-mode .active {
    background: var(--gold);
    color: var(--ink);
  }

  .schedule-decision {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 0.9rem;
    margin-top: 0.7rem;
    padding: 0.82rem;
    border-color: color-mix(in srgb, var(--gold) 58%, var(--line));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--gold) 13%, transparent), transparent 62%),
      color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .schedule-decision h2 {
    margin-top: 0.2rem;
    font-size: 1.22rem;
    line-height: 1.12;
  }

  .schedule-decision p {
    margin-top: 0.25rem;
    color: var(--muted);
    font-weight: 760;
    line-height: 1.34;
  }

  .schedule-decision__actions,
  .schedule-command {
    display: flex;
    gap: 0.48rem;
    align-items: center;
  }

  .schedule-decision__actions a,
  .schedule-command a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.3rem;
    padding: 0.5rem 0.78rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: inherit;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
  }

  .schedule-decision__actions .primary,
  .schedule-command a:last-child {
    border-color: color-mix(in srgb, var(--gold) 48%, var(--line));
    background: var(--gold);
    color: var(--ink);
  }

  .schedule-command {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    margin-top: 0.58rem;
    padding: 0.55rem;
  }

  .schedule-command a:first-child {
    justify-content: start;
    gap: 0.58rem;
    overflow: hidden;
    border-color: color-mix(in srgb, var(--gold) 38%, var(--line));
    background: color-mix(in srgb, var(--ink) 92%, var(--gold));
    color: var(--bg);
  }

  .schedule-command a:first-child span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .schedule-wave {
    display: inline-flex;
    align-items: center;
    gap: 0.13rem;
    flex: 0 0 auto;
  }

  .schedule-wave i {
    width: 0.14rem;
    border-radius: 999px;
    background: var(--gold);
  }

  .schedule-wave i:nth-child(1) { height: 0.44rem; }
  .schedule-wave i:nth-child(2) { height: 0.88rem; }
  .schedule-wave i:nth-child(3) { height: 0.62rem; }
  .schedule-wave i:nth-child(4) { height: 1rem; }

  .schedule-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: 0.68rem;
    margin-top: 0.68rem;
  }

  .schedule-main,
  .schedule-side {
    display: grid;
    align-content: start;
    gap: 0.68rem;
  }

  .schedule-panel {
    display: grid;
    gap: 0.7rem;
    padding: 0.82rem;
  }

  .schedule-panel__head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .schedule-panel__head strong {
    color: var(--muted);
    font-size: 0.84rem;
    text-align: right;
  }

  .schedule-timeline {
    display: grid;
  }

  .schedule-phase {
    display: grid;
    grid-template-columns: 1.65rem minmax(0, 1fr);
    gap: 0.62rem;
  }

  .schedule-phase__rail {
    display: grid;
    justify-items: center;
    grid-template-rows: 1.65rem 1fr;
  }

  .schedule-phase__rail span {
    display: grid;
    place-items: center;
    width: 1.45rem;
    height: 1.45rem;
    border: 2px solid var(--line);
    border-radius: 999px;
    background: var(--panel);
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 950;
  }

  .schedule-phase__rail i {
    width: 2px;
    min-height: 1.2rem;
    background: var(--line);
  }

  .schedule-phase--done .schedule-phase__rail span {
    border-color: var(--green);
    background: var(--green);
    color: var(--bg);
  }

  .schedule-phase--now .schedule-phase__rail span {
    border-color: var(--gold);
    box-shadow: inset 0 0 0 0.3rem var(--panel);
    background: var(--gold);
  }

  .schedule-phase--blocked .schedule-phase__rail span {
    border-color: color-mix(in srgb, var(--red, var(--gold)) 72%, var(--line));
    background: color-mix(in srgb, var(--red, var(--gold)) 18%, var(--panel));
  }

  .schedule-phase__body {
    display: grid;
    gap: 0.2rem;
    padding: 0 0 0.9rem;
    border-bottom: 1px solid var(--line);
  }

  .schedule-phase:last-child .schedule-phase__body {
    border-bottom: 0;
  }

  .schedule-phase__body small {
    color: var(--gold);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .schedule-phase__body strong {
    font-size: 1.03rem;
    line-height: 1.14;
  }

  .schedule-phase__body p,
  .schedule-empty,
  .schedule-gantt p {
    margin: 0;
    color: var(--muted);
    font-weight: 760;
    line-height: 1.32;
  }

  .schedule-chip {
    justify-self: start;
    display: inline-flex;
    min-height: 1.44rem;
    align-items: center;
    padding: 0.18rem 0.54rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--gold) 14%, var(--panel));
    color: var(--ink);
    font-size: 0.74rem;
    font-weight: 950;
  }

  .schedule-chip--done,
  .schedule-chip--future {
    background: color-mix(in srgb, var(--green) 14%, var(--panel));
    color: var(--green);
  }

  .schedule-chip--blocked {
    background: color-mix(in srgb, var(--red, var(--gold)) 12%, var(--panel));
    color: var(--red, var(--gold));
  }

  .schedule-crew-list {
    display: grid;
    gap: 0.45rem;
  }

  .schedule-crew-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.58rem;
    padding: 0.62rem;
    border: 1px solid var(--line);
    border-radius: 9px;
    background: var(--panel);
    color: inherit;
    text-decoration: none;
  }

  .schedule-crew-row > span {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--gold) 22%, var(--panel));
    color: var(--ink);
    font-weight: 950;
  }

  .schedule-crew-row strong,
  .schedule-crew-row p,
  .schedule-crew-row small {
    display: block;
  }

  .schedule-crew-row p {
    margin: 0.12rem 0;
    color: var(--ink);
    font-weight: 820;
  }

  .schedule-crew-row small {
    color: var(--muted);
    font-weight: 760;
    line-height: 1.25;
  }

  .schedule-gantt__months {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
  }

  .schedule-gantt__row {
    display: grid;
    grid-template-columns: 7rem minmax(0, 1fr);
    gap: 0.5rem;
    align-items: center;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .schedule-gantt__row i {
    display: block;
    height: 0.76rem;
    border-radius: 999px;
  }

  .schedule-gantt__row .current {
    width: 38%;
    margin-left: 12%;
    background: var(--gold);
  }

  .schedule-gantt__row .blocked {
    width: 46%;
    margin-left: 44%;
    border: 2px dashed var(--gold);
    background: transparent;
  }

  .schedule-gantt__row .clear {
    width: 36%;
    margin-left: 44%;
    background: var(--green);
  }

  .schedule-gantt__row .planned {
    width: 48%;
    margin-left: 52%;
    background: color-mix(in srgb, var(--ink) 18%, var(--panel));
  }

  @media (max-width: 820px) {
    .schedule-shell {
      padding-inline: 0.85rem;
    }

    .schedule-hero,
    .schedule-decision,
    .schedule-grid {
      grid-template-columns: 1fr;
    }

    .schedule-mode {
      justify-self: start;
      overflow-x: auto;
    }

    .schedule-decision__actions {
      flex-wrap: wrap;
    }

    .schedule-command {
      grid-template-columns: minmax(0, 1fr) 5.8rem;
    }

    .schedule-grid {
      gap: 0.58rem;
    }
  }
</style>
