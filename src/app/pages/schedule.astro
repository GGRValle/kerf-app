---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import '../styles/lane3work.css';

const { t, context } = createLayoutContext();
---

<Layout titleKey="schedule.title" activeHref="/schedule">
  <section class="schedule-page lane23-page" data-tenant-id={context.tenantId} aria-labelledby="schedule-title">
    <h1 id="schedule-title">{t('schedule.title')}</h1>
    <p class="lane23-notice">{t('schedule.assignment_centric')}</p>
    <Card title={t('schedule.events_title')}>
      <div id="schedule-events-mount">{t('schedule.loading')}</div>
    </Card>
    <p><a href="/team-ops/subs">{t('schedule.link_subs')}</a></p>
  </section>
  <script>
    const tenantId = document.querySelector('[data-tenant-id]')?.getAttribute('data-tenant-id') ?? 'tenant_ggr';
    fetch(`/api/v1/projects/proj_wegrzyn_kitchen/schedule-substrate?tenant_id=${tenantId}`)
      .then((r) => r.json())
      .then((data) => {
        const mount = document.getElementById('schedule-events-mount');
        const rows = (data.crew_assignments ?? []).map(
          (a) =>
            `<div class="lane3w-assign-row"><strong>${a.sub_label}</strong>
              <span>${a.envelope.resource} · ${a.envelope.start.slice(0, 10)} → ${a.envelope.end.slice(0, 10)}</span>
              <span>${a.envelope.location}</span></div>`,
        );
        mount.innerHTML = rows.join('') || '<p>No assignments.</p>';
      });
  </script>
</Layout>
