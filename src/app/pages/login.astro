---
// Crew login surface (Goal B PR-2). When the deploy gate is on, this is a real
// credentialed sign-in that posts to /auth/login and receives the #350 signed
// session cookie — no browser Basic dialog. When the gate is off (local dev),
// it falls back to the role-preview picker so dogfood DX is unchanged.
import Layout from '../layouts/Layout.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { ROLE_ROOT_COOKIE, roleHomePath } from '../lib/roleSession.js';
import {
  isBasicAuthEnabled,
  deployTenantId,
  platformSessionFromShellCookie,
  safeNextPath,
} from '../../shell/shellAuthSession.js';
import type { RoleRoot } from '../lib/layout-props.js';
import type { I18nKey } from '../../i18n/keys.js';

const { t } = createLayoutContext();
const authEnabled = isBasicAuthEnabled();
// A deploy whose BASIC_AUTH_USER is not a known binding can't bind a tenant, so
// crew login can't work — show an honest "unavailable" instead of a form that
// would always error. (The dialog is gone; this prevents a silent lockout.)
const signInAvailable = authEnabled && deployTenantId() !== null;

// Already signed in → go home (don't show login to an authenticated crew member).
const existing = platformSessionFromShellCookie(Astro.request.headers.get('cookie') ?? undefined);
if (existing !== null) {
  return Astro.redirect(safeNextPath(Astro.url.searchParams.get('next')) ?? roleHomePath(existing.roleRoot));
}

const nextParam = safeNextPath(Astro.url.searchParams.get('next')) ?? '';
const hasError = Astro.url.searchParams.get('error') !== null;

const roles: readonly RoleRoot[] = ['owner', 'pm', 'admin_ops', 'field_hand', 'sub'];
const ROLE_LABEL_KEYS: Record<RoleRoot, I18nKey> = {
  owner: 'roleRoot.owner',
  pm: 'roleRoot.pm',
  admin_ops: 'roleRoot.admin_ops',
  field_hand: 'roleRoot.field_hand',
  sub: 'roleRoot.sub',
};
---

<Layout titleKey="login.title" activeHref="/login">
  <section class="login" data-wireframe="F-LND1" data-auth-enabled={authEnabled ? 'true' : 'false'}>
    <h1>{t('login.title')}</h1>
    <p>{authEnabled ? t('login.subtitle_auth') : t('login.subtitle')}</p>

    {signInAvailable ? (
      <form class="login__form" method="POST" action="/auth/login">
        {hasError ? <p class="login__error" role="alert">{t('login.error')}</p> : null}
        <input type="hidden" name="next" value={nextParam} />
        <label class="login__field">
          <span>{t('login.username')}</span>
          <input type="text" name="username" autocomplete="username" autocapitalize="none"
            autocorrect="off" spellcheck="false" required />
        </label>
        <label class="login__field">
          <span>{t('login.password')}</span>
          <input type="password" name="password" autocomplete="current-password" required />
        </label>
        <button type="submit">{t('login.signin')}</button>
      </form>
    ) : authEnabled ? (
      <p class="login__error" role="alert">{t('login.unavailable')}</p>
    ) : (
      <>
        <p class="login__tenant">{t('login.tenant_label')}: tenant_ggr (dogfood)</p>
        <p class="login__dev" role="note">{t('login.dev_note')}</p>
        <form class="login__form" id="login-form">
          <fieldset>
            <legend>{t('shell.role_switcher.aria')}</legend>
            {roles.map((role) => (
              <label class="login__role">
                <input type="radio" name="role" value={role} checked={role === 'owner'} />
                <span>{t(ROLE_LABEL_KEYS[role])}</span>
                <span class="login__path">{roleHomePath(role)}</span>
              </label>
            ))}
          </fieldset>
          <button type="submit">{t('login.continue')}</button>
        </form>
      </>
    )}
  </section>
</Layout>

<script define:vars={{ cookieName: ROLE_ROOT_COOKIE }}>
  // Dev-only role preview — the form is only present when the deploy gate is off.
  const form = document.getElementById('login-form');
  form?.addEventListener('submit', (ev) => {
    ev.preventDefault();
    const data = new FormData(form);
    const role = String(data.get('role') || 'owner');
    document.cookie = `${cookieName}=${encodeURIComponent(role)}; path=/; max-age=2592000; SameSite=Lax`;
    const paths = {
      owner: '/home/owner',
      pm: '/home/pm',
      admin_ops: '/home/admin-ops',
      field_hand: '/home/field',
      sub: '/home/sub',
    };
    window.location.href = paths[role] ?? '/';
  });
</script>

<style>
  .login { max-width: 28rem; }
  .login h1 { margin: 0 0 0.35rem; font-size: 1.25rem; }
  .login p { color: var(--text-muted); }
  .login__tenant { font-size: 0.75rem; letter-spacing: 0.04em; text-transform: uppercase; }
  .login__dev { font-size: 0.8rem; }
  .login__error {
    margin: 0.75rem 0 0;
    padding: 0.6rem 0.75rem;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, #c0392b 45%, var(--border));
    background: color-mix(in srgb, #c0392b 12%, transparent);
    color: var(--text);
    font-size: 0.85rem;
  }
  .login__form { margin: 1rem 0; }
  .login__field { display: grid; gap: 0.3rem; margin: 0 0 0.85rem; }
  .login__field span { font-size: 0.8rem; color: var(--text-muted); }
  .login__field input {
    padding: 0.6rem 0.7rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface, #fff);
    color: inherit;
    font-size: 1rem;
  }
  .login__form fieldset { border: 1px solid var(--border); border-radius: 12px; padding: 1rem; margin: 1rem 0; }
  .login__role { display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 0.5rem; padding: 0.35rem 0; cursor: pointer; }
  .login__path { grid-column: 2; font-size: 0.7rem; color: var(--text-muted); }
  .login__form button {
    width: 100%;
    padding: 0.65rem 1rem;
    border-radius: 10px;
    border: none;
    background: var(--accent);
    color: var(--on-accent, #1a1300);
    font-weight: 600;
    cursor: pointer;
  }
</style>
