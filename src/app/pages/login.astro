---
import LoginSurface from '../components/LoginSurface.astro';
import NavBack from '../components/NavBack.astro';
import { roleHomePath } from '../lib/roleSession.js';
import {
  isBasicAuthEnabled,
  deployTenantId,
  platformSessionFromShellCookie,
  safeNextPath,
} from '../../shell/shellAuthSession.js';

const authEnabled = isBasicAuthEnabled();
const signInAvailable = authEnabled && deployTenantId() !== null;

const existing = platformSessionFromShellCookie(Astro.request.headers.get('cookie') ?? undefined);
if (existing !== null) {
  return Astro.redirect(safeNextPath(Astro.url.searchParams.get('next')) ?? roleHomePath(existing.roleRoot));
}

const nextParam = safeNextPath(Astro.url.searchParams.get('next')) ?? '';
const hasError = Astro.url.searchParams.get('error') !== null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Sign in to Right Hand</title>
    {/* PWA install metadata must be present on login because the installed app enters here before auth. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0A0D11" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Right Hand" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/180.png" />
  </head>
  <body>
    <NavBack href="/" />
    <LoginSurface
      mode="right-hand"
      authEnabled={authEnabled}
      signInAvailable={signInAvailable}
      hasError={hasError}
      nextParam={nextParam}
    />
    <script is:inline>
      // Register from the auth doorway too; the shell pages repeat this after login.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js')
            .then((registration) => registration.update())
            .catch(() => {});
        });
      }
    </script>
  </body>
</html>
