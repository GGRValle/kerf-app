---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Chip from '../../components/Chip.astro';

const { id } = Astro.params;
const packetId = id ?? 'co-wegrzyn-cabinet-wall';
const proofItems = [
  'Field photo: east cabinet wall marked by Marcus',
  'Labor basis: 12 carpenter hours, 4 painter hours',
  'Schedule note: two-day cabinet hold if approved today',
] as const;
---

<Layout titleKey="decisions.detail.title" activeHref="/decisions">
  <section class="decision-detail" aria-labelledby="decision-detail-title">
    <p class="decision-detail__crumb"><a href="/decisions">Back to decisions</a></p>
    <header class="decision-detail__head">
      <p>Decision</p>
      <h1 id="decision-detail-title">Approve the change.</h1>
    </header>

    <Card eyebrow="Owner approval" title="Approve the cabinet wall change?">
      <div class="decision-detail__status">
        <Chip label="Waiting on you" tone="amber" />
        <span>Nothing sends to the client until you approve the final copy.</span>
      </div>
      <dl class="decision-detail__facts">
        <div>
          <dt>Job</dt>
          <dd>Wegrzyn kitchen + primary bath</dd>
        </div>
        <div>
          <dt>Draft amount</dt>
          <dd>$4,850 · two-day schedule hit</dd>
        </div>
        <div>
          <dt>Packet</dt>
          <dd>{packetId}</dd>
        </div>
      </dl>
    </Card>

    <Card eyebrow="Proof" title="What Right Hand used">
      <ul class="decision-detail__proof">
        {proofItems.map((item) => <li>{item}</li>)}
      </ul>
    </Card>

    <Card eyebrow="Learning" title="Good / Fix trains the next draft">
      <div class="decision-detail__learn">
        <button type="button">Good</button>
        <button type="button">Fix</button>
      </div>
      <p class="decision-detail__copy">
        If you tap Fix, Right Hand keeps the correction with this job: what changed,
        which proof was wrong or missing, and how the next estimate or message should read.
      </p>
    </Card>

    <Card eyebrow="Next move" title="Review, adjust, then send">
      <div class="decision-detail__actions">
        <a href="/change-orders/new?decision=co-wegrzyn-cabinet-wall">Edit change order</a>
        <a href="/projects/proj_wegrzyn_kitchen">Open job</a>
        <a href="/relay">Office review cards</a>
      </div>
    </Card>
  </section>
</Layout>

<style>
  .decision-detail {
    display: grid;
    gap: 0.85rem;
  }

  .decision-detail__crumb {
    margin: 0;
    font-size: 0.85rem;
  }

  .decision-detail__head {
    display: grid;
    gap: 0.25rem;
  }

  .decision-detail__head p {
    margin: 0;
    color: var(--text-muted, #5c6670);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .decision-detail__head h1 {
    margin: 0;
    font-size: clamp(1.9rem, 10vw, 3.15rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .decision-detail__crumb a,
  .decision-detail__actions a {
    color: var(--accent, #0f766e);
    text-decoration: none;
    font-weight: 700;
  }

  .decision-detail__status {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.85rem;
    color: var(--text-muted, #5c6670);
  }

  .decision-detail__facts {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .decision-detail__facts div {
    display: grid;
    gap: 0.2rem;
  }

  .decision-detail__facts dt {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted, #5c6670);
  }

  .decision-detail__facts dd {
    margin: 0;
    line-height: 1.4;
  }

  .decision-detail__actions {
    display: grid;
    gap: 0.65rem;
  }

  .decision-detail__proof {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted, #5c6670);
    line-height: 1.4;
  }

  .decision-detail__copy {
    margin: 0.75rem 0 0;
    color: var(--text-muted, #5c6670);
    line-height: 1.4;
  }

  .decision-detail__learn {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .decision-detail__learn button {
    min-height: 2.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    background: var(--surface, #fff);
    color: inherit;
    font: inherit;
    font-weight: 950;
  }

  .decision-detail__learn button:first-child {
    background: color-mix(in srgb, var(--field-green, #0f7a53) 13%, var(--surface, #fff));
    border-color: color-mix(in srgb, var(--field-green, #0f7a53) 42%, var(--border, #d8dee6));
  }

  .decision-detail__learn button:last-child {
    background: color-mix(in srgb, var(--right-hand, #c9a961) 17%, var(--surface, #fff));
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 48%, var(--border, #d8dee6));
  }

  .decision-detail__actions a {
    display: block;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    background: var(--surface, #fff);
  }
</style>
