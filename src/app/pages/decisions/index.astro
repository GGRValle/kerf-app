---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import RhSummary from '../../components/RhSummary.astro';

const decisionLinks = [
  {
    href: '/decisions/sample-decision-packet',
    title: 'Decision packet library',
    detail: 'Inspect the proof shape after a decision is made.',
  },
  {
    href: '/kb-ingestion',
    title: 'Knowledge review',
    detail: 'See staged costs, corrections, and what can be promoted later.',
  },
  {
    href: '/audit/altpkt_proposal_fixture_viewed_owner_review',
    title: 'Audit trail',
    detail: 'Check what proof was used, who approved, and what stayed blocked.',
  },
] as const;
---

<Layout titleKey="decisions.title" activeHref="/decisions">
  <section class="decision-hub" aria-labelledby="decision-hub-title">
    <RhSummary
      headline="Decision records"
      detail="Inspection and learning live here. Day-to-day choices stay inside the job, design, money, or field surface where the work belongs."
      tone="green"
    />

    <Card eyebrow="Knowledge shelf" title="Inspect proof and learning">
      <div class="decision-hub__actions">
        {decisionLinks.map((link) => (
          <a class="decision-hub__action" href={link.href}>
            <span>{link.title}</span>
            <small>{link.detail}</small>
          </a>
        ))}
      </div>
    </Card>

    <Card eyebrow="Boundary" title="Not the daily work queue">
      <p class="decision-hub__copy">
        A tile selection opens in Design. An invoice opens in Money. A field note
        opens in the job or office review. This shelf keeps the proof and learning trail visible afterward.
      </p>
    </Card>
  </section>
</Layout>

<style>
  .decision-hub {
    display: grid;
    gap: 0.85rem;
  }

  .decision-hub__copy {
    margin: 0;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .decision-hub__actions {
    display: grid;
    gap: 0.65rem;
  }

  .decision-hub__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
  }

  .decision-hub__action:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .decision-hub__action span {
    font-weight: 700;
  }

  .decision-hub__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }
</style>
