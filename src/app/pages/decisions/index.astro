---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import RhSummary from '../../components/RhSummary.astro';

const decisionLinks = [
  {
    href: '/decisions/sample-decision-packet',
    title: 'Sample decision packet',
    detail: 'Inspect the approval shape without sending, paying, or filing anything.',
  },
  {
    href: '/proposals/prop_lane6_pass/send',
    title: 'Proposal send gate',
    detail: 'Open the client-send review path and its approval boundary.',
  },
  {
    href: '/relay',
    title: 'Office cards',
    detail: 'Review field captures that currently need a human decision.',
  },
] as const;
---

<Layout titleKey="decisions.title" activeHref="/decisions">
  <section class="decision-hub" aria-labelledby="decision-hub-title">
    <RhSummary
      headline="Decisions"
      detail="This is the review-before-action hub. It points to existing gates and keeps approvals inspectable."
      tone="green"
    />

    <Card eyebrow="Review queue" title="What can be inspected now">
      <div class="decision-hub__actions">
        {decisionLinks.map((link) => (
          <a class="decision-hub__action" href={link.href}>
            <span>{link.title}</span>
            <small>{link.detail}</small>
          </a>
        ))}
      </div>
    </Card>

    <Card eyebrow="Boundary" title="No automatic action">
      <p class="decision-hub__copy">
        Decisions shown here are review surfaces. Money movement, client sends,
        and durable writes still route through their specific gates.
      </p>
    </Card>
  </section>
</Layout>

<style>
  .decision-hub {
    display: grid;
    gap: 0.85rem;
  }

  .decision-hub__copy {
    margin: 0;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .decision-hub__actions {
    display: grid;
    gap: 0.65rem;
  }

  .decision-hub__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
  }

  .decision-hub__action:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .decision-hub__action span {
    font-weight: 700;
  }

  .decision-hub__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }
</style>
