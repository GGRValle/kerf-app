---
// F-EST1 · Estimate builder · /estimate/:projectId (Lane 2)
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import {
  estimateLinesForProject,
  lineBreakdown,
  estimateTotals,
  clientVisibleLines,
  selectionsForProject,
} from '../../../sales/index.js';
import { getRightHandEstimateStore } from '../../../api/lib/rightHandAssemblyStore.js';

const { context } = createLayoutContext();
const tenant = context.tenantId;
const projectId = Astro.params.projectId ?? '';
const rightHandEstimateId = Astro.url.searchParams.get('estimate_id') ?? '';
const rightHandConversationId = Astro.url.searchParams.get('rh_conversation') ?? '';
const rightHandDraft = rightHandEstimateId ? await getRightHandEstimateStore().read(tenant, rightHandEstimateId) : null;
const isLeadStageEstimate = rightHandDraft?.anchor_type === 'deal';
const dealId = rightHandDraft?.deal_id ?? Astro.url.searchParams.get('deal_id') ?? '';
const lines = estimateLinesForProject(tenant, projectId);
const breakdowns = lines.map(lineBreakdown);
const totals = estimateTotals(lines);
const clientLines = clientVisibleLines(lines).map(lineBreakdown);
const approvedCount = selectionsForProject(tenant, projectId).filter((s) => s.lifecycle === 'approved').length;
const fmt = (cents: number) => `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const rhPricedLines = rightHandDraft?.lines.filter((line) => typeof line.extended_cents === 'number' && line.extended_cents > 0) ?? [];
const rhOpenLines = rightHandDraft?.lines.filter((line) => line.open_item || !(typeof line.extended_cents === 'number' && line.extended_cents > 0)) ?? [];
const rhTotalCents = rhPricedLines.filter((line) => !line.flags.includes('removed')).reduce((sum, line) => sum + (line.extended_cents ?? line.price_cents ?? 0), 0);
const rhSuggestedCents = rhPricedLines.filter((line) => !line.flags.includes('removed') && line.flags.includes('suggested')).reduce((sum, line) => sum + (line.extended_cents ?? line.price_cents ?? 0), 0);
const qtyFor = (line: { quantity?: number; uom?: string }) => (
  typeof line.quantity === 'number' && line.uom ? `${line.quantity.toLocaleString('en-US')} ${line.uom}` : ''
);
---

<Layout title="Estimate builder" activeHref="/sales">
  <article class="es-page" data-project={projectId} data-project-id={projectId} data-deal-id={dealId} data-rh-conversation={rightHandConversationId}>
    <a class="es-back" href={isLeadStageEstimate && dealId ? `/sales/${dealId}` : `/design/${projectId}`}>{isLeadStageEstimate ? '‹ Deal' : '‹ Design'}</a>
    <header>
      <div class="es-crumb">{isLeadStageEstimate ? 'LEAD' : 'Estimate'} · {rightHandDraft ? rightHandDraft.title.replace(/\s*estimate draft$/i, '') : (isLeadStageEstimate && dealId ? dealId : projectId)}{isLeadStageEstimate ? ' · estimating' : ''}</div>
      <h1>Estimate builder</h1>
      <p class="es-sub">Operator total = client total. Markup is folded into the price, never shown to the client.</p>
    </header>

    {rightHandDraft ? (
      <section class="es-rh-draft" aria-label="Right Hand assembly draft">
        <div class="es-rh-head">
          <div>
            <div class="es-crumb">Right Hand assembly · draft for review</div>
            <h2>{rightHandDraft.title}</h2>
            <p class="es-meta">Source-labeled lead-stage estimate. Not filed, not sent, not a project, and not money-authoritative until you review and confirm.</p>
            <p class="es-seed-label">{rightHandDraft.pricing_data_label}</p>
            <p class="es-meta">Policy gate fired · {rightHandDraft.gate.allowed ? 'draft allowed' : `downstream action blocked: ${rightHandDraft.gate.blocked_reasons.join(', ') || 'review required'}`}</p>
          </div>
          <a class="es-rh-bubble" href={`/right-hand?conversation_id=${rightHandDraft.conversation_id}&return_to=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`}>
            Back to conversation
          </a>
        </div>
                {rightHandDraft.open_items.length > 0 ? (
          <div class="es-rh-open">
            <strong>Open items</strong>
            {rightHandDraft.open_items.slice(0, 5).map((item) => <span>{item}</span>)}
            {rightHandDraft.open_items.length > 5 ? (
              <details class="es-rh-open-more">
                <summary>Show all ({rightHandDraft.open_items.length})</summary>
                {rightHandDraft.open_items.slice(5).map((item) => <span>{item}</span>)}
              </details>
            ) : null}
          </div>
        ) : null}
      </section>
    ) : null}

    <details class="es-editor">
      <summary>Add or adjust lines</summary>
    <div class="es-toolbar">
      <button class="es-btn" id="seed" data-approved={approvedCount}>Seed from approved Selections ({approvedCount})</button>
      <button class="es-btn" id="add-toggle">+ Add line</button>
    </div>

    <form class="es-add" id="add-form" hidden>
      <input id="ln-label" placeholder="Label" />
      <select id="ln-type">
        <option value="material">material</option>
        <option value="labor">labor</option>
        <option value="product">product</option>
        <option value="allowance">allowance</option>
        <option value="subcontract">subcontract</option>
        <option value="equipment">equipment</option>
        <option value="fee">fee</option>
        <option value="markup">markup (internal)</option>
      </select>
      <input id="ln-qty" type="number" step="0.01" min="0" value="1" placeholder="Qty" />
      <input id="ln-cost" type="number" step="1" min="0" placeholder="Unit cost (cents)" />
      <input id="ln-markup" type="number" step="1" min="0" value="3000" placeholder="Markup bps" />
      <button class="es-btn primary" id="add-go" type="button">Add</button>
    </form>
    </details>

    <!-- Operator view: cost + markup + client price -->
    <section class="es-table">
      <h2>Operator view</h2>
      {rightHandDraft ? (
        <>
          {rhPricedLines.length === 0 ? <p class="es-empty">Right Hand captured the scope, but the draft still needs pricing.</p> : null}
          {rhPricedLines.filter((line) => !line.flags.includes('removed') && !line.flags.includes('suggested')).map((line) => (
            <div class="es-row" data-line-id={line.id}>
              <span class="es-ln-label">
                {line.label}
                <span class={`es-source ${line.source_type}`}>{line.source_label}</span>
                {line.division ? <span class="es-tag">{line.division.code} · {line.division.label}</span> : null}
                {line.cost_code ? <span class="es-tag">{line.cost_code}</span> : null}
                {line.matched_by ? <span class="es-tag es-match">{line.matched_by === 'line_id' ? 'exact' : 'matched'}</span> : null}
                {line.flags.includes('operator_edited') ? <span class="es-tag es-edited">edited</span> : null}
              </span>
              <span class="es-ln-num">{qtyFor(line)}</span>
              <span class="es-ln-num">{typeof line.unit_cents === 'number' ? fmt(line.unit_cents) + '/' + (line.uom ?? 'unit') : ''}</span>
              <span class="es-ln-num strong">{fmt(line.extended_cents ?? 0)}</span>
              <span class="es-ln-edit">
                <button class="es-btn es-btn-mini" type="button" data-edit-line={line.id} data-qty={line.quantity ?? ''} data-unit={line.unit_cents ?? ''}>Edit</button>
              </span>
            </div>
          ))}
          {rhPricedLines.some((line) => line.flags.includes('suggested') && !line.flags.includes('removed')) ? (
            <div class="es-suggested">
              <h3>Suggested for this scope — keep or remove</h3>
              {rhPricedLines.filter((line) => line.flags.includes('suggested') && !line.flags.includes('removed')).map((line) => (
                <div class="es-row es-row-suggested" data-line-id={line.id}>
                  <span class="es-ln-label">
                    {line.label}
                    <span class="es-tag es-suggested-tag">Suggested</span>
                    {line.division ? <span class="es-tag">{line.division.code} · {line.division.label}</span> : null}
                    {line.cost_code ? <span class="es-tag">{line.cost_code}</span> : null}
                  </span>
                  <span class="es-ln-num">{qtyFor(line)}</span>
                  <span class="es-ln-num">{typeof line.unit_cents === 'number' ? fmt(line.unit_cents) + '/' + (line.uom ?? 'unit') : ''}</span>
                  <span class="es-ln-num strong">{fmt(line.extended_cents ?? 0)}</span>
                  <span class="es-ln-edit"><button class="es-btn es-btn-mini" type="button" data-remove-suggested={line.id}>Remove</button></span>
                </div>
              ))}
            </div>
          ) : null}
          {rhPricedLines.some((line) => line.flags.includes('removed')) ? (
            <div class="es-removed-row">
              Removed ({rhPricedLines.filter((line) => line.flags.includes('removed')).length})
              {rhPricedLines.filter((line) => line.flags.includes('removed')).map((line) => (
                <button class="es-btn es-btn-mini" type="button" data-restore-line={line.id}>restore {line.label.slice(0, 24)}</button>
              ))}
            </div>
          ) : null}
          <div class="es-totals">
            <span class="strong">Operator total {fmt(rhTotalCents)}{rhSuggestedCents > 0 ? <span class="es-suggested-split"> — includes {fmt(rhSuggestedCents)} suggested, review</span> : null}</span>
            <span class={rightHandDraft.gate.allowed ? 'es-recon ok' : 'es-recon bad'}>
              {rightHandDraft.gate.allowed ? 'review-ready' : 'source basis required before file/send'}
            </span>
          </div>
        </>
      ) : (
        <>
          {breakdowns.length === 0 ? <p class="es-empty">No lines yet. Seed from approved Selections or add a line.</p> : null}
          {breakdowns.map((b) => (
            <div class="es-row" data-internal={b.line.client_visible ? 'false' : 'true'}>
              <span class="es-ln-label">{b.line.label} <span class="es-tag">{b.line.line_type}</span>{b.line.client_visible ? null : <span class="es-tag internal">internal</span>}</span>
              <span class="es-ln-num">cost {fmt(b.extended_cost_cents)}</span>
              <span class="es-ln-num">+mkup {fmt(b.markup_cents)}</span>
              <span class="es-ln-num strong">{fmt(b.client_price_cents)}</span>
            </div>
          ))}
          <div class="es-totals">
            <span>Cost {fmt(totals.cost_cents)}</span>
            <span>Markup {fmt(totals.markup_cents)}</span>
            <span class="strong">Operator total {fmt(totals.operator_total_cents)}</span>
            <span class={totals.reconciles ? 'es-recon ok' : 'es-recon bad'}>
              {totals.reconciles ? '✓ reconciles' : '✗ does not reconcile'}
            </span>
          </div>
        </>
      )}
    </section>

    {rightHandDraft && rhOpenLines.length > 0 ? (
      <section class="es-table es-open-items">
        <h2>Needs pricing or confirmation</h2>
        {rhOpenLines.map((line) => (
          <div class="es-row">
            <span class="es-ln-label">
              {line.label}
              <span class={`es-source ${line.source_type}`}>{line.source_label}</span>
              {line.division ? <span class="es-tag">{line.division.code} · {line.division.label}</span> : null}
              {line.cost_code ? <span class="es-tag">{line.cost_code}</span> : null}
            </span>
            <span class="es-ln-num strong">TBD</span>
          </div>
        ))}
      </section>
    ) : null}

    <!-- Client view: prices only; markup never appears -->
    <details class="es-client-toggle">
      <summary>Show client view <span class="es-meta">(what the client sees — no cost, no markup)</span></summary>
    <section class="es-table es-client">
      {rightHandDraft ? rhPricedLines.map((line) => (
          <div class="es-row">
            <span class="es-ln-label">{line.label}</span>
            <span class="es-ln-num strong">{fmt(line.extended_cents ?? 0)}</span>
          </div>
        )) : clientLines.map((b) => (
          <div class="es-row">
            <span class="es-ln-label">{b.line.label}</span>
            <span class="es-ln-num strong">{fmt(b.client_price_cents)}</span>
          </div>
        ))}
      <div class="es-totals">
        <span class="strong">Total {fmt(rightHandDraft ? rhTotalCents : totals.client_total_cents)}</span>
      </div>
    </section>
    </details>

    <section class="es-propose">
      <button class="es-btn primary" id="gen-proposal" disabled={rightHandDraft ? rhPricedLines.length === 0 || !rightHandDraft.gate.allowed : breakdowns.length === 0}>Generate proposal draft ›</button>
      <p class="es-meta">Drafts only. Kerf never auto-sends — sending is a separate, human-gated step.</p>
      <div id="draft-result" class="es-draft" hidden></div>
    </section>
  </article>
</Layout>

<script>
  const root = document.querySelector('.es-page');
  const projectId = root?.getAttribute('data-project') ?? '';
  const rhConversation = root?.getAttribute('data-rh-conversation') ?? '';
  if (rhConversation) {
    window.sessionStorage.setItem('kerf.voiceConversationId', rhConversation);
    window.localStorage.setItem('kerf.voiceConversationId', rhConversation);
  }

  async function post(url: string, body: Record<string, unknown>, confirmMsg: string) {
    if (!confirm(confirmMsg)) return null;
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ confirmed: true, ...body }),
    });
    if (!res.ok) { alert('Failed (' + res.status + '): ' + (await res.text())); return null; }
    return res.json();
  }

  // Lead-first card Part 5: tap-edit qty / unit override / remove-restore.
  // D-065 rung-0: server copies tier/source/gate untouched; edits never graduate.
  const estimateIdParam = new URLSearchParams(window.location.search).get('estimate_id') ?? '';
  async function patchLine(lineId: string, body: Record<string, unknown>): Promise<boolean> {
    const res = await fetch(`/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/lines/${encodeURIComponent(lineId)}`, {
      method: 'PATCH',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    if (!res.ok) { alert('Edit failed (' + res.status + '): ' + (await res.text())); return false; }
    return true;
  }
  document.querySelectorAll<HTMLButtonElement>('[data-edit-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-edit-line') ?? '';
      const currentQty = btn.getAttribute('data-qty') ?? '';
      const currentUnit = btn.getAttribute('data-unit') ?? '';
      const qtyRaw = prompt('Quantity (blank = keep, r = remove line):', currentQty);
      if (qtyRaw === null) return;
      if (qtyRaw.trim().toLowerCase() === 'r') {
        if (await patchLine(lineId, { removed: true })) window.location.reload();
        return;
      }
      const unitRaw = prompt('Unit price in dollars (blank = keep):', currentUnit ? String(Number(currentUnit) / 100) : '');
      if (unitRaw === null) return;
      const body: Record<string, unknown> = {};
      if (qtyRaw.trim()) body['quantity'] = Number(qtyRaw);
      if (unitRaw.trim()) body['unit_cents'] = Math.round(Number(unitRaw) * 100);
      if (Object.keys(body).length === 0) return;
      if (Number.isNaN(body['quantity'] as number) || Number.isNaN(body['unit_cents'] as number)) { alert('Numbers only.'); return; }
      if (await patchLine(lineId, body)) window.location.reload();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-remove-suggested]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-remove-suggested') ?? '';
      if (await patchLine(lineId, { removed: true })) window.location.reload();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-restore-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-restore-line') ?? '';
      if (await patchLine(lineId, { removed: false })) window.location.reload();
    });
  });

  document.getElementById('seed')?.addEventListener('click', async () => {
    const out = await post(`/api/v1/estimate/${projectId}/seed-from-selections`, {}, 'Create estimate lines from approved Selections?');
    if (out) window.location.reload();
  });

  document.getElementById('add-toggle')?.addEventListener('click', () => {
    const f = document.getElementById('add-form') as HTMLElement;
    f.hidden = !f.hidden;
  });

  document.getElementById('add-go')?.addEventListener('click', async () => {
    const label = (document.getElementById('ln-label') as HTMLInputElement).value.trim();
    const line_type = (document.getElementById('ln-type') as HTMLSelectElement).value;
    const quantity = parseFloat((document.getElementById('ln-qty') as HTMLInputElement).value || '1');
    const unit_cost_cents = parseInt((document.getElementById('ln-cost') as HTMLInputElement).value || '', 10);
    const markup_bps = parseInt((document.getElementById('ln-markup') as HTMLInputElement).value || '0', 10);
    if (!label || !Number.isInteger(unit_cost_cents)) { alert('Label and integer cents cost required.'); return; }
    const client_visible = line_type !== 'markup';
    const out = await post(`/api/v1/estimate/${projectId}/lines`, { label, line_type, quantity, unit_cost_cents, markup_bps, client_visible }, `Add line "${label}"?`);
    if (out) window.location.reload();
  });

  document.getElementById('gen-proposal')?.addEventListener('click', async () => {
    const out = await post(`/api/v1/estimate/${projectId}/generate-proposal`, {}, 'Generate a proposal draft from this estimate?');
    if (out) {
      const el = document.getElementById('draft-result') as HTMLElement;
      el.hidden = false;
      el.innerHTML = `<strong>Draft created.</strong> ${out.attention.headline}.
        <br/>Total $${(out.draft.client_total_cents / 100).toFixed(2)} · send requires your review
        <br/><a href="${out.draft.surface_route}">Open proposal draft ›</a>`;
    }
  });
</script>

<style>
  .es-page { padding: 1rem; max-width: 820px; }
  .es-back { color: var(--text-muted, #98a1b3); text-decoration: none; font-size: 0.85rem; }
  .es-crumb { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted, #6a7282); margin-top: 0.6rem; }
  .es-sub { color: var(--text-muted, #98a1b3); }
  .es-toolbar { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 0.8rem 0; }
  .es-btn { padding: 0.5rem 0.85rem; border: 1px solid var(--border, #2a3140); border-radius: 8px; background: var(--bg, #0a0d11); color: var(--text, #e8edf4); cursor: pointer; font: inherit; }
  .es-btn.primary { background: var(--field-green, #2f8f5b); border-color: transparent; color: #fff; }
  .es-btn[disabled] { opacity: 0.5; cursor: default; }
  .es-add { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .es-add input, .es-add select { padding: 0.45rem; border: 1px solid var(--border, #2a3140); border-radius: 8px; background: var(--bg, #0a0d11); color: var(--text, #e8edf4); font: inherit; }
  .es-table { border: 1px solid var(--border, #2a3140); border-radius: 12px; padding: 0.75rem; background: var(--surface, #11151c); margin-bottom: 1rem; }
  .es-table h2 { font-size: 0.95rem; margin: 0 0 0.6rem; }
  .es-row { display: flex; justify-content: space-between; gap: 0.6rem; padding: 0.4rem 0; border-bottom: 1px solid var(--border, #222a36); }
  .es-row[data-internal='true'] { opacity: 0.85; }
  .es-ln-label { flex: 1 1 auto; }
  .es-ln-num { font-variant-numeric: tabular-nums; font-size: 0.85rem; color: var(--text-muted, #98a1b3); white-space: nowrap; }
  .es-ln-num.strong, .strong { color: var(--text, #e8edf4); font-weight: 700; }
  .es-tag { font-size: 0.65rem; padding: 0.05rem 0.35rem; border: 1px solid var(--border, #2a3140); border-radius: 999px; margin-left: 0.3rem; color: var(--text-muted, #98a1b3); }
  .es-tag.internal { color: var(--accent, #f5b544); border-color: var(--accent, #f5b544); }
  .es-totals { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.6rem; padding-top: 0.5rem; border-top: 2px solid var(--border, #2a3140); font-variant-numeric: tabular-nums; }
  .es-recon.ok { color: var(--field-green, #38c977); }
  .es-recon.bad { color: #f87171; }
  .es-client { border-color: var(--field-green, #2f8f5b); }
  .es-meta { font-size: 0.75rem; color: var(--text-muted, #6a7282); font-weight: 400; }
  .es-seed-label { display: inline-block; margin: 0.15rem 0; padding: 0.2rem 0.45rem; border: 1px solid var(--accent, #f5b544); border-radius: 999px; color: var(--accent, #f5b544); font-size: 0.72rem; }
  .es-propose { margin-top: 0.5rem; }
  .es-draft { margin-top: 0.7rem; padding: 0.7rem; border: 1px solid var(--field-green, #2f8f5b); border-radius: 10px; background: var(--surface, #11151c); }
  .es-empty { color: var(--text-muted, #6a7282); }
  .es-rh-draft { border: 1px solid var(--field-green, #2f8f5b); border-radius: 8px; padding: 0.85rem; background: color-mix(in srgb, var(--surface, #11151c) 88%, var(--field-green, #2f8f5b)); margin: 1rem 0; }
  .es-rh-head { display: flex; gap: 1rem; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; }
  .es-rh-head h2 { margin: 0.15rem 0 0.25rem; font-size: 1.05rem; }
  .es-rh-bubble { position: sticky; top: 0.75rem; display: inline-flex; align-items: center; min-height: 2.25rem; padding: 0.45rem 0.7rem; border-radius: 999px; background: var(--field-green, #2f8f5b); color: #fff; text-decoration: none; font-weight: 700; white-space: nowrap; }
  .es-rh-lines { margin-top: 0.7rem; border-top: 1px solid var(--border, #2a3140); }
  .es-rh-line { display: flex; justify-content: space-between; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid var(--border, #222a36); }
  .es-rh-line[data-open='true'] { background: color-mix(in srgb, var(--accent, #f5b544) 10%, transparent); }
  .es-source { font-size: 0.65rem; padding: 0.05rem 0.35rem; border: 1px solid currentColor; border-radius: 999px; margin-left: 0.3rem; }
  .es-source.company_data { color: var(--field-green, #38c977); }
  .es-source.model_knowledge { color: #60a5fa; }
  .es-source.allowance { color: var(--accent, #f5b544); }
  .es-tag.pending { color: var(--accent, #f5b544); border-color: var(--accent, #f5b544); }
  .es-rh-open { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-top: 0.75rem; color: var(--text-muted, #98a1b3); font-size: 0.8rem; }
  .es-rh-open span { border: 1px solid var(--border, #2a3140); border-radius: 999px; padding: 0.1rem 0.45rem; }
</style>
