---
// F-EST1 · Estimate builder · /estimate/:projectId (Lane 2)
import Layout from '../../layouts/Layout.astro';
import PhaseStrip from '../../components/PhaseStrip.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import {
  estimateLinesForProject,
  loadSalesStore,
  lineBreakdown,
  estimateTotals,
  clientVisibleLines,
  selectionsForProject,
} from '../../../sales/index.js';
import { getRightHandEstimateStore } from '../../../api/lib/rightHandAssemblyStore.js';
import { evaluateEstimateArtifactAction } from '../../../api/lib/estimateArtifactActions.js';
import {
  operatorFacingBlockedReasons,
  operatorFacingPricingLabel,
} from '../../lib/operatorFacingReasons.js';

const { context } = createLayoutContext();
const tenant = context.tenantId;
const projectId = Astro.params.projectId ?? '';
const rightHandEstimateId = Astro.url.searchParams.get('estimate_id') ?? '';
const rightHandConversationId = Astro.url.searchParams.get('rh_conversation') ?? '';
const rightHandDraft = rightHandEstimateId ? await getRightHandEstimateStore().read(tenant, rightHandEstimateId) : null;
const isLeadStageEstimate = rightHandDraft?.anchor_type === 'deal';
const dealId = rightHandDraft?.deal_id ?? Astro.url.searchParams.get('deal_id') ?? '';
await loadSalesStore(tenant);
const lines = estimateLinesForProject(tenant, projectId);
const breakdowns = lines.map(lineBreakdown);
const totals = estimateTotals(lines);
const clientLines = clientVisibleLines(lines).map(lineBreakdown);
const approvedCount = selectionsForProject(tenant, projectId).filter((s) => s.lifecycle === 'approved').length;
const fmt = (cents: number) => `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const unitFor = (line: { uom?: string }) => line.uom ?? 'unit';
const rhPricedLines = rightHandDraft?.lines.filter((line) => typeof line.extended_cents === 'number' && line.extended_cents > 0) ?? [];
const rhOpenLines = rightHandDraft?.lines.filter((line) => line.open_item || !(typeof line.extended_cents === 'number' && line.extended_cents > 0)) ?? [];
const rhTotalCents = rhPricedLines.filter((line) => !line.flags.includes('removed')).reduce((sum, line) => sum + (line.extended_cents ?? line.price_cents ?? 0), 0);
const qtyFor = (line: { quantity?: number; uom?: string }) => (
  typeof line.quantity === 'number' && line.uom ? `${line.quantity.toLocaleString('en-US')} ${line.uom}` : ''
);
const rhActiveLines = rhPricedLines.filter((line) => !line.flags.includes('removed'));
const rhRemovedLines = rhPricedLines.filter((line) => line.flags.includes('removed'));
const rhGraduableLines = rhActiveLines.filter((line) => line.source_type !== 'company_data');
// One estimate review: every active priced line (incl. Right Hand suggestions),
// grouped by trade. Suggested lines carry a Needs-review chip + inline Remove.
const rhLineGroups = Array.from(rhActiveLines.reduce((groups, line) => {
  const code = line.division?.code ?? 'ZZ';
  const label = line.division?.label ?? 'Unassigned';
  const key = `${code}::${label}`;
  const current = groups.get(key) ?? { code, label, subtotal: 0, lines: [] as typeof rhActiveLines };
  current.subtotal += line.extended_cents ?? line.price_cents ?? 0;
  current.lines.push(line);
  groups.set(key, current);
  return groups;
}, new Map<string, { code: string; label: string; subtotal: number; lines: typeof rhActiveLines }>()).values())
  .sort((a, b) => a.code.localeCompare(b.code));
const gateStatus = rightHandDraft?.gate.allowed
  ? 'Ready for review'
  : 'Draft only - approve rates first';
const gateDetail = rightHandDraft?.gate.allowed
  ? 'Nothing has been filed or sent.'
  : `Proposal and invoice stay blocked. ${operatorFacingBlockedReasons(rightHandDraft?.gate.blocked_reasons ?? [])}`;
const pricingDataLabel = rightHandDraft ? operatorFacingPricingLabel(rightHandDraft.pricing_data_label) : '';
const proposalAction = rightHandDraft
  ? evaluateEstimateArtifactAction({ draft: rightHandDraft, intent: 'proposal_draft', now: new Date() })
  : null;
const invoiceAction = rightHandDraft
  ? evaluateEstimateArtifactAction({ draft: rightHandDraft, intent: 'down_payment_invoice', now: new Date() })
  : null;
const moneyRoute = rightHandDraft
  ? `/estimate/${encodeURIComponent(rightHandDraft.project_id)}/money?estimate_id=${encodeURIComponent(rightHandDraft.estimate_id)}${rightHandDraft.conversation_id ? `&rh_conversation=${encodeURIComponent(rightHandDraft.conversation_id)}` : ''}`
  : null;
const estimateTitle = rightHandDraft
  ? rightHandDraft.title.replace(/\s*estimate draft$/i, '')
  : (isLeadStageEstimate && dealId ? dealId : projectId);
const moneyFlowPhases = rightHandDraft ? [
  { id: 'estimate', label: 'Estimate', active: true },
  ...(proposalAction?.route ? [{ id: 'proposal', label: 'Proposal', href: proposalAction.route }] : [{ id: 'proposal', label: 'Proposal' }]),
  ...(invoiceAction?.route ? [{ id: 'invoice', label: 'Invoice', href: invoiceAction.route }] : [{ id: 'invoice', label: 'Invoice' }]),
  ...(moneyRoute && invoiceAction?.status === 'ready_for_review' ? [{ id: 'money', label: 'Money', href: moneyRoute }] : [{ id: 'money', label: 'Money' }]),
] : null;
---

<Layout title="Estimate builder" activeHref="/sales" surfaceContext={{ surface: 'estimate', project_id: projectId, estimate_id: rightHandDraft?.estimate_id ?? (rightHandEstimateId || undefined), line_ids: rightHandDraft?.lines.map((line) => line.id) ?? lines.map((line) => line.id), phase: 'draft' }}>
  <article class="es-page" data-grammar="canon" data-project={projectId} data-project-id={projectId} data-deal-id={dealId} data-rh-conversation={rightHandConversationId}>
    <a class="es-back" href={isLeadStageEstimate && dealId ? `/sales/${dealId}` : `/design/${projectId}`}>{isLeadStageEstimate ? '‹ Deal' : '‹ Design'}</a>
    <header class="es-hero">
      <div class="es-crumb">{isLeadStageEstimate ? 'Lead estimate' : 'Estimate'}{isLeadStageEstimate ? ' · estimating' : ''}</div>
      <h1>{estimateTitle}</h1>
      <p class="es-sub">Review the draft, adjust quantities or rates, then decide what becomes official.</p>
    </header>
    {moneyFlowPhases ? <PhaseStrip phases={moneyFlowPhases} /> : null}

    {rightHandDraft ? (
      <section class="es-rh-draft kg-card" aria-label="Right Hand assembly draft">
        <div class="es-rh-summary">
          <div class="es-total-card">
            <span class="es-kicker">Draft total</span>
            <strong>{fmt(rhTotalCents)}</strong>
          </div>
          <div class="es-stat-card">
            <span class="es-kicker">Priced lines</span>
            <strong>{rhActiveLines.length}</strong>
          </div>
          <div class="es-stat-card">
            <span class="es-kicker">Open items</span>
            <strong>{rightHandDraft.open_items.length}</strong>
          </div>
        </div>

        <div class="es-rh-status" data-allowed={rightHandDraft.gate.allowed ? 'true' : 'false'}>
          <div>
            <span class="es-sr-only">Safety check ran</span>
            <strong>{gateStatus}</strong>
            <span>{gateDetail}</span>
          </div>
          <span>{pricingDataLabel}</span>
        </div>

        <div class="es-rh-actions" aria-label="Estimate actions">
          <a class="es-btn primary" href={`/right-hand?conversation_id=${rightHandDraft.conversation_id}&return_to=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`} data-rh-speak>
            Back to conversation
          </a>
          <a class="es-btn" href={`/api/v1/right-hand/estimates/${encodeURIComponent(rightHandEstimateId)}/workbook`} download>Download workbook</a>
          <label class="es-btn es-wb-import">Import workbook<input id="wb-import" type="file" accept=".xlsx" hidden /></label>
          {rhGraduableLines.length > 0 ? (
            <button class="es-btn" type="button" id="rh-use-here-all">Confirm all</button>
          ) : null}
        </div>

        {rightHandDraft.open_items.length > 0 ? (
          <div class="es-rh-open" aria-label="Open questions">
            <strong>Open items</strong>
            {rightHandDraft.open_items.slice(0, 5).map((item) => <span>{item}</span>)}
            {rightHandDraft.open_items.length > 5 ? (
              <details class="es-rh-open-more">
                <summary>Show all ({rightHandDraft.open_items.length})</summary>
                {rightHandDraft.open_items.slice(5).map((item) => <span>{item}</span>)}
              </details>
            ) : null}
          </div>
        ) : null}
      </section>
    ) : null}

    <details class="es-editor es-control-panel kg-card">
      <summary>Add or adjust lines</summary>
    <div class="es-toolbar">
      <button class="es-btn" id="seed" data-approved={approvedCount}>Seed from approved Selections ({approvedCount})</button>
      <button class="es-btn" id="add-toggle">+ Add line</button>
    </div>

    <form class="es-add" id="add-form" hidden>
      <label class="es-field es-field-wide" for="ln-label">
        <span>Line item</span>
        <input id="ln-label" placeholder="Demolition labor, tile material, permit fee..." />
      </label>
      <label class="es-field" for="ln-type">
        <span>Type</span>
        <select id="ln-type">
          <option value="material">Material</option>
          <option value="labor">Labor</option>
          <option value="product">Product</option>
          <option value="allowance">Allowance</option>
          <option value="subcontract">Subcontractor</option>
          <option value="equipment">Equipment</option>
          <option value="fee">Fee</option>
          <option value="markup">Markup (internal)</option>
        </select>
      </label>
      <label class="es-field" for="ln-qty">
        <span>Quantity</span>
        <input id="ln-qty" type="number" step="0.01" min="0" value="1" placeholder="1" aria-describedby="ln-qty-help" />
        <small id="ln-qty-help">How many units.</small>
      </label>
      <label class="es-field" for="ln-uom">
        <span>Unit</span>
        <select id="ln-uom" aria-describedby="ln-uom-help">
          <option value="EA">EA · each</option>
          <option value="HR">HR · hour</option>
          <option value="LS">LS · lump sum</option>
          <option value="SF">SF · square foot</option>
          <option value="LF">LF · linear foot</option>
          <option value="DAY">DAY</option>
        </select>
        <small id="ln-uom-help">What the quantity counts.</small>
      </label>
      <label class="es-field" for="ln-cost">
        <span>Unit cost</span>
        <input id="ln-cost" type="text" inputmode="decimal" placeholder="$0.00" aria-describedby="ln-cost-help" />
        <small id="ln-cost-help">Dollar cost per selected unit.</small>
      </label>
      <label class="es-field" for="ln-markup">
        <span>Markup</span>
        <input id="ln-markup" type="number" step="0.1" min="0" value="30" placeholder="Markup %" />
      </label>
      <button class="es-btn primary" id="add-go" type="button">Add</button>
    </form>
    </details>

    <!-- Operator view: cost + markup + client price -->
    <section class="es-table es-lines-section kg-card">
      <div class="es-section-head">
        <div>
          <h2>Included lines</h2>
          <p class="es-meta">Grouped by trade division. Tap Edit to adjust this draft only.</p>
        </div>
        {rightHandDraft ? <span class="kg-chip green">{fmt(rhTotalCents)}</span> : null}
      </div>
      {rightHandDraft ? (
        <>
          {rhActiveLines.length === 0 ? <p class="es-empty">Right Hand captured the scope, but the draft still needs pricing.</p> : null}
          {rhLineGroups.map((group) => (
            <section class="es-division" aria-label={group.label}>
              <div class="es-division-head">
                <span>{group.label}</span>
                <strong>{fmt(group.subtotal)}</strong>
              </div>
              {group.lines.map((line) => (
                <article class="es-line-card" data-line-id={line.id}>
                  <div class="es-line-main">
                    <h3>{line.label}</h3>
                    <strong>{fmt(line.extended_cents ?? 0)}</strong>
                  </div>
                  <div class="es-line-math">
                    <span>{qtyFor(line) || 'Needs quantity'}</span>
                    <span>{typeof line.unit_cents === 'number' ? `${fmt(line.unit_cents)}/${line.uom ?? 'unit'}` : 'Needs rate'}</span>
                    <button class="es-btn es-btn-mini" type="button" data-edit-line={line.id} data-qty={line.quantity ?? ''} data-unit={line.unit_cents ?? ''}>Edit</button>
                    {line.source_type !== 'company_data' ? (
                      <button class="es-btn es-btn-mini" type="button" data-use-here-line={line.id}>Confirm</button>
                    ) : (
                      <button class="es-btn es-btn-mini" type="button" data-save-standard-line={line.id}>Save as standard</button>
                    )}
                    {line.flags.includes('suggested') ? (
                      <button class="es-btn es-btn-mini" type="button" data-remove-suggested={line.id}>Remove</button>
                    ) : null}
                  </div>
                  <div class="es-line-meta">
                    <span class={`es-source ${line.source_type}`}>{line.source_label}</span>
                    {(line.source_type !== 'company_data' && !line.flags.includes('approved_for_this_estimate')) || line.flags.includes('suggested') ? <span class="es-tag es-needs-review">Needs review</span> : null}
                    {line.matched_by ? <span class="es-tag es-match">{line.matched_by === 'line_id' ? 'exact match' : 'matched'}</span> : null}
                    {line.flags.includes('operator_edited') ? <span class="es-tag es-edited">edited</span> : null}
                    {line.flags.includes('approved_for_this_estimate') ? <span class="es-tag es-approved">approved here</span> : null}
                  </div>
                </article>
              ))}
            </section>
          ))}
          {rhRemovedLines.length > 0 ? (
            <details class="es-removed-row">
              <summary>Removed lines ({rhRemovedLines.length})</summary>
              <div class="es-restore-list">
                {rhRemovedLines.map((line) => (
                  <button class="es-btn es-btn-mini" type="button" data-restore-line={line.id}>Restore {line.label.slice(0, 32)}</button>
                ))}
              </div>
            </details>
          ) : null}
        </>
      ) : (
        <>
          {breakdowns.length === 0 ? <p class="es-empty">No lines yet. Seed from approved Selections or add a line.</p> : null}
          {breakdowns.map((b) => (
            <div class="es-row" data-internal={b.line.client_visible ? 'false' : 'true'}>
              <span class="es-ln-label">{b.line.label} <span class="es-tag">{b.line.line_type}</span>{b.line.client_visible ? null : <span class="es-tag internal">internal</span>}</span>
              <span class="es-ln-num">{b.line.quantity.toLocaleString('en-US')} {unitFor(b.line)} × {fmt(b.line.unit_cost_cents)}/{unitFor(b.line)}</span>
              <span class="es-ln-num">cost {fmt(b.extended_cost_cents)}</span>
              <span class="es-ln-num">+mkup {fmt(b.markup_cents)}</span>
              <span class="es-ln-num strong">{fmt(b.client_price_cents)}</span>
            </div>
          ))}
          <div class="es-totals">
            <span>Cost {fmt(totals.cost_cents)}</span>
            <span>Markup {fmt(totals.markup_cents)}</span>
            <span class="strong">Operator total {fmt(totals.operator_total_cents)}</span>
            <span class={totals.reconciles ? 'es-recon ok' : 'es-recon bad'}>
              {totals.reconciles ? '✓ reconciles' : '✗ does not reconcile'}
            </span>
          </div>
        </>
      )}
    </section>

    {rightHandDraft && rhOpenLines.length > 0 ? (
      <section class="es-table es-open-items kg-card">
        <div class="es-section-head">
          <div>
            <h2>Needs pricing or confirmation</h2>
            <p class="es-meta">These stay out of the total until you choose a rate, quantity, or scope answer.</p>
          </div>
          <span class="kg-chip green">{rhOpenLines.length}</span>
        </div>
        <div class="es-open-list">
          {rhOpenLines.map((line) => (
            <article class="es-open-card">
              <span>{line.label}</span>
              <div>
                <span class={`es-source ${line.source_type}`}>{line.source_label}</span>
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    <!-- Client view: prices only; markup never appears -->
    <details class="es-client-toggle kg-card">
      <summary>Show client view <span class="es-meta">(what the client sees — no cost, no markup)</span></summary>
    <section class="es-table es-client">
      {rightHandDraft ? rhActiveLines.map((line) => (
          <div class="es-row">
            <span class="es-ln-label">{line.label}</span>
            <span class="es-ln-num strong">{fmt(line.extended_cents ?? 0)}</span>
          </div>
        )) : clientLines.map((b) => (
          <div class="es-row">
            <span class="es-ln-label">{b.line.label}</span>
            <span class="es-ln-num strong">{fmt(b.client_price_cents)}</span>
          </div>
        ))}
      <div class="es-totals">
        <span class="strong">Total {fmt(rightHandDraft ? rhTotalCents : totals.client_total_cents)}</span>
      </div>
    </section>
    </details>

    <section class="es-propose kg-card" aria-label="Proposal and invoice drafts">
      <div class="es-section-head">
        <div>
          <h2>Client draft actions</h2>
          <p class="es-meta">Drafts only — send requires your review. Filing, charging, or posting is a separate confirmation.</p>
        </div>
        {rightHandDraft ? <span class={`kg-chip ${proposalAction?.status === 'ready_for_review' ? 'green' : 'amber'}`}>{proposalAction?.status === 'ready_for_review' ? 'Ready' : 'Blocked'}</span> : null}
      </div>
      {rightHandDraft ? (
        <div class="es-artifact-actions">
          <article class="es-artifact-action" data-state={proposalAction?.status ?? 'blocked'}>
            <div>
              <strong>Proposal draft</strong>
              <span>{proposalAction?.operator_message}</span>
              {proposalAction?.blocked_reasons.length ? <small>{operatorFacingBlockedReasons(proposalAction.blocked_reasons)}</small> : null}
            </div>
            {proposalAction?.route ? (
              <a class="es-btn primary" href={proposalAction.route}>Open</a>
            ) : (
              <span class="es-btn es-btn-disabled" aria-disabled="true">{proposalAction?.next_action ?? 'Use rates here first'}</span>
            )}
          </article>
          <article class="es-artifact-action" data-state={invoiceAction?.status ?? 'blocked'}>
            <div>
              <strong>Down-payment invoice</strong>
              <span>{invoiceAction?.operator_message}</span>
              {invoiceAction?.blocked_reasons.length ? <small>{operatorFacingBlockedReasons(invoiceAction.blocked_reasons)}</small> : null}
            </div>
            {invoiceAction?.route ? (
              <a class="es-btn primary" href={invoiceAction.route}>Open</a>
            ) : (
              <span class="es-btn es-btn-disabled" aria-disabled="true">{invoiceAction?.next_action ?? 'Use rates here first'}</span>
            )}
          </article>
          <article class="es-artifact-action" data-state={invoiceAction?.status ?? 'blocked'}>
            <div>
              <strong>Money</strong>
              <span>Review billing milestones, issued rows, and remaining balances. Issue stays behind your confirmation.</span>
              {invoiceAction?.blocked_reasons.length ? <small>{operatorFacingBlockedReasons(invoiceAction.blocked_reasons)}</small> : null}
            </div>
            {invoiceAction?.status === 'ready_for_review' && moneyRoute ? (
              <a class="es-btn primary" href={moneyRoute}>Open</a>
            ) : (
              <span class="es-btn es-btn-disabled" aria-disabled="true">{invoiceAction?.next_action ?? 'Use rates here first'}</span>
            )}
          </article>
        </div>
      ) : (
        <>
          <button class="es-btn primary" id="gen-proposal" disabled={breakdowns.length === 0}>Generate proposal draft ›</button>
          <p class="es-meta">Create estimate lines first; client draft actions appear once Right Hand has an active estimate artifact.</p>
          <div id="draft-result" class="es-draft" hidden></div>
        </>
      )}
    </section>
  </article>
</Layout>

<script>
  const root = document.querySelector('.es-page');
  const projectId = root?.getAttribute('data-project') ?? '';
  const rhConversation = root?.getAttribute('data-rh-conversation') ?? '';
  if (rhConversation) {
    window.sessionStorage.setItem('kerf.voiceConversationId', rhConversation);
    window.localStorage.setItem('kerf.voiceConversationId', rhConversation);
  }

  async function post(url: string, body: Record<string, unknown>, confirmMsg: string) {
    if (!confirm(confirmMsg)) return null;
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ confirmed: true, ...body }),
    });
    if (!res.ok) { alert('Failed (' + res.status + '): ' + (await res.text())); return null; }
    return res.json();
  }

  async function postJsonNoDefaultConfirm(url: string, body: Record<string, unknown>): Promise<{ ok?: boolean; operator_message?: string } | null> {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    const out = await res.json().catch(() => null) as { ok?: boolean; operator_message?: string; error?: string } | null;
    if (!res.ok || !out?.ok) {
      alert(out?.operator_message ?? out?.error ?? `Failed (${res.status}). Nothing was filed or sent.`);
      return null;
    }
    return out;
  }

  // Lead-first card Part 5: tap-edit qty / unit override / remove-restore.
  // D-065 rung-0: server copies tier/source/gate untouched; edits never graduate.
  const estimateIdParam = new URLSearchParams(window.location.search).get('estimate_id') ?? '';
  async function patchLine(lineId: string, body: Record<string, unknown>): Promise<boolean> {
    const res = await fetch(`/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/lines/${encodeURIComponent(lineId)}`, {
      method: 'PATCH',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify(body),
    });
    if (!res.ok) { alert('Edit failed (' + res.status + '): ' + (await res.text())); return false; }
    return true;
  }
  document.querySelectorAll<HTMLButtonElement>('[data-edit-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-edit-line') ?? '';
      const currentQty = btn.getAttribute('data-qty') ?? '';
      const currentUnit = btn.getAttribute('data-unit') ?? '';
      const qtyRaw = prompt('Quantity (blank = keep, r = remove line):', currentQty);
      if (qtyRaw === null) return;
      if (qtyRaw.trim().toLowerCase() === 'r') {
        if (await patchLine(lineId, { removed: true })) window.location.reload();
        return;
      }
      const unitRaw = prompt('Unit price in dollars (blank = keep):', currentUnit ? String(Number(currentUnit) / 100) : '');
      if (unitRaw === null) return;
      const body: Record<string, unknown> = {};
      if (qtyRaw.trim()) body['quantity'] = Number(qtyRaw);
      if (unitRaw.trim()) body['unit_cents'] = Math.round(Number(unitRaw) * 100);
      if (Object.keys(body).length === 0) return;
      if (Number.isNaN(body['quantity'] as number) || Number.isNaN(body['unit_cents'] as number)) { alert('Numbers only.'); return; }
      if (await patchLine(lineId, body)) window.location.reload();
    });
  });
  document.getElementById('wb-import')?.addEventListener('change', async (ev) => {
    const input = ev.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;
    const res = await fetch(`/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/workbook-import`, {
      method: 'POST', credentials: 'same-origin', body: file,
    });
    const out = await res.json().catch(() => null) as { ok?: boolean; applied?: string[]; added?: string[]; removed?: string[]; rejected?: { reason: string }[]; structural_error?: string } | null;
    if (!res.ok || !out?.ok) { alert('Workbook rejected: ' + (out?.structural_error ?? res.status)); input.value = ''; return; }
    alert(`Imported — ${out.applied?.length ?? 0} edited, ${out.added?.length ?? 0} added, ${out.removed?.length ?? 0} removed` + ((out.rejected?.length ?? 0) > 0 ? `, ${out.rejected!.length} rejected` : ''));
    window.location.reload();
  });

  document.getElementById('rh-use-here-all')?.addEventListener('click', async () => {
    const sure = window.confirm('Confirm these draft lines on this estimate only? This will not save company standards or change future estimates.');
    if (!sure) return;
    const out = await postJsonNoDefaultConfirm(
      `/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/use-here`,
      { confirmed: true, target: 'all_priced_illustrative' },
    );
    if (out) window.location.reload();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-use-here-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-use-here-line') ?? '';
      const sure = window.confirm('Confirm this line on this estimate only? This will not save a standard.');
      if (!sure) return;
      const out = await postJsonNoDefaultConfirm(
        `/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/use-here`,
        { confirmed: true, line_ids: [lineId] },
      );
      if (out) window.location.reload();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-save-standard-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-save-standard-line') ?? '';
      const sure = window.confirm('Save this as a tenant rate standard for future estimates? This is separate from confirming a rate on one estimate.');
      if (!sure) return;
      const out = await postJsonNoDefaultConfirm(
        `/api/v1/right-hand/estimates/${encodeURIComponent(estimateIdParam)}/save-rate-standard`,
        { confirmed: true, consequence: 'tenant_rate_standard', line_ids: [lineId] },
      );
      if (out) alert(out.operator_message ?? 'Standard saved.');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-remove-suggested]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-remove-suggested') ?? '';
      if (await patchLine(lineId, { removed: true })) window.location.reload();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-restore-line]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const lineId = btn.getAttribute('data-restore-line') ?? '';
      if (await patchLine(lineId, { removed: false })) window.location.reload();
    });
  });

  document.getElementById('seed')?.addEventListener('click', async () => {
    const out = await post(`/api/v1/estimate/${projectId}/seed-from-selections`, {}, 'Create estimate lines from approved Selections?');
    if (out) window.location.reload();
  });

  document.getElementById('add-toggle')?.addEventListener('click', () => {
    const f = document.getElementById('add-form') as HTMLElement;
    f.hidden = !f.hidden;
  });

  const lineTypeSelect = document.getElementById('ln-type') as HTMLSelectElement | null;
  const unitSelect = document.getElementById('ln-uom') as HTMLSelectElement | null;
  const unitCostInput = document.getElementById('ln-cost') as HTMLInputElement | null;
  const defaultUnitForType = (type: string): string => ({
    labor: 'HR',
    material: 'EA',
    product: 'EA',
    allowance: 'LS',
    subcontract: 'LS',
    equipment: 'DAY',
    fee: 'LS',
    markup: 'LS',
  }[type] ?? 'EA');
  lineTypeSelect?.addEventListener('change', () => {
    if (!unitSelect || unitSelect.dataset.touched === 'true') return;
    unitSelect.value = defaultUnitForType(lineTypeSelect.value);
  });
  unitSelect?.addEventListener('change', () => {
    unitSelect.dataset.touched = 'true';
  });
  const moneyFromInput = (value: string): number => Number(value.replace(/[$,\s]/g, ''));
  unitCostInput?.addEventListener('blur', () => {
    const dollars = moneyFromInput(unitCostInput.value);
    if (!Number.isFinite(dollars)) return;
    unitCostInput.value = `$${dollars.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  });
  unitCostInput?.addEventListener('focus', () => {
    unitCostInput.value = unitCostInput.value.replace(/[$,]/g, '');
  });

  document.getElementById('add-go')?.addEventListener('click', async () => {
    const label = (document.getElementById('ln-label') as HTMLInputElement).value.trim();
    const line_type = (document.getElementById('ln-type') as HTMLSelectElement).value;
    const quantity = parseFloat((document.getElementById('ln-qty') as HTMLInputElement).value || '1');
    const uom = ((document.getElementById('ln-uom') as HTMLSelectElement).value || 'EA').trim().toUpperCase();
    // Operator enters dollars + percent (same convention as the Edit prompt
    // above); convert to the stored integer cents / basis points before POST.
    // The API contract (unit_cost_cents / markup_bps) is unchanged.
    const unitDollars = moneyFromInput((document.getElementById('ln-cost') as HTMLInputElement).value || '');
    const markupPct = parseFloat((document.getElementById('ln-markup') as HTMLInputElement).value || '0');
    const unit_cost_cents = Math.round(unitDollars * 100);
    const markup_bps = Math.round((Number.isNaN(markupPct) ? 0 : markupPct) * 100);
    if (!label || Number.isNaN(unitDollars)) { alert('Label and a unit cost (in dollars) are required.'); return; }
    const client_visible = line_type !== 'markup';
    const out = await post(`/api/v1/estimate/${projectId}/lines`, { label, line_type, quantity, uom, unit_cost_cents, markup_bps, client_visible }, `Add line "${label}"?`);
    if (out) window.location.reload();
  });

  document.getElementById('gen-proposal')?.addEventListener('click', () => {
    const estimateIdParam = new URLSearchParams(window.location.search).get('estimate_id');
    if (!estimateIdParam) {
      alert('Open this estimate from Right Hand first.');
      return;
    }
    const rhConversation = new URLSearchParams(window.location.search).get('rh_conversation') ?? '';
    const qs = new URLSearchParams({ estimate_id: estimateIdParam });
    if (rhConversation) qs.set('rh_conversation', rhConversation);
    window.location.href = `/estimate/${encodeURIComponent(projectId)}/proposal?${qs.toString()}`;
  });
</script>

