---
// F-PV1 · Mobile/desktop proposal preview · /proposals/:id/preview
import Layout from '../../../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../../../components/SurfaceIrreversibilityWrap.astro';
import Card from '../../../components/Card.astro';
import { createTranslator } from '../../../../i18n/index.js';
import { getLane6Proposal } from '../../../lib/lane6Fixtures.js';
import { loadProposalCaptureOrigin } from '../../../lib/loadProposalCaptureOrigin.js';
import CaptureOriginPanel from '../../../components/CaptureOriginPanel.astro';
import ExportActions from '../../../components/ExportActions.astro';
import { renderProposalHtml } from '../../../../proposal/render.js';
import '../../../styles/lane6.css';

const { id } = Astro.params;
const proposal = id ? getLane6Proposal(id) : null;
const { t } = createTranslator('en');

if (proposal === null) {
  return Astro.redirect('/');
}

const paperHtml = renderProposalHtml(proposal);
const captureOrigin = await loadProposalCaptureOrigin(proposal.tenant_id, proposal.project_id);
---

<Layout
  titleKey="f_pv1.title"
  activeHref="/draft-review"
  surfaceContext={{
    surface: 'proposal',
    project_id: proposal.project_id,
    estimate_id: proposal.proposal_id,
    proposal_id: proposal.proposal_id,
    line_ids: proposal.divisions.flatMap((division) =>
      division.sections.flatMap((section) => section.lines.map((line) => line.line_id)),
    ),
    phase: proposal.status,
  }}
>
  <article class="lane6-page f-pv1">
    <header>
      <div class="lane6-crumb">{t('f_pv1.crumb')}</div>
      <h1 class="lane6-title">{t('f_pv1.title')}</h1>
      <p class="lane6-subtitle">{t('f_pv1.subtitle')} · {proposal.proposal_number}</p>
    </header>

    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <ExportActions
        surface="proposal.preview"
        scopeDescriptor={`Proposal ${proposal.proposal_number}`}
        itemCount={proposal.divisions.length}
        actions={[
          { label: t('action.print'), format: 'print' },
          { label: t('f_mn.export.pdf'), format: 'pdf' },
        ]}
      />
      <div class="lane6-operator-bar">
        <div class="eyebrow">{t('f_pv1.operator_eyebrow')}</div>
        <div class="lane6-seg" role="group" aria-label={t('f_pv1.operator_eyebrow')}>
          <span class="active" title={t('f_pv1.view_preview_note')}>{t('f_pv1.view_mobile')}</span>
          <span title={t('f_pv1.view_preview_note')}>{t('f_pv1.view_desktop')}</span>
          <span class="lane6-preview-chip">{t('route_shell.card_eyebrow')}</span>
        </div>
        <p class="lane6-subtitle">{t('f_pv1.view_preview_note')}</p>
      </div>

      <Card eyebrow={t('f_pv1.preview_label')} title={proposal.project_name}>
        <p class="lane6-subtitle">{t('f_pv1.read_only_note')}</p>
        <CaptureOriginPanel origin={captureOrigin} />
        <div class="lane6-paper-wrap">
          <iframe class="lane6-paper-html" title={proposal.project_name} sandbox="allow-same-origin" srcdoc={paperHtml}></iframe>
        </div>
        <div slot="footer" class="lane6-actions">
          <a class="lane6-btn ghost" href="/draft-review">{t('f_pv1.back_draft')}</a>
          <a class="lane6-btn primary" href={`/proposals/${proposal.proposal_id}/send`}>
            {t('f_pv1.continue_send_gate')}
          </a>
        </div>
      </Card>
    </SurfaceIrreversibilityWrap>
  </article>
</Layout>

<script>
  // Grow the sandboxed proposal-document iframe to its content height so the
  // paper reads inline instead of nested-scrolling. srcdoc is same-origin, so
  // reading contentDocument is permitted; the try/guard is purely defensive.
  for (const frame of document.querySelectorAll<HTMLIFrameElement>('iframe.lane6-paper-html')) {
    const fit = () => {
      try {
        const doc = frame.contentDocument;
        if (doc?.documentElement) frame.style.height = doc.documentElement.scrollHeight + 'px';
      } catch { /* cross-origin guard */ }
    };
    frame.addEventListener('load', fit);
    fit();
  }
</script>
