---
// F-PV1 · Mobile/desktop proposal preview · /proposals/:id/preview
import Layout from '../../../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../../../components/SurfaceIrreversibilityWrap.astro';
import { createTranslator } from '../../../../i18n/index.js';
import { createLayoutContext } from '../../../lib/createLayoutContext.js';
import { getLane6ProposalForTenant } from '../../../lib/lane6Fixtures.js';
import { formatDollars, renderProposalHtml } from '../../../../proposal/render.js';
import '../../../styles/lane6.css';

const { id } = Astro.params;
const { context } = createLayoutContext();
const proposal = id ? getLane6ProposalForTenant(id, context.tenantId) : null;
const { t } = createTranslator('en');

if (proposal === null) {
  return Astro.redirect('/');
}

const paperHtml = renderProposalHtml(proposal);
const lineItems = proposal.divisions.flatMap((division) =>
  division.sections.flatMap((section) => section.lines),
);
const previewLines = lineItems.slice(0, 4);
const reviewLabel =
  proposal.status === 'sent' || proposal.status === 'accepted'
    ? 'Client-facing'
    : 'Draft preview';
---

<Layout
  titleKey="f_pv1.title"
  activeHref="/draft-review"
  surfaceContext={{
    surface: 'proposal',
    project_id: proposal.project_id,
    estimate_id: proposal.proposal_id,
    proposal_id: proposal.proposal_id,
    line_ids: proposal.divisions.flatMap((division) =>
      division.sections.flatMap((section) => section.lines.map((line) => line.line_id)),
    ),
    phase: proposal.status,
  }}
>
  <article class="lane6-page f-pv1">
    <header class="lane6-pagehead">
      <div>
        <div class="lane6-crumb">Sales / Proposal preview</div>
        <h1 class="lane6-title">{proposal.project_name}</h1>
        <p class="lane6-subtitle">{proposal.proposal_number} · Valid until {new Date(proposal.valid_until_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}</p>
      </div>
      <div class="lane6-head-actions">
        <a class="lane6-btn" href="/draft-review">Back to draft</a>
        <a class="lane6-btn primary" href={`/proposals/${proposal.proposal_id}/send`}>
          {t('f_pv1.continue_send_gate')}
        </a>
      </div>
    </header>

    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <div class="lane6-preview-grid">
        <section class="lane6-client-paper" aria-label="Client proposal preview">
          <div class="lane6-paper-wrap">
            <iframe class="lane6-paper-html" title={proposal.project_name} sandbox="allow-same-origin" srcdoc={paperHtml}></iframe>
          </div>
        </section>

        <aside class="lane6-control-panel" aria-label="Operator controls">
          <div class="lane6-panel-kicker">{reviewLabel}</div>
          <h2>{formatDollars(proposal.total_cents)}</h2>
          <div class="lane6-control-row">
            <strong>Margin</strong>
            <span class="lane6-chip green">Hidden</span>
          </div>
          <div class="lane6-control-row">
            <strong>Send status</strong>
            <span class="lane6-chip amber">Gate required</span>
          </div>
          <div class="lane6-control-row">
            <strong>Contractor review</strong>
            <span class="lane6-chip">Required</span>
          </div>

          <div class="lane6-mini-lines" aria-label="Proposal line summary">
            {previewLines.map((line) => (
              <div class="lane6-mini-line">
                <span>{line.description}</span>
                <b>{formatDollars(line.extended_cents)}</b>
              </div>
            ))}
            <div class="lane6-mini-line total">
              <span>Total proposal</span>
              <b>{formatDollars(proposal.total_cents)}</b>
            </div>
          </div>

          <div class="lane6-actions lane6-actions--stacked">
            <a class="lane6-btn" href="/draft-review">Back to draft</a>
            <a class="lane6-btn primary" href={`/proposals/${proposal.proposal_id}/send`}>
              {t('f_pv1.continue_send_gate')}
            </a>
          </div>
          <p class="lane6-panel-note">
            Client artifact stays clean. Right Hand can draft and route; external send stays behind the visible gate.
          </p>
        </aside>
      </div>
    </SurfaceIrreversibilityWrap>
  </article>
</Layout>

<script>
  // Grow the sandboxed proposal-document iframe to its content height so the
  // paper reads inline instead of nested-scrolling. srcdoc is same-origin, so
  // reading contentDocument is permitted; the try/guard is purely defensive.
  for (const frame of document.querySelectorAll<HTMLIFrameElement>('iframe.lane6-paper-html')) {
    const fit = () => {
      try {
        const doc = frame.contentDocument;
        if (doc?.documentElement) frame.style.height = doc.documentElement.scrollHeight + 'px';
      } catch { /* cross-origin guard */ }
    };
    frame.addEventListener('load', fit);
    fit();
  }
</script>
