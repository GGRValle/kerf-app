---
// F-E1 · Mobile Field Capture · Phase 1C reconcile (Lane 1 Capture spine)
// Canon: KERF Canon v1/_docs/wireframes/F-E1_mobile_field_capture.html
// Doctrine: D-048 adoption-layer + classify-before-harden learning governance
//
// Three states (rendered as labeled sections; client-side interactivity ships
// with Phase 1D capture-mutation API):
//   State 1 · Pre-capture · assign client/project/location + Daily Log anchor
//   State 2 · Active capture · live transcript + accumulating items
//   State 3 · Pre-flight · review + draft-intent picker + override path + submit
//
// D-048 eventfulness hooks (typed event shapes ready · emission wires in 1D):
//   Operator picks an intent that differs from Kerf's suggestion →
//     `suggestion.overridden` event with `override_reason` (free-text) PLUS
//     `correction.classified` (scope + locality + evidence_source_class)
//   Operator edits the transcript (edits overlay original per transcript canon) →
//     `correction.classified` event tracking which axis the operator corrected
//   Submit → existing `capture.recorded` + `daily_log.entry_captured` chain
//
// Wrap discipline: kind="daily" through State 1+2 (routine capture) ·
//   kind="irreversibility" on State 3 because Submit writes immutably to
//   Daily Log and may launch a draft workflow (CO/estimate) the operator
//   sees on F-G1. Action context is explicit per D-048.

import Layout from '../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../components/SurfaceIrreversibilityWrap.astro';
import Card from '../components/Card.astro';
import Row from '../components/Row.astro';
import Chip from '../components/Chip.astro';
import SectionLabel from '../components/SectionLabel.astro';
import PhaseStrip from '../components/PhaseStrip.astro';
import { createTranslator } from '../../i18n/index.js';

// Translator pulled from layout context in Phase 1D · default to EN for now.
const { t } = createTranslator('en');

// Fixture context for the wireframe-accurate render. Real assignment lands
// via tenant-scoped read of the operator's active project in Phase 1D.
const assignment = {
  client: 'Wegrzyn, Mark & Grace',
  project: 'Kitchen + Primary bath',
  location: 'Kitchen',
  tenant_id: 'tenant_ggr',
  project_id: 'proj_wegrzyn_kitchen_bath',
};

// Kerf's suggested draft intent (inferred from voice content in Phase 1D).
// When the operator picks something different, the override path lights up.
const kerfSuggestedIntent: 'change_order' | 'estimate_update' | 'daily_log_only' = 'change_order';
---

<Layout title="F-E1 · Field Capture" activeHref={Astro.url.pathname}>
  <article class="f-e1">

    <!-- ============= Header ============= -->
    <header class="f-e1-header">
      <div class="crumb">{t('f_e1.crumb')}</div>
      <h1>{t('f_e1.title')}</h1>
      <p class="subtitle">{t('f_e1.subtitle')}</p>
      <PhaseStrip phases={[
        { id: 'capture', label: 'Capture', active: true },
        { id: 'review', label: 'Review' },
        { id: 'draft', label: 'Draft' },
      ]} />
    </header>

    <!-- ============= STATE 1 · Pre-capture · daily wrap ============= -->
    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <section class="state-block" data-state="1" aria-label={t('f_e1.state1.label')}>
        <SectionLabel label={t('f_e1.state1.label')} />

        <Card eyebrow={t('f_e1.state1.eyebrow')} title={t('f_e1.state1.title')}>
          <!-- Assignment card · canon-explicit "where this goes" -->
          <div class="assign-block">
            <div class="assign-eyebrow">{t('f_e1.state1.assign.eyebrow')}</div>
            <dl class="assign-list">
              <div class="assign-row">
                <dt>{t('f_e1.state1.assign.client')}</dt>
                <dd>{assignment.client} · <button class="link" type="button">{t('f_e1.state1.assign.change')}</button></dd>
              </div>
              <div class="assign-row">
                <dt>{t('f_e1.state1.assign.project')}</dt>
                <dd>{assignment.project} · <button class="link" type="button">{t('f_e1.state1.assign.change')}</button></dd>
              </div>
              <div class="assign-row">
                <dt>{t('f_e1.state1.assign.location')}</dt>
                <dd>{assignment.location} · <button class="link" type="button">{t('f_e1.state1.assign.change')}</button></dd>
              </div>
            </dl>
          </div>

          <!-- Daily Log anchor · canon-explicit per kerf_daily_log_canon.md -->
          <aside class="daily-log-anchor" role="note">
            <strong>{t('f_e1.state1.daily_log.anchor_title')}</strong>
            <span class="dl-detail">{t('f_e1.state1.daily_log.anchor_detail')}</span>
          </aside>

          <!-- Record affordances -->
          <div class="record-area">
            <button class="record-button" type="button" aria-label={t('f_e1.state1.record.label')}>
              <span class="rb-dot" aria-hidden="true"></span>
            </button>
            <div class="record-label">{t('f_e1.state1.record.label')}</div>
            <div class="record-sub">{t('f_e1.state1.record.sub')}</div>
          </div>

          <div class="secondary-actions">
            <button type="button" class="secondary-action">{t('f_e1.state1.add_photo')}</button>
            <button type="button" class="secondary-action">{t('f_e1.state1.type_note')}</button>
          </div>

          <div slot="footer" class="state1-footer">
            <button type="button" class="ar-btn cancel">{t('f_e1.action.cancel')}</button>
            <button type="button" class="ar-btn primary" disabled aria-disabled="true">
              {t('f_e1.state3.submit')} · <em>{t('f_e1.state1.submit.disabled_hint')}</em>
            </button>
          </div>
        </Card>
      </section>

      <!-- ============= STATE 2 · Active capture · daily wrap ============= -->
      <section class="state-block" data-state="2" aria-label={t('f_e1.state2.label')}>
        <SectionLabel label={t('f_e1.state2.label')} />

        <Card eyebrow={t('f_e1.state2.eyebrow')} title={t('f_e1.state2.title')}>
          <div class="live-record">
            <span class="live-dot" aria-hidden="true"></span>
            <div class="live-body">
              <div class="live-eyebrow">{t('f_e1.state2.recording_label')}</div>
              <div class="live-time" aria-live="polite">0:48</div>
            </div>
            <button type="button" class="live-stop">{t('f_e1.state2.stop')}</button>
          </div>

          <div class="live-transcript">
            <div class="lt-eyebrow">{t('f_e1.state2.live_transcript_label')}</div>
            <p class="lt-text">
              "Standing in the kitchen at Wegrzyn. The plumbing rough-in for the island is in.
              Coastal Mech finished the gas line yesterday — supply lines came up through the
              floor instead of the wall, <em>better for the way the cabinet runs are going to land</em>."
            </p>
          </div>

          <SectionLabel label={t('f_e1.state2.captured_label')} count="2 voice · 1 photo" />
          <div class="captured-list">
            <Row title="Voice memo · 0:32" meta='"Heather wants to upgrade the tile spec…"' state="10:42" />
            <Row title="Photo · island plumbing" meta="Tap to add caption" state="10:42" />
            <Row title="Photo · gas line stub" meta="Coastal Mech work · 2026-05-08" state="10:42" />
          </div>

          <div slot="footer" class="state2-footer">
            <button type="button" class="ar-btn">{t('f_e1.state1.add_photo')}</button>
            <button type="button" class="ar-btn primary">{t('f_e1.state2.done_capturing')}</button>
            <button type="button" class="ar-btn cancel">{t('f_e1.action.cancel')}</button>
          </div>
        </Card>
      </section>
    </SurfaceIrreversibilityWrap>

    <!-- ============= STATE 3 · Pre-flight · irreversibility wrap ============= -->
    <SurfaceIrreversibilityWrap kind="irreversibility" actionContext={t('f_e1.state3.irreversibility.action_context')}>
      <section class="state-block" data-state="3" aria-label={t('f_e1.state3.label')}>
        <SectionLabel label={t('f_e1.state3.label')} />

        <Card eyebrow={t('f_e1.state3.eyebrow')} title={t('f_e1.state3.title')}>
          <div class="preflight-summary">
            <div class="pf-eyebrow">{t('f_e1.state3.summary_eyebrow')}</div>
            <div class="pf-title">Wegrzyn · kitchen plumbing rough done</div>
            <div class="pf-meta">Daniel · 2:14 total · 2 voice + 3 photos · writes to Wegrzyn / today's Daily Log</div>
          </div>

          <!-- Draft-intent picker · the override gate.
               D-048: when the operator's pick != kerfSuggestedIntent, emit
               suggestion.overridden + correction.classified per L0.3 axes.
               The free-text reason captures real reasoning for memory; the
               one-question follow-up disambiguates scope (correction_scope:
               this_job vs general_rule). NEVER thumbs-up/down. -->
          <fieldset class="intent-picker" data-suggested={kerfSuggestedIntent}>
            <legend>{t('f_e1.state3.intent.eyebrow')}</legend>

            <label class="intent-option" data-intent="change_order">
              <input type="radio" name="draft_intent" value="change_order" checked={kerfSuggestedIntent === 'change_order'} />
              <span class="intent-title">
                {t('f_e1.state3.intent.co.title')}
                {kerfSuggestedIntent === 'change_order' && (
                  <Chip label={t('f_e1.state3.intent.suggested_hint')} tone="amber" variant="outlined" />
                )}
              </span>
              <span class="intent-detail">{t('f_e1.state3.intent.co.detail')}</span>
            </label>

            <label class="intent-option" data-intent="estimate_update">
              <input type="radio" name="draft_intent" value="estimate_update" checked={kerfSuggestedIntent === 'estimate_update'} />
              <span class="intent-title">
                {t('f_e1.state3.intent.estimate.title')}
                {kerfSuggestedIntent === 'estimate_update' && (
                  <Chip label={t('f_e1.state3.intent.suggested_hint')} tone="amber" variant="outlined" />
                )}
              </span>
              <span class="intent-detail">{t('f_e1.state3.intent.estimate.detail')}</span>
            </label>

            <label class="intent-option" data-intent="daily_log_only">
              <input type="radio" name="draft_intent" value="daily_log_only" checked={kerfSuggestedIntent === 'daily_log_only'} />
              <span class="intent-title">
                {t('f_e1.state3.intent.daily_log.title')}
                {kerfSuggestedIntent === 'daily_log_only' && (
                  <Chip label={t('f_e1.state3.intent.suggested_hint')} tone="amber" variant="outlined" />
                )}
              </span>
              <span class="intent-detail">{t('f_e1.state3.intent.daily_log.detail')}</span>
            </label>
          </fieldset>

          <!-- Override reason · visible only when operator picks a different intent.
               In Phase 1C this is rendered always-visible (no client JS yet);
               Phase 1D toggles visibility based on radio selection state. -->
          <div class="override-block" data-override-active="false">
            <label class="override-label" for="override_reason">{t('f_e1.state3.override.reason_label')}</label>
            <textarea
              id="override_reason"
              name="override_reason"
              rows="2"
              placeholder={t('f_e1.state3.override.reason_placeholder')}
            ></textarea>
            <div class="classify-prompt">{t('f_e1.state3.override.classify_prompt')}</div>
            <!-- correction.classified emission shape (Phase 1D wires):
                 { type: 'correction.classified',
                   correction_scope: 'this_job' | 'general_rule',
                   memory_locality: 'project_only' | 'tenant_wide',
                   evidence_source_class: 'operator_field_correction' } -->
          </div>

          <!-- Transcript review · edit affordance opens edits-overlay per
               kerf_transcript_canon.md. Each edit emits correction.classified
               classified by which axis the operator corrected (typo vs scope
               vs fact). Original stays immutable. -->
          <div class="final-transcript">
            <div class="ft-eyebrow">
              <span>{t('f_e1.state3.transcript.eyebrow')}</span>
              <button type="button" class="link">{t('f_e1.state3.transcript.edit')}</button>
            </div>
            <div class="ft-block">
              <div class="ft-meta">0:32 · 10:42</div>
              <p class="ft-text">"Heather wants to upgrade the tile spec to the Carrara herringbone — I told her we'd need a change order for that since it's about double the per-square-foot cost."</p>
            </div>
            <div class="ft-block">
              <div class="ft-meta">0:48 · 10:43</div>
              <p class="ft-text">"Standing in the kitchen at Wegrzyn. Plumbing rough-in for the island is in. Coastal Mech finished the gas line yesterday — supply lines came up through the floor instead of the wall, better for the cabinet runs."</p>
            </div>
            <aside class="transcript-canon-hint">
              <strong>{t('f_e1.state3.transcript.edit')}.</strong> {t('f_e1.state3.transcript.canon_hint')}
            </aside>
          </div>

          <!-- AI disclosure §13 -->
          <aside class="ai-disclosure" role="note">{t('f_e1.state3.ai_disclosure')}</aside>

          <div slot="footer" class="state3-footer">
            <button type="button" class="ar-btn">{t('f_e1.action.back')}</button>
            <button
              type="button"
              class="ar-btn primary"
              id="f-e1-submit"
              data-tenant-id={assignment.tenant_id}
              data-project-id={assignment.project_id}
            >
              {t('f_e1.state3.submit')} · <em>{t('f_e1.state3.submit_sub')}</em>
            </button>
          </div>
          <p class="submit-status" id="f-e1-submit-status" role="status" aria-live="polite"></p>
        </Card>
      </section>
    </SurfaceIrreversibilityWrap>

  </article>
</Layout>

<script>
  const submitButton = document.querySelector('#f-e1-submit');
  const statusNode = document.querySelector('#f-e1-submit-status');
  const transcriptNodes = [...document.querySelectorAll('.ft-text')];

  function setStatus(message, tone = 'neutral') {
    if (!(statusNode instanceof HTMLElement)) return;
    statusNode.textContent = message;
    statusNode.dataset.tone = tone;
  }

  async function submitDailyLogEntry() {
    if (!(submitButton instanceof HTMLElement)) return;
    const tenantId = submitButton.dataset.tenantId;
    const projectId = submitButton.dataset.projectId;
    if (!tenantId || !projectId) {
      setStatus('Missing project assignment. Pick the project before submit.', 'error');
      return;
    }
    const transcript = transcriptNodes
      .map((node) => node.textContent?.trim() ?? '')
      .filter(Boolean)
      .join('\n\n');
    submitButton.setAttribute('aria-busy', 'true');
    setStatus('Saving to Daily Log...', 'neutral');
    try {
      const res = await fetch(`/api/v1/projects/${encodeURIComponent(projectId)}/daily-log/entries`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tenant_id: tenantId,
          entry_kind: 'progress_update',
          transcript_text: transcript,
          photo_uris: ['kerf://field-capture/wegrzyn/island-plumbing'],
          actor: { id: 'browser_operator', role: 'field_super' },
        }),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(body.error ?? `submit_failed_${res.status}`);
      }
      setStatus(`Saved to Daily Log. Event ${body.event_id}.`, 'success');
    } catch (err) {
      setStatus(`Could not save: ${err instanceof Error ? err.message : String(err)}`, 'error');
    } finally {
      submitButton.removeAttribute('aria-busy');
    }
  }

  submitButton?.addEventListener('click', () => {
    void submitDailyLogEntry();
  });
</script>

<style>
  .f-e1 {
    max-width: 920px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
    color: var(--text, #0a0d11);
  }

  .f-e1-header { margin-bottom: 1.5rem; }
  .f-e1-header .crumb {
    font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-muted, #6a7282); margin-bottom: 0.5rem;
  }
  .f-e1-header h1 { font-size: 1.4rem; margin: 0 0 0.4rem; font-weight: 600; }
  .f-e1-header .subtitle { color: var(--text-muted, #4a5462); font-size: 0.95rem; line-height: 1.55; margin: 0 0 1rem; }

  .state-block { margin-top: 1.5rem; }

  .assign-block { margin-bottom: 0.85rem; }
  .assign-eyebrow {
    font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--field-green, #38c977); font-weight: 700; margin-bottom: 0.4rem;
  }
  .assign-list { margin: 0; padding: 0; }
  .assign-row {
    display: flex; justify-content: space-between; padding: 0.35rem 0;
    border-bottom: 1px solid var(--border-soft, #1f2530);
    font-size: 0.85rem;
  }
  .assign-row:last-child { border-bottom: none; }
  .assign-row dt {
    font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-muted, #6a7282); font-weight: 600; margin: 0;
  }
  .assign-row dd { margin: 0; font-weight: 600; }

  .daily-log-anchor {
    background: rgba(56, 201, 119, 0.04);
    border-left: 3px solid var(--field-green, #38c977);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    margin: 0.75rem 0;
  }
  .daily-log-anchor strong { color: var(--field-green, #38c977); display: block; margin-bottom: 0.15rem; }
  .daily-log-anchor .dl-detail { color: var(--text-muted, #6a7282); }

  .record-area {
    display: flex; flex-direction: column; align-items: center;
    gap: 0.4rem; margin: 1.25rem 0 0.75rem;
  }
  .record-button {
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--field-green, #38c977); border: none;
    box-shadow: 0 6px 18px rgba(56, 201, 119, 0.25);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
  }
  .record-button .rb-dot { width: 24px; height: 24px; border-radius: 50%; background: #0a1a0f; }
  .record-label { font-weight: 600; font-size: 0.9rem; }
  .record-sub { color: var(--text-muted, #6a7282); font-size: 0.78rem; text-align: center; max-width: 360px; line-height: 1.4; }

  .secondary-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.75rem; }
  .secondary-action {
    background: var(--surface, #1a1f28); border: 1px solid var(--border-soft, #2a3140);
    color: inherit; border-radius: 8px; padding: 0.55rem 0.5rem; font-size: 0.85rem; cursor: pointer;
  }

  .state1-footer, .state2-footer, .state3-footer {
    display: grid; gap: 0.5rem; margin-top: 0.75rem;
  }
  .state1-footer { grid-template-columns: 1fr 2fr; }
  .state2-footer { grid-template-columns: 1fr 2fr 1fr; }
  .state3-footer { grid-template-columns: 1fr 2fr; }

  .ar-btn {
    padding: 0.7rem 0.5rem; border-radius: 10px; font-weight: 600; font-size: 0.85rem;
    background: var(--surface, #1a1f28); border: 1px solid var(--border-soft, #2a3140);
    color: inherit; cursor: pointer;
  }
  .ar-btn em { color: var(--text-muted, #6a7282); font-style: normal; font-weight: 400; font-size: 0.75rem; }
  .ar-btn.primary { background: var(--field-green, #38c977); color: #0a1a0f; border-color: var(--field-green, #38c977); }
  .ar-btn.primary em { color: rgba(10, 26, 15, 0.65); }
  .ar-btn.cancel { color: var(--red, #f87171); }
  .ar-btn[disabled] { opacity: 0.45; cursor: not-allowed; }

  .live-record {
    display: flex; align-items: center; gap: 0.6rem;
    background: rgba(56, 201, 119, 0.06);
    border: 1px solid rgba(56, 201, 119, 0.4);
    border-radius: 10px; padding: 0.6rem 0.75rem;
    margin-bottom: 0.6rem;
  }
  .live-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--field-green, #38c977);
    box-shadow: 0 0 0 4px rgba(56, 201, 119, 0.2);
  }
  .live-body { flex: 1; }
  .live-eyebrow { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--field-green, #38c977); font-weight: 700; }
  .live-time { font-size: 1rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  .live-stop { background: var(--field-green, #38c977); color: #0a1a0f; border: none; padding: 0.4rem 0.8rem; border-radius: 7px; font-weight: 700; cursor: pointer; }

  .live-transcript {
    background: var(--bg-2, #14181f); border: 1px solid var(--border-soft, #1f2530);
    border-radius: 8px; padding: 0.55rem 0.75rem; margin-bottom: 0.6rem;
  }
  .lt-eyebrow { font-size: 0.65rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted, #6a7282); font-weight: 700; margin-bottom: 0.25rem; }
  .lt-text { margin: 0; font-size: 0.85rem; line-height: 1.5; }
  .lt-text em { color: var(--field-green, #38c977); font-style: normal; font-weight: 500; }

  .captured-list { display: flex; flex-direction: column; gap: 0.35rem; margin-top: 0.5rem; }

  .preflight-summary {
    background: linear-gradient(135deg, rgba(56, 201, 119, 0.07), rgba(123, 168, 255, 0.04));
    border: 1px solid rgba(56, 201, 119, 0.3);
    border-radius: 10px; padding: 0.7rem 0.85rem; margin-bottom: 0.75rem;
  }
  .pf-eyebrow { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--field-green, #38c977); font-weight: 700; margin-bottom: 0.25rem; }
  .pf-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.2rem; }
  .pf-meta { font-size: 0.78rem; color: var(--text-muted, #6a7282); }

  .intent-picker {
    border: 1px solid var(--border-soft, #2a3140); border-radius: 10px;
    padding: 0.6rem 0.75rem 0.4rem; margin-bottom: 0.75rem;
  }
  .intent-picker legend { font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--field-green, #38c977); font-weight: 700; padding: 0 0.25rem; }
  .intent-option {
    display: grid; grid-template-columns: 18px 1fr; gap: 0.5rem;
    padding: 0.5rem; border-radius: 6px; cursor: pointer;
    border: 1px solid transparent;
  }
  .intent-option:hover { background: rgba(123, 168, 255, 0.04); }
  .intent-option input[type="radio"]:checked + .intent-title { font-weight: 700; }
  .intent-title { font-size: 0.9rem; display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
  .intent-detail { grid-column: 2; font-size: 0.78rem; color: var(--text-muted, #6a7282); margin-top: 0.15rem; }

  .override-block {
    background: rgba(245, 181, 68, 0.04);
    border-left: 3px solid var(--amber, #f5b544);
    border-radius: 6px; padding: 0.55rem 0.75rem; margin-bottom: 0.75rem;
  }
  .override-label { display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.3rem; }
  .override-block textarea {
    width: 100%; font: inherit; padding: 0.45rem 0.55rem;
    background: var(--bg, transparent); color: inherit;
    border: 1px solid var(--border-soft, #2a3140); border-radius: 6px;
    resize: vertical;
  }
