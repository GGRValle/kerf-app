---
// F-E1 · Mobile Field Capture · Phase 1J visual-fidelity port
// Canon anchor: docs/wireframes/canon/F-E1_mobile_field_capture.html
//
// Phase 1J Agent B ports the canon F-E1 visual treatment onto this surface
// now that Agent A's shared token + phone-shell foundation is on main. The
// state machine, event/API wiring, captured-media model, and loop links are
// preserved verbatim — only the visual layer is brought up to canon.
//
// Three states, canon-anchored:
//   State 1 · pre-capture   — assignment + Daily Log anchor + record + secondary
//   State 2 · active        — live record bar + transcript + captured items
//   State 3 · pre-flight    — summary + draft-intent + transcript + media + submit
// Submit writes daily_log.entry_captured and runs the Right Hand chain.

import Layout from '../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../components/SurfaceIrreversibilityWrap.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { LANE23_FIXTURE_DRAFT_ID } from '../lib/lane23Fixtures.js';

const { t } = createLayoutContext();
const fixtureDraftHref = `/draft-review/${LANE23_FIXTURE_DRAFT_ID}`;

const assignment = {
  client: 'Wegrzyn, Mark & Grace',
  project: 'Kitchen + Primary bath',
  location: 'Kitchen',
  tenant_id: 'tenant_ggr',
  project_id: 'proj_wegrzyn_kitchen',
  matched_by: 'job-site GPS',
};
---

<Layout title="Field Capture" activeHref={Astro.url.pathname}>
  <main
    class="field-shell"
    data-view-state="pre"
    data-tenant-id={assignment.tenant_id}
    data-project-id={assignment.project_id}
  >
    <section class="phone-frame" aria-label="Mobile field capture">
      <div class="status-bar" aria-hidden="true">
        <span>10:42</span>
        <span class="right">●●● 84%</span>
      </div>

      <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={2}>
        <!-- ===================== STATE 1 · PRE-CAPTURE ===================== -->
        <section class="capture-state state-pre" aria-label="Start field capture">
          <header class="top-chrome">
            <div class="tc-eyebrow">
              <span class="tc-mode">New capture</span>
              <a class="tc-back" href="/">Back</a>
            </div>
            <h1 class="tc-title">What are you capturing?</h1>
            <p class="tc-meta">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
              <span>Wegrzyn site · 4287 Pacifica Way</span>
            </p>
          </header>

          <div class="dest-selector">
            <label class="assign-eyebrow" for="f-e1-destination">Capture goes to</label>
            <select
              class="dest-select"
              id="f-e1-destination"
              data-active-project-id={assignment.project_id}
              data-active-client={assignment.client}
              data-active-project={assignment.project}
              data-active-location={assignment.location}
              data-matched-by={assignment.matched_by}
            >
              <option value="active" data-project-id={assignment.project_id} selected>
                Active job · {assignment.client}
              </option>
              <option value="pick-project" data-project-id="">Pick a different project…</option>
              <option value="pick-client" data-project-id="">Pick a different client…</option>
              <option value="unassigned" data-project-id="">New client / unassigned note</option>
            </select>
            <p class="dest-hint" id="f-e1-dest-hint">
              Matched to your active job by {assignment.matched_by}. Change it above if this
              capture belongs elsewhere.
            </p>
          </div>

          <div class="assign-card" id="f-e1-assign-card">
            <div class="assign-row">
              <span class="ar-key">Client</span>
              <span class="ar-val" id="f-e1-dest-client">{assignment.client}</span>
            </div>
            <div class="assign-row">
              <span class="ar-key">Project</span>
              <span class="ar-val" id="f-e1-dest-project">{assignment.project}</span>
            </div>
            <div class="assign-row">
              <span class="ar-key">Location</span>
              <span class="ar-val ar-val-dim" id="f-e1-dest-location">{assignment.location}</span>
            </div>
          </div>

          <aside class="dl-anchor" aria-label="Daily Log destination">
            <strong id="f-e1-dl-anchor">Writes to {assignment.client} · today's Daily Log.</strong>
            <span class="dl-detail">
              Every capture lands in the project's Daily Log for this day — your voice,
              photos, and notes file together as one day's record. Right Hand reviews
              after submit.
            </span>
          </aside>

          <div class="record-area">
            <button class="record-button" id="f-e1-record" type="button" aria-label="Start voice capture">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/></svg>
            </button>
            <p class="record-label">Hold or tap to record</p>
            <p class="record-sublabel">Describe scope, conditions, decisions, questions — long voice memos welcome.</p>
          </div>

          <div class="cap-secondary">
            <button type="button" class="cap-button" id="f-e1-photo">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 2 7 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-3l-2-2zm3 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/></svg>
              <span class="cb-label">Photo / Video</span>
              <span class="cb-sub">Camera or library</span>
            </button>
            <button type="button" class="cap-button" id="f-e1-type-note">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm-1 7V3.5L18.5 9zM8 13h8v1.5H8zm0 3h8v1.5H8zm0 3h5v1.5H8z"/></svg>
              <span class="cb-label">Type a note</span>
              <span class="cb-sub">If voice isn't possible</span>
            </button>
          </div>

          <div class="action-ribbon">
            <a class="ar-btn cancel" href="/">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 6.4 17.6 5 12 10.6 6.4 5 5 6.4 10.6 12 5 17.6 6.4 19 12 13.4 17.6 19 19 17.6 13.4 12z"/></svg>
              Cancel
            </a>
          </div>
        </section>

        <!-- ===================== STATE 2 · ACTIVE CAPTURE ===================== -->
        <section class="capture-state state-active" aria-label="Active capture">
          <header class="top-chrome">
            <div class="tc-eyebrow">
              <span class="tc-mode" id="f-e1-active-mode">Capturing · {assignment.client} / {assignment.location}</span>
              <span class="tc-user" id="f-e1-active-count">0 items</span>
            </div>
            <h1 class="tc-title tc-title-sm">Recording voice · accumulating evidence</h1>
          </header>

          <div class="live-record-bar">
            <span class="live-rec-dot" aria-hidden="true"></span>
            <div class="live-rec-body">
              <p class="live-rec-label">Recording</p>
              <strong class="live-rec-time" id="f-e1-timer">0:00</strong>
            </div>
            <button type="button" class="live-rec-stop" id="f-e1-stop">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
              Stop
            </button>
          </div>

          <label class="note-card" for="f-e1-note">
            <span class="card-eyebrow">Typed summary</span>
            <p class="note-helper">
              Voice is saved for this capture. Until transcription is wired, type a short summary before submit.
            </p>
            <textarea
              id="f-e1-note"
              rows="6"
              enterkeyhint="done"
              autocomplete="off"
              autocapitalize="sentences"
              placeholder="Type what Right Hand should read. Example: Plumbing rough-in is complete, but tile changed to Carrara and needs CO pricing."
            ></textarea>
          </label>

          <section class="captured-items">
            <div class="captured-eyebrow">
              <span>Captured this session</span>
              <span class="ce-count" id="f-e1-captured-count">0 items</span>
            </div>
            <ul id="f-e1-captured-list" class="cap-list">
              <li class="cap-empty">Voice memos, photos, and videos will show here.</li>
            </ul>
          </section>

          <div class="action-ribbon">
            <button type="button" class="ar-btn" id="f-e1-record-active">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/></svg>
              Record more
            </button>
            <button type="button" class="ar-btn" id="f-e1-photo-active">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 2 7 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-3l-2-2zm3 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/></svg>
              Photo / Video
            </button>
            <button type="button" class="ar-btn primary" id="f-e1-done">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 16.2 5.5 12.7 4.1 14l5 5L21 7.1 19.6 5.7z"/></svg>
              Done capturing
            </button>
          </div>
        </section>
      </SurfaceIrreversibilityWrap>

      <SurfaceIrreversibilityWrap
        kind="irreversibility"
        actionContext="Submit field capture to Daily Log and run Right Hand review."
      >
        <!-- ===================== STATE 3 · PRE-FLIGHT + SUBMIT ===================== -->
        <section class="capture-state state-preflight" aria-label="Review and submit field capture">
          <header class="top-chrome">
            <div class="tc-eyebrow">
              <span class="tc-mode">Pre-flight · review &amp; submit</span>
              <button type="button" class="tc-back tc-back-btn" id="f-e1-back-active">‹ Back</button>
            </div>
            <h1 class="tc-title tc-title-sm">Ready to send?</h1>
          </header>

          <p class="preflight-status" id="f-e1-preflight-status" role="status"></p>

          <div class="preflight-card">
            <p class="pf-eyebrow">Capture session · ready</p>
            <p class="pf-title">{assignment.location} update</p>
            <p class="pf-meta" id="f-e1-preflight-meta">Daily Log · review what you captured below</p>
          </div>

          <section class="capture-readout" id="f-e1-capture-readout" aria-label="Captured items readout">
            <p class="card-eyebrow">What you captured</p>
            <ul class="readout-list" id="f-e1-readout-list"></ul>
            <p class="readout-warning" id="f-e1-transcript-warning" hidden></p>
          </section>

          <fieldset class="draft-intent-card">
            <legend class="di-eyebrow">What should Right Hand do with this?</legend>
            <label class="di-option">
              <input type="radio" name="entry_kind" value="change_signal" checked />
              <span class="di-radio" aria-hidden="true"></span>
              <span class="di-body">
                <span class="di-option-title">Watch for change-order or scope drift</span>
                <span class="di-option-detail">Right Hand reads the capture for pricing or scope changes and surfaces a relay card if it finds one.</span>
              </span>
            </label>
            <label class="di-option">
              <input type="radio" name="entry_kind" value="progress_update" />
              <span class="di-radio" aria-hidden="true"></span>
              <span class="di-body">
                <span class="di-option-title">Just log progress</span>
                <span class="di-option-detail">Files as field evidence on today's Daily Log · no drafting forced.</span>
              </span>
            </label>
            <label class="di-option">
              <input type="radio" name="entry_kind" value="blocker" />
              <span class="di-radio" aria-hidden="true"></span>
              <span class="di-body">
                <span class="di-option-title">Flag a blocker</span>
                <span class="di-option-detail">Marks the entry as something stopping work · surfaces for office review.</span>
              </span>
            </label>
          </fieldset>

          <section class="final-transcript">
            <div class="ft-eyebrow">
              <span>Typed summary</span>
              <button type="button" class="ft-edit" id="f-e1-edit-note">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75zm17.71-10.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75z"/></svg>
                Edit
              </button>
            </div>
            <p class="ft-text" id="f-e1-review-text">No typed summary yet.</p>
            <p class="transcript-canon-hint">
              <strong>This is not a live transcript.</strong> Voice is stored separately until transcription ships — your typed summary is what Right Hand reads.
            </p>
          </section>

          <section class="media-card">
            <div class="ft-eyebrow">
              <span>Media</span>
              <span class="ce-count" id="f-e1-photo-count">0</span>
            </div>
            <div class="photo-grid-mini" id="f-e1-photo-grid"></div>
          </section>

          <section class="continue-capture" aria-label="Add more capture before submit">
            <div class="compact-record-zone">
              <button
                class="record-button compact-record-button"
                id="f-e1-record-more"
                type="button"
                aria-label="Record more voice"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/></svg>
              </button>
              <div>
                <p class="record-label">Add more before submit</p>
                <p class="record-sublabel">Record another note, add photo/video, or edit the summary.</p>
              </div>
            </div>
            <div class="cap-secondary">
              <button type="button" class="cap-button cap-button-row" id="f-e1-photo-preflight">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 2 7 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-3l-2-2zm3 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/></svg>
                <span class="cb-label">Photo / Video</span>
              </button>
              <button type="button" class="cap-button cap-button-row" id="f-e1-edit-note-inline">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75zm17.71-10.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75z"/></svg>
                <span class="cb-label">Edit summary</span>
              </button>
            </div>
          </section>

          <aside class="ai-disclosure">
            <strong>AI-assisted by Kerf Right Hand.</strong> Drafts are prepared from your capture; review before approval.
          </aside>

          <div class="action-ribbon">
            <button type="button" class="ar-btn" id="f-e1-back">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Back
            </button>
            <button
              type="button"
              class="ar-btn primary"
              id="f-e1-submit"
              data-tenant-id={assignment.tenant_id}
              data-project-id={assignment.project_id}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="ar-label">Submit to Daily Log</span>
            </button>
          </div>
        </section>
      </SurfaceIrreversibilityWrap>

      <section class="submit-outcome" id="f-e1-submit-outcome" aria-live="polite" hidden>
        <p class="submit-status" id="f-e1-submit-status" role="status"></p>
        <p class="submit-play-error" id="f-e1-play-error" role="alert" hidden></p>
        <a class="relay-link" id="f-e1-relay-link" href="/relay" hidden>Open Relay →</a>
        <nav class="loop-links" id="f-e1-loop-links" aria-label="Capture review loop" hidden>
          <a class="loop-link" href="/transcript-review?capture_id=cap_lane23_wegrzyn_001">Transcript review →</a>
          <a class="loop-link" href={fixtureDraftHref}>{t('f_e1.loop.draft_preview')}</a>
          <a class="loop-link" id="f-e1-field-detail-link" href="/field-detail">Field detail →</a>
        </nav>
      </section>
      <input id="f-e1-camera-input" type="file" accept="image/*,video/*" capture="environment" hidden />
    </section>
  </main>

  <script>
  const shell = document.querySelector('.field-shell');
  const recordButton = document.querySelector('#f-e1-record');
  const recordMoreButton = document.querySelector('#f-e1-record-more');
  const recordActiveButton = document.querySelector('#f-e1-record-active');
  const stopButton = document.querySelector('#f-e1-stop');
  const photoButtons = [
    document.querySelector('#f-e1-photo'),
    document.querySelector('#f-e1-photo-active'),
    document.querySelector('#f-e1-photo-preflight'),
  ];
  const cameraInput = document.querySelector('#f-e1-camera-input');
  const typeNoteButton = document.querySelector('#f-e1-type-note');
  const doneButton = document.querySelector('#f-e1-done');
  const backButton = document.querySelector('#f-e1-back-active');
  const backRibbonButton = document.querySelector('#f-e1-back');
  const editNoteButton = document.querySelector('#f-e1-edit-note');
  const editNoteInlineButton = document.querySelector('#f-e1-edit-note-inline');
  const submitButton = document.querySelector('#f-e1-submit');
  const note = document.querySelector('#f-e1-note');
  const timer = document.querySelector('#f-e1-timer');
  const list = document.querySelector('#f-e1-captured-list');
  const count = document.querySelector('#f-e1-captured-count');
  const activeCount = document.querySelector('#f-e1-active-count');
  const reviewText = document.querySelector('#f-e1-review-text');
  const preflightMeta = document.querySelector('#f-e1-preflight-meta');
  const preflightStatus = document.querySelector('#f-e1-preflight-status');
  const readoutList = document.querySelector('#f-e1-readout-list');
  const transcriptWarning = document.querySelector('#f-e1-transcript-warning');
  const photoCount = document.querySelector('#f-e1-photo-count');
  const photoGrid = document.querySelector('#f-e1-photo-grid');
  const statusNode = document.querySelector('#f-e1-submit-status');
  const playErrorNode = document.querySelector('#f-e1-play-error');
  const outcomeNode = document.querySelector('#f-e1-submit-outcome');
  const relayLink = document.querySelector('#f-e1-relay-link');
  const loopLinks = document.querySelector('#f-e1-loop-links');
  const fieldDetailLink = document.querySelector('#f-e1-field-detail-link');

  const ICON_VOICE =
    '<path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z"/><path d="M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/>';
  const ICON_PHOTO =
    '<path d="M9 2 7 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-3l-2-2zm3 15a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>';
  const ICON_NOTE =
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zm-1 7V3.5L18.5 9zM8 13h8v1.5H8zm0 3h8v1.5H8zm0 3h5v1.5H8z"/>';
  const ICON_CLOSE =
    '<path d="M19 6.4 17.6 5 12 10.6 6.4 5 5 6.4 10.6 12 5 17.6 6.4 19 12 13.4 17.6 19 19 17.6 13.4 12z"/>';

  let mediaRecorder = null;
  let mediaStream = null;
  let chunks = [];
  let startedAt = 0;
  let timerHandle = 0;
  let audioUri = null;
  let voiceDurationSec = 0;
  let voiceBlobKb = 0;
  const photos = [];
  const videos = [];
  const captured = [];

  function nowLabel() {
    const d = new Date();
    return `${d.getHours()}:${String(d.getMinutes()).padStart(2, '0')}`;
  }

  function setState(state) {
    if (shell instanceof HTMLElement) {
      shell.dataset.viewState = state;
    }
    if (state === 'active' && note instanceof HTMLTextAreaElement) {
      window.setTimeout(() => note.focus(), 100);
    }
  }

  function setStatus(message, tone = 'neutral') {
    if (!(statusNode instanceof HTMLElement)) return;
    statusNode.textContent = message;
    statusNode.dataset.tone = tone;
    if (outcomeNode instanceof HTMLElement) {
      outcomeNode.hidden = message.length === 0 && (playErrorNode instanceof HTMLElement ? playErrorNode.hidden : true);
    }
  }

  function setPlayError(message) {
    if (!(playErrorNode instanceof HTMLElement)) return;
    if (message.length === 0) {
      playErrorNode.hidden = true;
      playErrorNode.textContent = '';
      return;
    }
    playErrorNode.hidden = false;
    playErrorNode.textContent = message;
    if (outcomeNode instanceof HTMLElement) outcomeNode.hidden = false;
  }

  function setRelayLinkVisible(visible) {
    if (!(relayLink instanceof HTMLElement)) return;
    relayLink.hidden = !visible;
    if (visible && outcomeNode instanceof HTMLElement) outcomeNode.hidden = false;
  }

  function showLoopLinks(entryId) {
    if (!(loopLinks instanceof HTMLElement)) return;
    loopLinks.hidden = false;
    if (outcomeNode instanceof HTMLElement) outcomeNode.hidden = false;
    if (fieldDetailLink instanceof HTMLAnchorElement && typeof entryId === 'string' && entryId.length > 0) {
      fieldDetailLink.href = `/field-detail?entry_id=${encodeURIComponent(entryId)}`;
    }
  }

  function resetSubmitOutcome() {
    setPlayError('');
    setRelayLinkVisible(false);
    if (loopLinks instanceof HTMLElement) loopLinks.hidden = true;
    setStatus('');
    if (outcomeNode instanceof HTMLElement) outcomeNode.hidden = true;
  }

  function finalizeSubmitOutcome(body, transcriptLength) {
    applySubmitOutcome(body, transcriptLength);
    const entryId =
      typeof body?.event?.entry_id === 'string'
        ? body.event.entry_id
        : typeof body?.entry_id === 'string'
          ? body.entry_id
          : null;
    if (entryId) {
      showLoopLinks(entryId);
    }
  }

  function applySubmitOutcome(body, transcriptLength) {
    const playError = typeof body.play_error === 'string' ? body.play_error.trim() : '';
    const surfaced = body.surfaced_event ?? null;
    const driftSeverity = body.drift_event?.severity ?? null;
    const hasVoiceOrPhotoOnly = transcriptLength === 0 && (audioUri !== null || photos.length > 0 || videos.length > 0);

    if (playError.length > 0) {
      setStatus('Captured to Daily Log, but Right Hand hit a problem while reviewing.', 'error');
      setPlayError(`Right Hand error: ${playError}`);
      setRelayLinkVisible(Boolean(surfaced));
      return;
    }

    setPlayError('');

    if (surfaced) {
      setStatus('Saved to Daily Log. Right Hand flagged this for office review. Open Relay.', 'success');
      setRelayLinkVisible(true);
      return;
    }

    if (driftSeverity) {
      setStatus(
        'Saved to Daily Log. Right Hand noted something to watch but did not open a new Relay card for this entry.',
        'success',
      );
      setRelayLinkVisible(false);
      return;
    }

    if (hasVoiceOrPhotoOnly) {
      setStatus(
        'Saved to Daily Log as media-only. Add a typed summary next time for Right Hand review.',
        'success',
      );
      setRelayLinkVisible(false);
      return;
    }

    setStatus(
      'Saved to Daily Log. Right Hand is reviewing — open Relay only if something needs your attention.',
      'success',
    );
    setRelayLinkVisible(false);
  }

  function tickTimer() {
    if (!(timer instanceof HTMLElement) || startedAt === 0) return;
    const elapsed = Math.floor((Date.now() - startedAt) / 1000);
    const minutes = Math.floor(elapsed / 60);
    const seconds = String(elapsed % 60).padStart(2, '0');
    timer.textContent = `${minutes}:${seconds}`;
  }

  function captureIconKind(item) {
    if (item.kind === 'photo' || item.kind === 'video') return { cls: 'photo', svg: ICON_PHOTO };
    if (item.kind === 'note') return { cls: 'note', svg: ICON_NOTE };
    return { cls: 'voice', svg: ICON_VOICE };
  }

  function removeCapturedItem(index) {
    const item = captured[index];
    if (!item) return;
    if (item.kind === 'photo' && item.ref) {
      const i = photos.indexOf(item.ref);
      if (i >= 0) photos.splice(i, 1);
    } else if (item.kind === 'video' && item.ref) {
      const i = videos.indexOf(item.ref);
      if (i >= 0) videos.splice(i, 1);
    } else if (item.kind === 'voice') {
      audioUri = null;
      voiceDurationSec = 0;
      voiceBlobKb = 0;
    }
    captured.splice(index, 1);
    renderCaptured();
  }

  function renderCaptured() {
    if (!(list instanceof HTMLElement) || !(count instanceof HTMLElement)) return;
    list.innerHTML = '';
    if (captured.length === 0) {
      const empty = document.createElement('li');
      empty.className = 'cap-empty';
      empty.textContent = 'Voice memos, photos, and videos will show here.';
      list.append(empty);
    } else {
      captured.forEach((item, index) => {
        const li = document.createElement('li');
        li.className = 'cap-item';

        const icon = captureIconKind(item);
        const iconWrap = document.createElement('div');
        iconWrap.className = `cap-item-icon ${icon.cls}`;
        iconWrap.innerHTML = `<svg viewBox="0 0 24 24" aria-hidden="true">${icon.svg}</svg>`;

        const bodyWrap = document.createElement('div');
        bodyWrap.className = 'cap-item-body';
        const title = document.createElement('div');
        title.className = 'cap-item-title';
        title.textContent = item.title;
        const sub = document.createElement('div');
        sub.className = 'cap-item-sub';
        sub.textContent = item.detail;
        bodyWrap.append(title, sub);

        const meta = document.createElement('div');
        meta.className = 'cap-item-meta';
        meta.textContent = item.time ?? '';

        const action = document.createElement('button');
        action.type = 'button';
        action.className = 'cap-item-action';
        action.setAttribute('aria-label', `Remove ${item.title}`);
        action.innerHTML = `<svg viewBox="0 0 24 24" aria-hidden="true">${ICON_CLOSE}</svg>`;
        action.addEventListener('click', () => removeCapturedItem(index));

        li.append(iconWrap, bodyWrap, meta, action);
        list.append(li);
      });
    }
    const label = `${captured.length} item${captured.length === 1 ? '' : 's'}`;
    count.textContent = label;
    if (activeCount instanceof HTMLElement) activeCount.textContent = label;
  }

  function formatVoiceDuration(seconds) {
    const mins = Math.floor(seconds / 60);
    const secs = String(seconds % 60).padStart(2, '0');
    return `${mins}:${secs}`;
  }

  function renderCaptureReadout(transcript) {
    if (!(readoutList instanceof HTMLElement)) return;
    readoutList.innerHTML = '';
    const rows = [];
    if (audioUri !== null) {
      const durationLabel = voiceDurationSec > 0 ? formatVoiceDuration(voiceDurationSec) : 'saved';
      const sizeLabel = voiceBlobKb > 0 ? `${voiceBlobKb} KB` : 'audio on device';
      rows.push({
        title: 'Voice memo',
        detail: `${durationLabel} · ${sizeLabel} · not transcribed yet`,
      });
    }
    if (photos.length > 0) {
      rows.push({
        title: `${photos.length} photo${photos.length === 1 ? '' : 's'}`,
        detail: 'Attached to this Daily Log entry',
      });
    }
    if (videos.length > 0) {
      rows.push({
        title: `${videos.length} video${videos.length === 1 ? '' : 's'}`,
        detail: 'Attached to this capture session · durable upload ships with media library',
      });
    }
    if (transcript.length > 0) {
      rows.push({
        title: 'Typed summary',
        detail: `${transcript.length} characters ready for Right Hand`,
      });
    }
    if (rows.length === 0) {
      const li = document.createElement('li');
      li.className = 'cap-empty';
      li.textContent = 'Nothing captured yet.';
      readoutList.append(li);
    } else {
      for (const row of rows) {
        const li = document.createElement('li');
        const title = document.createElement('strong');
        title.textContent = row.title;
        const detail = document.createElement('span');
        detail.textContent = row.detail;
        li.append(title, detail);
        readoutList.append(li);
      }
    }

    const needsSummary = transcript.length === 0 && (audioUri !== null || photos.length > 0 || videos.length > 0);
    if (transcriptWarning instanceof HTMLElement) {
      if (needsSummary) {
        transcriptWarning.hidden = false;
        transcriptWarning.textContent =
          'Voice captured, but not transcribed yet. Type a short summary so Right Hand can extract facts.';
      } else {
        transcriptWarning.hidden = true;
        transcriptWarning.textContent = '';
      }
    }

    if (submitButton instanceof HTMLElement) {
      const labelNode = submitButton.querySelector('.ar-label');
      const submitLabel = needsSummary ? 'Submit media only' : 'Submit to Daily Log';
      if (labelNode instanceof HTMLElement) {
        labelNode.textContent = submitLabel;
      } else {
        submitButton.dataset.label = submitLabel;
      }
    }
  }

  function renderPreflight() {
    const transcript = note instanceof HTMLTextAreaElement ? note.value.trim() : '';
    renderCaptureReadout(transcript);
    if (reviewText instanceof HTMLElement) {
      reviewText.textContent =
        transcript ||
        'No typed summary yet. Voice is not transcribed yet — type a short summary before submit.';
    }
    if (preflightMeta instanceof HTMLElement) {
      const parts = [];
      if (audioUri !== null) parts.push('voice');
      if (photos.length > 0) parts.push(`${photos.length} photo${photos.length === 1 ? '' : 's'}`);
      if (videos.length > 0) parts.push(`${videos.length} video${videos.length === 1 ? '' : 's'}`);
      if (transcript.length > 0) parts.push('typed summary');
      const destClientNode = document.getElementById('f-e1-dest-client');
      const destClient =
        destClientNode instanceof HTMLElement && destClientNode.textContent
          ? destClientNode.textContent.trim()
          : 'this job';
      preflightMeta.textContent =
        parts.length > 0
          ? `Daniel · writes to ${destClient} / today's Daily Log · ${parts.join(' · ')}`
          : 'Daily Log · nothing captured yet';
    }
    if (photoCount instanceof HTMLElement) {
      const mediaCount = photos.length + videos.length;
      photoCount.textContent = String(mediaCount);
    }
    if (photoGrid instanceof HTMLElement) {
      photoGrid.innerHTML = '';
      for (const photo of photos) {
        const tile = document.createElement('div');
        tile.className = 'photo-tile-mini';
        const img = document.createElement('img');
        img.src = photo.url;
        img.alt = photo.name;
        tile.append(img);
        photoGrid.append(tile);
      }
      for (const video of videos) {
        const tile = document.createElement('div');
        tile.className = 'photo-tile-mini video';
        tile.innerHTML = `<svg viewBox="0 0 24 24" aria-hidden="true">${ICON_PHOTO}</svg>`;
        const cap = document.createElement('span');
        cap.className = 'tile-cap';
        cap.textContent = video.name;
        tile.append(cap);
        photoGrid.append(tile);
      }
      const add = document.createElement('button');
      add.type = 'button';
      add.className = 'photo-tile-mini add';
      add.id = 'f-e1-photo-grid-add';
      add.setAttribute('aria-label', 'Add photo or video');
      add.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11 5v6H5v2h6v6h2v-6h6v-2h-6V5z"/></svg>';
      add.addEventListener('click', openCamera);
      photoGrid.append(add);
    }
  }

  function chooseMimeType() {
    if (!('MediaRecorder' in window)) return '';
    const options = ['audio/mp4', 'audio/aac', 'audio/webm;codecs=opus', 'audio/webm'];
    return options.find((option) => MediaRecorder.isTypeSupported(option)) ?? '';
  }

  async function startRecording() {
    setState('active');
    setStatus('');
    if (mediaRecorder && mediaRecorder.state !== 'inactive') {
      setStatus('Recording is already running. Tap Stop before starting another voice memo.', 'neutral');
      return;
    }
    if (!navigator.mediaDevices?.getUserMedia || !('MediaRecorder' in window)) {
      setStatus('Voice recording is not available here. Type the update and add photos.', 'neutral');
      return;
    }
    try {
      mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
      chunks = [];
      const mimeType = chooseMimeType();
      mediaRecorder = new MediaRecorder(mediaStream, mimeType ? { mimeType } : undefined);
      mediaRecorder.addEventListener('dataavailable', (event) => {
        if (event.data.size > 0) chunks.push(event.data);
      });
      mediaRecorder.addEventListener('stop', () => {
        const type = mediaRecorder?.mimeType || 'audio/webm';
        const blob = new Blob(chunks, { type });
        voiceBlobKb = Math.max(1, Math.round(blob.size / 1024));
        if (startedAt > 0) {
          voiceDurationSec = Math.max(1, Math.round((Date.now() - startedAt) / 1000));
        }
        // Phase 1G-A · the audio_uri is a stable in-browser handle for the
        // submit payload. Durable cloud upload of the audio blob is NOT
        // implemented in this lane — the blob lives in browser memory only
        // until submit. The capture still emits daily_log.entry_captured
        // with this URI so the event chain is intact; future media-library
        // lane wires real audio persistence.
        audioUri = `kerf://field-capture/audio-${Date.now()}`;
        const voiceItem = {
          kind: 'voice',
          title: 'Voice memo',
          detail: `${formatVoiceDuration(voiceDurationSec)} · ${voiceBlobKb} KB · transcribing…`,
          time: nowLabel(),
        };
        captured.push(voiceItem);
        renderCaptured();
        void transcribeBlob(blob, voiceItem);
      });
      mediaRecorder.start();
      startedAt = Date.now();
      tickTimer();
      timerHandle = window.setInterval(tickTimer, 500);
    } catch (err) {
      setStatus(`Could not start microphone: ${err instanceof Error ? err.message : String(err)}. Type the note instead.`, 'error');
    }
  }

  function stopRecording() {
    if (timerHandle) window.clearInterval(timerHandle);
    timerHandle = 0;
    if (startedAt > 0 && voiceDurationSec === 0) {
      voiceDurationSec = Math.max(1, Math.round((Date.now() - startedAt) / 1000));
    }
    startedAt = 0;
    if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
    if (mediaStream) {
      for (const track of mediaStream.getTracks()) track.stop();
    }
    mediaRecorder = null;
    mediaStream = null;
  }

  /**
   * Phase 1G-A · upload the recorded audio blob to /api/v1/transcribe and
   * insert the transcript into the typed-note textarea on success. On any
   * failure (unavailable, route-rejected, upstream error) the voice memo
   * stays captured and the operator is prompted to type the note instead.
   *
   * Honest contract:
   *   - No fake transcript. Failure paths show real status, not silent insert.
   *   - Successful transcript appends to existing note text (so the operator
   *     can record multiple clips that combine).
   *   - The "transcribing…" detail on the captured item flips to either the
   *     transcript word count or a "transcription unavailable" note.
   */
  async function transcribeBlob(blob, voiceItem) {
    const contentType = blob.type || 'audio/webm';
    let res;
    try {
      res = await fetch('/api/v1/transcribe', {
        method: 'POST',
        headers: { 'Content-Type': contentType },
        body: blob,
      });
    } catch (err) {
      updateCapturedTranscribeStatus(voiceItem, 'unavailable');
      setStatus(
        `Voice memo saved (${formatVoiceDuration(voiceDurationSec)}). Could not transcribe — type the note instead.`,
        'neutral',
      );
      return;
    }

    if (res.status === 503) {
      updateCapturedTranscribeStatus(voiceItem, 'unavailable');
      setStatus(
        'Transcription is not configured on this deploy. Voice memo saved — type the note.',
        'neutral',
      );
      return;
    }

    if (!res.ok) {
      updateCapturedTranscribeStatus(voiceItem, 'failed');
      setStatus(
        `Voice memo saved (${formatVoiceDuration(voiceDurationSec)}). Transcription failed — type the note instead.`,
        'neutral',
      );
      return;
    }

    let body;
    try {
      body = await res.json();
    } catch {
      body = {};
    }
    const transcript = typeof body?.transcript === 'string' ? body.transcript.trim() : '';
    if (transcript.length === 0) {
      updateCapturedTranscribeStatus(voiceItem, 'empty');
      setStatus(
        `Voice memo saved (${formatVoiceDuration(voiceDurationSec)}). No speech detected — type the note if needed.`,
        'neutral',
      );
      return;
    }

    if (note instanceof HTMLTextAreaElement) {
      const existing = note.value.trim();
      note.value = existing.length === 0 ? transcript : `${existing}\n\n${transcript}`;
    }
    const wordCount = transcript.split(/\s+/).filter(Boolean).length;
    updateCapturedTranscribeStatus(voiceItem, 'ok', wordCount);
    setStatus(`Transcribed ${wordCount} word${wordCount === 1 ? '' : 's'} into the note.`, 'success');
  }

  function updateCapturedTranscribeStatus(voiceItem, outcome, wordCount) {
    if (!voiceItem || !captured.includes(voiceItem)) return;
    const base = `${formatVoiceDuration(voiceDurationSec)} · ${voiceBlobKb} KB`;
    switch (outcome) {
      case 'ok':
        voiceItem.detail = `${base} · transcribed (${wordCount} words)`;
        break;
      case 'unavailable':
        voiceItem.detail = `${base} · transcription not available — type the note`;
        break;
      case 'failed':
        voiceItem.detail = `${base} · transcription failed — type the note`;
        break;
      case 'empty':
        voiceItem.detail = `${base} · no speech detected`;
        break;
      default:
        voiceItem.detail = base;
    }
    renderCaptured();
  }

  function openCamera() {
    if (cameraInput instanceof HTMLInputElement) cameraInput.click();
  }

  function handlePhotoPick() {
    if (!(cameraInput instanceof HTMLInputElement) || !cameraInput.files?.length) return;
    const file = cameraInput.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const time = nowLabel();
    if (file.type.startsWith('video/')) {
      const ref = { name: file.name || 'Field video', url };
      videos.push(ref);
      captured.push({ kind: 'video', title: 'Video', detail: file.name || 'Video walkthrough', time, ref });
    } else {
      const ref = { name: file.name || 'Field photo', url };
      photos.push(ref);
      captured.push({ kind: 'photo', title: 'Photo', detail: file.name || 'Camera capture', time, ref });
    }
    renderCaptured();
    cameraInput.value = '';
    setState('active');
  }

  async function submitDailyLogEntry() {
    if (!(submitButton instanceof HTMLElement)) return;
    const tenantId = submitButton.dataset.tenantId;
    const projectId = submitButton.dataset.projectId;
    const transcript = note instanceof HTMLTextAreaElement ? note.value.trim() : '';
    if (!tenantId || !projectId) {
      setStatus('Missing project assignment. Pick the project before submit.', 'error');
      return;
    }
    if (transcript.length === 0 && photos.length === 0 && videos.length === 0 && audioUri === null) {
      setStatus('Add a voice memo, note, photo, or video before submit.', 'error');
      return;
    }
    const checked = document.querySelector('input[name="entry_kind"]:checked');
    const entryKind = checked instanceof HTMLInputElement ? checked.value : 'progress_update';
    submitButton.setAttribute('aria-busy', 'true');
    resetSubmitOutcome();
    setStatus('Saving to Daily Log and running Right Hand...', 'neutral');
    try {
      // Phase 1G-A · media URIs are synthetic in-browser refs · photo/video
      // blobs are NOT durably uploaded by this lane (preview only via
      // URL.createObjectURL). The event chain still persists these URIs
      // so the daily_log.entry_captured source_refs are non-empty when
      // a media-only capture happens. A future media-library lane wires
      // durable media upload; until then these refs point at nothing.
      const synthesizedPhotoUris = photos.map(
        (_, index) => `kerf://field-capture/photo-${Date.now()}-${index + 1}`,
      );
      const synthesizedVideoUris = videos.map(
        (_, index) => `kerf://field-capture/video-${Date.now()}-${index + 1}`,
      );
      const res = await fetch(`/api/v1/projects/${encodeURIComponent(projectId)}/daily-log/entries`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tenant_id: tenantId,
          entry_kind: entryKind,
          transcript_text: transcript,
          audio_uri: audioUri,
          photo_uris: [...synthesizedPhotoUris, ...synthesizedVideoUris],
          actor: { id: 'browser_operator', role: 'field_super' },
        }),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) {
        const detail =
          typeof body.error === 'string'
            ? body.error
            : Array.isArray(body.errors)
              ? body.errors.join('; ')
              : `submit_failed_${res.status}`;
        throw new Error(detail);
      }
      finalizeSubmitOutcome(body, transcript.length);
    } catch (err) {
      setPlayError('');
      setRelayLinkVisible(false);
      setStatus(`Could not save: ${err instanceof Error ? err.message : String(err)}`, 'error');
    } finally {
      submitButton.removeAttribute('aria-busy');
    }
  }

  recordButton?.addEventListener('click', () => {
    void startRecording();
  });
  recordMoreButton?.addEventListener('click', () => {
    void startRecording();
  });
  recordActiveButton?.addEventListener('click', () => {
    void startRecording();
  });
  stopButton?.addEventListener('click', stopRecording);
  typeNoteButton?.addEventListener('click', () => setState('active'));
  photoButtons.forEach((button) => button?.addEventListener('click', openCamera));
  cameraInput?.addEventListener('change', handlePhotoPick);
  doneButton?.addEventListener('click', () => {
    stopRecording();
    const transcript = note instanceof HTMLTextAreaElement ? note.value.trim() : '';
    if (transcript.length === 0 && photos.length === 0 && videos.length === 0 && audioUri === null) {
      setStatus('Add a voice memo, typed note, photo, or video, then tap Done capturing again.', 'error');
      return;
    }
    renderPreflight();
    setState('preflight');
    if (preflightStatus instanceof HTMLElement) {
      preflightStatus.textContent =
        'Captured items moved here for review. Check voice, media, and typed summary before submit.';
    }
    if (transcript.length === 0 && (audioUri !== null || photos.length > 0 || videos.length > 0)) {
      setStatus(
        'Ready to submit — voice is saved but not transcribed yet. Add a typed summary if you want Right Hand review.',
        'neutral',
      );
    } else {
      setStatus('');
    }
  });
  backButton?.addEventListener('click', () => setState('active'));
  backRibbonButton?.addEventListener('click', () => setState('active'));
  editNoteButton?.addEventListener('click', () => setState('active'));
  editNoteInlineButton?.addEventListener('click', () => setState('active'));
  submitButton?.addEventListener('click', () => {
    void submitDailyLogEntry();
  });

  // ---- Destination selector (1J-C) ----
  // Capture is no longer hard-bound to one job. Default is the GPS/job-context
  // matched active job (dogfood: proj_wegrzyn_kitchen); the worker can switch to
  // pick-project / pick-client / unassigned. Non-active modes clear the project
  // binding so the existing submit guard asks for a project before send.
  const destSelect = document.getElementById('f-e1-destination');
  const fieldShellEl = document.querySelector('.field-shell');
  if (destSelect instanceof HTMLSelectElement) {
    const destClientEl = document.getElementById('f-e1-dest-client');
    const destProjectEl = document.getElementById('f-e1-dest-project');
    const destLocationEl = document.getElementById('f-e1-dest-location');
    const destHintEl = document.getElementById('f-e1-dest-hint');
    const dlAnchorEl = document.getElementById('f-e1-dl-anchor');
    const activeModeEl = document.getElementById('f-e1-active-mode');
    const activeClient = destSelect.dataset.activeClient ?? 'this job';
    const activeProject = destSelect.dataset.activeProject ?? '';
    const activeLocation = destSelect.dataset.activeLocation ?? '';
    const matchedBy = destSelect.dataset.matchedBy ?? 'job-site GPS';
    const applyDestination = () => {
      const option = destSelect.selectedOptions[0];
      const projectId = option instanceof HTMLOptionElement ? option.dataset.projectId ?? '' : '';
      if (fieldShellEl instanceof HTMLElement) fieldShellEl.dataset.projectId = projectId;
      if (submitButton instanceof HTMLElement) submitButton.dataset.projectId = projectId;
      const isActive = destSelect.value === 'active';
      if (destClientEl) destClientEl.textContent = isActive ? activeClient : '—';
      if (destProjectEl) destProjectEl.textContent = isActive ? activeProject : 'Choose a project';
      if (destLocationEl) destLocationEl.textContent = isActive ? activeLocation : '—';
      if (dlAnchorEl) {
        dlAnchorEl.textContent = isActive
          ? `Writes to ${activeClient} · today's Daily Log.`
          : 'Pick a project to file this capture before submit.';
      }
      if (activeModeEl) {
        activeModeEl.textContent = isActive
          ? `Capturing · ${activeClient} / ${activeLocation}`
          : 'Capturing · unassigned';
      }
      if (destHintEl) {
        destHintEl.textContent = isActive
          ? `Matched to your active job by ${matchedBy}. Change it above if this capture belongs elsewhere.`
          : 'Project / client pickers arrive in a later release — for now, capture to your active job or save as an unassigned note.';
      }
    };
    destSelect.addEventListener('change', applyDestination);
  }

  renderCaptured();
</script>

<style>
  /* Canon --kerf-* tokens live in the shared skin (styles/shell.css).
     Phase 1J Agent B ports the F-E1 canon visual treatment here; no local
     :root is reintroduced — the page consumes the shared canon tokens. */
