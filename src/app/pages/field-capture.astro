    min-height: 100vh;
    margin: -2rem;
    padding: 18px 12px 34px;
    background:
      radial-gradient(circle at 12% 0%, rgba(56, 201, 119, 0.16), transparent 34%),
      linear-gradient(180deg, var(--kerf-bg-2) 0%, var(--kerf-bg) 55%, var(--kerf-bg) 100%);
    color: var(--kerf-text);
    display: flex;
    justify-content: center;
  }

  .phone-frame {
    width: min(100%, 392px);
    min-height: calc(100vh - 36px);
    background: var(--kerf-bg);
    border: 1.5px solid var(--kerf-border);
    border-radius: 30px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
    overflow: hidden;
    padding: 12px 12px 14px;
  }

  /* ===== Status bar ===== */
  .status-bar {
    display: flex;
    justify-content: space-between;
    padding: 6px 10px 8px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--kerf-text);
  }
  .status-bar .right {
    color: var(--kerf-text-dim);
    letter-spacing: 0.04em;
  }

  /* ===== Top chrome (per state) ===== */
  .top-chrome {
    padding: 6px 6px 12px;
    border-bottom: 1px solid var(--kerf-border-soft);
    margin-bottom: 12px;
  }
  .tc-eyebrow {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
    font-size: 0.62rem;
  }
  .tc-mode {
    color: var(--field-green);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 800;
  }
  .tc-user {
    color: var(--kerf-text-mute);
    font-variant-numeric: tabular-nums;
  }
  .tc-back,
  .tc-back-btn {
    color: var(--field-green);
    text-decoration: none;
    font-weight: 700;
    background: none;
    border: 0;
    padding: 0;
    font: inherit;
    cursor: pointer;
  }
  .tc-title {
    margin: 0;
    font-size: 1.06rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--kerf-text);
  }
  .tc-title-sm {
    font-size: 0.95rem;
  }
  .tc-meta {
    display: flex;
    gap: 6px;
    align-items: center;
    margin: 5px 0 0;
    font-size: 0.66rem;
    color: var(--kerf-text-dim);
  }
  .tc-meta svg {
    width: 12px;
    height: 12px;
    fill: currentColor;
    flex-shrink: 0;
  }

  /* ===== State machine ===== */
  .capture-state {
    display: none;
  }
  .field-shell[data-view-state='pre'] .state-pre,
  .field-shell[data-view-state='active'] .state-active,
  .field-shell[data-view-state='preflight'] .state-preflight {
    display: block;
  }

  /* ===== Assignment card ===== */
  .dest-selector {
    margin-bottom: 10px;
  }
  .dest-select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    background: var(--kerf-surface);
    color: var(--kerf-text);
    border: 1px solid var(--kerf-border);
    border-radius: 12px;
    padding: 11px 13px;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .dest-select:focus-visible {
    outline: 2px solid var(--field-green);
    outline-offset: 1px;
  }
  .dest-hint {
    margin: 6px 2px 0;
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--kerf-text-mute);
  }
  .assign-card {
    background: var(--kerf-surface);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 12px;
    padding: 11px 13px;
    margin-bottom: 10px;
  }
  .assign-eyebrow {
    display: block;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--field-green);
    font-weight: 800;
    margin: 0 0 7px;
  }
  .assign-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid var(--kerf-border-soft);
    font-size: 0.78rem;
  }
  .assign-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .ar-key {
    font-size: 0.6rem;
    color: var(--kerf-text-mute);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .ar-val {
    color: var(--kerf-text);
    font-weight: 600;
    text-align: right;
  }
  .ar-val-dim {
    font-weight: 500;
    color: var(--kerf-text-dim);
  }

  /* ===== Daily Log anchor ===== */
  .dl-anchor {
    margin: 0 0 12px;
    background: rgba(56, 201, 119, 0.04);
    border: 1px solid rgba(56, 201, 119, 0.25);
    border-left: 3px solid var(--field-green);
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.7rem;
    color: var(--kerf-text-dim);
    line-height: 1.45;
  }
  .dl-anchor strong {
    color: var(--field-green);
    display: block;
    margin-bottom: 3px;
  }
  .dl-anchor .dl-detail {
    color: var(--kerf-text-mute);
    display: block;
  }

  /* ===== Record area ===== */
  .record-area {
    margin: 16px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }
  .record-button {
    width: 88px;
    height: 88px;
    border: 0;
    border-radius: 50%;
    background: var(--field-green);
    color: #0a1a0f;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 22px rgba(56, 201, 119, 0.3);
    position: relative;
    cursor: pointer;
  }
  .record-button::after {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px solid rgba(56, 201, 119, 0.3);
  }
  .record-button svg {
    width: 38px;
    height: 38px;
    fill: currentColor;
  }
  .record-label {
    margin: 6px 0 0;
    font-size: 0.82rem;
    color: var(--kerf-text);
    font-weight: 700;
  }
  .record-sublabel {
    margin: 0;
    font-size: 0.7rem;
    color: var(--kerf-text-mute);
    line-height: 1.4;
    padding: 0 14px;
  }

  /* ===== Secondary capture ===== */
  .cap-secondary {
    margin: 12px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .cap-button {
    background: var(--kerf-surface);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 10px;
    padding: 10px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    color: var(--kerf-text);
    cursor: pointer;
    font: inherit;
  }
  .cap-button svg {
    width: 18px;
    height: 18px;
    fill: var(--field-green);
  }
  .cb-label {
    font-size: 0.76rem;
    font-weight: 700;
  }
  .cb-sub {
    font-size: 0.62rem;
    color: var(--kerf-text-mute);
  }
  .cap-button-row {
    flex-direction: row;
    justify-content: center;
    gap: 7px;
    padding: 11px 8px;
  }

  /* ===== Live record bar ===== */
  .live-record-bar {
    margin: 0 0 10px;
    background: rgba(56, 201, 119, 0.06);
    border: 1px solid rgba(56, 201, 119, 0.4);
    border-radius: 10px;
    padding: 9px 11px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .live-rec-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--field-green);
    flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(56, 201, 119, 0.2);
  }
  .live-rec-body {
    flex: 1;
  }
  .live-rec-label {
    margin: 0;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--field-green);
    font-weight: 800;
  }
  .live-rec-time {
    font-size: 0.86rem;
    color: var(--kerf-text);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }
  .live-rec-stop {
    background: var(--field-green);
    color: #0a1a0f;
    font-weight: 800;
    padding: 6px 12px;
    border: 0;
    border-radius: 7px;
    font-size: 0.72rem;
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    font-family: inherit;
  }
  .live-rec-stop svg {
    width: 10px;
    height: 10px;
    fill: currentColor;
  }

  /* ===== Cards (note / readout / preflight / transcript / media / continue) ===== */
  .note-card,
  .preflight-card,
  .capture-readout,
  .final-transcript,
  .media-card,
  .draft-intent-card,
  .continue-capture {
    background: var(--kerf-surface);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 12px;
    padding: 12px 13px;
    margin-bottom: 10px;
  }
  .note-card {
    display: block;
  }
  .card-eyebrow {
    margin: 0 0 5px;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--field-green);
    font-weight: 800;
  }
  .note-helper {
    margin: 0 0 8px;
    color: var(--kerf-text-mute);
    font-size: 0.74rem;
    line-height: 1.4;
  }
  textarea {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--kerf-border-soft);
    border-radius: 10px;
    background: var(--kerf-bg-2);
    color: var(--kerf-text);
    padding: 11px;
    resize: vertical;
    font-size: 16px;
    font-family: inherit;
  }
  textarea:focus-visible {
    outline: 2px solid var(--field-green);
    outline-offset: 1px;
  }

  /* ===== Captured items (canon cap-item grid) ===== */
  .captured-items {
    margin: 0 0 10px;
  }
  .captured-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kerf-text-dim);
    font-weight: 800;
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .captured-eyebrow .ce-count {
    color: var(--kerf-text-mute);
    font-weight: 500;
  }
  .cap-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .cap-empty {
    border: 1px dashed var(--kerf-border-soft);
    border-radius: 8px;
    padding: 12px 10px;
    color: var(--kerf-text-mute);
    font-size: 0.76rem;
    text-align: center;
  }
  .cap-item {
    background: var(--kerf-surface);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 8px;
    padding: 8px 10px;
    display: grid;
    grid-template-columns: 26px 1fr auto auto;
    gap: 9px;
    align-items: center;
  }
  .cap-item-icon {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cap-item-icon svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }
  .cap-item-icon.voice {
    background: rgba(56, 201, 119, 0.14);
    color: var(--field-green);
  }
  .cap-item-icon.photo {
    background: rgba(123, 168, 255, 0.14);
    color: var(--kerf-blue);
  }
  .cap-item-icon.note {
    background: rgba(245, 181, 68, 0.14);
    color: var(--kerf-amber);
  }
  .cap-item-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .cap-item-title {
    font-size: 0.76rem;
    color: var(--kerf-text);
    font-weight: 700;
  }
  .cap-item-sub {
    font-size: 0.66rem;
    color: var(--kerf-text-mute);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cap-item-meta {
    font-size: 0.62rem;
    color: var(--kerf-text-mute);
    font-variant-numeric: tabular-nums;
  }
  .cap-item-action {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    background: transparent;
    border: 1px solid var(--kerf-border-soft);
    color: var(--kerf-text-mute);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .cap-item-action svg {
    width: 11px;
    height: 11px;
    fill: currentColor;
  }

  /* ===== Pre-flight summary ===== */
  .preflight-status {
    margin: 0 0 10px;
    color: var(--field-green);
    font-size: 0.8rem;
    line-height: 1.4;
  }
  .preflight-card {
    background: linear-gradient(135deg, rgba(56, 201, 119, 0.07), rgba(123, 168, 255, 0.04));
    border: 1px solid rgba(56, 201, 119, 0.3);
  }
  .pf-eyebrow {
    margin: 0 0 4px;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--field-green);
    font-weight: 800;
  }
  .pf-title {
    margin: 0 0 4px;
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--kerf-text);
    line-height: 1.3;
  }
  .pf-meta {
    margin: 0;
    font-size: 0.7rem;
    color: var(--kerf-text-dim);
    line-height: 1.4;
  }

  /* ===== Capture readout ===== */
  .readout-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }
  .readout-list li {
    border: 1px solid var(--kerf-border-soft);
    border-radius: 8px;
    padding: 9px 10px;
    background: var(--kerf-bg-2);
  }
  .readout-list strong,
  .readout-list span {
    display: block;
  }
  .readout-list strong {
    font-size: 0.76rem;
  }
  .readout-list span {
    color: var(--kerf-text-mute);
    font-size: 0.68rem;
    margin-top: 2px;
  }
  .readout-warning {
    margin: 10px 0 0;
    padding: 9px 10px;
    border-radius: 8px;
    border: 1px solid rgba(245, 181, 68, 0.45);
    background: rgba(245, 181, 68, 0.12);
    color: #f8e6b5;
    font-size: 0.72rem;
    line-height: 1.42;
  }
  .readout-warning[hidden] {
    display: none;
  }

  /* ===== Draft-intent picker (canon radio cards) ===== */
  .draft-intent-card {
    border: 1px solid var(--kerf-border-soft);
    margin: 0 0 10px;
    padding: 11px 13px;
  }
  .di-eyebrow {
    padding: 0;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--field-green);
    font-weight: 800;
    margin-bottom: 8px;
  }
  .di-option {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 9px;
    align-items: flex-start;
    background: var(--kerf-bg-2);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 8px;
    padding: 9px 10px;
    margin-bottom: 6px;
    cursor: pointer;
  }
  .di-option:last-child {
    margin-bottom: 0;
  }
  .di-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .di-radio {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--kerf-border);
    margin-top: 2px;
    grid-column: 1;
  }
  .di-body {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .di-option:has(input:checked) {
    background: rgba(56, 201, 119, 0.06);
    border-color: var(--field-green);
  }
  .di-option:has(input:checked) .di-radio {
    border-color: var(--field-green);
    background: var(--field-green);
    position: relative;
  }
  .di-option:has(input:checked) .di-radio::after {
    content: '';
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--kerf-bg);
    margin: 2.5px auto;
  }
  .di-option:has(input:focus-visible) {
    outline: 2px solid var(--field-green);
    outline-offset: 1px;
  }
  .di-option-title {
    font-size: 0.76rem;
    color: var(--kerf-text);
    font-weight: 700;
  }
  .di-option-detail {
    font-size: 0.66rem;
    color: var(--kerf-text-mute);
    line-height: 1.4;
  }

  /* ===== Final transcript ===== */
  .ft-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--kerf-text-dim);
    font-weight: 800;
    margin-bottom: 7px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ft-edit {
    color: var(--kerf-blue);
    font-size: 0.64rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    text-transform: none;
    letter-spacing: 0;
  }
  .ft-edit svg {
    width: 11px;
    height: 11px;
    fill: currentColor;
  }
  .ft-text {
    margin: 0;
    white-space: pre-wrap;
    font-size: 0.78rem;
    color: var(--kerf-text);
    line-height: 1.5;
  }
  .transcript-canon-hint {
    margin: 8px 0 0;
    padding: 7px 9px;
    background: rgba(123, 168, 255, 0.05);
    border-left: 2px solid var(--kerf-blue);
    border-radius: 3px;
    font-size: 0.66rem;
    color: var(--kerf-text-mute);
    line-height: 1.42;
  }
  .transcript-canon-hint strong {
    color: var(--kerf-blue);
  }

  /* ===== Media / photo grid mini ===== */
  .media-card .ce-count {
    color: var(--kerf-text-mute);
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0;
  }
  .photo-grid-mini {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }
  .photo-tile-mini {
    aspect-ratio: 1;
    border-radius: 6px;
    background: linear-gradient(135deg, #2a3a4a, #1a2530);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(56, 201, 119, 0.3);
    overflow: hidden;
    position: relative;
    padding: 0;
    color: var(--field-green);
  }
  .photo-tile-mini img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .photo-tile-mini svg {
    width: 14px;
    height: 14px;
    fill: var(--field-green);
  }
  .photo-tile-mini .tile-cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    font-size: 0.52rem;
    line-height: 1.2;
    color: var(--kerf-text);
    background: rgba(10, 13, 17, 0.7);
    padding: 2px 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .photo-tile-mini.add {
    background: rgba(56, 201, 119, 0.05);
    border-style: dashed;
    cursor: pointer;
  }
  .photo-tile-mini.add svg {
    opacity: 0.75;
  }

  /* ===== Continue capture ===== */
  .continue-capture {
    border-color: rgba(56, 201, 119, 0.28);
  }
  .compact-record-zone {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }
  .compact-record-button {
    width: 58px;
    height: 58px;
    flex: 0 0 auto;
    box-shadow: 0 6px 16px rgba(56, 201, 119, 0.26);
  }
  .compact-record-button::after {
    inset: -5px;
  }
  .compact-record-button svg {
    width: 24px;
    height: 24px;
  }
  .compact-record-zone .record-label {
    margin: 0;
    text-align: left;
  }
  .compact-record-zone .record-sublabel {
    padding: 0;
    text-align: left;
  }
  .continue-capture .cap-secondary {
    margin: 0;
  }

  /* ===== AI disclosure ===== */
  .ai-disclosure {
    margin: 0 0 10px;
    padding: 8px 11px;
    background: rgba(201, 169, 97, 0.05);
    border-left: 2px solid var(--right-hand);
    border-radius: 3px;
    font-size: 0.66rem;
    color: var(--kerf-text-mute);
    line-height: 1.42;
  }
  .ai-disclosure strong {
    color: var(--right-hand);
  }

  /* ===== Action ribbon ===== */
  .action-ribbon {
    background: var(--kerf-bg-2);
    border: 1px solid var(--kerf-border);
    border-radius: 12px;
    padding: 8px;
    display: flex;
    gap: 6px;
    align-items: stretch;
    margin-top: 12px;
  }
  .ar-btn {
    flex: 1;
    padding: 10px 8px;
    text-align: center;
    background: var(--kerf-surface);
    border: 1px solid var(--kerf-border-soft);
    border-radius: 10px;
    font-size: 0.72rem;
    color: var(--kerf-text);
    font-weight: 700;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
  }
  .ar-btn svg {
    width: 15px;
    height: 15px;
    fill: currentColor;
  }
  .ar-btn.primary {
    background: var(--field-green);
    color: #0a1a0f;
    border-color: var(--field-green);
  }
  .ar-btn.cancel {
    color: var(--kerf-red);
  }
  .ar-btn[aria-busy='true'] {
    opacity: 0.6;
  }

  /* ===== Submit outcome ===== */
  .submit-outcome {
    max-width: min(100%, 392px);
    margin: 14px auto 0;
    padding: 12px;
    border: 1px solid var(--kerf-border-soft);
    border-radius: 12px;
    background: var(--kerf-surface);
  }
  .submit-outcome[hidden] {
    display: none;
  }
  .submit-status {
    min-height: 1.25rem;
    margin: 0;
    color: var(--kerf-text-dim);
    line-height: 1.45;
    text-align: center;
    font-size: 0.82rem;
  }
  .submit-status[data-tone='success'] {
    color: var(--field-green);
  }
  .submit-status[data-tone='error'] {
    color: var(--kerf-red);
  }
  .submit-play-error {
    margin: 10px 0 0;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid rgba(248, 113, 113, 0.45);
    background: rgba(248, 113, 113, 0.12);
    color: #ffb4b4;
    font-size: 0.74rem;
    line-height: 1.4;
  }
  .submit-play-error[hidden] {
    display: none;
  }
  .relay-link {
    display: block;
    margin-top: 12px;
    text-align: center;
    color: var(--field-green);
    text-decoration: none;
    font-weight: 800;
  }
  .loop-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }
  .loop-links[hidden] {
    display: none;
  }
  .loop-link {
    display: block;
    text-align: center;
    color: var(--field-green);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.82rem;
  }

  @media (min-width: 760px) {
