---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import RhSummary from '../components/RhSummary.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { moreDomainLinksForRole } from '../../shell/moreDomainNav.js';
import type { ShellRoleRoot } from '../../contracts/lane1/domains.js';

const { context, t } = createLayoutContext();
const domainLinks = moreDomainLinksForRole(context.roleRoot as ShellRoleRoot);

const quickLinks = [
  {
    href: '/schedule',
    titleKey: 'shell.domain.schedule' as const,
    detailKey: 'shell.more.schedule_detail' as const,
  },
  {
    href: '/reports',
    titleKey: 'nav.reports' as const,
    detailKey: 'shell.more.reports_detail' as const,
  },
  {
    href: '/settings',
    titleKey: 'nav.settings' as const,
    detailKey: 'shell.more.settings_detail' as const,
  },
].filter((item) => domainLinks.some((link) => link.href === item.href));
---

<Layout titleKey="shell.more.title" activeHref="/more">
  <section class="more-page" aria-labelledby="more-title">
    <RhSummary
      headline={t('shell.more.title')}
      detail={t('shell.more.lead')}
      tone="green"
    />

    <Card eyebrow="Route anywhere" title="Say it, type it, or tap it.">
      <form class="more-page__route" action="/right-hand" method="get" role="search">
        <label class="sr-only" for="more-route-q">Ask Right Hand to route you</label>
        <input id="more-route-q" name="q" type="search" placeholder="Ask: take me to Wegrzyn daily..." />
        <button type="submit">Ask</button>
      </form>
      <div class="more-page__route-chips" aria-label="Common routes">
        <a href="/projects/proj_wegrzyn_kitchen">This job</a>
        <a href="/camera">Camera</a>
        <a href="/sales">Sales</a>
        <a href="/change-orders/new">Change order</a>
      </div>
    </Card>

    <Card eyebrow={t('shell.more.domains_eyebrow')} title={t('shell.more.domains_title')}>
      <p class="more-page__copy">{t('shell.more.domains_copy')}</p>
      <nav class="more-page__nav" aria-label={t('shell.more.domains_aria')}>
        {domainLinks.map((link) => (
          <a href={link.href}>
            <span>{t(link.labelKey)}</span>
          </a>
        ))}
      </nav>
    </Card>

    {quickLinks.length > 0 ? (
      <Card eyebrow={t('shell.more.quick_eyebrow')} title={t('shell.more.quick_title')}>
        <div class="more-page__actions">
          {quickLinks.map((item) => (
            <a class="more-page__action" href={item.href}>
              <span>{t(item.titleKey)}</span>
              <small>{t(item.detailKey)}</small>
            </a>
          ))}
        </div>
      </Card>
    ) : null}
  </section>
</Layout>

<style>
  .more-page {
    display: grid;
    gap: 0.85rem;
  }

  .more-page__copy {
    margin: 0 0 0.85rem;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .more-page__route {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    margin-bottom: 0.7rem;
  }

  .more-page__route input,
  .more-page__route button {
    min-height: 44px;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    font: inherit;
  }

  .more-page__route input {
    min-width: 0;
    padding: 0 0.8rem;
    background: var(--surface-2, #f1efe7);
    color: var(--text, #181713);
  }

  .more-page__route button {
    padding: 0 0.9rem;
    background: var(--kerf-text, #181713);
    color: var(--kerf-bg, #f7f6f1);
    font-weight: 900;
  }

  .more-page__route-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .more-page__route-chips a {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 999px;
    padding: 0 0.65rem;
    background: var(--surface-2, #f1efe7);
    color: inherit;
    font-size: 0.78rem;
    font-weight: 900;
    text-decoration: none;
  }

  .more-page__actions {
    display: grid;
    gap: 0.65rem;
  }

  .more-page__action,
  .more-page__nav a {
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
    box-shadow: 0 10px 24px rgba(24, 23, 19, 0.06);
  }

  .more-page__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
  }

  .more-page__action:hover,
  .more-page__nav a:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .more-page__action span,
  .more-page__nav a span {
    font-weight: 700;
  }

  .more-page__action small,
  .more-page__nav a small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
    font-weight: 500;
    font-size: 0.72rem;
  }

  .more-page__nav {
    display: grid;
    gap: 0.55rem;
  }

  .more-page__nav a {
    display: grid;
    gap: 0.12rem;
    padding: 0.75rem 0.85rem;
  }

  .more-page__nav a::after {
    content: none;
  }
</style>
