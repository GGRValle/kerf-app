---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import RhSummary from '../components/RhSummary.astro';
import { MORE_NAV_LINKS } from '../lib/shellRoutes.js';
import { createLayoutContext } from '../lib/createLayoutContext.js';

const { t } = createLayoutContext();

const primaryDestinations = [
  {
    href: '/schedule',
    title: 'Schedule',
    detail: 'See the current schedule preview and jump back to projects or office cards.',
  },
  {
    href: '/reports',
    title: 'Reports',
    detail: 'Open audit, project, and money views that are already safe to inspect.',
  },
  {
    href: '/settings',
    title: 'Settings',
    detail: 'Review tenant-safe defaults and the role-routing preview.',
  },
] as const;
---

<Layout titleKey="shell.more.title" activeHref="/more">
  <section class="more-page" aria-labelledby="more-title">
    <RhSummary
      headline="More"
      detail="These are the secondary surfaces for the phone test. Working links open real routes; preview areas say so plainly."
      tone="green"
    />

    <Card eyebrow="Available now" title="Keep moving">
      <p class="more-page__copy">
        Right Hand stays on the bottom mic. Use these destinations when you want
        to leave the conversation and inspect a specific part of the business.
      </p>
      <div class="more-page__actions">
        {primaryDestinations.map((item) => (
          <a class="more-page__action" href={item.href}>
            <span>{item.title}</span>
            <small>{item.detail}</small>
          </a>
        ))}
      </div>
    </Card>

    <Card eyebrow="All destinations" title={t('shell.more.title')}>
      <nav class="more-page__nav" aria-label={t('shell.more.nav_aria')}>
        {MORE_NAV_LINKS.map((link) => (
          <a href={link.href}>{t(link.labelKey)}</a>
        ))}
      </nav>
    </Card>
  </section>
</Layout>

<style>
  .more-page {
    display: grid;
    gap: 0.85rem;
  }

  .more-page__copy {
    margin: 0 0 0.85rem;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .more-page__actions {
    display: grid;
    gap: 0.65rem;
  }

  .more-page__action,
  .more-page__nav a {
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
  }

  .more-page__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
  }

  .more-page__action:hover,
  .more-page__nav a:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .more-page__action span {
    font-weight: 700;
  }

  .more-page__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }

  .more-page__nav {
    display: grid;
    gap: 0.55rem;
  }

  .more-page__nav a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0.85rem;
    font-weight: 650;
  }

  .more-page__nav a::after {
    content: '->';
    color: var(--text-muted, #5c6670);
  }
</style>
