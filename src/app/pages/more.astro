---
import Layout from '../layouts/Layout.astro';
import RhSummary from '../components/RhSummary.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';

const { context } = createLayoutContext();
const isFieldRole = context.roleRoot === 'field_hand' || context.roleRoot === 'sub';

const ownerWorkAreas = [
  { href: '/start', title: 'Start', detail: 'Capture, new lead, change order, room scan.' },
  { href: '/design/proj_wegrzyn_kitchen', title: 'Design', detail: 'Selections, visual choices, owner questions.' },
  { href: '/sales', title: 'Sales', detail: 'Leads, estimates, proposals, signatures.' },
  { href: '/projects', title: 'Project', detail: 'Jobs, scope, dailies, files.' },
  { href: '/schedule', title: 'Schedule & Crew', detail: 'Crew map, dispatch, job timing, blockers.' },
  { href: '/money', title: 'Money', detail: 'Invoices, bills, margin, exports.' },
  { href: '/client-success', title: 'Success', detail: 'Closeout, warranty, referrals.' },
] as const;

const fieldWorkAreas = [
  { href: '/start', title: 'Start', detail: 'Capture, note, work order update.' },
  { href: '/schedule', title: 'Schedule', detail: 'Today, assignments, proof, start windows.' },
] as const;

const ownerDetailLinks = [
  { href: '/settings/people', title: 'People & permissions', detail: 'Add users, roles, employee records, pay, and access.' },
  { href: '/connections', title: 'Connections', detail: 'What Right Hand can use: sources, files, and outside tools.' },
  { href: '/library', title: 'Knowledge base', detail: 'Standards, templates, lessons, and company memory.' },
  { href: '/settings', title: 'Company settings', detail: 'Tenant setup, audit, app status, and account controls.' },
] as const;

const fieldDetailLinks = [
  { href: '/settings/me', title: 'My access', detail: 'Account, language, and field profile.' },
  { href: '/connections', title: 'Saved proof', detail: 'Local capture and sync status for work you filed.' },
] as const;

const workAreas = isFieldRole ? fieldWorkAreas : ownerWorkAreas;
const detailLinks = isFieldRole ? fieldDetailLinks : ownerDetailLinks;
---

<Layout titleKey="shell.more.title" activeHref="/more">
  <section class="more-page" aria-labelledby="more-title">
    <RhSummary
      headline="More"
      detail="Open the part of the job you need. Home stays focused on what needs your call."
      tone="green"
    />

    <section class="more-page__shell" aria-label="Work areas">
      <aside class="more-page__sidebar" aria-labelledby="more-domains-title">
        <div class="more-page__sidebar-head">
          <p>From capture to completion</p>
          <h2 id="more-domains-title">Work areas</h2>
        </div>
        <nav class="more-page__nav" aria-label="Job spine work areas">
          {workAreas.map((area) => (
            <a href={area.href}>
              <span>{area.title}</span>
              <small>{area.detail}</small>
            </a>
          ))}
        </nav>
      </aside>

      <section class="more-page__details" aria-labelledby="more-details-title">
        <div class="more-page__details-head">
          <p>Keep the company wired</p>
          <h2 id="more-details-title">Company details</h2>
        </div>
        <div class="more-page__detail-grid">
          {detailLinks.map((item) => (
            <a href={item.href}>
              <span>{item.title}</span>
              <small>{item.detail}</small>
            </a>
          ))}
        </div>
      </section>
    </section>
  </section>
</Layout>

<style>
  .more-page {
    display: grid;
    gap: 0.85rem;
    padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
  }

  .more-page__shell {
    display: grid;
    gap: 1rem;
  }

  .more-page__sidebar,
  .more-page__details {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    background: var(--surface, #fff);
    box-shadow: 0 12px 28px rgba(24, 23, 19, 0.06);
  }

  .more-page__sidebar-head {
    display: grid;
    gap: 0.18rem;
  }

  .more-page__sidebar-head p,
  .more-page__sidebar-head h2,
  .more-page__details-head p,
  .more-page__details-head h2 {
    margin: 0;
  }

  .more-page__details-head {
    display: grid;
    gap: 0.18rem;
  }

  .more-page__sidebar-head p,
  .more-page__details-head p {
    color: var(--text-muted, #5c6670);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .more-page__sidebar-head h2,
  .more-page__details-head h2 {
    font-size: 1.18rem;
    line-height: 1.05;
  }

  .more-page__nav a,
  .more-page__detail-grid a {
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
    box-shadow: 0 10px 24px rgba(24, 23, 19, 0.06);
  }

  .more-page__nav a:hover,
  .more-page__detail-grid a:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .more-page__nav a span,
  .more-page__detail-grid a span {
    font-weight: 700;
    font-size: 1rem;
  }

  .more-page__nav a small,
  .more-page__detail-grid a small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
    font-weight: 500;
    font-size: 0.72rem;
  }

  .more-page__nav,
  .more-page__detail-grid {
    display: grid;
    gap: 0.55rem;
  }

  .more-page__nav a,
  .more-page__detail-grid a {
    display: grid;
    gap: 0.12rem;
    padding: 0.75rem 0.85rem;
  }

  .more-page__detail-grid a {
    background: color-mix(in srgb, var(--surface, #fff) 92%, var(--right-hand, #c9a961) 8%);
  }

  .more-page__nav a::after {
    content: none;
  }

  @media (max-width: 600px) {
    .more-page {
      padding-bottom: calc(7rem + env(safe-area-inset-bottom, 0px));
    }
  }

  @media (min-width: 860px) {
    .more-page {
      max-width: 64rem;
    }

    .more-page__sidebar,
    .more-page__details {
      gap: 1rem;
      padding: 1.1rem;
    }

    .more-page__nav,
    .more-page__detail-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .more-page__nav a {
      min-height: 6.25rem;
      align-content: start;
      padding: 0.95rem;
    }

    .more-page__detail-grid a {
      align-content: start;
      padding: 0.95rem;
    }
  }
</style>
