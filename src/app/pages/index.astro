---
import Layout from '../layouts/Layout.astro';
import RoleHomeSurface from '../components/RoleHomeSurface.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { parseRoleRootCookie, ROLE_ROOT_COOKIE } from '../lib/roleSession.js';

const cookieRole = parseRoleRootCookie(Astro.cookies.get(ROLE_ROOT_COOKIE)?.value);
const { context } = createLayoutContext({ roleRoot: cookieRole ?? undefined });
---

<Layout context={context} titleKey="home.title" activeHref="/" surfaceContext={{ surface: 'home', phase: 'today' }} voiceSurface="bubble" voiceState="minimized">
  <RoleHomeSurface roleRoot={context.roleRoot} />
</Layout>
