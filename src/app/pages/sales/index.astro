---
// F-SL2 · Sales pipeline · /sales (Lane 2)
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { loadSalesStore, pipelineColumns, dealStageLabel } from '../../../sales/index.js';

const { context } = createLayoutContext();
const tenant = context.tenantId;
const store = await loadSalesStore(tenant);
const columns = pipelineColumns(store.deals);
const fmt = (cents: number) => `$${(cents / 100).toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
---

<Layout title="Sales · Pipeline" activeHref="/sales">
  <article class="sl-page" data-grammar="canon">
    <header class="sl-head">
      <div class="sl-crumb">Sales</div>
      <h1>Pipeline</h1>
      <p class="sl-sub">A lead becomes a priced, proposable job. Open a deal to enter Design.</p>
    </header>

    {store.deals.length === 0 ? (
      <p class="sl-empty">No deals yet for this tenant.</p>
    ) : (
      <div class="sl-board kg-grid-auto">
        {columns.map((col) => (
          <section class="sl-col">
            <h2 class="sl-col-head">{col.label} <span class="sl-count">{col.deals.length}</span></h2>
            {col.deals.map((deal) => (
              <a class="sl-card" href={`/sales/${deal.id}`}>
                <strong>{deal.name}</strong>
                <span class="sl-client">{deal.client_name}</span>
                <span class="sl-meta">{fmt(deal.value_cents)} · {dealStageLabel(deal.stage)}</span>
                <span class="sl-src">{deal.source}</span>
              </a>
            ))}
            {col.deals.length === 0 ? <p class="sl-col-empty">—</p> : null}
          </section>
        ))}
      </div>
    )}
  </article>
</Layout>

<style>
  .sl-page { display: grid; gap: 0.85rem; padding: 0 0 5.5rem; }
  .sl-crumb { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0; color: var(--muted); font-weight: 900; }
  .sl-head h1 { margin: 0.1rem 0; }
  .sl-sub { color: var(--muted); margin: 0; }
  .sl-board { --kg-cell: 190px; }
  .sl-col { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; padding: 0.6rem; box-shadow: var(--shadow); }
  .sl-col-head { font-size: 0.85rem; margin: 0 0 0.5rem; display: flex; justify-content: space-between; }
  .sl-count { color: var(--muted); }
  .sl-card { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.65rem; margin-bottom: 0.4rem; border: 1px solid var(--line); border-radius: 8px; background: var(--bg); color: var(--ink); text-decoration: none; }
  .sl-card:hover { border-color: var(--gold); }
  .sl-client { font-size: 0.82rem; }
  .sl-meta { font-size: 0.75rem; color: var(--muted); font-variant-numeric: tabular-nums; }
  .sl-src { font-size: 0.7rem; color: var(--muted); }
  .sl-col-empty { color: var(--muted); text-align: center; margin: 0.2rem 0; }
  .sl-empty { color: var(--muted); }
</style>
