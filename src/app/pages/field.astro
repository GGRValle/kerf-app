---
import Layout from '../layouts/Layout.astro';
import NavBack from '../components/NavBack.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { getApiDeps } from '../../api/lib/deps.js';
import { listAssignmentsForProject } from '../lib/lane3WorkFixtures.js';
import { listProjectRecordsForTenant } from '../lib/projectRecords.js';

const { context } = createLayoutContext();
const { tenantReader } = getApiDeps();
const projects = await listProjectRecordsForTenant(tenantReader, context.tenantId);

const pinPositions = [
  { x: 24, y: 38 },
  { x: 58, y: 54 },
  { x: 78, y: 28 },
  { x: 38, y: 70 },
] as const;

function toneForProject(phase: string, hasCrew: boolean): 'green' | 'amber' | 'blue' {
  if (hasCrew) return 'green';
  if (phase === 'closeout') return 'blue';
  return 'amber';
}

const projectRows = projects.map((project, index) => {
  const assignments = listAssignmentsForProject(
    context.tenantId as 'tenant_ggr' | 'tenant_valle' | 'tenant_hpg',
    project.project_id,
  );
  const position = pinPositions[index % pinPositions.length];
  return {
    project,
    assignments,
    href: `/projects/${project.project_id}`,
    status: assignments.length > 0 ? 'Crew assigned' : project.phase === 'closeout' ? 'Punch list' : 'Needs dispatch',
    tone: toneForProject(project.phase, assignments.length > 0),
    x: position.x,
    y: position.y,
  };
});

const crew = [
  {
    name: 'Ana Morales',
    role: 'Lead carpenter',
    initials: 'AM',
    job: projectRows[0]?.project.project_name ?? 'Active job',
    href: projectRows[0]?.href ?? '/projects',
    status: 'Clocked in · rough carpentry',
    action: 'Needs cabinet blocking answer',
    tone: 'amber',
  },
  {
    name: 'Marco Silva',
    role: 'Field tech',
    initials: 'MS',
    job: projectRows[1]?.project.project_name ?? projectRows[0]?.project.project_name ?? 'Active job',
    href: projectRows[1]?.href ?? projectRows[0]?.href ?? '/projects',
    status: 'On route · punch photos due',
    action: 'Ask for final proof set',
    tone: 'blue',
  },
  {
    name: 'Rigo Perez',
    role: 'Superintendent',
    initials: 'RP',
    job: projectRows[0]?.project.project_name ?? 'Active job',
    href: projectRows[0]?.href ?? '/projects',
    status: 'Available · 22 min away',
    action: 'Dispatch for intake photos',
    tone: 'green',
  },
] as const;

const primaryProjectRow = projectRows[0];
const secondaryProjectRow = projectRows[1] ?? projectRows[0];
const comms = [
  {
    source: 'Crew channel',
    title: `${primaryProjectRow?.project.project_name ?? 'Active job'} question needs a PM call`,
    detail: 'Right Hand marked the crew message as project-impacting and queued it with the job context.',
    project: primaryProjectRow?.project.client_name.split(',')[0] ?? 'Job',
    tone: 'amber',
    href: primaryProjectRow?.href ?? '/projects',
  },
  {
    source: 'Slack connection',
    title: 'Slack can mirror field channels here',
    detail: 'When connected, project channels stay searchable while Right Hand keeps the project context.',
    project: 'Setup',
    tone: 'blue',
    href: '/connections',
  },
  {
    source: 'Elevated by Right Hand',
    title: `${secondaryProjectRow?.project.project_name ?? 'Active job'} needs proof before closeout`,
    detail: 'Crew can add photos from Capture or upload from the phone library before this is cleared.',
    project: secondaryProjectRow?.project.client_name.split(',')[0] ?? 'Proof',
    tone: secondaryProjectRow?.tone ?? 'amber',
    href: secondaryProjectRow?.href ?? '/projects',
  },
] as const;

const jobCountLabel = projectRows.length === 1 ? 'One job moving now' : `${projectRows.length} jobs moving now`;
---

<Layout
  title="Field"
  activeHref="/field"
  surfaceContext={{
    surface: 'field_capture',
    phase: 'field_ops',
  }}
>
  <NavBack href="/" />
  <article class="field-ops" data-grammar="canon">
    <header class="field-ops__hero">
      <p class="field-ops__eyebrow">Field</p>
      <h1>Crew map and dispatch.</h1>
      <p>
        See active jobs, who is moving, and the field messages that need a fast call.
      </p>
    </header>

    <section class="field-map kg-grid-aside" aria-label="Active job map">
      <div class="field-map__copy">
        <span class="field-ops__eyebrow">Active map</span>
        <h2>{jobCountLabel}</h2>
        <p>Tap a job to open its work, proof, schedule, and messages.</p>
      </div>
      <div class="field-map__canvas" aria-hidden="true">
        <span class="map-road map-road--one"></span>
        <span class="map-road map-road--two"></span>
        <span class="map-road map-road--three"></span>
        {projectRows.map((row) => (
          <a
            class={`map-pin map-pin--${row.tone}`}
            href={row.href}
            style={`--x:${row.x}%; --y:${row.y}%;`}
            aria-label={`${row.project.project_name} · ${row.status}`}
          >
            <span></span>
          </a>
        ))}
      </div>
      <div class="field-map__jobs kg-grid">
        {projectRows.map((row) => (
          <a class="field-job-row kg-span-4" href={row.href}>
            <span class={`kg-chip ${row.tone}`}>{row.status}</span>
            <strong>{row.project.project_name}</strong>
            <small>{row.project.address_line}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="field-section" aria-label="Crew dispatch">
      <div class="field-section__head">
        <div>
          <span class="field-ops__eyebrow">Crew dispatch</span>
          <h2>People and what they are doing</h2>
        </div>
        <a class="field-action" href="/schedule">Open schedule</a>
      </div>
      <div class="crew-grid kg-grid">
        {crew.map((person) => (
          <article class="crew-card kg-span-4">
            <div class="crew-card__top">
              <span class="crew-avatar" aria-label={`${person.name} headshot`}>
                <span>{person.initials}</span>
              </span>
              <div>
                <h3>{person.name}</h3>
                <p>{person.role}</p>
              </div>
              <span class={`kg-chip ${person.tone}`}>{person.status.split(' · ')[0]}</span>
            </div>
            <dl>
              <div>
                <dt>Assigned</dt>
                <dd>{person.job}</dd>
              </div>
              <div>
                <dt>Status</dt>
                <dd>{person.status}</dd>
              </div>
              <div>
                <dt>Next move</dt>
                <dd>{person.action}</dd>
              </div>
            </dl>
            <div class="crew-card__actions">
              <a href="/camera">Capture</a>
              <a href={person.href}>Job</a>
              <button type="button">Message</button>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="field-section field-section--comms" aria-label="Field communications">
      <div class="field-section__head">
        <div>
          <span class="field-ops__eyebrow">Comms</span>
          <h2>What needs attention</h2>
        </div>
        <a class="field-action" href="/connections">Connect Slack</a>
      </div>
      <div class="comms-list">
        {comms.map((item) => (
          <article class="comm-card">
            <span class={`kg-chip ${item.tone}`}>{item.project}</span>
            <div>
              <p>{item.source}</p>
              <h3>{item.title}</h3>
              <span>{item.detail}</span>
            </div>
            <a href={item.href}>Review</a>
          </article>
        ))}
      </div>
    </section>
  </article>
</Layout>

<style>
  .field-ops {
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 1rem 1rem 6.5rem;
    color: var(--ink);
  }

  .field-ops__hero {
    max-width: 46rem;
    margin-bottom: 1rem;
  }

  .field-ops__eyebrow {
    display: inline-flex;
    margin: 0 0 0.25rem;
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .field-ops h1,
  .field-ops h2,
  .field-ops h3,
  .field-ops p {
    margin: 0;
    letter-spacing: 0;
  }

  .field-ops h1 {
    font-size: 2rem;
    line-height: 1.02;
  }

  .field-ops__hero p,
  .field-map__copy p,
  .crew-card p,
  .comm-card p,
  .comm-card span,
  .field-job-row small {
    color: var(--muted);
    line-height: 1.35;
  }

  .field-map {
    --kg-main-min: 14rem;
    --kg-main: 0.72fr;
    --kg-aside-min: 18rem;
    --kg-aside: 1.2fr;
    --kg-gap: 0.85rem;
    margin: 1rem 0;
  }

  .field-map__copy,
  .field-map__jobs,
  .field-map__canvas,
  .crew-card,
  .comm-card {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .field-map__copy {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    padding: 1rem;
  }

  .field-map__canvas {
    position: relative;
    min-height: 18rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 24% 38%, color-mix(in srgb, var(--green) 22%, transparent) 0 3.2rem, transparent 3.3rem),
      radial-gradient(circle at 58% 54%, color-mix(in srgb, var(--gold) 20%, transparent) 0 3.6rem, transparent 3.7rem),
      radial-gradient(circle at 78% 28%, color-mix(in srgb, var(--blue) 18%, transparent) 0 3rem, transparent 3.1rem),
      linear-gradient(90deg, color-mix(in srgb, var(--line) 42%, transparent) 1px, transparent 1px),
      linear-gradient(0deg, color-mix(in srgb, var(--line) 42%, transparent) 1px, transparent 1px),
      color-mix(in srgb, var(--bg) 88%, var(--panel));
    background-size: auto, auto, auto, 34px 34px, 34px 34px, auto;
  }

  .map-road {
    position: absolute;
    height: 2px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--ink) 22%, transparent);
    transform-origin: left center;
  }

  .map-road--one {
    width: 72%;
    left: 13%;
    top: 41%;
    transform: rotate(8deg);
  }

  .map-road--two {
    width: 54%;
    left: 31%;
    top: 64%;
    transform: rotate(-20deg);
  }

  .map-road--three {
    width: 48%;
    left: 20%;
    top: 24%;
    transform: rotate(-7deg);
  }

  .map-pin {
    position: absolute;
    left: var(--x);
    top: var(--y);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: 0 14px 30px color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .map-pin span {
    width: 0.84rem;
    height: 0.84rem;
    border-radius: 999px;
    background: var(--gold);
  }

  .map-pin--green span { background: var(--green); }
  .map-pin--blue span { background: var(--blue); }
  .map-pin--amber span { background: var(--gold); }

  .field-map__jobs {
    grid-column: 1 / -1;
    --kg-gap: 0.65rem;
    padding: 0.65rem;
  }

  .field-job-row {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
    padding: 0.75rem;
    color: inherit;
    text-decoration: none;
    border-radius: 8px;
    background: var(--panel);
    border: 1px solid var(--line);
  }

  .field-job-row strong {
    line-height: 1.15;
  }

  .field-section {
    margin-top: 1rem;
  }

  .field-section__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.7rem;
  }

  .field-action,
  .crew-card__actions a,
  .crew-card__actions button,
  .comm-card > a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.15rem;
    padding: 0.42rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font: inherit;
    font-weight: 800;
    text-decoration: none;
    cursor: pointer;
  }

  .crew-grid {
    --kg-gap: 0.75rem;
  }

  .crew-card {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
    padding: 0.85rem;
  }

  .crew-card__top {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.65rem;
  }

  .crew-avatar {
    position: relative;
    display: grid;
    place-items: end center;
    width: 3.15rem;
    height: 3.15rem;
    overflow: hidden;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--gold) 42%, var(--line));
    background:
      radial-gradient(circle at 50% 30%, #f0c18c 0 0.54rem, transparent 0.58rem),
      radial-gradient(ellipse at 50% 88%, color-mix(in srgb, var(--ink) 62%, var(--gold)) 0 1.08rem, transparent 1.11rem),
      linear-gradient(135deg, color-mix(in srgb, var(--gold) 25%, var(--panel)), color-mix(in srgb, var(--green) 16%, var(--panel)));
  }

  .crew-avatar span {
    position: relative;
    z-index: 1;
    margin-bottom: 0.18rem;
    padding: 0.08rem 0.24rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel) 86%, transparent);
    color: var(--ink);
    font-size: 0.62rem;
    font-weight: 900;
  }

  .crew-card h3 {
    font-size: 1rem;
    line-height: 1.15;
  }

  .crew-card dl {
    display: grid;
    gap: 0.55rem;
    margin: 0;
  }

  .crew-card dt {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .crew-card dd {
    margin: 0.1rem 0 0;
    line-height: 1.25;
  }

  .crew-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .comm-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: start;
    padding: 0.8rem;
  }

  .comms-list {
    display: grid;
    gap: 0.65rem;
  }

  .comm-card h3 {
    margin: 0.08rem 0 0.16rem;
    font-size: 1rem;
  }

  @media (max-width: 820px) {
    .field-ops {
      padding-inline: 0.85rem;
    }

    .field-ops h1 {
      font-size: 1.7rem;
    }

    .field-map__canvas {
      min-height: 15rem;
    }

    .field-section__head {
      align-items: start;
      flex-direction: column;
    }

    .crew-card__top,
    .comm-card {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .crew-card__top .kg-chip,
    .comm-card > a {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
</style>
