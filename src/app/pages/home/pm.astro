---
import Layout from '../../layouts/Layout.astro';
import NavBack from '../../components/NavBack.astro';
import RoleHomeSurface from '../../components/RoleHomeSurface.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';

const { context } = createLayoutContext({ roleRoot: 'pm' });
---

<Layout context={context} titleKey="home.title" activeHref="/">
  <NavBack href="/" />
  <RoleHomeSurface roleRoot="pm" wireframeOverride="F-P2" />
</Layout>
