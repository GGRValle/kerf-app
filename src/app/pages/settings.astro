---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import RhSummary from '../components/RhSummary.astro';

const settingLinks = [
  {
    href: '/settings/me',
    title: 'Your settings',
    detail: 'Personal profile, language, and notifications — separate from Admin.',
  },
  {
    href: '/connections',
    title: 'Connections',
    detail: 'QuickBooks, calendar, email, SMS, RoomPlan, Bluebeam, DocuSign, storage.',
  },
  {
    href: '/role-routing',
    title: 'Role routing',
    detail: 'Preview how owner, PM, admin, and field views are separated.',
  },
  {
    href: '/wireframes',
    title: 'Build map',
    detail: 'Internal route and launch-state checklist.',
  },
  {
    href: '/clients',
    title: 'Clients',
    detail: 'Open the client list and current client detail surfaces.',
  },
  {
    href: '/projects',
    title: 'Projects',
    detail: 'Open the current project graph and job-level details.',
  },
] as const;
---

<Layout titleKey="settings.title" activeHref="/settings">
  <section class="settings-page" aria-labelledby="settings-title">
    <RhSummary
      headline="Settings"
      detail="Settings are read-only in this phone pass. Use these links to check company preferences and role views."
      tone="green"
    />

    <Card eyebrow="Current company" title="GGR internal test">
      <dl class="settings-page__facts">
        <div>
          <dt>Voice</dt>
          <dd>Bottom mic opens Right Hand. Page-level duplicate recorders should not be the primary path.</dd>
        </div>
        <div>
          <dt>Writes</dt>
          <dd>Money, sends, and durable records still require the validated gates.</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>Preview only. No company setting is changed from this page.</dd>
        </div>
      </dl>
    </Card>

    <Card eyebrow="Inspect" title="Useful settings-adjacent routes">
      <div class="settings-page__actions">
        {settingLinks.map((link) => (
          <a class="settings-page__action" href={link.href}>
            <span>{link.title}</span>
            <small>{link.detail}</small>
          </a>
        ))}
      </div>
    </Card>

    <Card eyebrow="Trust" title="Audit trail">
      <div class="settings-page__actions">
        <a class="settings-page__action" href="/projects/proj_wegrzyn_kitchen/audit">
          <span>Open the audit trail</span>
          <small>Every approval, export, and durable write is recorded. Audit lives here in Settings — one click deep, never in the top nav.</small>
        </a>
      </div>
    </Card>
  </section>
</Layout>

<style>
  .settings-page {
    display: grid;
    gap: 0.85rem;
  }

  .settings-page__facts {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .settings-page__facts div {
    display: grid;
    gap: 0.2rem;
  }

  .settings-page__facts dt {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted, #5c6670);
  }

  .settings-page__facts dd {
    margin: 0;
    line-height: 1.4;
  }

  .settings-page__actions {
    display: grid;
    gap: 0.65rem;
  }

  .settings-page__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
  }

  .settings-page__action:hover {
    border-color: color-mix(in srgb, var(--right-hand, #c9a961) 45%, var(--border, #d8dee6));
  }

  .settings-page__action span {
    font-weight: 700;
  }

  .settings-page__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }
</style>
