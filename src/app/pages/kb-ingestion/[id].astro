---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import Chip from '../../components/Chip.astro';

const { id } = Astro.params;
const batchId = id ?? 'cost-kb-preview';
---

<Layout titleKey="kb.ingestion.detail.title" activeHref="/kb-ingestion">
  <section class="kb-detail" aria-labelledby="kb-detail-title">
    <p class="kb-detail__crumb"><a href="/kb-ingestion">Back to cost knowledge review</a></p>
    <header class="kb-detail__head">
      <p>Cost batch</p>
      <h1 id="kb-detail-title">Check before promotion.</h1>
    </header>

    <Card eyebrow="Ingestion batch" title={batchId}>
      <div class="kb-detail__status">
        <Chip label="Preview" tone="amber" />
        <span>Read-only inspection. No pricing data is imported from this page.</span>
      </div>

      <dl class="kb-detail__facts">
        <div>
          <dt>What this is</dt>
          <dd>A staged batch of cost data that must pass validation before it can affect estimates.</dd>
        </div>
        <div>
          <dt>Current state</dt>
          <dd>Preview only. No data has been imported, trained, or promoted.</dd>
        </div>
      </dl>
    </Card>

    <Card eyebrow="Next move" title="Open a wired surface">
      <div class="kb-detail__actions">
        <a href="/kb-ingestion">Cost knowledge review</a>
        <a href="/projects">Projects</a>
        <a href="/proposals/prop_lane6_pass/preview">Proposal preview</a>
      </div>
    </Card>
  </section>
</Layout>

<style>
  .kb-detail {
    display: grid;
    gap: 0.85rem;
  }

  .kb-detail__crumb {
    margin: 0;
    font-size: 0.85rem;
  }

  .kb-detail__head {
    display: grid;
    gap: 0.25rem;
  }

  .kb-detail__head p {
    margin: 0;
    color: var(--text-muted, #5c6670);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .kb-detail__head h1 {
    margin: 0;
    font-size: clamp(1.8rem, 9vw, 3rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .kb-detail__crumb a,
  .kb-detail__actions a {
    color: var(--accent, #0f766e);
    text-decoration: none;
    font-weight: 700;
  }

  .kb-detail__status {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.85rem;
    color: var(--text-muted, #5c6670);
  }

  .kb-detail__facts {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .kb-detail__facts div {
    display: grid;
    gap: 0.2rem;
  }

  .kb-detail__facts dt {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--text-muted, #5c6670);
  }

  .kb-detail__facts dd {
    margin: 0;
    line-height: 1.4;
  }

  .kb-detail__actions {
    display: grid;
    gap: 0.65rem;
  }

  .kb-detail__actions a {
    display: block;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    background: var(--surface, #fff);
  }
</style>
