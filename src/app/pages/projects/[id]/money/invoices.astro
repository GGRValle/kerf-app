---
import Layout from '../../../../layouts/Layout.astro';
import {
  formatInvoiceMoney,
  invoicesForProject,
  jobInvoiceContractTotal,
} from '../../../../lib/jobInvoiceFixtures.js';

const projectId = Astro.params.id ?? 'proj_wegrzyn_kitchen';
const invoices = invoicesForProject(projectId);

if (invoices.length === 0) {
  return Astro.redirect('/money');
}

const project = invoices[0]!;
const contractTotal = jobInvoiceContractTotal(projectId);
const openAmount = invoices
  .filter((invoice) => invoice.status === 'ready')
  .reduce((sum, invoice) => sum + invoice.amount_cents, 0);
const activeInvoice = invoices.find((invoice) => invoice.status === 'ready') ?? invoices[0]!;
const statusTone = {
  paid: 'green',
  ready: 'amber',
  scheduled: '',
  blocked: 'red',
} as const;
---

<Layout
  title="Job invoices"
  activeHref="/money"
  surfaceContext={{
    surface: 'project_invoices',
    project_id: projectId,
    phase: 'money_guard',
  }}
>
  <article class="job-invoices kg-grid-aside" data-grammar="canon">
    <header class="ji-head kg-pagehead">
      <a class="ji-back" href={`/projects/${projectId}`}>Back to job</a>
      <span class="kg-chip kg-routechip">Project money</span>
    </header>

    <section class="ji-summary kg-card">
      <p class="ji-eyebrow">Invoices</p>
      <h1>{project.project_name}</h1>
      <p>Deposit, progress, and final invoices live under this job. Money can find them, but the job owns the invoice set.</p>
      <div class="ji-stats kg-grid-auto">
        <div>
          <span>Contract</span>
          <strong>{formatInvoiceMoney(contractTotal)}</strong>
        </div>
        <div>
          <span>Open AR</span>
          <strong>{formatInvoiceMoney(openAmount)}</strong>
        </div>
        <div>
          <span>Next gate</span>
          <strong>{activeInvoice.status_label}</strong>
        </div>
        <div>
          <span>Line thread</span>
          <strong>{activeInvoice.line_ids.length} lines</strong>
        </div>
      </div>
    </section>

    <section class="ji-list" aria-label="Invoices for this job">
      <div class="ji-section">Invoices for this job</div>
      {invoices.map((invoice) => (
        <a class="ji-invoice kg-card" href={`/money/invoices/${invoice.id}?return_to=${encodeURIComponent(`/projects/${projectId}/money/invoices`)}`}>
          <div class="ji-invoice-head">
            <h2>{invoice.label}</h2>
            <strong>{formatInvoiceMoney(invoice.amount_cents)}</strong>
          </div>
          <p>{invoice.milestone} · {invoice.invoice_no} · {invoice.detail}</p>
          <div class="ji-chips">
            <span class:list={['kg-chip', statusTone[invoice.status]]}>{invoice.status_label}</span>
            <span class="kg-chip">Contract milestone</span>
            {invoice.line_ids.length > 1 ? <span class="kg-chip">{invoice.line_ids.length} line IDs</span> : null}
          </div>
        </a>
      ))}
    </section>

    <aside class="ji-thread kg-card">
      <strong>Carry-through</strong>
      <span>{activeInvoice.line_ids.join(', ')}. Draft totals stay tied to the signed contract.</span>
    </aside>

    <div class="ji-actions kg-grid-auto">
      <a class="ji-btn ji-btn--primary" href={`/money/invoices/${activeInvoice.id}?return_to=${encodeURIComponent(`/projects/${projectId}/money/invoices`)}`}>Open detail</a>
      <a class="ji-btn" href="/money">Open Money</a>
    </div>
  </article>
</Layout>

<style>
  .job-invoices {
    --kg-gap: 0.85rem;
    --kg-main: 1.1fr;
    --kg-aside: 0.9fr;
    --kg-aside-min: 280px;
    --kg-aside-align: start;
    padding-bottom: 5.5rem;
  }

  .ji-head,
  .ji-summary,
  .ji-actions {
    grid-column: 1 / -1;
  }

  .ji-back {
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 900;
    text-decoration: none;
  }

  .ji-summary {
    border-color: color-mix(in srgb, var(--gold) 28%, var(--line));
    background: color-mix(in srgb, var(--gold-soft) 36%, var(--panel));
  }

  .ji-eyebrow,
  .ji-section {
    margin: 0;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .ji-summary h1 {
    margin: 0.25rem 0 0.35rem;
    font-size: clamp(1.65rem, 7vw, 2.25rem);
    line-height: 1;
  }

  .ji-summary p {
    margin: 0;
    color: var(--muted);
    line-height: 1.4;
  }

  .ji-stats {
    --kg-cell: 8rem;
    --kg-gap: 8px;
    margin-top: 0.85rem;
  }

  .ji-stats div {
    display: grid;
    gap: 0.12rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0.65rem;
    background: var(--panel);
  }

  .ji-stats span {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .ji-stats strong {
    font-size: 1.02rem;
  }

  .ji-list {
    display: grid;
    gap: 0.65rem;
  }

  .ji-invoice {
    color: inherit;
    text-decoration: none;
  }

  .ji-invoice-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .ji-invoice h2 {
    margin: 0;
    font-size: 1rem;
  }

  .ji-invoice-head strong {
    font-variant-numeric: tabular-nums;
  }

  .ji-invoice p {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .ji-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 0.65rem;
  }

  .ji-thread {
    display: grid;
    gap: 0.25rem;
    border-style: dashed;
  }

  .ji-thread span {
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.35;
  }

  .ji-actions {
    --kg-cell: 7rem;
    --kg-gap: 8px;
  }

  .ji-btn {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font-weight: 900;
    text-decoration: none;
  }

  .ji-btn--primary {
    border-color: var(--gold);
    background: var(--gold);
    color: #181713;
  }

</style>
