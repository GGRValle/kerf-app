---
import Layout from '../../../layouts/Layout.astro';
import ProjectTabStrip from '../../../components/ProjectTabStrip.astro';
import Card from '../../../components/Card.astro';
import Chip from '../../../components/Chip.astro';
import { createLayoutContext } from '../../../lib/createLayoutContext.js';
import { getLane23Project } from '../../../lib/lane23Fixtures.js';
import '../../../styles/lane23.css';

const { t, context } = createLayoutContext();
const { id } = Astro.params;
const project = id ? getLane23Project(id) : null;
---

<Layout titleKey="project.status.title" activeHref="/projects">
  {project === null ? (
    <p>{t('project.not_found')}</p>
  ) : (
    <div class="lane23-page">
      <p class="lane23-crumb"><a href={`/projects/${project.project_id}`}>{t('project.detail.back')}</a></p>
      <ProjectTabStrip projectId={project.project_id} activeTab="scope" labelFor={t} />
      <Card title={t('project.status.title')}>
        <div class="lane23-status-grid">
          <p>{t('project.status.phase')}: <Chip label={project.phase} tone="green" /></p>
          <p>{t('project.status.last_activity')}: {new Date(project.last_activity_at).toLocaleString()}</p>
        </div>
      </Card>
    </div>
  )}
</Layout>
