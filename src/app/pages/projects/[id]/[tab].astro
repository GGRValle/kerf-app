---
import Layout from '../../../layouts/Layout.astro';
import ActionsStrip from '../../../components/ActionsStrip.astro';
import ProjectTabStrip from '../../../components/ProjectTabStrip.astro';
import ProjectTabContent from '../../../components/project/ProjectTabContent.astro';
import ProjectBrainSummary from '../../../components/ProjectBrainSummary.astro';
import { createLayoutContext } from '../../../lib/createLayoutContext.js';
import { getLane23Project, isProjectTabId } from '../../../lib/lane23Fixtures.js';
import { getProjectBrain } from '../../../lib/lane3WorkFixtures.js';
import '../../../styles/lane23.css';
import '../../../styles/lane3work.css';

const { t, context } = createLayoutContext();
const { id, tab } = Astro.params;
const project = id ? getLane23Project(id) : null;
const activeTab = tab && isProjectTabId(tab) ? tab : null;

if (tab === 'scope' && project !== null) {
  return Astro.redirect(`/projects/${project.project_id}`);
}

const brain = project ? getProjectBrain(project.project_id) : null;
---

<Layout titleKey="project.list.title" activeHref="/projects">
  {project === null || activeTab === null ? (
    <p>{t('project.not_found')}</p>
  ) : (
    <div class="lane23-page" data-project-id={project.project_id} data-tenant={context.tenantId}>
      <div class="lane23-bc">
        <div class="lane23-bc-bar">
          <p class="lane23-crumb"><a href="/projects">{t('project.detail.back')}</a></p>
          <div class="lane23-project-header">
            <h1>{project.project_name}</h1>
            <p class="lane23-project-meta">{project.client_name} · {project.address_line}</p>
          </div>
        </div>
        <ActionsStrip surface="project_detail" projectId={project.project_id} tenantId={context.tenantId} wired />
      </div>

      {brain !== null && (
        <ProjectBrainSummary
          brain={brain}
          labels={{
            nextAction: t('project.brain.next_action'),
            crewOnSite: t('project.brain.crew_on_site'),
            openItems: t('project.brain.open_items'),
            lastCapture: t('project.brain.last_capture'),
          }}
        />
      )}

      <ProjectTabStrip projectId={project.project_id} activeTab={activeTab} labelFor={t} />

      <div class="lane23-tab-panel">
        <ProjectTabContent
          project={project}
          activeTab={activeTab}
          labelFor={t}
          tenantId={context.tenantId}
        />
      </div>
    </div>
  )}
</Layout>
