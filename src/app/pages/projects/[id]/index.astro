---
import Layout from '../../../layouts/Layout.astro';
import ActionsStrip from '../../../components/ActionsStrip.astro';
import { createLayoutContext } from '../../../lib/createLayoutContext.js';
import { getApiDeps } from '../../../../api/lib/deps.js';
import { formatCentsDisplay } from '../../../lib/lane23Fixtures.js';
import { invoicesForProject } from '../../../lib/jobInvoiceFixtures.js';
import { getProjectRecordForTenant } from '../../../lib/projectRecords.js';
import {
  getProjectBrain,
  listAssignmentsForProject,
  listProjectNotes,
  listProjectSelections,
} from '../../../lib/lane3WorkFixtures.js';
import '../../../styles/lane23.css';
import '../../../styles/lane3work.css';

const { t, context } = createLayoutContext();
const { id } = Astro.params;
const { tenantReader } = getApiDeps();
const project = id ? await getProjectRecordForTenant(tenantReader, context.tenantId, id) : null;
const brain = project ? getProjectBrain(project.project_id) : null;
const selections = project ? listProjectSelections(project.project_id) : [];
const notes = project ? listProjectNotes(project.project_id) : [];
const assignments = project
  ? listAssignmentsForProject(
      context.tenantId as 'tenant_ggr' | 'tenant_valle' | 'tenant_hpg',
      project.project_id,
    )
  : [];
const openWorkCount = project?.work_orders.filter((workOrder) => workOrder.status !== 'complete').length ?? 0;
const completeWorkCount = project?.work_orders.filter((workOrder) => workOrder.status === 'complete').length ?? 0;
const openCloseoutCount = project?.closeout_steps.filter((step) => !step.done).length ?? 0;
const openSelections = selections.filter((selection) => selection.lifecycle !== 'approved');
const approvedSelections = selections.filter((selection) => selection.lifecycle === 'approved');
const nextWorkOrder = project?.work_orders.find((workOrder) => workOrder.status !== 'complete');
const primaryAssignment = assignments[0];
const primaryNote = notes[0];
const decisionLabel = openSelections[0]?.label ?? brain?.next_action ?? nextWorkOrder?.title ?? 'Review current job state';
const decisionHref = project
  ? openSelections.length > 0
    ? `/projects/${project.project_id}/selections`
    : `/projects/${project.project_id}`
  : '/projects';
const scheduleHref = project ? `/work?project_id=${project.project_id}` : '/work';
const dailySummaryHref = project ? `/projects/${project.project_id}/daily` : '/projects';
const dailyLogHref = project ? `/projects/${project.project_id}/daily-log` : '/projects';
const invoicesHref = project ? `/projects/${project.project_id}/money/invoices` : '/money';
const docsHref = project ? `/projects/${project.project_id}/docs` : '/projects';
const commsHref = project ? `/projects/${project.project_id}/comms` : '/projects';
const cameraHref = project
  ? `/camera?project_id=${project.project_id}&return_to=${encodeURIComponent(`/projects/${project.project_id}`)}`
  : '/camera';
const changeOrderHref = project ? `/projects/${project.project_id}/change-order` : '/projects';
const projectInvoices = project ? invoicesForProject(project.project_id) : [];
const billedToDateCents = projectInvoices
  .filter((invoice) => invoice.status === 'paid')
  .reduce((sum, invoice) => sum + invoice.amount_cents, 0);
const readyToBillCents = projectInvoices
  .filter((invoice) => invoice.status === 'ready')
  .reduce((sum, invoice) => sum + invoice.amount_cents, 0);
const completionPercent =
  project && project.work_orders.length > 0
    ? Math.round((completeWorkCount / project.work_orders.length) * 100)
    : 0;
const changeOrderStatus = openCloseoutCount > 0 ? 'Gate open' : 'Clear';
const projectTaskItems = project
  ? [
      ...(nextWorkOrder
        ? [
            {
              title: nextWorkOrder.title,
              detail: primaryAssignment
                ? `${primaryAssignment.trade} · ${primaryAssignment.sub_label}`
                : `${nextWorkOrder.trade} · ${nextWorkOrder.scheduled_date}`,
              status: primaryAssignment?.wo_sent_at ? 'Sent' : 'Pinned',
              tone: 'amber',
              source: 'from schedule',
            },
          ]
        : []),
      ...(openSelections.length > 0
        ? [
            {
              title: openSelections[0]!.label,
              detail: 'Selection can affect schedule and ordering.',
              status: 'Needs decision',
              tone: 'amber',
              source: 'agent raised',
            },
          ]
        : []),
      {
        title: 'File today’s field proof',
        detail: primaryNote?.body ?? 'Add photos, voice note, or walkthrough to today’s job log.',
        status: notes.length > 0 ? 'Proof attached' : 'Ready',
        tone: notes.length > 0 ? 'green' : 'blue',
        source: 'from capture',
      },
      ...(openCloseoutCount > 0
        ? [
            {
              title: `${openCloseoutCount} closeout checks remain`,
              detail: 'Punch, client walk, and final invoice stay visible until closed.',
              status: 'Queued',
              tone: 'blue',
              source: 'from job',
            },
          ]
        : []),
    ]
  : [];
---

<Layout title="Project" activeHref="/projects">
  {project === null ? (
    <p>{t('project.not_found')}</p>
  ) : (
    <article class="project-detail" data-grammar="canon" data-project-id={project.project_id} data-tenant={context.tenantId}>
      <header class="project-hero">
        <div class="project-hero__top">
          <a class="project-back" href="/projects">Projects</a>
          <details class="project-menu">
            <summary aria-label="Project actions">•••</summary>
            <div class="project-menu__panel">
              <ActionsStrip surface="project_detail" projectId={project.project_id} tenantId={context.tenantId} wired />
            </div>
          </details>
        </div>
        <div class="project-hero__main">
          <div>
            <span class="project-phase-dot">{project.phase}</span>
            <a class="project-title-link" href={`/projects/${project.project_id}`} aria-label="Project overview">
              <h1>{project.project_name}</h1>
            </a>
            <p>{project.client_name} · {project.address_line}</p>
          </div>
          <div class="project-money-story" aria-label="Project money story">
            <a href={invoicesHref}>
              <span>Budget</span>
              <strong>{formatCentsDisplay(project.budget_cents)}</strong>
            </a>
            <a href="#project-tasks">
              <span>Complete</span>
              <strong>{completionPercent}%</strong>
            </a>
            <a href={invoicesHref}>
              <span>Billed</span>
              <strong>{formatCentsDisplay(billedToDateCents)}</strong>
              {readyToBillCents > 0 ? <em>{formatCentsDisplay(readyToBillCents)} ready</em> : null}
            </a>
            <a href={changeOrderHref}>
              <span>Changes</span>
              <strong>{changeOrderStatus}</strong>
            </a>
          </div>
        </div>
      </header>

      <nav class="project-section-strip" aria-label="Project sections">
        <a href="#project-tasks">Tasks</a>
        <a href={scheduleHref}>Schedule</a>
        <a href={dailySummaryHref}>Daily</a>
        <a href={docsHref}>Docs</a>
        <a href={commsHref}>Comms</a>
        <a href={invoicesHref}>Money</a>
      </nav>

      <section class="project-rh-handoff" id="rh-project-detail-handoff" aria-label={t('project.detail.rh_handoff_title')} hidden>
        <strong>{t('project.detail.rh_handoff_title')}</strong>
        <span class="project-rh-handoff__body">{t('project.detail.rh_handoff_body')}</span>
      </section>

      <section class="project-capture-note" id="camera-landed-banner" hidden>
        <span class="project-capture-note__thumb" aria-hidden="true"></span>
        <div>
          <strong id="camera-landed-title">Capture filed</strong>
          <p id="camera-landed-detail"></p>
        </div>
        <a href={dailySummaryHref}>{t('project.daily_log.view')}</a>
      </section>

      <section class="project-decision" aria-label="Project decision">
        <div class="project-decision__head">
          <span>Needs you</span>
          <small>next safe move</small>
        </div>
        <p>
          <strong>{decisionLabel}</strong>
          {openSelections.length > 0
            ? ' is open and can affect schedule. Review it before the next field phase moves.'
            : ' is the next project move. The job context, crew, and proof are ready.'}
        </p>
        <div class="project-proof-row">
          <span class="kg-chip amber">{openSelections.length > 0 ? `${openSelections.length} selection open` : 'Review ready'}</span>
          <span class="kg-chip green">{notes.length > 0 ? 'Proof attached' : 'Job context loaded'}</span>
        </div>
        <div class="project-decision__actions">
          <a href={decisionHref}>Review</a>
          <a class="primary" href={scheduleHref}>Open schedule</a>
        </div>
      </section>

      <section class="project-command" aria-label="Log or capture on this job">
        <a class="project-command__talk" href="/right-hand" data-rh-speak>
          <span class="project-wave" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          <span>Tell Right Hand what happened on this job…</span>
        </a>
        <a class="project-command__camera" href={cameraHref} aria-label="Capture for this project">
          <span>Add proof</span>
        </a>
      </section>

      <section class="project-board" aria-label="Project breakdown">
        <div class="project-board__main">
          <section class="project-block project-block--tasks" id="project-tasks">
            <div class="project-block__head">
              <span>Tasks</span>
              <a href={scheduleHref}>Schedule</a>
            </div>
            <p class="project-task-intro">Right Hand keeps this list organized from schedule, field proof, selections, and daily notes.</p>
            <div class="project-task-list">
              {projectTaskItems.map((task, index) => (
                <article class:list={['project-task-row', index === 0 ? 'project-task-row--pinned' : '']}>
                  <span class="project-task-row__check" aria-hidden="true">{index === 0 ? '★' : '✓'}</span>
                  <div>
                    <strong>{task.title}</strong>
                    <p>{task.detail}</p>
                    <small>{task.source}</small>
                  </div>
                  <span class:list={['kg-chip', task.tone]}>{task.status}</span>
                </article>
              ))}
            </div>
          </section>

          <section class="project-block">
            <div class="project-block__head">
              <span>Held for you</span>
              <a href={decisionHref}>Open</a>
            </div>
            <div class="project-hold-list">
              <article>
                <strong>{decisionLabel}</strong>
                <span class="kg-chip amber">{openSelections.length > 0 ? 'Needs review' : 'Needs call'}</span>
              </article>
              <article>
                <strong>{openCloseoutCount === 0 ? 'Closeout clear' : `${openCloseoutCount} closeout items`}</strong>
                <span class="kg-chip blue">{openCloseoutCount === 0 ? 'Clear' : 'Queued'}</span>
              </article>
            </div>
          </section>
        </div>

        <aside class="project-board__side">
          <section class="project-block">
            <div class="project-block__head">
              <span>Recent proof</span>
              <a href={commsHref}>Comms</a>
            </div>
            <p class="project-proof-copy">{primaryNote?.body ?? brain?.last_capture ?? 'No field proof logged yet.'}</p>
            <div class="project-proof-row">
              <span class="kg-chip green">{primaryNote?.evidence_label ?? 'Proof ready'}</span>
              <span class="kg-chip blue">Durable</span>
            </div>
          </section>

          <section class="project-block" id="project-audit">
            <div class="project-block__head">
              <span>Activity & audit</span>
              <a href={commsHref}>Comms</a>
            </div>
            <div class="project-audit-list">
              <article>
                <strong>Latest field signal</strong>
                <p>{primaryNote?.body ?? brain?.last_capture ?? 'Right Hand is ready to capture the next field signal.'}</p>
              </article>
              <article>
                <strong>Nothing moves silently</strong>
                <p>Client updates, sends, invoices, and change orders stay behind visible approval gates.</p>
              </article>
            </div>
          </section>
        </aside>
      </section>
    </article>
  )}

  <script>
    const TURN_RESOLUTION_SESSION_KEY = 'kerf.turnResolution';
    const parseTurnResolution = (raw) => {
      try {
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || typeof parsed !== 'object') return null;
        if (typeof parsed.heard_text !== 'string') return null;
        return parsed;
      } catch {
        return null;
      }
    };
    const likelyProjectMatches = (trp, currentProjectId, currentProjectName) => {
      const likely = trp?.context_hypothesis?.likely_entity;
      if (likely?.type !== 'project') return false;
      if (likely.id && likely.id === currentProjectId) return true;
      const label = typeof likely.label === 'string' ? likely.label.toLowerCase() : '';
      return label.length > 0 && currentProjectName.toLowerCase().includes(label);
    };

    const hydrateRightHandProjectHandoff = () => {
      const handoff = document.getElementById('rh-project-detail-handoff');
      if (!handoff) return;
      let raw = null;
      try {
        raw = sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY);
      } catch {
        raw = null;
      }
      const trp = parseTurnResolution(raw);
      if (!trp) return;
      const currentProjectId = document.querySelector('.project-detail')?.getAttribute('data-project-id') ?? '';
      const currentProjectName = document.querySelector('.project-hero h1')?.textContent?.trim() ?? '';
      if (!likelyProjectMatches(trp, currentProjectId, currentProjectName)) return;
      const body = handoff.querySelector('.project-rh-handoff__body');
      if (body) {
        body.textContent = `Right Hand brought this over: ${trp.heard_text} Nothing has been filed yet.`;
      }
      handoff.hidden = false;
    };

    const params = new URLSearchParams(window.location.search);
    const projectId = document.querySelector('.project-detail')?.getAttribute('data-project-id') ?? '';
    hydrateRightHandProjectHandoff();
    if (params.get('src') === 'camera' && projectId) {
      let raw = null;
      try {
        raw = sessionStorage.getItem('kerf.cameraCapture');
      } catch {
        raw = null;
      }
      if (raw) {
        const capture = JSON.parse(raw);
        const banner = document.getElementById('camera-landed-banner');
        const title = document.getElementById('camera-landed-title');
        const detail = document.getElementById('camera-landed-detail');
        if (banner) banner.hidden = false;
        if (title && capture.status === 'filed_to_daily_log') {
          title.textContent = `${capture.kind === 'walkthrough' ? 'Walkthrough' : capture.kind === 'scan' ? 'Document scan' : 'Photo'} filed`;
        }
        if (detail) {
          detail.textContent = capture.status === 'filed_to_daily_log'
            ? `Filed to Daily Log${capture.work_artifact_ref ? ` · ${capture.work_artifact_ref}` : ''}`
            : 'Capture is still pending — open Camera to try filing again.';
        }
        if (capture.status === 'filed_to_daily_log') {
          try {
            sessionStorage.setItem('kerf.cameraLastShot', JSON.stringify({
              kind: capture.kind,
              preview_url: typeof capture.preview_url === 'string' ? capture.preview_url : '',
              captured_at: capture.returned_at || Date.now(),
            }));
          } catch {
            // Cosmetic camera history only; the daily-log event is already filed.
          }
          sessionStorage.removeItem('kerf.cameraCapture');
        }
      }
    }
  </script>
</Layout>

<style>
  .project-detail {
    width: min(100%, 1080px);
    margin: 0 auto;
    padding: 0.58rem 1rem 6.5rem;
    color: var(--ink);
  }

  .project-detail h1,
  .project-detail h2,
  .project-detail h3,
  .project-detail p {
    margin: 0;
    letter-spacing: 0;
  }

  .project-hero,
  .project-capture-note,
  .project-rh-handoff,
  .project-decision,
  .project-command,
  .project-block {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .project-hero {
    display: grid;
    gap: 0.82rem;
    padding: 0.92rem;
    border-color: color-mix(in srgb, var(--ink) 82%, var(--gold));
    background:
      radial-gradient(circle at 84% 10%, color-mix(in srgb, var(--gold) 25%, transparent), transparent 30%),
      linear-gradient(135deg, color-mix(in srgb, var(--ink) 96%, var(--gold)), var(--ink));
    color: var(--bg);
    box-shadow: 0 18px 38px color-mix(in srgb, var(--ink) 14%, transparent);
  }

  .project-hero__top,
  .project-hero__main {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-hero__main {
    align-items: end;
  }

  .project-back,
  .project-capture-note a {
    color: inherit;
    font-weight: 900;
    text-decoration: none;
  }

  .project-back {
    color: color-mix(in srgb, var(--bg) 72%, var(--gold));
    font-size: 0.86rem;
  }

  .project-hero h1 {
    margin-top: 0.34rem;
    color: var(--bg);
    font-size: 1.82rem;
    line-height: 1.04;
  }

  .project-title-link {
    display: inline-block;
    color: inherit;
    text-decoration: none;
  }

  .project-title-link:hover h1 {
    color: color-mix(in srgb, var(--bg) 88%, var(--gold));
  }

  .project-capture-note p {
    color: var(--muted);
    line-height: 1.35;
  }

  .project-hero p {
    color: color-mix(in srgb, var(--bg) 74%, var(--gold));
    line-height: 1.35;
  }

  .project-phase-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    color: color-mix(in srgb, var(--bg) 88%, var(--gold));
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-phase-dot::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--gold);
    box-shadow: 0 0 0 0.24rem color-mix(in srgb, var(--gold) 18%, transparent);
  }

  .project-money-story {
    display: grid;
    grid-template-columns: repeat(2, minmax(6.2rem, 1fr));
    gap: 0.38rem;
    width: min(25rem, 46vw);
    align-self: stretch;
  }

  .project-money-story a {
    display: grid;
    align-content: center;
    gap: 0.12rem;
    min-height: 3.2rem;
    padding: 0.48rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--gold) 27%, transparent);
    border-radius: 9px;
    background: color-mix(in srgb, var(--bg) 8%, transparent);
    color: inherit;
    text-decoration: none;
  }

  .project-money-story a:first-child {
    border-color: color-mix(in srgb, var(--gold) 48%, transparent);
    background: color-mix(in srgb, var(--gold) 12%, transparent);
  }

  .project-money-story span,
  .project-eyebrow {
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-money-story strong {
    color: var(--bg);
    font-size: 1rem;
    line-height: 1.05;
  }

  .project-money-story em {
    color: color-mix(in srgb, var(--bg) 70%, var(--gold));
    font-size: 0.68rem;
    font-style: normal;
    font-weight: 850;
    line-height: 1.05;
  }

  .project-menu {
    position: relative;
  }

  .project-menu summary {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid color-mix(in srgb, var(--bg) 18%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg) 10%, transparent);
    color: var(--bg);
    cursor: pointer;
    list-style: none;
  }

  .project-menu summary::-webkit-details-marker {
    display: none;
  }

  .project-menu__panel {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    z-index: 4;
    min-width: 13rem;
    padding: 0.65rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--panel);
    box-shadow: 0 18px 42px color-mix(in srgb, var(--ink) 18%, transparent);
  }

  .project-menu__panel :global(.actions-strip),
  .project-menu__panel :global(.export-print-bar) {
    display: grid;
    gap: 0.45rem;
  }

  .project-menu__panel :global(.epb-btn) {
    width: 100%;
    min-height: 2.2rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--panel) 94%, var(--bg));
    color: var(--ink);
    font: inherit;
    font-weight: 850;
  }

  .project-capture-note a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.95rem;
    padding: 0.34rem 0.58rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    font-size: 0.84rem;
    white-space: nowrap;
  }

  .project-section-strip {
    position: sticky;
    top: var(--shell-top-offset, 0);
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.32rem;
    margin-top: 0.62rem;
    padding: 0.42rem;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--panel) 96%, var(--bg));
    box-shadow: 0 10px 24px color-mix(in srgb, var(--ink) 6%, transparent);
  }

  .project-section-strip a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 2.18rem;
    padding: 0.34rem 0.68rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 920;
    text-decoration: none;
  }

  .project-section-strip a.active {
    border-color: color-mix(in srgb, var(--gold) 58%, var(--line));
    background: color-mix(in srgb, var(--gold) 15%, var(--panel));
    color: var(--ink);
  }

  .project-rh-handoff[hidden],
  .project-capture-note[hidden] {
    display: none;
  }

  .project-rh-handoff,
  .project-capture-note {
    align-items: center;
    gap: 0.75rem;
    margin: 0.8rem 0;
    padding: 0.75rem;
  }

  .project-rh-handoff {
    display: grid;
  }

  .project-capture-note {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
  }

  .project-capture-note__thumb {
    width: 3rem;
    height: 3rem;
    border-radius: 8px;
    background:
      radial-gradient(circle at 40% 35%, color-mix(in srgb, var(--gold) 44%, transparent), transparent 38%),
      linear-gradient(135deg, color-mix(in srgb, var(--green) 22%, var(--panel)), color-mix(in srgb, var(--ink) 10%, var(--panel)));
    border: 1px solid var(--line);
  }

  .project-decision {
    display: grid;
    gap: 0.72rem;
    margin-top: 0.72rem;
    padding: 0.78rem;
    border-width: 1.5px;
    border-color: color-mix(in srgb, var(--gold) 58%, var(--line));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--gold) 16%, transparent), transparent 58%),
      color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .project-decision__head,
  .project-block__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .project-decision__head span,
  .project-block__head span {
    color: var(--gold);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-decision__head small {
    color: var(--muted);
    font-weight: 850;
    text-align: right;
  }

