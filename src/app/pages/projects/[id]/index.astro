---
import Layout from '../../../layouts/Layout.astro';
import ActionsStrip from '../../../components/ActionsStrip.astro';
import ProjectTabStrip from '../../../components/ProjectTabStrip.astro';
import ProjectTabContent from '../../../components/project/ProjectTabContent.astro';
import ProjectBrainSummary from '../../../components/ProjectBrainSummary.astro';
import { createLayoutContext } from '../../../lib/createLayoutContext.js';
import { getLane23Project } from '../../../lib/lane23Fixtures.js';
import { getProjectBrain } from '../../../lib/lane3WorkFixtures.js';
import '../../../styles/lane23.css';
import '../../../styles/lane3work.css';

const { t, context } = createLayoutContext();
const { id } = Astro.params;
const project = id ? getLane23Project(id) : null;
const brain = project ? getProjectBrain(project.project_id) : null;
---

<Layout titleKey="project.list.title" activeHref="/projects">
  {project === null ? (
    <p>{t('project.not_found')}</p>
  ) : (
    <div class="lane23-page" data-project-id={project.project_id} data-tenant={context.tenantId}>
      <div class="lane23-bc">
        <div class="lane23-bc-bar">
          <p class="lane23-crumb"><a href="/projects">{t('project.detail.back')}</a></p>
          <div class="lane23-project-header">
            <h1>{project.project_name}</h1>
            <p class="lane23-project-meta">{project.client_name} · {project.address_line}</p>
          </div>
        </div>
        <ActionsStrip surface="project_detail" projectId={project.project_id} tenantId={context.tenantId} wired />
      </div>

      <section class="lane23-rh-handoff" id="rh-project-detail-handoff" aria-label={t('project.detail.rh_handoff_title')} hidden>
        <p class="lane23-rh-handoff__eyebrow">{t('project.detail.rh_handoff_title')}</p>
        <p class="lane23-rh-handoff__body">{t('project.detail.rh_handoff_body')}</p>
      </section>

      <section class="lane23-camera-landed" id="camera-landed-banner" hidden>
        <p><strong id="camera-landed-title">Capture filed</strong></p>
        <p class="lane23-notice" id="camera-landed-detail"></p>
        <a class="lane23-btn-link" href={`/projects/${project.project_id}/daily_log`}>{t('project.daily_log.view')}</a>
      </section>

      {brain !== null && (
        <ProjectBrainSummary
          brain={brain}
          labels={{
            nextAction: t('project.brain.next_action'),
            crewOnSite: t('project.brain.crew_on_site'),
            openItems: t('project.brain.open_items'),
            lastCapture: t('project.brain.last_capture'),
          }}
        />
      )}

      <ProjectTabStrip projectId={project.project_id} activeTab="overview" labelFor={t} />

      <div class="lane23-tab-panel">
        <ProjectTabContent
          project={project}
          activeTab="overview"
          labelFor={t}
          tenantId={context.tenantId}
        />
      </div>
    </div>
  )}

  <script define:vars={{ tenantId: context.tenantId }}>
    const params = new URLSearchParams(window.location.search);
    const projectId = document.querySelector('.lane23-page')?.getAttribute('data-project-id') ?? '';
    if (params.get('src') === 'camera' && projectId) {
      let raw = null;
      try {
        raw = sessionStorage.getItem('kerf.cameraCapture');
      } catch {
        raw = null;
      }
      if (raw) {
        const capture = JSON.parse(raw);
        const banner = document.getElementById('camera-landed-banner');
        const title = document.getElementById('camera-landed-title');
        const detail = document.getElementById('camera-landed-detail');
        if (banner) banner.hidden = false;
        fetch(`/api/v1/projects/${projectId}/camera-capture?tenant_id=${tenantId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tenant_id: tenantId,
            capture_kind: capture.kind === 'walkthrough' ? 'walkthrough' : capture.kind === 'scan' ? 'scan' : 'photo',
            file_name: capture.name,
            confirmed: true,
          }),
        })
          .then((r) => r.json())
          .then((data) => {
            if (title && data.artifacts?.attention?.headline) {
              title.textContent = data.artifacts.attention.headline;
            }
            if (detail && data.artifacts?.work?.body_preview) {
              detail.textContent = data.artifacts.work.body_preview;
            }
            sessionStorage.removeItem('kerf.cameraCapture');
          })
          .catch(() => {
            if (detail) detail.textContent = 'Capture session saved — reload daily log to review.';
          });
      }
    }
  </script>
</Layout>

<style>
  .lane23-camera-landed[hidden] { display: none; }
  .lane23-camera-landed {
    margin: 0.75rem 0;
    padding: 0.85rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--field-green, #38c977) 35%, var(--border, #d8dee6));
    background: color-mix(in srgb, var(--field-green, #38c977) 8%, var(--surface, #fff));
  }
  .lane23-btn-link {
    display: inline-block;
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--border, #d8dee6);
    color: var(--accent, #0f766e);
    font-weight: 600;
    text-decoration: none;
  }
</style>
