---
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { getApiDeps } from '../../../api/lib/deps.js';
import { formatCentsDisplay } from '../../lib/lane23Fixtures.js';
import { listProjectRecordsForTenant } from '../../lib/projectRecords.js';

const { context } = createLayoutContext();
const { tenantReader } = getApiDeps();
const projects = await listProjectRecordsForTenant(tenantReader, context.tenantId);

const pinPositions = [
  { x: 24, y: 38 },
  { x: 58, y: 54 },
  { x: 78, y: 28 },
  { x: 38, y: 70 },
] as const;

function toneForPhase(phase: string): 'green' | 'amber' | 'blue' {
  if (phase === 'active') return 'green';
  if (phase === 'closeout') return 'blue';
  return 'amber';
}

function labelForPhase(phase: string): string {
  if (phase === 'active') return 'Active';
  if (phase === 'closeout') return 'Closeout';
  return 'Complete';
}

function nextMoveForProject(project: (typeof projects)[number]): string {
  const openWork = project.work_orders.find((workOrder) => workOrder.status !== 'complete');
  if (openWork !== undefined) return openWork.title;
  const openCloseout = project.closeout_steps.find((step) => !step.done);
  if (openCloseout !== undefined) return 'Closeout step waiting';
  return 'Ready for review';
}

const projectPins = projects.map((project, index) => ({
  project,
  tone: toneForPhase(project.phase),
  phase: labelForPhase(project.phase),
  nextMove: nextMoveForProject(project),
  position: pinPositions[index % pinPositions.length],
}));
---

<Layout title="Projects" activeHref="/projects">
  <article class="projects-page" data-grammar="canon">
    <header class="projects-hero">
      <p class="projects-eyebrow">Projects</p>
      <h1>Active jobs and where they stand.</h1>
    </header>

    {projects.length === 0 ? (
      <section class="projects-empty">
        <h2>No projects yet</h2>
        <p>Start from Capture or add a project when a lead becomes real work.</p>
        <a href="/start">Start</a>
      </section>
    ) : (
      <>
        <section class="projects-map" aria-label="Active projects map">
          <div class="projects-map__copy">
            <span class="projects-eyebrow">Active map</span>
            <h2>{projects.length === 1 ? 'One job moving now' : `${projects.length} jobs moving now`}</h2>
            <p>Tap a pin or job to open the project.</p>
          </div>
          <div class="projects-map__canvas" aria-hidden="true">
            <span class="map-road map-road--one"></span>
            <span class="map-road map-road--two"></span>
            <span class="map-road map-road--three"></span>
            {projectPins.map(({ project, tone, phase, position }) => (
              <a
                class={`map-pin map-pin--${tone}`}
                href={`/projects/${project.project_id}`}
                style={`--x:${position.x}%; --y:${position.y}%;`}
                aria-label={`${project.project_name} · ${phase}`}
              >
                <span></span>
              </a>
            ))}
          </div>
        </section>

        <section class="projects-list" aria-label="Project queue">
          <div class="projects-section-head">
            <div>
              <span class="projects-eyebrow">Project queue</span>
              <h2>Projects</h2>
            </div>
            <a class="projects-action" href="/start">Start new</a>
          </div>
          <div class="project-grid">
            {projectPins.map(({ project, tone, phase, nextMove }) => (
              <a class="project-card" href={`/projects/${project.project_id}`}>
                <span class={`project-dot project-dot--${tone}`} aria-hidden="true"></span>
                <div class="project-card__main">
                  <h3>{project.project_name}</h3>
                  <p>{project.client_name} · {project.address_line}</p>
                  <span>{nextMove}</span>
                </div>
                <div class="project-card__status">
                  <span class={`kg-chip ${tone}`}>{phase}</span>
                  <strong>{formatCentsDisplay(project.budget_cents)}</strong>
                </div>
              </a>
            ))}
          </div>
        </section>
      </>
    )}
  </article>
</Layout>

<style>
  .projects-page {
    width: min(100%, 1120px);
    margin: 0 auto;
    padding: 1rem 1rem 6.5rem;
    color: var(--ink);
  }

  .projects-hero {
    margin-bottom: 1rem;
  }

  .projects-eyebrow {
    display: inline-flex;
    margin: 0 0 0.25rem;
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .projects-page h1,
  .projects-page h2,
  .projects-page h3,
  .projects-page p {
    margin: 0;
    letter-spacing: 0;
  }

  .projects-page h1 {
    font-size: 2rem;
    line-height: 1.03;
  }

  .projects-map {
    display: grid;
    grid-template-columns: minmax(13rem, 0.58fr) minmax(19rem, 1.42fr);
    gap: 0.85rem;
    margin: 1rem 0;
  }

  .projects-map__copy,
  .projects-map__canvas,
  .project-card,
  .projects-empty {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--panel) 96%, var(--bg));
  }

  .projects-map__copy {
    display: grid;
    align-content: start;
    gap: 0.35rem;
    padding: 1rem;
  }

  .projects-map__copy p,
  .project-card p,
  .project-card dt,
  .projects-empty p {
    color: var(--muted);
    line-height: 1.35;
  }

  .projects-map__canvas {
    position: relative;
    min-height: 18rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 24% 38%, color-mix(in srgb, var(--green) 22%, transparent) 0 3.2rem, transparent 3.3rem),
      radial-gradient(circle at 58% 54%, color-mix(in srgb, var(--gold) 20%, transparent) 0 3.6rem, transparent 3.7rem),
      radial-gradient(circle at 78% 28%, color-mix(in srgb, var(--blue) 18%, transparent) 0 3rem, transparent 3.1rem),
      linear-gradient(90deg, color-mix(in srgb, var(--line) 42%, transparent) 1px, transparent 1px),
      linear-gradient(0deg, color-mix(in srgb, var(--line) 42%, transparent) 1px, transparent 1px),
      color-mix(in srgb, var(--bg) 88%, var(--panel));
    background-size: auto, auto, auto, 34px 34px, 34px 34px, auto;
  }

  .map-road {
    position: absolute;
    height: 2px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--ink) 22%, transparent);
    transform-origin: left center;
  }

  .map-road--one {
    width: 72%;
    left: 13%;
    top: 41%;
    transform: rotate(8deg);
  }

  .map-road--two {
    width: 54%;
    left: 31%;
    top: 64%;
    transform: rotate(-20deg);
  }

  .map-road--three {
    width: 48%;
    left: 20%;
    top: 24%;
    transform: rotate(-7deg);
  }

  .map-pin {
    position: absolute;
    left: var(--x);
    top: var(--y);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: 0 14px 30px color-mix(in srgb, var(--ink) 16%, transparent);
  }

  .map-pin span {
    width: 0.84rem;
    height: 0.84rem;
    border-radius: 999px;
    background: var(--gold);
  }

  .map-pin--green span { background: var(--green); }
  .map-pin--blue span { background: var(--blue); }
  .map-pin--amber span { background: var(--gold); }

  .projects-section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.7rem;
  }

  .projects-action,
  .projects-empty a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.15rem;
    padding: 0.42rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
  }

  .project-grid {
    display: grid;
    gap: 0.5rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
    padding: 0.68rem 0.75rem;
    color: inherit;
    text-decoration: none;
  }

  .project-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: var(--gold);
  }

  .project-dot--green { background: var(--green); }
  .project-dot--blue { background: var(--blue); }
  .project-dot--amber { background: var(--gold); }

  .project-card__main {
    min-width: 0;
  }

  .project-card h3 {
    overflow: hidden;
    font-size: 1rem;
    line-height: 1.15;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-card__main p,
  .project-card__main span {
    display: block;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-card__status {
    display: grid;
    justify-items: end;
    gap: 0.25rem;
    min-width: max-content;
  }

  .project-card__status strong {
    font-size: 0.92rem;
  }

  .projects-empty {
    display: grid;
    gap: 0.65rem;
    max-width: 34rem;
    padding: 1rem;
  }

  @media (max-width: 820px) {
    .projects-page {
      padding-inline: 0.85rem;
    }

    .projects-page h1 {
      font-size: 1.7rem;
    }

    .projects-map,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .project-card__status {
      grid-column: 2;
      justify-items: start;
      display: flex;
      align-items: center;
      gap: 0.45rem;
    }

    .projects-map__canvas {
      min-height: 15rem;
    }

    .projects-section-head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
