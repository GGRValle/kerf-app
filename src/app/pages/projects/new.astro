---
import Layout from '../../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../../components/SurfaceIrreversibilityWrap.astro';
import Card from '../../components/Card.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { getLane6Client } from '../../lib/lane6Fixtures.js';
import '../../styles/money.css';

const { t, context } = createLayoutContext();
const clientId = Astro.url.searchParams.get('client_id');
const presetClient = clientId ? getLane6Client(clientId) : null;
---

<Layout titleKey="f_pr.new.title" activeHref="/projects">
  <article class="money-page f-pr-new">
    <header>
      <div class="money-crumb">
        <a href="/projects">{t('project.list.title')}</a>
        {presetClient ? <> · {presetClient.display_name}</> : null}
      </div>
      <h1 class="money-title">{t('f_pr.new.title')}</h1>
      <p class="money-subtitle">{t('f_pr.new.subtitle')}</p>
    </header>

    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <section
        class="money-card rh-project-handoff"
        id="rh-project-handoff"
        aria-label={t('f_pr.new.handoff_title')}
        hidden
      >
        <p class="rh-project-handoff__eyebrow">{t('f_pr.new.handoff_title')}</p>
        <p class="rh-project-handoff__body">{t('f_pr.new.handoff_body')}</p>
        <dl class="rh-project-handoff__facts">
          <div>
            <dt>{t('f_pr.new.handoff_heard')}</dt>
            <dd id="rh-project-handoff-heard"></dd>
          </div>
          <div>
            <dt>{t('f_pr.new.handoff_context')}</dt>
            <dd id="rh-project-handoff-context"></dd>
          </div>
        </dl>
      </section>

      <Card title={t('f_pr.new.title')}>
        <form class="money-form" id="new-project-form">
          <label>
            {t('f_pr.new.project_name')}
            <input name="project_name" required />
          </label>
          <label>
            {t('f_pr.new.client_name')}
            <input
              name="client_name"
              required
              value={presetClient?.display_name ?? ''}
            />
          </label>
          <input type="hidden" name="client_id" value={clientId ?? ''} />
          <label>
            {t('f_pr.new.archetype')}
            <select name="archetype_hint">
              <option value="">{t('f_pr.new.archetype_none')}</option>
              <option value="kitchen_remodel">Kitchen remodel</option>
              <option value="adu">ADU addition</option>
              <option value="bath_refresh">Bath refresh</option>
            </select>
          </label>
          <div class="money-actions">
            <a class="money-btn ghost" href={presetClient ? `/clients/${presetClient.client_id}` : '/projects'}>
              {t('f_cl.form.cancel')}
            </a>
            <button type="submit" class="money-btn primary">{t('f_pr.new.submit')}</button>
          </div>
        </form>
        <p class="money-notice" id="new-project-status" role="status"></p>
      </Card>
    </SurfaceIrreversibilityWrap>
  </article>

  <script define:vars={{ tenantId: context.tenantId, successMsg: 'Project created — opens in Projects.', errorMsg: 'Could not create project.' }}>
    const TURN_RESOLUTION_SESSION_KEY = 'kerf.turnResolution';

    const parseTurnResolution = (raw) => {
      try {
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || typeof parsed !== 'object') return null;
        if (typeof parsed.heard_text !== 'string') return null;
        return parsed;
      } catch {
        return null;
      }
    };

    const inferProjectName = (trp) => {
      const likely = trp.context_hypothesis?.likely_entity;
      if (likely?.type === 'project' && likely.label) return likely.label;
      const text = `${trp.heard_text} ${trp.context_hypothesis?.label ?? ''}`.toLowerCase();
      if (/\bkitchen|cabinet|countertop|appliance|island|pantry\b/.test(text)) return 'Kitchen estimate walk';
      if (/\bbath|bathroom|shower|tub|vanity\b/.test(text)) return 'Bath estimate walk';
      return trp.context_hypothesis?.label ? `${trp.context_hypothesis.label} follow-up` : '';
    };

    const inferArchetype = (trp) => {
      const text = `${trp.heard_text} ${trp.context_hypothesis?.label ?? ''}`.toLowerCase();
      if (/\bkitchen|cabinet|countertop|appliance|island|pantry\b/.test(text)) return 'kitchen_remodel';
      if (/\bbath|bathroom|shower|tub|vanity\b/.test(text)) return 'bath_refresh';
      if (/\badu|addition\b/.test(text)) return 'adu';
      return '';
    };

    const hydrateRightHandHandoff = () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get('src') !== 'voice') return;
      const archetypeHint = ['kitchen_remodel', 'bath_refresh', 'adu'].includes(params.get('archetype') ?? '')
        ? params.get('archetype')
        : '';
      let raw = null;
      try {
        raw = sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY);
      } catch {
        raw = null;
      }
      const trp = parseTurnResolution(raw);
      const handoff = document.getElementById('rh-project-handoff');
      const heard = document.getElementById('rh-project-handoff-heard');
      const contextEl = document.getElementById('rh-project-handoff-context');
      if (!trp && !archetypeHint) return;

      if (heard) {
        heard.textContent = trp?.heard_text || 'Right Hand started this from your last conversation.';
      }
      if (contextEl && trp) {
        const routed = trp.context_hypothesis?.routed_label ?? 'Create a new estimate';
        contextEl.textContent = routed
          .replace(/estimate intake/gi, 'estimate')
          .replace(/intake packet/gi, 'estimate')
          .replace(/estimate-start packet/gi, 'estimate');
      } else if (contextEl) {
        contextEl.textContent = archetypeHint === 'bath_refresh'
          ? 'New bathroom estimate'
          : archetypeHint === 'kitchen_remodel'
            ? 'New kitchen estimate'
            : archetypeHint === 'adu'
              ? 'New addition estimate'
              : 'Create a new estimate';
      }
      if (handoff) handoff.hidden = false;

      const form = document.getElementById('new-project-form');
      const projectName = form?.querySelector('[name="project_name"]');
      const clientName = form?.querySelector('[name="client_name"]');
      const archetype = form?.querySelector('[name="archetype_hint"]');
      const likely = trp?.context_hypothesis?.likely_entity;
      const projectSuggestion = trp
        ? inferProjectName(trp)
        : archetypeHint === 'bath_refresh'
          ? 'Bath estimate walk'
          : archetypeHint === 'kitchen_remodel'
            ? 'Kitchen estimate walk'
            : archetypeHint === 'adu'
              ? 'Addition estimate walk'
              : '';
      const archetypeSuggestion = trp ? inferArchetype(trp) : archetypeHint;

      if (projectName && !projectName.value && projectSuggestion) projectName.value = projectSuggestion;
      if (clientName && !clientName.value && likely?.type === 'client' && likely.label) clientName.value = likely.label;
      if (archetype && !archetype.value && archetypeSuggestion) archetype.value = archetypeSuggestion;
    };

    hydrateRightHandHandoff();

    document.getElementById('new-project-form')?.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const form = ev.target;
      const fd = new FormData(form);
      const status = document.getElementById('new-project-status');
      const res = await fetch(`/api/v1/projects?tenant_id=${tenantId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          project_name: fd.get('project_name'),
          client_name: fd.get('client_name'),
          client_id: String(fd.get('client_id') || '') || null,
          archetype_hint: fd.get('archetype_hint') || null,
        }),
      });
      if (res.ok) {
        const data = await res.json();
        status.textContent = successMsg;
        window.location.href = `/projects/${data.project_id}`;
        return;
      }
      status.textContent = errorMsg;
    });
  </script>

  <style>
    .rh-project-handoff[hidden] { display: none; }
    .rh-project-handoff {
      margin-bottom: 0.85rem;
      border-color: color-mix(in srgb, var(--field-green, #38c977) 34%, var(--border, #d8dee6));
      background: color-mix(in srgb, var(--field-green, #38c977) 7%, var(--surface, #fff));
    }
    .rh-project-handoff__eyebrow {
      margin: 0 0 0.35rem;
      font-size: 0.72rem;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      font-weight: 800;
      color: var(--field-green, #38c977);
    }
    .rh-project-handoff__body {
      margin: 0 0 0.7rem;
      color: var(--text-muted, #6a7282);
      line-height: 1.45;
    }
    .rh-project-handoff__facts {
      display: grid;
      gap: 0.55rem;
      margin: 0;
    }
    .rh-project-handoff__facts div {
      display: grid;
      gap: 0.12rem;
    }
    .rh-project-handoff__facts dt {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 800;
      color: var(--text-muted, #6a7282);
    }
    .rh-project-handoff__facts dd {
      margin: 0;
      color: var(--text, #1a1f24);
      line-height: 1.4;
    }
  </style>
</Layout>
