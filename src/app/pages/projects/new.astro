---
// F-PR0a / F-PR0b · project graph setup · /projects/new
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { getLane6ClientForTenant } from '../../lib/lane6Fixtures.js';
import '../../styles/intake-sales-wireframes.css';

const { context } = createLayoutContext();
const clientId = Astro.url.searchParams.get('client_id');
const presetClient = clientId
  ? getLane6ClientForTenant(
      clientId,
      context.tenantId as Parameters<typeof getLane6ClientForTenant>[1],
    )
  : null;
const source = Astro.url.searchParams.get('src') ?? 'projects';
const captureId = Astro.url.searchParams.get('capture_id') ?? '';
const fromCamera = source === 'camera' || Boolean(captureId);
const sourceLabel = fromCamera ? 'Camera route' : source === 'voice' ? 'Right Hand voice' : presetClient ? 'Client record' : 'Projects';
---

<Layout
  title="New project"
  activeHref="/projects"
  surfaceContext={{
    surface: 'project',
    client_id: presetClient?.client_id ?? clientId ?? undefined,
    phase: fromCamera ? 'capture_route' : 'create',
  }}
>
  <article class="rh-intake kg-grid" data-grammar="canon">
    <header class="kg-pagehead kg-span-12">
      <div>
        <p class="rh-eyebrow">F-PR0 · Project graph setup</p>
        <h1 class="rh-title">Where does this work live?</h1>
        <p class="rh-subtitle">
          Create the project graph from a client, sales conversation, voice handoff, or capture route.
          Captured media can file here after confirmation, but no proposal, invoice, or send happens on this face.
        </p>
      </div>
      <div class="rh-chiprow" aria-label="Project setup state">
        <span class="kg-chip kg-routechip">Project graph</span>
        <span class="kg-chip amber">Operator confirm</span>
        {fromCamera ? <span class="kg-chip green">Can file capture</span> : null}
      </div>
    </header>

    <section
      class="kg-card kg-span-12 rh-handoff"
      id="rh-project-handoff"
      aria-label="Right Hand handoff"
      hidden
    >
      <p class="rh-eyebrow">Right Hand handoff</p>
      <p class="rh-note">Right Hand carried the working draft here. Confirm the project before anything becomes part of the project record.</p>
      <dl class="rh-route-list rh-rule">
        <div>
          <dt>Heard</dt>
          <dd id="rh-project-handoff-heard"></dd>
        </div>
        <div>
          <dt>Context</dt>
          <dd id="rh-project-handoff-context"></dd>
        </div>
      </dl>
    </section>

    <section class="kg-card kg-span-8">
      <form class="rh-form" id="new-project-form">
        <div class="rh-fields">
          <label class="rh-field">
            <span>Client</span>
            <input
              name="client_name"
              required
              value={presetClient?.display_name ?? ''}
              autocomplete="name"
            />
          </label>
          <label class="rh-field">
            <span>Project name</span>
            <input name="project_name" required />
          </label>
          <label class="rh-field">
            <span>Stage</span>
            <select name="project_stage">
              <option value="lead">Lead / intake</option>
              <option value="design">Design</option>
              <option value="estimate">Estimate</option>
              <option value="active">Active job</option>
            </select>
          </label>
          <label class="rh-field">
            <span>Source</span>
            <input name="source_label" value={sourceLabel} readonly />
          </label>
          <label class="rh-field">
            <span>Archetype</span>
            <select name="archetype_hint">
              <option value="">Not sure yet</option>
              <option value="kitchen_remodel">Kitchen remodel</option>
              <option value="adu">ADU addition</option>
              <option value="bath_refresh">Bath refresh</option>
            </select>
          </label>
          <label class="rh-field">
            <span>Capture waiting</span>
            <input name="capture_id_display" value={captureId || 'None'} readonly />
          </label>
          <label class="rh-field full">
            <span>Site</span>
            <input name="site_hint" placeholder="Address, GPS hint, or site note" />
          </label>
        </div>

        <input type="hidden" name="client_id" value={presetClient?.client_id ?? clientId ?? ''} />
        <input type="hidden" name="capture_id" value={captureId} />
        <div class="rh-actions">
          <button type="submit" class="rh-btn primary" data-next="project">Create project</button>
          <button type="submit" class="rh-btn" data-next="estimate">Create + build estimate</button>
          <button type="submit" class="rh-btn" data-next="daily_log">Create + file capture</button>
          <a class="rh-btn" href={presetClient ? `/clients/${presetClient.client_id}` : '/projects'}>Cancel</a>
        </div>
      </form>
      <p class="rh-note rh-rule" id="new-project-status" role="status"></p>
    </section>

    <aside class="kg-card kg-span-4">
      <p class="rh-eyebrow">Allowed next</p>
      <dl class="rh-route-list">
        <div>
          <dt>Open project</dt>
          <dd>The project becomes the canonical home for this work.</dd>
        </div>
        <div>
          <dt>Build estimate</dt>
          <dd>Moves to F-EST1 with project context. This is not a proposal or money write.</dd>
        </div>
        <div>
          <dt>File capture</dt>
          <dd>When a capture launched this route, it files to the project Daily Log after the project exists.</dd>
        </div>
      </dl>
    </aside>
  </article>

  <script define:vars={{ tenantId: context.tenantId, successMsg: 'Project created — opens in Projects.', errorMsg: 'Could not create project.' }}>
    const TURN_RESOLUTION_SESSION_KEY = 'kerf.turnResolution';
    const VOICE_CONVERSATION_STORAGE_KEY = 'kerf.voiceConversation';

    const parseTurnResolution = (raw) => {
      try {
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || typeof parsed !== 'object') return null;
        if (typeof parsed.heard_text !== 'string') return null;
        return parsed;
      } catch {
        return null;
      }
    };

    const readVoiceConversation = () => {
      try {
        const raw = localStorage.getItem(VOICE_CONVERSATION_STORAGE_KEY)
          || sessionStorage.getItem(VOICE_CONVERSATION_STORAGE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : null;
      } catch {
        return null;
      }
    };

    const voiceWorkingDraft = (voice) => {
      const draft = voice?.workingDraft || voice?.working_draft;
      return draft && typeof draft === 'object' ? draft : null;
    };

    const inferProjectName = (trp) => {
      const likely = trp.context_hypothesis?.likely_entity;
      if (likely?.type === 'project' && likely.label) return likely.label;
      const text = `${trp.heard_text} ${trp.context_hypothesis?.label ?? ''}`.toLowerCase();
      if (/\bkitchen|cabinet|countertop|appliance|island|pantry\b/.test(text)) return 'Kitchen estimate walk';
      if (/\bbath|bathroom|shower|tub|vanity\b/.test(text)) return 'Bath estimate walk';
      return trp.context_hypothesis?.label ? `${trp.context_hypothesis.label} follow-up` : '';
    };

    const inferArchetype = (trp) => {
      const text = `${trp.heard_text} ${trp.context_hypothesis?.label ?? ''}`.toLowerCase();
      if (/\bkitchen|cabinet|countertop|appliance|island|pantry\b/.test(text)) return 'kitchen_remodel';
      if (/\bbath|bathroom|shower|tub|vanity\b/.test(text)) return 'bath_refresh';
      if (/\badu|addition\b/.test(text)) return 'adu';
      return '';
    };

    const hydrateRightHandHandoff = () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get('src') !== 'voice') return;
      const archetypeHint = ['kitchen_remodel', 'bath_refresh', 'adu'].includes(params.get('archetype') ?? '')
        ? params.get('archetype')
        : '';
      let raw = null;
      try {
        raw = sessionStorage.getItem(TURN_RESOLUTION_SESSION_KEY);
      } catch {
        raw = null;
      }
      const trp = parseTurnResolution(raw);
      const voice = readVoiceConversation();
      const workingDraft = voiceWorkingDraft(voice);
      const handoff = document.getElementById('rh-project-handoff');
      const heard = document.getElementById('rh-project-handoff-heard');
      const contextEl = document.getElementById('rh-project-handoff-context');
      if (!trp && !archetypeHint && !workingDraft) return;

      if (heard) {
        heard.textContent = workingDraft?.rawText || trp?.heard_text || 'Right Hand started this from your last conversation.';
      }
      if (contextEl && Array.isArray(workingDraft?.scopeFacts) && workingDraft.scopeFacts.length) {
        contextEl.textContent = `New project intake · ${workingDraft.scopeFacts.join(', ')}`;
      } else if (contextEl && trp) {
        const routed = trp.context_hypothesis?.routed_label ?? 'Create a new estimate';
        contextEl.textContent = routed
          .replace(/estimate intake/gi, 'estimate')
          .replace(/intake packet/gi, 'estimate')
          .replace(/estimate-start packet/gi, 'estimate');
      } else if (contextEl) {
        contextEl.textContent = archetypeHint === 'bath_refresh'
          ? 'New bathroom estimate'
          : archetypeHint === 'kitchen_remodel'
            ? 'New kitchen estimate'
            : archetypeHint === 'adu'
              ? 'New addition estimate'
              : 'Create a new estimate';
      }
      if (handoff) handoff.hidden = false;

      const form = document.getElementById('new-project-form');
      const projectName = form?.querySelector('[name="project_name"]');
      const clientName = form?.querySelector('[name="client_name"]');
      const archetype = form?.querySelector('[name="archetype_hint"]');
      const likely = trp?.context_hypothesis?.likely_entity;
      const projectSuggestion = workingDraft?.projectName || (trp
        ? inferProjectName(trp)
        : archetypeHint === 'bath_refresh'
          ? 'Bath estimate walk'
          : archetypeHint === 'kitchen_remodel'
            ? 'Kitchen estimate walk'
            : archetypeHint === 'adu'
              ? 'Addition estimate walk'
              : '');
      const archetypeSuggestion = workingDraft?.archetypeHint || (trp ? inferArchetype(trp) : archetypeHint);

      if (projectName && !projectName.value && projectSuggestion) projectName.value = projectSuggestion;
      if (clientName && !clientName.value && workingDraft?.clientName) clientName.value = workingDraft.clientName;
      else if (clientName && !clientName.value && likely?.type === 'client' && likely.label) clientName.value = likely.label;
      if (archetype && !archetype.value && archetypeSuggestion) archetype.value = archetypeSuggestion;
    };

    hydrateRightHandHandoff();

    document.getElementById('new-project-form')?.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      const form = ev.target;
      const submitter = ev.submitter;
      const next = submitter?.getAttribute('data-next') || 'project';
      const fd = new FormData(form);
      const projectName = String(fd.get('project_name') || '').trim();
      const clientName = String(fd.get('client_name') || '').trim();
      if (!projectName || !clientName) return;
      if (!confirm(`Create project "${projectName}" for ${clientName}?`)) return;

      const status = document.getElementById('new-project-status');
      if (status) status.textContent = 'Creating project…';
      const res = await fetch(`/api/v1/projects?tenant_id=${tenantId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          project_name: projectName,
          client_name: clientName,
          client_id: String(fd.get('client_id') || '') || null,
          archetype_hint: fd.get('archetype_hint') || null,
        }),
      });
      if (res.ok) {
        const data = await res.json();
        if (status) status.textContent = successMsg;
        if (next === 'estimate') {
          window.location.href = `/estimate/${data.project_id}?src=project_setup`;
          return;
        }
        if (next === 'daily_log') {
          window.location.href = `/projects/${data.project_id}/daily-log?src=project_setup`;
          return;
        }
        window.location.href = `/projects/${data.project_id}`;
        return;
      }
      if (status) status.textContent = errorMsg;
    });
  </script>
</Layout>
