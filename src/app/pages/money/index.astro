---
import Layout from '../../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../../components/SurfaceIrreversibilityWrap.astro';
import RhSummary from '../../components/RhSummary.astro';
import Card from '../../components/Card.astro';
import ExportActions from '../../components/ExportActions.astro';
import MoneyQueueList from '../../components/MoneyQueueList.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { projectForRole, DEFAULT_BUSINESS_GRAPH_SLICE } from '../../lib/roleRootProjection.js';
import {
  formatMoneyUsd,
  MONEY_HOME_SUMMARY,
  MONEY_AR_ROWS,
  MONEY_AP_ROWS,
  MONEY_ALLOWANCE_ROWS,
  moneyTenant,
} from '../../lib/moneyFixtures.js';
import '../../styles/money.css';

const { t, context } = createLayoutContext();
const projected = projectForRole(DEFAULT_BUSINESS_GRAPH_SLICE, context, null);
if (!projected.capabilities.moneyRead) {
  return Astro.redirect('/');
}
if (moneyTenant() !== context.tenantId) {
  return Astro.redirect('/');
}
const summary = MONEY_HOME_SUMMARY;
---

<Layout
  titleKey="f_mn.home.title"
  activeHref="/money"
  surfaceContext={{
    surface: 'money',
    phase: 'operating_queue',
  }}
>
  <article class="money-page">
    <header>
      <div class="money-crumb">{t('f_mn.crumb')}</div>
      <h1 class="money-title">{t('f_mn.home.title')}</h1>
      <p class="money-subtitle">{t('f_mn.home.subtitle')}</p>
      <nav class="money-nav-pills" aria-label={t('f_mn.nav.aria')}>
        <a class="active" href="/money">{t('f_mn.nav.home')}</a>
        <a href="/money/ar">{t('f_mn.nav.ar')}</a>
        <a href="/money/ap">{t('f_mn.nav.ap')}</a>
        <a href="/money/allowances">{t('f_mn.nav.allowances')}</a>
        <a href="/money/bookkeeping">{t('f_mn.nav.bookkeeping')}</a>
        <a href="/money/qb-export">{t('f_mn.nav.qb')}</a>
        {projected.capabilities.marginVisible ? (
          <a href="/money/margin">{t('f_mn.nav.margin')}</a>
        ) : null}
      </nav>
    </header>

    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <ExportActions
        surface="money.home"
        scopeDescriptor="Money home · operating queue"
        itemCount={summary.ar_count + summary.ap_count + summary.allowance_count}
        actions={[
          { label: t('action.print'), format: 'print' },
          { label: t('f_mn.export.pdf'), format: 'pdf' },
        ]}
      />
      <RhSummary headline={t('f_mn.home.rh_headline')} detail={t('f_mn.home.rh_detail')} tone="green" />

      <dl class="money-summary-grid">
        <div class="money-summary-tile">
          <dt>{t('f_mn.home.ar_due')}</dt>
          <dd>{formatMoneyUsd(summary.ar_due_cents)}</dd>
        </div>
        <div class="money-summary-tile">
          <dt>{t('f_mn.home.ap_due')}</dt>
          <dd>{formatMoneyUsd(summary.ap_due_cents)}</dd>
        </div>
        <div class="money-summary-tile">
          <dt>{t('f_mn.home.allowance_risk')}</dt>
          <dd>{formatMoneyUsd(summary.allowance_risk_cents)}</dd>
        </div>
      </dl>

      <Card title={t('f_mn.home.ar_section')} eyebrow={t('f_mn.home.attention')}>
        <MoneyQueueList rows={MONEY_AR_ROWS.slice(0, 2)} emptyLabel={t('f_mn.empty')} />
        <div class="money-actions">
          <a class="money-btn ghost" href="/money/ar">{t('f_mn.home.see_ar')}</a>
        </div>
      </Card>

      <Card title={t('f_mn.home.ap_section')}>
        <MoneyQueueList rows={MONEY_AP_ROWS.slice(0, 2)} emptyLabel={t('f_mn.empty')} />
        <div class="money-actions">
          <a class="money-btn ghost" href="/money/ap">{t('f_mn.home.see_ap')}</a>
        </div>
      </Card>

      <Card title={t('f_mn.home.allowance_section')}>
        <MoneyQueueList rows={MONEY_ALLOWANCE_ROWS} emptyLabel={t('f_mn.empty')} />
      </Card>

      <p class="money-notice">{t('f_mn.no_payment_notice')}</p>
    </SurfaceIrreversibilityWrap>
  </article>
</Layout>
