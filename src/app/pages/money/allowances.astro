---
import Layout from '../../layouts/Layout.astro';
import SurfaceIrreversibilityWrap from '../../components/SurfaceIrreversibilityWrap.astro';
import Card from '../../components/Card.astro';
import ExportActions from '../../components/ExportActions.astro';
import MoneyQueueList from '../../components/MoneyQueueList.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import { projectForRole, DEFAULT_BUSINESS_GRAPH_SLICE } from '../../lib/roleRootProjection.js';
import { MONEY_ALLOWANCE_ROWS } from '../../lib/moneyFixtures.js';
import '../../styles/money.css';

const { t, context } = createLayoutContext();
const projected = projectForRole(DEFAULT_BUSINESS_GRAPH_SLICE, context, null);
if (!projected.capabilities.moneyRead) {
  return Astro.redirect('/');
}
---

<Layout titleKey="f_mn.allowances.title" activeHref="/money">
  <article class="money-page">
    <header>
      <div class="money-crumb"><a href="/money">{t('f_mn.crumb')}</a> · {t('f_mn.allowances.title')}</div>
      <h1 class="money-title">{t('f_mn.allowances.title')}</h1>
      <p class="money-subtitle">{t('f_mn.allowances.subtitle')}</p>
    </header>

    <SurfaceIrreversibilityWrap kind="daily" safetyLineBudget={3}>
      <ExportActions
        surface="money.allowance_exceptions"
        scopeDescriptor="Allowance exceptions"
        itemCount={MONEY_ALLOWANCE_ROWS.length}
      />
      <Card title={t('f_mn.allowances.queue')}>
        <MoneyQueueList rows={MONEY_ALLOWANCE_ROWS} emptyLabel={t('f_mn.empty')} />
      </Card>
    </SurfaceIrreversibilityWrap>
  </article>
</Layout>
