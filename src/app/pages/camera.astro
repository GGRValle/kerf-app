---
import Layout from '../layouts/Layout.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { listLane23Projects } from '../lib/lane23Fixtures.js';

const { context } = createLayoutContext();
const projects = listLane23Projects(context.tenantId);
const safeProjectId = (raw: string | null) => raw && /^[A-Za-z0-9_-]+$/.test(raw) ? raw : '';
const requestedProjectId = safeProjectId(Astro.url.searchParams.get('project_id'));
const selectedProject = projects.find((project) => project.project_id === requestedProjectId) ?? null;
const suggestedJob = selectedProject ?? projects[0] ?? null;
const routePrefilled = selectedProject !== null;
const rawReturnTo = Astro.url.searchParams.get('return_to') ?? '';
const safeReturnTo = rawReturnTo.startsWith('/') && !rawReturnTo.startsWith('//') ? rawReturnTo : '';
const fallbackReturn = selectedProject ? `/projects/${selectedProject.project_id}?src=camera` : '/';
const returnHref = safeReturnTo || fallbackReturn;
const modeParam = Astro.url.searchParams.get('mode');
const initialMode = modeParam === 'walkthru' || modeParam === 'scan' ? modeParam : 'photo';
---

<Layout
  title="Camera"
  activeHref="/camera"
  surfaceContext={{
    surface: 'field_capture',
    phase: routePrefilled ? 'capture' : 'route_pending',
    ...(routePrefilled && selectedProject ? { project_id: selectedProject.project_id } : {}),
  }}
>
  <section
    class="f-cam1"
    data-grammar="canon"
    aria-labelledby="camera-title"
    data-suggested-project-id={suggestedJob?.project_id ?? ''}
    data-suggested-project-name={suggestedJob?.project_name ?? ''}
    data-suggested-project-client={suggestedJob?.client_name ?? ''}
    data-suggested-match="job-site GPS"
    data-route-confirmed={routePrefilled ? 'true' : 'false'}
    data-selected-project-id={routePrefilled ? (selectedProject?.project_id ?? '') : ''}
    data-return-href={returnHref}
    data-initial-mode={initialMode}
  >
    <h1 id="camera-title" class="cam-sr-only">Camera</h1>

    <section class="cam-stage" aria-label="Camera capture">
      <div class="cam-viewfinder" data-mode={initialMode}>
        <video
          id="cam-video"
          class="cam-video"
          playsinline
          muted
          autoplay
          aria-label="Live camera preview"
        ></video>
        <canvas id="cam-canvas" hidden></canvas>
        <div class="cam-topbar">
          <div class="cam-topbar__group">
            <a class="cam-back" href={returnHref} aria-label="Close camera">×</a>
            <button type="button" class="cam-icon-btn" aria-label="Camera settings">⚙</button>
          </div>
          <div class="cam-job-chip kg-routechip" id="cam-job-chip">
            <span class="cam-job-chip__label">Capture</span>
            <strong id="cam-job-chip-label">{routePrefilled ? (selectedProject?.project_name ?? 'Active job') : 'Photo · walkthru · scan'}</strong>
          </div>
          <div class="cam-topbar__group">
            <button type="button" class="cam-icon-btn" aria-label="Flash">⚡</button>
            <button type="button" class="cam-icon-btn" aria-label="Flip camera">↻</button>
          </div>
        </div>

        <div class="cam-rec-pill kg-chip green" id="cam-rec-pill" hidden>Right Hand listening · REC</div>
        <div class="cam-camera-state" id="cam-camera-state" hidden>
          <strong>Camera access needed</strong>
          <span>Use the fallback only if the browser cannot open the camera here.</span>
        </div>
        <div class="cam-crosshair" aria-hidden="true"></div>
        <p class="cam-viewfinder__copy" id="cam-viewfinder-copy">
          {initialMode === 'walkthru'
            ? 'Talk while you film. Right Hand will route the walkthrough after you capture.'
            : initialMode === 'scan'
              ? 'Room scan needs native LiDAR. This web build keeps it separate for now.'
              : 'Capture first — Right Hand will suggest where it goes.'}
        </p>
      </div>

      <a class="cam-room-link" href="/room-capture?src=camera&mode=start">Room scan</a>

      <div class="cam-bottom-overlay">
        <div class="cam-zoom" aria-label="Zoom">
          <button type="button">.5</button>
          <button type="button" aria-pressed="true">1×</button>
          <button type="button">3×</button>
        </div>

        <div class="cam-mode-strip" role="tablist" aria-label="Camera mode">
          <button type="button" role="tab" data-mode="walkthru" aria-selected={initialMode === 'walkthru' ? 'true' : 'false'}>Walkthru</button>
          <button type="button" role="tab" data-mode="photo" aria-selected={initialMode === 'photo' ? 'true' : 'false'}>Photo</button>
          <button type="button" role="tab" data-mode="scan" aria-selected={initialMode === 'scan' ? 'true' : 'false'}>Scan</button>
        </div>

        <div class="cam-controls">
          <div class="cam-last-shot" aria-hidden="true">
            <span>Last</span>
          </div>
          <button type="button" class="cam-shutter" id="cam-shutter" aria-label="Capture media"></button>
          <button type="button" class="cam-done" id="cam-done">Done</button>
        </div>
      </div>

      <section class="cam-captured kg-card" id="cam-captured" aria-label="Captured media" hidden>
        <p class="cam-captured__eyebrow">Captured this session</p>
        <div class="cam-captured__item" id="cam-captured-item">
          <div class="cam-thumb" id="cam-thumb" aria-hidden="true"></div>
          <div class="cam-captured__copy">
            <strong id="cam-captured-title">Media ready</strong>
            <span id="cam-captured-detail">Capture first. Choose where it goes before filing.</span>
          </div>
        </div>
      </section>

      <section class="cam-route-panel kg-card" id="cam-route-panel" hidden aria-label="Confirm capture destination">
        <div class="cam-route-head">
          <p class="cam-route-eyebrow">Goes to</p>
          <button type="button" class="cam-route-close" id="cam-route-close" aria-label="Close destination panel">×</button>
        </div>
        <p class="cam-route-suggestion" id="cam-route-suggestion">
          {suggestedJob
            ? `Active job · ${suggestedJob.client_name.split(',')[0]?.trim() ?? suggestedJob.project_name}`
            : 'Choose a destination'}
        </p>
        <label class="cam-route-label" for="cam-route-select">Change destination</label>
        <select class="cam-route-select" id="cam-route-select">
          {projects.map((project) => (
            <option
              value={project.project_id}
              data-project-name={project.project_name}
              data-project-client={project.client_name}
              selected={project.project_id === (suggestedJob?.project_id ?? '')}
            >
              {project.project_name} · {project.client_name}
            </option>
          ))}
        </select>
        <p class="cam-route-hint" id="cam-route-hint">
          {suggestedJob
            ? `Right Hand matched your active job by job-site GPS. Confirm or change before filing.`
            : 'Pick where this capture belongs before filing.'}
        </p>
        <div class="cam-route-actions">
          <button type="button" class="cam-route-confirm" id="cam-route-confirm">Confirm destination</button>
          <a class="cam-route-link" href="/projects?src=camera">Search jobs</a>
        </div>
      </section>

      <p class="cam-status" id="camera-status" role="status" aria-live="polite">
        {routePrefilled && selectedProject
          ? `Ready for ${selectedProject.project_name}.`
          : 'Camera open — capture now, route after.'}
      </p>

      <input id="camera-photo-input" type="file" accept="image/*" capture="environment" hidden />
      <input id="camera-video-input" type="file" accept="video/*" capture="environment" hidden />
    </section>
  </section>

  <script>
    const root = document.querySelector('.f-cam1');
    const status = document.querySelector('#camera-status');
    const jobChipLabel = document.querySelector('#cam-job-chip-label');
    const routePanel = document.querySelector('#cam-route-panel');
    const routeSuggestion = document.querySelector('#cam-route-suggestion');
    const routeSelect = document.querySelector('#cam-route-select');
    const routeConfirm = document.querySelector('#cam-route-confirm');
    const routeClose = document.querySelector('#cam-route-close');
    const viewfinder = document.querySelector('.cam-viewfinder');
    const video = document.querySelector('#cam-video');
    const canvas = document.querySelector('#cam-canvas');
    const cameraState = document.querySelector('#cam-camera-state');
    const viewfinderCopy = document.querySelector('#cam-viewfinder-copy');
    const recPill = document.querySelector('#cam-rec-pill');
    const photoInput = document.querySelector('#camera-photo-input');
    const videoInput = document.querySelector('#camera-video-input');
    const captured = document.querySelector('#cam-captured');
    const capturedTitle = document.querySelector('#cam-captured-title');
    const capturedDetail = document.querySelector('#cam-captured-detail');
    const thumb = document.querySelector('#cam-thumb');
    let currentMode = root?.getAttribute('data-initial-mode') || 'photo';
    let suggestedProjectId = root?.getAttribute('data-suggested-project-id') || '';
    let suggestedProjectName = root?.getAttribute('data-suggested-project-name') || '';
    let suggestedProjectClient = root?.getAttribute('data-suggested-project-client') || '';
    let selectedProjectId = root?.getAttribute('data-selected-project-id') || '';
    let selectedProjectName = selectedProjectId ? suggestedProjectName : '';
    let routeConfirmed = root?.getAttribute('data-route-confirmed') === 'true';
    let lastCapture = null;
    let cameraStream = null;
    let cameraFailure = null;
    let recorder = null;
    let recorderChunks = [];
    let recordingStartedAt = 0;

    const copyForMode = (mode) => {
      if (mode === 'walkthru') return 'Talk while you film. Right Hand will route the walkthrough after you capture.';
      if (mode === 'scan') return 'Room scan needs native LiDAR. This web build keeps it separate for now.';
      return 'Capture first — Right Hand will suggest where it goes.';
    };
    const setStatus = (message) => {
      if (status instanceof HTMLElement) status.textContent = message;
    };
    const syncRouteChip = () => {
      if (!(jobChipLabel instanceof HTMLElement)) return;
      if (routeConfirmed && selectedProjectName) {
        jobChipLabel.textContent = selectedProjectName;
      } else {
        jobChipLabel.textContent = 'Photo · walkthru · scan';
      }
    };
    const updateSurfaceContextProject = (projectId) => {
      const ctx = window.__KERF_SURFACE_CONTEXT__;
      if (!ctx || typeof ctx !== 'object') return;
      ctx.project_id = projectId || undefined;
      ctx.phase = projectId ? 'capture' : 'route_pending';
      window.__KERF_SURFACE_CONTEXT__ = ctx;
      const el = document.getElementById('kerf-surface-context');
      if (el) el.textContent = JSON.stringify(ctx);
    };
    const syncRouteSuggestion = () => {
      if (!(routeSuggestion instanceof HTMLElement)) return;
      if (selectedProjectClient) {
        const shortClient = selectedProjectClient.split(',')[0]?.trim() || selectedProjectName;
        routeSuggestion.textContent = `Active job · ${shortClient}`;
      } else if (selectedProjectName) {
        routeSuggestion.textContent = selectedProjectName;
      } else {
        routeSuggestion.textContent = 'Choose a destination';
      }
    };
    const showRoutePanel = () => {
      if (!(routePanel instanceof HTMLElement)) return;
      routePanel.hidden = false;
      routePanel.style.display = 'grid';
      if (root instanceof HTMLElement) root.classList.add('route-pending');
      syncRouteSuggestion();
      setStatus('Confirm where this capture goes, then tap Done again.');
    };
    const hideRoutePanel = () => {
      if (!(routePanel instanceof HTMLElement)) return;
      routePanel.hidden = true;
      routePanel.style.display = 'none';
      if (root instanceof HTMLElement) root.classList.remove('route-pending');
      if (lastCapture) {
        setStatus(`${friendlyForKind(lastCapture.kind)} captured — tap Done to choose where it goes.`);
      }
    };
    const applySelectedRoute = () => {
      if (routeSelect instanceof HTMLSelectElement) {
        const option = routeSelect.selectedOptions[0];
        selectedProjectId = option?.value || suggestedProjectId;
        selectedProjectName = option?.dataset.projectName || suggestedProjectName;
        selectedProjectClient = option?.dataset.projectClient || suggestedProjectClient;
      } else {
        selectedProjectId = suggestedProjectId;
        selectedProjectName = suggestedProjectName;
        selectedProjectClient = suggestedProjectClient;
      }
      routeConfirmed = selectedProjectId.length > 0;
      if (root instanceof HTMLElement) {
        root.dataset.selectedProjectId = selectedProjectId;
        root.dataset.routeConfirmed = routeConfirmed ? 'true' : 'false';
      }
      updateSurfaceContextProject(selectedProjectId);
      syncRouteChip();
      hideRoutePanel();
      if (lastCapture) {
        if (capturedDetail instanceof HTMLElement) {
          capturedDetail.textContent = `Ready to file to ${selectedProjectName} · Daily Log.`;
        }
        setStatus(`${friendlyForKind(lastCapture.kind)} ready — tap Done to file to ${selectedProjectName}.`);
      }
    };
    const stopCamera = () => {
      if (typeof MediaStream !== 'undefined' && cameraStream instanceof MediaStream) {
        cameraStream.getTracks().forEach((track) => track.stop());
      }
      cameraStream = null;
      if (video instanceof HTMLVideoElement) video.srcObject = null;
      if (viewfinder instanceof HTMLElement) viewfinder.classList.remove('is-live');
    };
    const setCameraState = (headline, detail) => {
      if (!(cameraState instanceof HTMLElement)) return;
      if (!headline) {
        cameraState.hidden = true;
        return;
      }
      cameraState.hidden = false;
      const title = cameraState.querySelector('strong');
      const copy = cameraState.querySelector('span');
      if (title instanceof HTMLElement) title.textContent = headline;
      if (copy instanceof HTMLElement) copy.textContent = detail;
    };
    const mediaConstraintsForMode = (mode) => ({
      video: {
        facingMode: { ideal: 'environment' },
        width: { ideal: 1280 },
        height: { ideal: 720 },
      },
      audio: mode === 'walkthru',
    });
    const startCamera = async () => {
      cameraFailure = null;
      if (currentMode === 'scan') {
        stopCamera();
        setCameraState('Native scan is separate', 'LiDAR/room scan is not available in this web camera yet.');
        return false;
      }
      if (!window.isSecureContext) {
        cameraFailure = 'secure_context_required';
        stopCamera();
        setCameraState('Open on HTTPS to use camera', 'Use the file fallback only for this browser session.');
        return false;
      }
      if (!navigator.mediaDevices?.getUserMedia) {
        cameraFailure = 'getusermedia_unavailable';
        stopCamera();
        setCameraState('Camera unavailable here', 'Use the file fallback because this browser cannot open an in-app camera.');
        return false;
      }
      stopCamera();
      try {
        cameraStream = await navigator.mediaDevices.getUserMedia(mediaConstraintsForMode(currentMode));
      } catch (err) {
        if (currentMode === 'walkthru') {
          try {
            cameraStream = await navigator.mediaDevices.getUserMedia(mediaConstraintsForMode('photo'));
          } catch (fallbackErr) {
            cameraFailure = fallbackErr instanceof Error ? fallbackErr.name : 'camera_denied';
          }
        } else {
          cameraFailure = err instanceof Error ? err.name : 'camera_denied';
        }
      }
      if (!(cameraStream instanceof MediaStream)) {
        stopCamera();
        setCameraState('Camera access blocked', 'Enable camera access or use the fallback file picker.');
        return false;
      }
      if (video instanceof HTMLVideoElement) {
        video.srcObject = cameraStream;
        await video.play().catch(() => undefined);
      }
      if (viewfinder instanceof HTMLElement) viewfinder.classList.add('is-live');
      setCameraState('', '');
      return true;
    };
    const setMode = async (mode) => {
      currentMode = mode;
      if (viewfinder instanceof HTMLElement) viewfinder.dataset.mode = mode;
      if (viewfinderCopy instanceof HTMLElement) viewfinderCopy.textContent = copyForMode(mode);
      if (recPill instanceof HTMLElement) {
        recPill.hidden = mode !== 'walkthru'
          || typeof MediaRecorder === 'undefined'
          || !(recorder instanceof MediaRecorder && recorder.state === 'recording');
      }
      document.querySelectorAll('[data-mode]').forEach((button) => {
        if (button instanceof HTMLButtonElement) button.setAttribute('aria-selected', button.dataset.mode === mode ? 'true' : 'false');
      });
      if (mode === 'scan') {
        setStatus('');
      } else {
        setStatus(routeConfirmed && selectedProjectName
          ? `Ready for ${selectedProjectName}.`
          : 'Camera open — capture now, route after.');
      }
      await startCamera();
    };
    routeSelect?.addEventListener('change', () => {
      if (!(routeSelect instanceof HTMLSelectElement)) return;
      const option = routeSelect.selectedOptions[0];
      selectedProjectId = option?.value || '';
      selectedProjectName = option?.dataset.projectName || '';
      selectedProjectClient = option?.dataset.projectClient || '';
      syncRouteSuggestion();
    });
    routeConfirm?.addEventListener('click', () => {
      applySelectedRoute();
    });
    routeClose?.addEventListener('click', () => {
      hideRoutePanel();
    });
    const handleRouteAction = (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const action = target?.closest('#cam-route-close, #cam-route-confirm');
      if (!action) return;
      event.preventDefault();
      event.stopPropagation();
      event.stopImmediatePropagation?.();
      if (action.id === 'cam-route-confirm') {
        applySelectedRoute();
      } else {
        hideRoutePanel();
      }
    };
    document.addEventListener('pointerdown', handleRouteAction, true);
    document.addEventListener('click', handleRouteAction, true);
    const kindForMode = () => currentMode === 'walkthru' ? 'walkthrough' : currentMode === 'scan' ? 'scan' : 'photo';
    const friendlyForKind = (kind) => kind === 'walkthrough' ? 'Walkthrough' : kind === 'scan' ? 'Document scan' : 'Photo';
    const fallbackInputForMode = () => currentMode === 'walkthru' ? videoInput : photoInput;
    const openFallbackCapture = () => {
      if (currentMode === 'scan') {
        setStatus('Room scan is native LiDAR and is not available in this web camera yet.');
        return;
      }
      const input = fallbackInputForMode();
      if (input instanceof HTMLInputElement) input.click();
    };
    const updateLastShot = (kind, previewUrl = '') => {
      const friendly = friendlyForKind(kind);
      if (root instanceof HTMLElement) root.classList.add('has-capture');
      if (captured instanceof HTMLElement) captured.hidden = false;
      if (viewfinderCopy instanceof HTMLElement) viewfinderCopy.hidden = true;
      if (capturedTitle instanceof HTMLElement) capturedTitle.textContent = `${friendly} ready`;
      if (capturedDetail instanceof HTMLElement) {
        capturedDetail.textContent = routeConfirmed && selectedProjectName
          ? `Ready to file to ${selectedProjectName} · Daily Log.`
          : 'Captured — confirm destination before filing.';
      }
      if (thumb instanceof HTMLElement) {
        thumb.className = `cam-thumb ${kind === 'photo' ? 'is-photo' : kind === 'scan' ? 'is-scan' : 'is-video'}`;
        thumb.style.backgroundImage = previewUrl ? `url("${previewUrl}")` : '';
        thumb.textContent = previewUrl ? '' : kind === 'walkthrough' ? 'REC' : kind === 'scan' ? 'DOC' : 'IMG';
      }
      setStatus(routeConfirmed && selectedProjectName
        ? `${friendly} ready — tap Done to file to ${selectedProjectName}.`
        : `${friendly} captured — tap Done to choose where it goes.`);
      if (!routeConfirmed) showRoutePanel();
    };
    const rememberCapture = (capture) => {
      lastCapture = {
        project_id: routeConfirmed ? selectedProjectId : '',
        project_name: routeConfirmed ? selectedProjectName : '',
        at: Date.now(),
        status: routeConfirmed ? 'ready_to_file' : 'pending_route',
        ...capture,
      };
      try {
        sessionStorage.setItem('kerf.cameraCapture', JSON.stringify(lastCapture));
      } catch {
        // Visible state still tells the operator what happened.
      }
    };
    const captureStillFromVideo = (kind = 'photo') => {
      if (!(video instanceof HTMLVideoElement) || !(canvas instanceof HTMLCanvasElement)) {
        return false;
      }
      const width = video.videoWidth || 1280;
      const height = video.videoHeight || 720;
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');
      if (!ctx) return false;
      ctx.drawImage(video, 0, 0, width, height);
      const dataUrl = canvas.toDataURL('image/jpeg', 0.82);
      const name = `${kind === 'walkthrough' ? 'walkthrough-frame' : 'photo'}-${Date.now()}.jpg`;
      rememberCapture({ kind, name, source: 'getUserMedia_canvas_frame' });
      updateLastShot(kind, dataUrl);
      return true;
    };
    const finishWalkthruRecording = () => new Promise((resolve) => {
      if (!(recorder instanceof MediaRecorder) || recorder.state === 'inactive') {
        resolve(false);
        return;
      }
      recorder.addEventListener('stop', () => {
        const mime = recorder.mimeType || 'video/webm';
        const blob = new Blob(recorderChunks, { type: mime });
        const ext = mime.includes('mp4') ? 'mp4' : 'webm';
        const objectUrl = URL.createObjectURL(blob);
        rememberCapture({
          kind: 'walkthrough',
          name: `walkthrough-${recordingStartedAt || Date.now()}.${ext}`,
          source: 'getUserMedia_mediarecorder',
          bytes: blob.size,
        });
        updateLastShot('walkthrough', objectUrl);
        if (recPill instanceof HTMLElement) recPill.hidden = true;
        resolve(true);
      }, { once: true });
      recorder.stop();
    });
    const startWalkthruRecording = () => {
      if (!(cameraStream instanceof MediaStream) || typeof MediaRecorder === 'undefined') {
        return captureStillFromVideo('walkthrough');
      }
      if (recorder instanceof MediaRecorder && recorder.state === 'recording') {
        void finishWalkthruRecording();
        return true;
      }
      recorderChunks = [];
      recorder = new MediaRecorder(cameraStream);
      recordingStartedAt = Date.now();
      recorder.addEventListener('dataavailable', (event) => {
        if (event.data.size > 0) recorderChunks.push(event.data);
      });
      recorder.start();
      if (recPill instanceof HTMLElement) recPill.hidden = false;
      setStatus('Recording walkthrough — tap shutter or Done to finish.');
      return true;
    };
    const openCapture = async () => {
      if (currentMode === 'scan') {
        setStatus('Scan needs native LiDAR. Use Room scan when the native capture path is ready.');
        setCameraState('Native scan is separate', 'Nothing was filed. LiDAR capture is deferred to the native track.');
        return;
      }
      if (!(cameraStream instanceof MediaStream)) {
        const started = await startCamera();
        if (!started) {
          setStatus('Camera unavailable here — using fallback file picker.');
          openFallbackCapture();
          return;
        }
      }
      const capturedInline = currentMode === 'walkthru'
        ? startWalkthruRecording()
        : captureStillFromVideo('photo');
      if (!capturedInline) {
        setStatus('Camera unavailable here — using fallback file picker.');
        openFallbackCapture();
      }
    };
    const onSelectedFile = (file, kind) => {
      if (!file) return;
      const objectUrl = kind === 'photo' && file.type?.startsWith('image/') ? URL.createObjectURL(file) : '';
      rememberCapture({
        kind,
        name: file.name || `${kind} capture`,
        source: 'file_input_fallback',
      });
      updateLastShot(kind, objectUrl);
    };
    const done = async () => {
      if (recorder instanceof MediaRecorder && recorder.state === 'recording') {
        setStatus('Finishing walkthrough…');
        await finishWalkthruRecording();
      }
      if (!lastCapture) {
        setStatus('Nothing captured yet. Take a photo, scan a document, or record a walkthrough first.');
        return;
      }
      if (!routeConfirmed || !selectedProjectId) {
        showRoutePanel();
        return;
      }
      setStatus(`Filing ${friendlyForKind(lastCapture.kind).toLowerCase()} to ${selectedProjectName}…`);
      const doneButton = document.querySelector('#cam-done');
      if (doneButton instanceof HTMLButtonElement) doneButton.disabled = true;
      try {
        const response = await fetch(`/api/v1/projects/${selectedProjectId}/camera-capture`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            capture_kind: lastCapture.kind,
            file_name: lastCapture.name,
            confirmed: true,
          }),
        });
        if (!response.ok) {
          throw new Error(`file_failed_${response.status}`);
        }
        const result = await response.json();
        const filedCapture = {
          ...lastCapture,
          status: 'filed_to_daily_log',
          daily_log_route: result.daily_log_route,
          work_artifact_ref: result.artifacts?.work?.id,
          attention_artifact_ref: result.artifacts?.attention?.id,
          returned_at: Date.now(),
        };
        try {
          sessionStorage.setItem('kerf.cameraCapture', JSON.stringify(filedCapture));
        } catch {
          // Status below remains the visible fallback.
        }
        if (capturedTitle instanceof HTMLElement) capturedTitle.textContent = `${friendlyForKind(lastCapture.kind)} attached`;
        if (capturedDetail instanceof HTMLElement) {
          capturedDetail.textContent = `Attached to ${selectedProjectName} · Daily Log.`;
        }
        setStatus(`${friendlyForKind(lastCapture.kind)} attached to ${selectedProjectName}.`);
      } catch {
        if (doneButton instanceof HTMLButtonElement) doneButton.disabled = false;
        setStatus('Could not file that yet. Nothing was attached — try again or choose another job.');
        return;
      }
      const base = root?.getAttribute('data-return-href') || `/projects/${selectedProjectId}`;
      const destination = base.includes('?') ? `${base}&src=camera` : `${base}?src=camera`;
      window.location.href = destination;
    };

    document.querySelectorAll('.cam-mode-strip [data-mode]').forEach((button) => {
      button.addEventListener('click', () => void setMode(button.getAttribute('data-mode') || 'photo'));
    });
    document.querySelector('#cam-shutter')?.addEventListener('click', () => void openCapture());
    document.querySelector('#cam-done')?.addEventListener('click', done);
    photoInput?.addEventListener('change', () => onSelectedFile(photoInput instanceof HTMLInputElement ? photoInput.files?.[0] : null, 'photo'));
    videoInput?.addEventListener('change', () => onSelectedFile(videoInput instanceof HTMLInputElement ? videoInput.files?.[0] : null, 'walkthrough'));
