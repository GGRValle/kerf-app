---
import Layout from '../layouts/Layout.astro';
import CaptureSyncBadge from '../components/CaptureSyncBadge.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { listLane23Projects } from '../lib/lane23Fixtures.js';

const { context } = createLayoutContext();
const projects = listLane23Projects(context.tenantId);
const safeProjectId = (raw: string | null) => raw && /^[A-Za-z0-9_-]+$/.test(raw) ? raw : '';
const requestedProjectId = safeProjectId(Astro.url.searchParams.get('project_id'));
const selectedProject = projects.find((project) => project.project_id === requestedProjectId) ?? null;
const suggestedJob = selectedProject ?? projects[0] ?? null;
const routePrefilled = selectedProject !== null;
const rawReturnTo = Astro.url.searchParams.get('return_to') ?? '';
const safeReturnTo = rawReturnTo.startsWith('/') && !rawReturnTo.startsWith('//') ? rawReturnTo : '';
const fallbackReturn = selectedProject ? `/projects/${selectedProject.project_id}?src=camera` : '/';
const returnHref = safeReturnTo || fallbackReturn;
const modeParam = Astro.url.searchParams.get('mode');
const initialMode = modeParam === 'walkthru' || modeParam === 'scan' ? modeParam : 'photo';
// System-intake label: top stays CAPTURE; the mode reads CAPTURE Photo / Walkthrough / Scan.
const modeLabel = (m: string): string => (m === 'walkthru' ? 'Walkthrough' : m === 'scan' ? 'Scan' : 'Photo');
---

<Layout
  title="Camera"
  activeHref="/camera"
  surfaceContext={{
    surface: 'field_capture',
    phase: routePrefilled ? 'capture' : 'route_pending',
    ...(routePrefilled && selectedProject ? { project_id: selectedProject.project_id } : {}),
  }}
>
  <section
    class="f-cam1"
    data-grammar="canon"
    aria-labelledby="camera-title"
    data-suggested-project-id={suggestedJob?.project_id ?? ''}
    data-suggested-project-name={suggestedJob?.project_name ?? ''}
    data-suggested-project-client={suggestedJob?.client_name ?? ''}
    data-suggested-match="job-site GPS"
    data-route-confirmed={routePrefilled ? 'true' : 'false'}
    data-selected-project-id={routePrefilled ? (selectedProject?.project_id ?? '') : ''}
    data-return-href={returnHref}
    data-initial-mode={initialMode}
    data-tenant-id={context.tenantId}
    data-principal-user-id={context.roleRoot}
  >
    <h1 id="camera-title" class="cam-sr-only">Camera</h1>

    <section class="cam-stage" aria-label="Camera capture">
      <div class="cam-viewfinder" data-mode={initialMode}>
        <video
          id="cam-video"
          class="cam-video"
          playsinline
          muted
          autoplay
          aria-label="Live camera preview"
        ></video>
        <canvas id="cam-canvas" hidden></canvas>
        <div class="cam-topbar">
          <div class="cam-topbar__group">
            <a class="cam-back" href={returnHref} aria-label="Close camera">×</a>
            <button type="button" class="cam-icon-btn" aria-label="Camera settings">⚙</button>
          </div>
          <div class="cam-job-chip kg-routechip" id="cam-job-chip">
            <span class="cam-job-chip__label">CAPTURE</span>
            <strong id="cam-job-chip-label">{routePrefilled ? (selectedProject?.project_name ?? 'Active job') : modeLabel(initialMode)}</strong>
          </div>
          <div class="cam-topbar__group">
            <button type="button" class="cam-icon-btn" aria-label="Flash">⚡</button>
            <button type="button" class="cam-icon-btn" aria-label="Flip camera">↻</button>
          </div>
        </div>

        <div class="cam-rec-pill kg-chip green" id="cam-rec-pill" hidden>Right Hand listening · REC</div>
        <div class="cam-camera-state" id="cam-camera-state" hidden>
          <strong>Camera access needed</strong>
          <span>Use the fallback only if the browser cannot open the camera here.</span>
        </div>
        <div class="cam-crosshair" aria-hidden="true"></div>
        <p class="cam-viewfinder__copy" id="cam-viewfinder-copy">
          {initialMode === 'walkthru'
            ? 'Talk while you film. Right Hand will route the walkthrough after you capture.'
            : initialMode === 'scan'
              ? 'Room scan needs native LiDAR. This web build keeps it separate for now.'
              : 'Capture first. Choose where it goes before filing.'}
        </p>
      </div>

      <a class="cam-room-link" href="/room-capture?src=camera&mode=start">Room scan</a>

      <div class="cam-bottom-overlay">
        <div class="cam-zoom" aria-label="Zoom">
          <button type="button">.5</button>
          <button type="button" aria-pressed="true">1×</button>
          <button type="button">3×</button>
        </div>

        <div class="cam-mode-strip" role="tablist" aria-label="Camera mode">
          <button type="button" role="tab" data-mode="walkthru" aria-selected={initialMode === 'walkthru' ? 'true' : 'false'}>Walkthrough</button>
          <button type="button" role="tab" data-mode="photo" aria-selected={initialMode === 'photo' ? 'true' : 'false'}>Photo</button>
          <button type="button" role="tab" data-mode="scan" aria-selected={initialMode === 'scan' ? 'true' : 'false'}>Scan</button>
        </div>

        <div class="cam-controls">
          <div class="cam-last-shot" id="cam-last-shot" aria-hidden="true">
            <span>Last</span>
          </div>
          <button type="button" class="cam-shutter" id="cam-shutter" aria-label="Capture media"></button>
          <button type="button" class="cam-done" id="cam-done">Done</button>
        </div>
      </div>

      <section class="cam-captured kg-card" id="cam-captured" aria-label="Captured media" hidden>
        <p class="cam-captured__eyebrow">Captured this session</p>
        <div class="cam-captured__item" id="cam-captured-item">
          <div class="cam-thumb" id="cam-thumb" aria-hidden="true"></div>
          <div class="cam-captured__copy">
            <strong id="cam-captured-title">Media ready</strong>
            <span id="cam-sync-badge"><CaptureSyncBadge state="captured" /></span>
            <span id="cam-captured-detail">Capture first. Choose where it goes before filing.</span>
          </div>
        </div>
      </section>

      <section class="cam-route-panel kg-card" id="cam-route-panel" hidden aria-label="Confirm capture destination">
        <div class="cam-route-head">
          <p class="cam-route-eyebrow">Goes to</p>
          <button type="button" class="cam-route-close" id="cam-route-close" aria-label="Close destination panel">×</button>
        </div>
        <p class="cam-route-suggestion" id="cam-route-suggestion">
          {suggestedJob
            ? `Active job · ${suggestedJob.client_name.split(',')[0]?.trim() ?? suggestedJob.project_name}`
            : 'Choose a destination'}
        </p>
        <div class="cam-route-kinds" role="radiogroup" aria-label="Capture destination type">
          <button type="button" class="cam-route-kind is-active" data-route-kind="job" aria-pressed="true">
            <strong>Existing job</strong>
            <span>File to Daily Log</span>
          </button>
          <button type="button" class="cam-route-kind" data-route-kind="lead" aria-pressed="false">
            <strong>New lead</strong>
            <span>Start intake</span>
          </button>
          <button type="button" class="cam-route-kind" data-route-kind="review" aria-pressed="false">
            <strong>Review later</strong>
            <span>Office queue</span>
          </button>
        </div>
        <div class="cam-route-job-fields" id="cam-route-job-fields">
          <label class="cam-route-label" for="cam-route-select">Change job</label>
          <select class="cam-route-select" id="cam-route-select">
            {projects.map((project) => (
              <option
                value={project.project_id}
                data-project-name={project.project_name}
                data-project-client={project.client_name}
                selected={project.project_id === (suggestedJob?.project_id ?? '')}
              >
                {project.project_name} · {project.client_name}
              </option>
            ))}
          </select>
        </div>
        <p class="cam-route-hint" id="cam-route-hint">
          {suggestedJob
            ? `Right Hand matched your active job by job-site GPS. Pick a destination, then confirm.`
            : 'Pick where this capture belongs, then confirm.'}
        </p>
        <div class="cam-route-actions">
          <button type="button" class="cam-route-confirm" id="cam-route-confirm">Confirm destination</button>
          <a class="cam-route-link" id="cam-route-search-jobs" href="/projects?src=camera">Search jobs</a>
        </div>
      </section>

      <p class="cam-status" id="camera-status" role="status" aria-live="polite">
        {routePrefilled && selectedProject
          ? `Ready for ${selectedProject.project_name}.`
          : 'Camera open — capture now, route after.'}
      </p>

      <input id="camera-photo-input" type="file" accept="image/*" capture="environment" hidden />
      <input id="camera-video-input" type="file" accept="video/*" capture="environment" hidden />
    </section>
  </section>

  <script>
    import {
      addItem,
      createSession,
      listItems,
      listPending,
      markNeedsAttention,
      principalSnapshotFromSurfaceContext,
      setDestination,
    } from '../lib/captureStore.js';
    import { installCaptureUploadQueue, processCaptureUploadQueue } from '../lib/captureUploadQueue.js';
    import { CAPTURE_SYNC } from '../lib/captureSyncState.js';

    const root = document.querySelector('.f-cam1');
    const status = document.querySelector('#camera-status');
    const jobChipLabel = document.querySelector('#cam-job-chip-label');
    const routePanel = document.querySelector('#cam-route-panel');
    const routeSuggestion = document.querySelector('#cam-route-suggestion');
    const routeHint = document.querySelector('#cam-route-hint');
    const routeSelect = document.querySelector('#cam-route-select');
    const routeJobFields = document.querySelector('#cam-route-job-fields');
    const routeConfirm = document.querySelector('#cam-route-confirm');
    const routeClose = document.querySelector('#cam-route-close');
    const routeSearchJobs = document.querySelector('#cam-route-search-jobs');
    const routeKindButtons = [...document.querySelectorAll('[data-route-kind]')];
    const viewfinder = document.querySelector('.cam-viewfinder');
    const video = document.querySelector('#cam-video');
    const canvas = document.querySelector('#cam-canvas');
    const cameraState = document.querySelector('#cam-camera-state');
    const viewfinderCopy = document.querySelector('#cam-viewfinder-copy');
    const recPill = document.querySelector('#cam-rec-pill');
    const photoInput = document.querySelector('#camera-photo-input');
    const videoInput = document.querySelector('#camera-video-input');
    const captured = document.querySelector('#cam-captured');
    const capturedTitle = document.querySelector('#cam-captured-title');
    const capturedDetail = document.querySelector('#cam-captured-detail');
    const thumb = document.querySelector('#cam-thumb');
    const lastShot = document.querySelector('#cam-last-shot');
    const shutter = document.querySelector('#cam-shutter');
    const doneButton = document.querySelector('#cam-done');
    let currentMode = root?.getAttribute('data-initial-mode') || 'photo';
    let suggestedProjectId = root?.getAttribute('data-suggested-project-id') || '';
    let suggestedProjectName = root?.getAttribute('data-suggested-project-name') || '';
    let suggestedProjectClient = root?.getAttribute('data-suggested-project-client') || '';
    let selectedProjectId = root?.getAttribute('data-selected-project-id') || '';
    let selectedProjectName = selectedProjectId ? suggestedProjectName : '';
    let selectedProjectClient = selectedProjectId ? suggestedProjectClient : '';
    let selectedRouteKind = 'job';
    let routeConfirmed = root?.getAttribute('data-route-confirmed') === 'true';
    let lastCapture = null;
    let cameraStream = null;
    let cameraFailure = null;
    let recorder = null;
    let recorderChunks = [];
    let recordingStartedAt = 0;
    let isFiling = false;
    let activeCaptureSessionId = '';
    let activeCaptureItemId = '';
    let lastCapturePreviewUrl = '';

    const copyForMode = (mode) => {
      if (mode === 'walkthru') return 'Talk while you film. Right Hand will route the walkthrough after you capture.';
      if (mode === 'scan') return 'Room scan needs native LiDAR. This web build keeps it separate for now.';
      return 'Capture first. Choose where it goes before filing.';
    };
    const modeLabel = (mode) => (mode === 'walkthru' ? 'Walkthrough' : mode === 'scan' ? 'Scan' : 'Photo');
    const setStatus = (message) => {
      if (status instanceof HTMLElement) status.textContent = message;
    };
    const setCaptureSyncState = (state) => {
      const badge = document.querySelector('#cam-sync-badge [data-sync-state]');
      if (!(badge instanceof HTMLElement)) return;
      const meta = CAPTURE_SYNC[state] || CAPTURE_SYNC.captured;
      badge.setAttribute('data-sync-state', state);
      badge.classList.toggle('blue', meta.tone === 'blue');
      badge.classList.toggle('green', meta.tone === 'green');
      badge.classList.toggle('amber', meta.tone === 'amber');
      badge.classList.toggle('red', meta.tone === 'red');
      badge.classList.toggle('cap-sync--working', state === 'syncing');
      const label = badge.querySelector('.cap-sync__label');
      if (label instanceof HTMLElement) label.textContent = meta.label;
    };
    const reflectCaptureItemStatus = (item) => {
      if (!item || item.id !== activeCaptureItemId) return;
      if (lastCapture) {
        lastCapture = {
          ...lastCapture,
          status: item.status,
          server_ref: item.server_ref || '',
        };
      }
      setCaptureSyncState(item.status);
      if (capturedDetail instanceof HTMLElement) {
        if (item.status === 'syncing') capturedDetail.textContent = 'Syncing to Right Hand. Keep capturing — this keeps working in the background.';
        if (item.status === 'synced') capturedDetail.textContent = 'Synced. The server has the capture.';
        if (item.status === 'failed') capturedDetail.textContent = 'Saved on phone. Sync failed — retry when you have a better connection.';
        if (item.status === 'needs_attention') capturedDetail.textContent = 'Saved on phone. Choose where it goes before filing.';
      }
    };
    const capturePrincipalSnapshot = () => principalSnapshotFromSurfaceContext({
      tenant_id: root instanceof HTMLElement ? root.dataset.tenantId || '' : '',
      user_id: root instanceof HTMLElement ? root.dataset.principalUserId || '' : '',
    });
    const processActiveCaptureQueue = async () => {
      try {
        await processCaptureUploadQueue(capturePrincipalSnapshot(), {
          onItemStatus: reflectCaptureItemStatus,
        });
      } catch {
        // Queue failures are reflected per item when possible; local save remains truthful.
      }
    };
    const ensureCaptureSession = async () => {
      if (activeCaptureSessionId) return activeCaptureSessionId;
      const session = await createSession(
        currentMode === 'walkthru' ? 'estimate_walk' : 'daily_log',
        capturePrincipalSnapshot(),
      );
      activeCaptureSessionId = session.id;
      if (routeConfirmed && selectedProjectId) {
        await setDestination(activeCaptureSessionId, { kind: 'job', id: selectedProjectId });
      }
      return session.id;
    };
    const persistSessionDestination = async (destination) => {
      if (!activeCaptureSessionId) return;
      try {
        await setDestination(activeCaptureSessionId, destination);
        await processActiveCaptureQueue();
      } catch {
        // Destination still travels through the visible route flow; local store is best-effort.
      }
    };
    const markActiveCaptureNeedsAttention = async (reason) => {
      if (!activeCaptureItemId) return;
      try {
        const item = await markNeedsAttention(activeCaptureItemId, reason);
        if (item) reflectCaptureItemStatus(item);
      } catch {
        // The visible route panel remains the source of action.
      }
    };
    const blobFromCanvas = () => new Promise((resolve) => {
      if (!(canvas instanceof HTMLCanvasElement)) {
        resolve(null);
        return;
      }
      canvas.toBlob((blob) => resolve(blob), 'image/jpeg', 0.82);
    });
    const syncRouteChip = () => {
      if (!(jobChipLabel instanceof HTMLElement)) return;
      if (routeConfirmed && selectedProjectName) {
        jobChipLabel.textContent = selectedProjectName;
      } else {
        jobChipLabel.textContent = modeLabel(currentMode);
      }
    };
    const setRouteKind = (kind) => {
      selectedRouteKind = kind === 'lead' || kind === 'review' ? kind : 'job';
      routeKindButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const active = button.dataset.routeKind === selectedRouteKind;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      if (routeJobFields instanceof HTMLElement) routeJobFields.hidden = selectedRouteKind !== 'job';
      if (routeSearchJobs instanceof HTMLElement) routeSearchJobs.hidden = selectedRouteKind !== 'job';
      if (routeConfirm instanceof HTMLButtonElement) {
        routeConfirm.textContent = selectedRouteKind === 'job'
          ? 'Confirm and file'
          : selectedRouteKind === 'lead'
            ? 'Start intake'
            : 'Save for review';
      }
      if (root instanceof HTMLElement) root.dataset.routeKind = selectedRouteKind;
      syncRouteSuggestion();
      syncRouteConfirmState();
    };
    const updateSurfaceContextProject = (projectId) => {
      const ctx = window.__KERF_SURFACE_CONTEXT__;
      if (!ctx || typeof ctx !== 'object') return;
      ctx.project_id = projectId || undefined;
      ctx.phase = projectId ? 'capture' : 'route_pending';
      window.__KERF_SURFACE_CONTEXT__ = ctx;
      const el = document.getElementById('kerf-surface-context');
      if (el) el.textContent = JSON.stringify(ctx);
    };
    const syncRouteSuggestion = () => {
      if (!(routeSuggestion instanceof HTMLElement)) return;
      if (selectedRouteKind === 'lead') {
        routeSuggestion.textContent = 'New lead · Sales intake';
        if (routeHint instanceof HTMLElement) {
          routeHint.textContent = 'Starts a new lead intake. It does not create a project until you convert it later.';
        }
        return;
      }
      if (selectedRouteKind === 'review') {
        routeSuggestion.textContent = 'Review later · Office queue';
        if (routeHint instanceof HTMLElement) {
          routeHint.textContent = 'Saves the capture for review when it is not tied to a job or lead yet.';
        }
        return;
      }
      if (selectedProjectClient) {
        const shortClient = selectedProjectClient.split(',')[0]?.trim() || selectedProjectName;
        routeSuggestion.textContent = `Active job · ${shortClient}`;
      } else if (selectedProjectName) {
        routeSuggestion.textContent = selectedProjectName;
      } else {
        routeSuggestion.textContent = 'Choose a destination';
      }
      if (routeHint instanceof HTMLElement) {
        routeHint.textContent = selectedProjectName
          ? 'Files this capture to the selected job Daily Log.'
          : 'Choose an existing job, a new lead, or review later.';
      }
    };
    const syncRouteConfirmState = () => {
      if (!(routeConfirm instanceof HTMLButtonElement)) return;
      routeConfirm.disabled = !lastCapture || isFiling;
      routeConfirm.setAttribute('aria-disabled', routeConfirm.disabled ? 'true' : 'false');
    };
    const showRoutePanel = () => {
      if (!(routePanel instanceof HTMLElement)) return;
      if (!lastCapture) {
        routePanel.hidden = true;
        routePanel.style.display = 'none';
        if (root instanceof HTMLElement) root.classList.remove('route-pending');
        setStatus('Capture first. Then choose where it goes.');
        syncRouteConfirmState();
        return;
      }
      routePanel.hidden = false;
      routePanel.style.display = 'grid';
      if (root instanceof HTMLElement) root.classList.add('route-pending');
      syncRouteSuggestion();
      syncRouteConfirmState();
      setStatus('Confirm where this capture goes, then tap Done again.');
    };
    const hideRoutePanel = () => {
      if (!(routePanel instanceof HTMLElement)) return;
      routePanel.hidden = true;
      routePanel.style.display = 'none';
      if (root instanceof HTMLElement) root.classList.remove('route-pending');
      if (lastCapture) {
        setStatus(`${friendlyForKind(lastCapture.kind)} captured — tap Done to choose where it goes.`);
      }
    };
    const applySelectedRoute = () => {
      if (selectedRouteKind !== 'job') {
        routeConfirmed = false;
        selectedProjectId = '';
        selectedProjectName = '';
        selectedProjectClient = '';
        if (root instanceof HTMLElement) {
          root.dataset.selectedProjectId = '';
          root.dataset.routeConfirmed = 'false';
        }
        updateSurfaceContextProject('');
        syncRouteChip();
        hideRoutePanel();
        void persistSessionDestination(selectedRouteKind === 'lead'
          ? { kind: 'lead', id: 'new' }
          : { kind: 'review', id: 'office_queue' });
        if (lastCapture && capturedDetail instanceof HTMLElement) {
          capturedDetail.textContent = selectedRouteKind === 'lead'
            ? 'Ready to start a new lead intake.'
            : 'Ready to save for office review.';
        }
        return;
      }
      if (routeSelect instanceof HTMLSelectElement) {
        const option = routeSelect.selectedOptions[0];
        selectedProjectId = option?.value || suggestedProjectId;
        selectedProjectName = option?.dataset.projectName || suggestedProjectName;
        selectedProjectClient = option?.dataset.projectClient || suggestedProjectClient;
      } else {
        selectedProjectId = suggestedProjectId;
        selectedProjectName = suggestedProjectName;
        selectedProjectClient = suggestedProjectClient;
      }
      routeConfirmed = selectedProjectId.length > 0;
      if (root instanceof HTMLElement) {
        root.dataset.selectedProjectId = selectedProjectId;
        root.dataset.routeConfirmed = routeConfirmed ? 'true' : 'false';
      }
      updateSurfaceContextProject(selectedProjectId);
      syncRouteChip();
      hideRoutePanel();
      void persistSessionDestination({ kind: 'job', id: selectedProjectId });
      if (lastCapture) {
        if (capturedDetail instanceof HTMLElement) {
          capturedDetail.textContent = `Ready to file to ${selectedProjectName} · Daily Log.`;
        }
        setStatus(`${friendlyForKind(lastCapture.kind)} ready — tap Done to file to ${selectedProjectName}.`);
      }
      syncRouteConfirmState();
    };
    const routeCaptureToLead = async () => {
      if (!lastCapture) {
        setStatus('Capture a photo or video first, then start the lead intake.');
        return false;
      }
      if (isFiling) return true;
      isFiling = true;
      if (doneButton instanceof HTMLButtonElement) doneButton.disabled = true;
      if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = true;
      setStatus(`Opening lead intake from ${friendlyForKind(lastCapture.kind).toLowerCase()}…`);
      try {
        try {
          sessionStorage.setItem('kerf.cameraCapture', JSON.stringify({
            ...lastCapture,
            status: 'pending_lead_intake',
            route_kind: 'lead',
            source: 'camera',
            returned_at: Date.now(),
          }));
        } catch {
          // Visible navigation is still the fallback.
        }
        setStatus('Opening new lead intake.');
        window.location.href = `/clients/new?src=camera&capture_kind=${encodeURIComponent(lastCapture.kind)}`;
        return true;
      } catch (err) {
        isFiling = false;
        if (doneButton instanceof HTMLButtonElement) doneButton.disabled = false;
        if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = false;
        setStatus('Could not open the lead intake. Nothing was filed.');
        return false;
      }
    };
    const routeCaptureToReview = async () => {
      if (!lastCapture) {
        setStatus('Capture a photo or video first, then save it for review.');
        return false;
      }
      if (isFiling) return true;
      isFiling = true;
      if (doneButton instanceof HTMLButtonElement) doneButton.disabled = true;
      if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = true;
      setStatus(`Saving ${friendlyForKind(lastCapture.kind).toLowerCase()} for review…`);
      try {
        const response = await fetch('/api/v1/camera-captures/review', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            capture_kind: lastCapture.kind,
            file_name: lastCapture.name,
            confirmed: true,
          }),
        });
        if (!response.ok) throw new Error(`review_failed_${response.status}`);
        const result = await response.json();
        const reviewRoute = result.review_route || '/relay?src=camera';
        try {
          sessionStorage.setItem('kerf.cameraCapture', JSON.stringify({
            ...lastCapture,
            status: 'queued_for_review',
            route_kind: 'review',
            capture_id: result.capture_id,
            returned_at: Date.now(),
          }));
        } catch {
          // Visible navigation is still the fallback.
        }
        setStatus('Saved for review. Opening office queue.');
        window.location.href = reviewRoute;
        return true;
      } catch (err) {
        isFiling = false;
        if (doneButton instanceof HTMLButtonElement) doneButton.disabled = false;
        if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = false;
        const code = err instanceof Error ? err.message : '';
        setStatus(
          code === 'review_failed_401'
            ? 'Your session expired — sign in again, then save for review.'
            : code === 'review_failed_403'
              ? 'You do not have access to save that review item.'
              : 'Could not save for review. Nothing was filed.',
        );
        return false;
      }
    };
    const fileCapture = async () => {
      // Founder spec: Confirm-and-file is NEVER a silent no-op — every refusal says why.
      if (!lastCapture) {
        setStatus('Capture a photo or video first, then choose where it goes.');
        return false;
      }
      if (selectedRouteKind === 'lead') return routeCaptureToLead();
      if (selectedRouteKind === 'review') return routeCaptureToReview();
      if (!routeConfirmed || !selectedProjectId) {
        setStatus('Choose where this capture goes, then tap Confirm and file.');
        showRoutePanel();
        return false;
      }
      if (isFiling) return true;
      isFiling = true;
      setStatus(`Filing ${friendlyForKind(lastCapture.kind).toLowerCase()} to ${selectedProjectName}…`);
      void persistSessionDestination({ kind: 'job', id: selectedProjectId });
      if (doneButton instanceof HTMLButtonElement) doneButton.disabled = true;
      if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = true;
      try {
        const response = await fetch(`/api/v1/projects/${selectedProjectId}/camera-capture`, {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            capture_kind: lastCapture.kind,
            file_name: lastCapture.name,
            confirmed: true,
          }),
        });
        if (!response.ok) {
          throw new Error(`file_failed_${response.status}`);
        }
        const result = await response.json();
        const filedCapture = {
          ...lastCapture,
          status: 'filed_to_daily_log',
          daily_log_route: result.daily_log_route,
          work_artifact_ref: result.artifacts?.work?.id,
          attention_artifact_ref: result.artifacts?.attention?.id,
          returned_at: Date.now(),
        };
        try {
          sessionStorage.setItem('kerf.cameraCapture', JSON.stringify(filedCapture));
        } catch {
          // Status below remains the visible fallback.
        }
        setStatus(`${friendlyForKind(lastCapture.kind)} attached to ${selectedProjectName}.`);
      } catch (err) {
        isFiling = false;
        if (doneButton instanceof HTMLButtonElement) doneButton.disabled = false;
        if (routeConfirm instanceof HTMLButtonElement) routeConfirm.disabled = false;
        // Surface the exact failure class in operator-safe copy (founder spec) —
        // never generic "nothing happened."
        const code = err instanceof Error ? err.message : '';
        setStatus(
          code === 'file_failed_401'
            ? 'Your session expired — sign in again, then re-file. Nothing was attached.'
            : code === 'file_failed_403'
              ? 'You do not have access to that job. Nothing was attached.'
              : code === 'file_failed_404'
                ? "That job isn't available — pick another. Nothing was attached."
                : /^file_failed_5\d\d$/.test(code)
                  ? 'The server could not record that. Nothing was attached.'
                  : code.startsWith('file_failed_')
                    ? 'That capture was not accepted. Nothing was attached.'
                    : 'Could not reach the server — check your connection. Nothing was attached.',
        );
        return false;
      }
      const base = `/projects/${encodeURIComponent(selectedProjectId)}`;
      const destination = base.includes('?') ? `${base}&src=camera` : `${base}?src=camera`;
      window.location.href = destination;
      return true;
    };
    const stopCamera = () => {
      if (typeof MediaStream !== 'undefined' && cameraStream instanceof MediaStream) {
        cameraStream.getTracks().forEach((track) => track.stop());
      }
      cameraStream = null;
      if (video instanceof HTMLVideoElement) video.srcObject = null;
      if (viewfinder instanceof HTMLElement) viewfinder.classList.remove('is-live');
    };
    const setCameraState = (headline, detail) => {
      if (!(cameraState instanceof HTMLElement)) return;
      if (!headline) {
        cameraState.hidden = true;
        return;
      }
      cameraState.hidden = false;
      const title = cameraState.querySelector('strong');
      const copy = cameraState.querySelector('span');
      if (title instanceof HTMLElement) title.textContent = headline;
      if (copy instanceof HTMLElement) copy.textContent = detail;
    };
    const mediaConstraintsForMode = (mode) => ({
      video: {
        facingMode: { ideal: 'environment' },
        width: { ideal: 1280 },
        height: { ideal: 720 },
      },
      audio: mode === 'walkthru',
    });
    const startCamera = async () => {
      cameraFailure = null;
      if (currentMode === 'scan') {
        stopCamera();
        setCameraState('Native scan is separate', 'LiDAR/room scan is not available in this web camera yet.');
        return false;
      }
      if (!window.isSecureContext) {
        cameraFailure = 'secure_context_required';
        stopCamera();
        setCameraState('Open on HTTPS to use camera', 'Use the file fallback only for this browser session.');
        return false;
      }
      if (!navigator.mediaDevices?.getUserMedia) {
        cameraFailure = 'getusermedia_unavailable';
        stopCamera();
        setCameraState('Camera unavailable here', 'Use the file fallback because this browser cannot open an in-app camera.');
        return false;
      }
      stopCamera();
      try {
        cameraStream = await navigator.mediaDevices.getUserMedia(mediaConstraintsForMode(currentMode));
      } catch (err) {
        if (currentMode === 'walkthru') {
          try {
            cameraStream = await navigator.mediaDevices.getUserMedia(mediaConstraintsForMode('photo'));
          } catch (fallbackErr) {
            cameraFailure = fallbackErr instanceof Error ? fallbackErr.name : 'camera_denied';
          }
        } else {
          cameraFailure = err instanceof Error ? err.name : 'camera_denied';
        }
      }
      if (typeof MediaStream === 'undefined' || !(cameraStream instanceof MediaStream)) {
        stopCamera();
        setCameraState('Camera access blocked', 'Enable camera access or use the fallback file picker.');
        return false;
      }
      if (video instanceof HTMLVideoElement) {
        video.srcObject = cameraStream;
        await video.play().catch(() => undefined);
      }
      if (viewfinder instanceof HTMLElement) viewfinder.classList.add('is-live');
      setCameraState('', '');
      return true;
    };
    const setMode = async (mode) => {
      currentMode = mode;
      if (viewfinder instanceof HTMLElement) viewfinder.dataset.mode = mode;
      if (viewfinderCopy instanceof HTMLElement) viewfinderCopy.textContent = copyForMode(mode);
      syncRouteChip();
      if (recPill instanceof HTMLElement) {
        recPill.hidden = mode !== 'walkthru'
          || typeof MediaRecorder === 'undefined'
          || !(recorder instanceof MediaRecorder && recorder.state === 'recording');
      }
      document.querySelectorAll('[data-mode]').forEach((button) => {
        if (button instanceof HTMLButtonElement) button.setAttribute('aria-selected', button.dataset.mode === mode ? 'true' : 'false');
      });
      if (mode === 'scan') {
        setStatus('');
      } else {
        setStatus(routeConfirmed && selectedProjectName
          ? `Ready for ${selectedProjectName}.`
          : 'Camera open — capture now, route after.');
      }
      await startCamera();
    };
    routeSelect?.addEventListener('change', () => {
      if (!(routeSelect instanceof HTMLSelectElement)) return;
      const option = routeSelect.selectedOptions[0];
      selectedProjectId = option?.value || '';
      selectedProjectName = option?.dataset.projectName || '';
      selectedProjectClient = option?.dataset.projectClient || '';
      syncRouteSuggestion();
    });
    routeKindButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLButtonElement)) return;
        setRouteKind(button.dataset.routeKind || 'job');
      });
    });
    routeConfirm?.addEventListener('click', () => {
      if (!lastCapture) {
        setStatus('Capture first. Then choose where it goes.');
        syncRouteConfirmState();
        return;
      }
      applySelectedRoute();
      void fileCapture();
    });
    routeClose?.addEventListener('click', () => {
      hideRoutePanel();
    });
    // One confirm handler (founder spec): the direct routeConfirm/routeClose click
    // listeners above own the taps. The prior document-level capture-phase
    // interceptor (pointerdown + click with preventDefault + stopImmediatePropagation)
    // was removed — competing handlers and preventDefault-on-pointerdown made the
    // iOS tap path unreliable (a likely cause of "Confirm and file did nothing").
    const kindForMode = () => currentMode === 'walkthru' ? 'walkthrough' : currentMode === 'scan' ? 'scan' : 'photo';
    const friendlyForKind = (kind) => kind === 'walkthrough' ? 'Walkthrough' : kind === 'scan' ? 'Document scan' : 'Photo';
    const fallbackInputForMode = () => currentMode === 'walkthru' ? videoInput : photoInput;
    const openFallbackCapture = () => {
      if (currentMode === 'scan') {
        setStatus('Room scan is native LiDAR and is not available in this web camera yet.');
        return;
      }
      const input = fallbackInputForMode();
      if (input instanceof HTMLInputElement) input.click();
    };
    const persistLastShotSnapshot = (kind, previewUrl = '') => {
      const durablePreview = previewUrl.startsWith('data:image/') ? previewUrl : '';
      try {
        sessionStorage.setItem('kerf.cameraLastShot', JSON.stringify({
          kind,
          preview_url: durablePreview,
          captured_at: Date.now(),
        }));
      } catch {
        // Cosmetic history only. IndexedDB remains the durable capture source.
      }
    };
    const hydrateLastShotSnapshot = () => {
      if (!(lastShot instanceof HTMLElement)) return;
      let raw = null;
      try {
        raw = sessionStorage.getItem('kerf.cameraLastShot');
      } catch {
        raw = null;
      }
      if (!raw) return;
      try {
        const snapshot = JSON.parse(raw);
        const kind = snapshot?.kind === 'walkthrough' || snapshot?.kind === 'scan' ? snapshot.kind : 'photo';
        const previewUrl = typeof snapshot?.preview_url === 'string' ? snapshot.preview_url : '';
        const friendly = friendlyForKind(kind);
        lastShot.classList.add('has-last-shot');
        lastShot.dataset.kind = kind;
        lastShot.style.setProperty('--last-shot-image', previewUrl ? `url("${previewUrl}")` : 'none');
        const label = lastShot.querySelector('span');
        if (label instanceof HTMLElement) label.textContent = friendly;
      } catch {
        // Ignore malformed cosmetic history.
      }
    };
    const updateLastShot = (kind, previewUrl = '') => {
      const friendly = friendlyForKind(kind);
      if (root instanceof HTMLElement) root.classList.add('has-capture');
      if (captured instanceof HTMLElement) captured.hidden = false;
      if (viewfinderCopy instanceof HTMLElement) viewfinderCopy.hidden = true;
      if (capturedTitle instanceof HTMLElement) capturedTitle.textContent = `${friendly} ready`;
      if (capturedDetail instanceof HTMLElement) {
        capturedDetail.textContent = routeConfirmed && selectedProjectName
          ? `Ready to file to ${selectedProjectName} · Daily Log.`
          : lastCapture?.status === 'saved_on_phone'
            ? 'Saved on phone. Choose where it goes before filing.'
            : 'Captured — keep this screen open until it saves.';
      }
      if (thumb instanceof HTMLElement) {
        thumb.className = `cam-thumb ${kind === 'photo' ? 'is-photo' : kind === 'scan' ? 'is-scan' : 'is-video'}`;
        thumb.style.backgroundImage = previewUrl ? `url("${previewUrl}")` : '';
        thumb.textContent = previewUrl ? '' : kind === 'walkthrough' ? 'REC' : kind === 'scan' ? 'DOC' : 'IMG';
      }
      if (lastShot instanceof HTMLElement) {
        lastShot.classList.add('has-last-shot');
        lastShot.dataset.kind = kind;
        lastShot.style.setProperty('--last-shot-image', previewUrl ? `url("${previewUrl}")` : 'none');
        const label = lastShot.querySelector('span');
        if (label instanceof HTMLElement) label.textContent = friendly;
      }
      persistLastShotSnapshot(kind, previewUrl);
      if (lastCapture && previewUrl.startsWith('data:image/')) {
        lastCapture = { ...lastCapture, preview_url: previewUrl };
        try {
          sessionStorage.setItem('kerf.cameraCapture', JSON.stringify(lastCapture));
        } catch {
          // The visual thumbnail already updated; capture storage remains durable.
        }
      }
      setStatus(routeConfirmed && selectedProjectName
        ? `${friendly} saved on phone — tap Done to file to ${selectedProjectName}.`
        : lastCapture?.status === 'saved_on_phone'
          ? `${friendly} saved on phone — tap Done to choose where it goes.`
          : `${friendly} captured — tap Done to choose where it goes.`);
      if (!routeConfirmed) showRoutePanel();
    };
    const rememberCapture = async (capture, blob) => {
      let savedItem = null;
      const sessionId = await ensureCaptureSession();
      lastCapture = {
        project_id: routeConfirmed ? selectedProjectId : '',
        project_name: routeConfirmed ? selectedProjectName : '',
        at: Date.now(),
        status: 'captured',
        capture_store_session_id: sessionId,
        ...capture,
      };
      setCaptureSyncState('captured');
      syncRouteConfirmState();
      if (blob instanceof Blob) {
        try {
          savedItem = await addItem(sessionId, {
            kind: capture.kind === 'walkthrough' ? 'video' : capture.kind,
            blob,
            name: capture.name || `${capture.kind} capture`,
            metadata: {
              source: capture.source || '',
              route_kind: selectedRouteKind,
            },
          });
          activeCaptureItemId = savedItem.id;
          lastCapture = {
            ...lastCapture,
            status: 'saved_on_phone',
            capture_store_item_id: savedItem.id,
            bytes: savedItem.blob.size,
          };
          setCaptureSyncState('saved_on_phone');
          syncRouteConfirmState();
        } catch {
          lastCapture = {
            ...lastCapture,
            status: 'captured',
            capture_store_item_id: '',
          };
          setCaptureSyncState('captured');
          syncRouteConfirmState();
          setStatus(`${friendlyForKind(capture.kind)} captured, but not saved on phone yet. Keep this screen open.`);
        }
      }
      try {
        sessionStorage.setItem('kerf.cameraCapture', JSON.stringify(lastCapture));
      } catch {
        // Visible state still tells the operator what happened.
      }
      return savedItem;
    };
    const captureStillFromVideo = async (kind = 'photo') => {
      if (!(video instanceof HTMLVideoElement) || !(canvas instanceof HTMLCanvasElement)) {
        return false;
      }
      const width = video.videoWidth || 1280;
      const height = video.videoHeight || 720;
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d');
      if (!ctx) return false;
      ctx.drawImage(video, 0, 0, width, height);
      const dataUrl = canvas.toDataURL('image/jpeg', 0.82);
      const name = `${kind === 'walkthrough' ? 'walkthrough-frame' : 'photo'}-${Date.now()}.jpg`;
      const blob = await blobFromCanvas();
      await rememberCapture({ kind, name, source: 'getUserMedia_canvas_frame' }, blob);
      updateLastShot(kind, dataUrl);
      return true;
    };
    const finishWalkthruRecording = () => new Promise((resolve) => {
      if (typeof MediaRecorder === 'undefined' || !(recorder instanceof MediaRecorder) || recorder.state === 'inactive') {
        resolve(false);
        return;
      }
      recorder.addEventListener('stop', async () => {
        const mime = recorder.mimeType || 'video/webm';
        const blob = new Blob(recorderChunks, { type: mime });
        const ext = mime.includes('mp4') ? 'mp4' : 'webm';
        const objectUrl = URL.createObjectURL(blob);
        await rememberCapture({
          kind: 'walkthrough',
          name: `walkthrough-${recordingStartedAt || Date.now()}.${ext}`,
          source: 'getUserMedia_mediarecorder',
          bytes: blob.size,
        }, blob);
        updateLastShot('walkthrough', objectUrl);
        if (recPill instanceof HTMLElement) recPill.hidden = true;
        if (root instanceof HTMLElement) root.classList.remove('is-recording');
        if (shutter instanceof HTMLElement) shutter.classList.remove('is-recording');
        resolve(true);
      }, { once: true });
      recorder.stop();
    });
    const startWalkthruRecording = async () => {
      if (typeof MediaStream === 'undefined' || !(cameraStream instanceof MediaStream) || typeof MediaRecorder === 'undefined') {
        return captureStillFromVideo('walkthrough');
      }
      if (recorder instanceof MediaRecorder && recorder.state === 'recording') {
        void finishWalkthruRecording();
        return true;
      }
      recorderChunks = [];
      recorder = new MediaRecorder(cameraStream);
      recordingStartedAt = Date.now();
      recorder.addEventListener('dataavailable', (event) => {
        if (event.data.size > 0) recorderChunks.push(event.data);
      });
      recorder.start();
      if (recPill instanceof HTMLElement) recPill.hidden = false;
      if (root instanceof HTMLElement) root.classList.add('is-recording');
      if (shutter instanceof HTMLElement) shutter.classList.add('is-recording');
      setStatus('Recording walkthrough — tap shutter or Done to finish.');
      return true;
    };
    const openCapture = async () => {
      if (currentMode === 'scan') {
        setStatus('Scan needs native LiDAR. Use Room scan when the native capture path is ready.');
        setCameraState('Native scan is separate', 'Nothing was filed. LiDAR capture is deferred to the native track.');
        return;
      }
      if (typeof MediaStream === 'undefined' || !(cameraStream instanceof MediaStream)) {
        const started = await startCamera();
        if (!started) {
          setStatus('Camera unavailable here — using fallback file picker.');
          openFallbackCapture();
          return;
        }
      }
      const capturedInline = currentMode === 'walkthru'
        ? startWalkthruRecording()
        : captureStillFromVideo('photo');
      if (!(await capturedInline)) {
        setStatus('Camera unavailable here — using fallback file picker.');
        openFallbackCapture();
      }
    };
    const onSelectedFile = (file, kind) => {
      if (!file) return;
      const objectUrl = kind === 'photo' && file.type?.startsWith('image/') ? URL.createObjectURL(file) : '';
      void rememberCapture({
        kind,
        name: file.name || `${kind} capture`,
        source: 'file_input_fallback',
      }, file);
      updateLastShot(kind, objectUrl);
    };
    const hydratePendingCapture = async () => {
      if (lastCapture) return;
      try {
        const pending = await listPending(capturePrincipalSnapshot());
        const session = pending.find((candidate) => candidate.destination === null && candidate.item_ids.length > 0);
        if (!session) return;
        const items = await listItems(session.id);
        const item = items[items.length - 1];
        if (!item || !(item.blob instanceof Blob)) return;
        activeCaptureSessionId = session.id;
        activeCaptureItemId = item.id;
        const captureKind = item.kind === 'video' ? 'walkthrough' : item.kind;
        lastCapturePreviewUrl = item.kind === 'photo' ? URL.createObjectURL(item.blob) : '';
        lastCapture = {
          kind: captureKind,
          name: item.name,
          source: 'indexeddb_recovery',
          at: item.created_at,
          status: item.status,
          capture_store_session_id: session.id,
          capture_store_item_id: item.id,
          bytes: item.blob.size,
        };
        setCaptureSyncState(item.status);
        updateLastShot(captureKind, lastCapturePreviewUrl);
        setStatus(`${friendlyForKind(captureKind)} restored from this phone — tap Done to choose where it goes.`);
      } catch {
        // Recovery is best-effort; a fresh capture still works.
      }
    };
    const done = async () => {
      if (recorder instanceof MediaRecorder && recorder.state === 'recording') {
        setStatus('Finishing walkthrough…');
        await finishWalkthruRecording();
      }
      if (!lastCapture) {
        setStatus('Nothing captured yet. Take a photo, scan a document, or record a walkthrough first.');
        return;
      }
      if (!routeConfirmed || !selectedProjectId) {
        await markActiveCaptureNeedsAttention('destination_required');
        showRoutePanel();
        return;
      }
      await fileCapture();
    };

    document.querySelectorAll('.cam-mode-strip [data-mode]').forEach((button) => {
      button.addEventListener('click', () => void setMode(button.getAttribute('data-mode') || 'photo'));
    });
    document.querySelector('#cam-shutter')?.addEventListener('click', () => void openCapture());
    document.querySelector('#cam-done')?.addEventListener('click', done);
    photoInput?.addEventListener('change', () => onSelectedFile(photoInput instanceof HTMLInputElement ? photoInput.files?.[0] : null, 'photo'));
    videoInput?.addEventListener('change', () => onSelectedFile(videoInput instanceof HTMLInputElement ? videoInput.files?.[0] : null, 'walkthrough'));
    window.addEventListener('pagehide', stopCamera);
    const stopCaptureQueue = installCaptureUploadQueue(capturePrincipalSnapshot(), {
      onItemStatus: reflectCaptureItemStatus,
    });
    window.addEventListener('pagehide', stopCaptureQueue, { once: true });

    if (routeConfirmed) {
      syncRouteChip();
    }
    setRouteKind('job');
    void setMode(currentMode);
    hydrateLastShotSnapshot();
    syncRouteConfirmState();
    void hydratePendingCapture();
  </script>
</Layout>

