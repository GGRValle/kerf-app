---
import Layout from '../layouts/Layout.astro';
import { CONNECTIONS, connectionStatusLabel } from '../lib/connectionsRegistry.js';

const readySources = [
  {
    badge: 'JOB',
    title: 'Project records',
    detail: 'Jobs, clients, estimates, daily logs, invoices, and signed work already filed inside Right Hand.',
    proof: 'Checked 18 job records this morning. Last saved: Wegrzyn kitchen estimate.',
    state: 'Ready',
  },
  {
    badge: 'COST',
    title: 'Cost knowledge',
    detail: 'Labor notes, material history, scope patterns, and estimate accuracy notes from approved company work.',
    proof: 'Used 42 line items and 11 hour logs to tighten the cabinet install draft.',
    state: 'Ready',
  },
  {
    badge: 'CAP',
    title: 'Photos and scans',
    detail: 'Field photos, camera notes, room measurements, and queued uploads tied to the job before they feed a draft.',
    proof: '3 captures saved on device. Sync will retry when signal is back.',
    state: 'Ready',
  },
];

const sourceRank = ['email', 'qbo', 'calendar', 'sms', 'docusign', 'storage', 'roomplan', 'bluebeam'];
const setupQueue = [...CONNECTIONS].sort(
  (a, b) => sourceRank.indexOf(a.id) - sourceRank.indexOf(b.id),
);
const prioritySource = setupQueue.find((source) => source.id === 'email');
const prioritySourceId = prioritySource?.id ?? 'email';
const prioritySourceStatus = prioritySource?.status ?? 'not_wired';
const needsSetupCount = setupQueue.filter((source) => source.status !== 'connected').length;

const sourceProof: Record<string, string> = {
  qbo: 'Money exports are held in Right Hand until books access is approved.',
  calendar: 'Crew dates stay inside the job schedule until a calendar owner connects the account.',
  email: 'Proposal and invoice drafts are ready for review. Sending stays blocked until email is approved.',
  sms: 'Client and crew texts are drafted only. A person confirms every outbound message.',
  roomplan: 'Room scans are stored as verify-labelled measurements before they affect an estimate.',
  bluebeam: 'Plan markups can be attached today. Round-trip updates need setup before they become source truth.',
  docusign: 'Signature packets can be prepared. Contracts do not send until owner approval and e-sign setup.',
  storage: 'Photos and docs remain in Right Hand until the company storage folder is approved.',
};

const sourceShortNames: Record<string, string> = {
  qbo: 'QB',
  calendar: 'CAL',
  email: 'MAIL',
  sms: 'SMS',
  roomplan: 'SCAN',
  bluebeam: 'PLAN',
  docusign: 'SIGN',
  storage: 'FILE',
};

const guardrails = [
  'No credentials are stored from this page.',
  'Email, text, invoice, and signature sends stay behind approval.',
  'Field captures save first, then sync when service comes back.',
  'Language follows each worker setting: English, Spanish, or both.',
];
---

<Layout
  title="Connections"
  activeHref="/settings"
  surfaceContext={{ surface: 'connections', phase: 'settings' }}
>
  <section class="connections-page" data-grammar="canon" aria-labelledby="connections-title">
    <div class="connections-crumb"><a href="/settings">Settings</a> / Connections</div>

    <header class="connections-hero">
      <p class="connections-eyebrow">Company sources</p>
      <h1 id="connections-title">What Right Hand can use.</h1>
      <p>
        Right Hand reads approved company sources, drafts the work, and shows its proof.
        Outside tools wait here until the owner or admin turns them on.
      </p>
      <div class="connections-work" aria-label="Right Hand source status">
        <div>
          <strong>{readySources.length}</strong>
          <span>Ready inside Right Hand</span>
        </div>
        <div>
          <strong>{needsSetupCount}</strong>
          <span>Need setup</span>
        </div>
        <div>
          <strong>0</strong>
          <span>Outbound sends allowed without approval</span>
        </div>
      </div>
    </header>

    <section class="connections-decision kg-card" aria-labelledby="connections-next-title">
      <div>
        <span class="connections-state">Needs you</span>
        <h2 id="connections-next-title">Set up email next.</h2>
        <p>
          That lets Right Hand draft proposals, invoices, and client updates from the company domain.
          Every send still stops for review.
        </p>
        <ul>
          <li>Drafts can use job photos, estimates, and daily logs now.</li>
          <li>Customer-facing messages stay held until email is approved.</li>
          <li>The owner can turn this on without changing worker screens.</li>
        </ul>
      </div>
      <div class="connections-decision__actions">
        <button
          type="button"
          class="connections-primary"
          data-connection={prioritySourceId}
          data-status={prioritySourceStatus}
        >
          Request setup
        </button>
        <a class="connections-secondary" href="/settings/me">User language</a>
        <p data-status-for={prioritySourceId} role="status" aria-live="polite"></p>
      </div>
    </section>

    <div class="connections-layout">
      <main class="connections-main" aria-label="Source list">
        <section class="connections-section" aria-labelledby="ready-title">
          <div class="connections-section-head">
            <p>Can use now</p>
            <h2 id="ready-title">Ready inside Right Hand</h2>
          </div>
          <div class="connections-ready-list">
            {readySources.map((source) => (
              <article class="source-row source-row--ready">
                <div class="source-badge" aria-hidden="true">{source.badge}</div>
                <div class="source-copy">
                  <div class="source-topline">
                    <h3>{source.title}</h3>
                    <span class="source-chip is-ready">{source.state}</span>
                  </div>
                  <p>{source.detail}</p>
                  <small>{source.proof}</small>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="connections-section" aria-labelledby="setup-title">
          <div class="connections-section-head">
            <p>Outside tools</p>
            <h2 id="setup-title">Setup queue</h2>
          </div>
          <div class="connections-queue-list">
            {setupQueue.map((source) => (
              <article class="source-row" data-source-status={source.status}>
                <div class="source-badge" aria-hidden="true">{sourceShortNames[source.id] ?? 'SRC'}</div>
                <div class="source-copy">
                  <div class="source-topline">
                    <h3>{source.name}</h3>
                    <span class:list={['source-chip', `is-${source.status}`]}>
                      {connectionStatusLabel(source.status)}
                    </span>
                  </div>
                  <p>{source.purpose}</p>
                  <small>{sourceProof[source.id]}</small>
                  <p class="source-status" data-status-for={source.id} role="status" aria-live="polite"></p>
                </div>
                <button
                  type="button"
                  class="source-request"
                  data-connection={source.id}
                  data-status={source.status}
                >
                  {source.status === 'connected' ? 'Manage' : 'Request'}
                </button>
              </article>
            ))}
          </div>
        </section>
      </main>

      <aside class="connections-proof" aria-label="Proof and controls">
        <section class="proof-card kg-card">
          <p>Owner gates</p>
          <h2>Nothing sends without you.</h2>
          <ul>
            {guardrails.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="proof-card kg-card">
          <p>Find anything</p>
          <h2>Say it, type it, or tap it.</h2>
          <div class="route-list">
            <a href="/projects/proj_wegrzyn_kitchen">Open Wegrzyn kitchen</a>
            <a href="/estimate/proj_wegrzyn_kitchen/money">Show the money</a>
            <a href="/camera">Capture a photo</a>
          </div>
        </section>

        <section class="proof-card kg-card">
          <p>Offline work</p>
          <h2>Saved first. Synced when ready.</h2>
          <dl class="sync-list">
            <div>
              <dt>Field capture</dt>
              <dd>3 saved on device</dd>
            </div>
            <div>
              <dt>Office draft</dt>
              <dd>1 proposal held</dd>
            </div>
            <div>
              <dt>Books</dt>
              <dd>IIF export available</dd>
            </div>
          </dl>
        </section>
      </aside>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-connection]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.connection ?? '';
      const status = btn.dataset.status ?? 'not_wired';
      const msgEl = document.querySelector(`[data-status-for="${id}"]`);
      if (!(msgEl instanceof HTMLElement)) return;
      if (status === 'connected') {
        msgEl.textContent = 'This source is available to Right Hand. Admin changes require a fresh approval.';
      } else {
        msgEl.textContent = 'Setup request held for owner approval. No credentials were stored from this page.';
      }
    });
  });
</script>

<style>
  .connections-page {
    --conn-ink: var(--text, #191814);
    --conn-muted: var(--text-muted, #5f665f);
    --conn-panel: var(--surface, #fffdf8);
    --conn-panel-2: var(--surface-2, #f4f1e8);
    --conn-line: var(--border, #d9d4c7);
    --conn-green: var(--green, #0f7a53);
    --conn-gold: #a06f18;
    display: grid;
    gap: 1rem;
    color: var(--conn-ink);
  }

  .connections-crumb {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    color: var(--conn-muted);
  }

  .connections-crumb a {
    color: inherit;
    text-decoration: none;
  }

  .connections-hero {
    display: grid;
    gap: 0.75rem;
  }

  .connections-eyebrow,
  .connections-section-head p,
  .proof-card > p {
    margin: 0;
    color: var(--conn-muted);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .connections-hero h1 {
    margin: 0;
    max-width: 13ch;
    font-size: clamp(2.15rem, 8vw, 4.4rem);
    line-height: 0.92;
  }

  .connections-hero > p {
    margin: 0;
    max-width: 46rem;
    color: var(--conn-muted);
    font-size: 1.02rem;
    line-height: 1.5;
  }

  .connections-work {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
  }

  .connections-work div {
    min-height: 5.5rem;
    padding: 0.85rem;
    border: 1px solid var(--conn-line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--conn-panel) 92%, transparent), var(--conn-panel-2));
    box-shadow: 0 12px 26px rgba(21, 20, 17, 0.06);
  }

  .connections-work strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.65rem;
    line-height: 1;
  }

  .connections-work span {
    display: block;
    color: var(--conn-muted);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .connections-decision {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(13rem, 18rem);
    gap: 1rem;
    align-items: stretch;
    padding: 1rem;
    border-color: color-mix(in srgb, var(--conn-green) 36%, var(--conn-line));
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--conn-green) 9%, var(--conn-panel)), var(--conn-panel));
  }

  .connections-state,
  .source-chip {
    font-size: 0.72rem;
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
    padding: 0.28rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--conn-line);
  }

  .connections-state {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 0.7rem;
    color: #513806;
    border-color: color-mix(in srgb, var(--conn-gold) 55%, var(--conn-line));
    background: color-mix(in srgb, var(--conn-gold) 13%, var(--conn-panel));
  }

  .connections-decision h2,
  .proof-card h2,
  .connections-section-head h2 {
    margin: 0;
    line-height: 1.08;
  }

  .connections-decision p {
    margin: 0.5rem 0 0;
    color: var(--conn-muted);
    line-height: 1.45;
  }

  .connections-decision ul,
  .proof-card ul {
    display: grid;
    gap: 0.45rem;
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
    color: var(--conn-muted);
    line-height: 1.35;
  }

  .connections-decision li,
  .proof-card li {
    position: relative;
    padding-left: 1rem;
  }

  .connections-decision li::before,
  .proof-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.48em;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--conn-green);
  }

  .connections-decision__actions {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.65rem;
    padding: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--conn-green) 28%, var(--conn-line));
    border-radius: 8px;
    background: color-mix(in srgb, var(--conn-panel) 78%, var(--conn-green));
  }

  .connections-primary,
  .connections-secondary,
  .source-request {
    min-height: 2.75rem;
    border: 1px solid var(--conn-line);
    border-radius: 8px;
    font: inherit;
    font-weight: 900;
    text-decoration: none;
    cursor: pointer;
  }

  .connections-primary {
    background: var(--conn-green);
    border-color: var(--conn-green);
    color: #fff;
  }

  .connections-secondary {
    display: grid;
    place-items: center;
    background: var(--conn-panel);
    color: var(--conn-ink);
  }

  .connections-decision__actions p,
  .source-status {
    min-height: 1.1rem;
    margin: 0;
    color: var(--conn-muted);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .connections-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 22rem);
    gap: 1rem;
    align-items: start;
  }

  .connections-main,
  .connections-section,
  .connections-proof {
    display: grid;
    gap: 0.8rem;
  }

  .connections-section-head {
    display: grid;
    gap: 0.2rem;
  }

  .connections-ready-list,
  .connections-queue-list {
    display: grid;
    gap: 0.6rem;
  }

  .source-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem;
    border: 1px solid var(--conn-line);
    border-radius: 8px;
    background: var(--conn-panel);
  }

  .source-row--ready {
    grid-template-columns: auto minmax(0, 1fr);
    border-color: color-mix(in srgb, var(--conn-green) 30%, var(--conn-line));
  }

  .source-badge {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--conn-line);
    border-radius: 8px;
    background: var(--conn-panel-2);
    color: var(--conn-ink);
    font-size: 0.68rem;
    font-weight: 950;
  }

  .source-copy {
    display: grid;
    gap: 0.28rem;
    min-width: 0;
  }

  .source-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .source-topline h3 {
    min-width: 0;
    margin: 0;
    font-size: 1rem;
    line-height: 1.15;
  }

  .source-copy p,
  .source-copy small {
    margin: 0;
    color: var(--conn-muted);
    line-height: 1.35;
  }

  .source-copy small {
    font-size: 0.78rem;
    font-weight: 700;
  }

  .source-chip.is-ready,
  .source-chip.is-connected {
    color: #0f5132;
    border-color: color-mix(in srgb, var(--conn-green) 55%, var(--conn-line));
    background: color-mix(in srgb, var(--conn-green) 12%, var(--conn-panel));
  }

  .source-chip.is-not_connected {
    color: #664500;
    border-color: color-mix(in srgb, var(--conn-gold) 55%, var(--conn-line));
    background: color-mix(in srgb, var(--conn-gold) 12%, var(--conn-panel));
  }

  .source-chip.is-not_wired {
    color: var(--conn-muted);
    border-style: dashed;
    background: var(--conn-panel-2);
  }

  .source-request {
    align-self: stretch;
    min-width: 5.75rem;
    padding: 0 0.75rem;
    background: var(--conn-panel-2);
    color: var(--conn-ink);
  }

  .proof-card {
    display: grid;
    gap: 0.65rem;
    padding: 0.9rem;
  }

  .route-list {
    display: grid;
    gap: 0.45rem;
  }

  .route-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 2.6rem;
    padding: 0.55rem 0.65rem;
    border: 1px solid var(--conn-line);
    border-radius: 8px;
    background: var(--conn-panel-2);
    color: var(--conn-ink);
    font-weight: 900;
    text-decoration: none;
  }

  .route-list a::after {
    content: '>';
    color: var(--conn-muted);
  }

  .sync-list {
    display: grid;
    gap: 0.5rem;
    margin: 0;
  }

  .sync-list div {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-top: 1px solid var(--conn-line);
  }

  .sync-list dt,
  .sync-list dd {
    margin: 0;
    font-size: 0.85rem;
  }

  .sync-list dt {
    font-weight: 900;
  }

  .sync-list dd {
    color: var(--conn-muted);
    text-align: right;
  }

  @media (prefers-color-scheme: dark) {
    .connections-page {
      --conn-gold: #d8a13a;
    }

    .connections-state {
      color: #f3d99b;
    }

    .source-chip.is-ready,
    .source-chip.is-connected {
      color: #b9f3d5;
    }

    .source-chip.is-not_connected {
      color: #ffe2a0;
    }
  }

  @media (max-width: 820px) {
    .connections-work,
    .connections-decision,
    .connections-layout {
      grid-template-columns: 1fr;
    }

    .connections-hero h1 {
      max-width: 11ch;
    }
  }

  @media (max-width: 560px) {
    .connections-page {
      gap: 0.85rem;
    }

    .connections-work {
      grid-template-columns: 1fr;
    }

    .connections-work div {
      min-height: auto;
    }

    .source-row {
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
    }

    .source-request {
      grid-column: 1 / -1;
      width: 100%;
    }

    .source-topline {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
