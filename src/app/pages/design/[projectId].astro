---
// F-DES1a / F-DS1 · Design workspace · /design/:projectId
import Layout from '../../layouts/Layout.astro';
import { createLayoutContext } from '../../lib/createLayoutContext.js';
import {
  getSalesStore,
  selectionsForProject,
  catalogItemById,
  toSelectionView,
  catalogUnitCents,
} from '../../../sales/index.js';
import '../../styles/intake-sales-wireframes.css';

const { context } = createLayoutContext();
const tenant = context.tenantId;
const projectId = Astro.params.projectId ?? '';
const dealId = projectId.replace(/^proj_/, '');
const store = getSalesStore(tenant);
const libraryItems = store.items.filter((i) => i.collection === 'selections');
const selections = selectionsForProject(tenant, projectId).map((s) =>
  toSelectionView(s, { tenant, label: catalogItemById(tenant, s.library_ref)?.label ?? s.library_ref }),
);
const approvedSelections = selections.filter((s) => s.lifecycle === 'approved');
const fmt = (cents: number) => `$${(cents / 100).toLocaleString('en-US', { maximumFractionDigits: 0 })}`;

const TABS = [
  { id: 'scope', label: 'Scope' },
  { id: 'selections', label: 'Selections' },
  { id: 'questions', label: 'Questions' },
  { id: 'model', label: '3D model' },
  { id: 'integrations', label: 'Integrations' },
] as const;
---

<Layout
  title="Design workspace"
  activeHref="/sales"
  surfaceContext={{
    surface: 'design',
    project_id: projectId,
    phase: 'review_gate',
  }}
>
  <article class="rh-design kg-grid" data-grammar="canon" data-project={projectId}>
    <header class="kg-pagehead kg-span-12">
      <div>
        <a class="ds-back" href={`/sales/${dealId}`}>‹ Deal</a>
        <p class="rh-eyebrow">F-DES1 / F-DS1 · Deal to estimate bridge</p>
        <h1 class="rh-title">Design workspace</h1>
        <p class="rh-subtitle">
          Collect selections, scope assumptions, and open questions before the estimate.
          Right Hand can organize the work, but estimate lines are created only when the operator builds the estimate.
        </p>
      </div>
      <div class="rh-chiprow" aria-label="Design state">
        <span class="kg-chip kg-routechip">Review gate</span>
        <span class="kg-chip">No money write</span>
        <span class="kg-chip green">{approvedSelections.length} approved</span>
      </div>
    </header>

    <section class="kg-span-8 rh-stack">
      <section class="kg-card">
        <p class="rh-eyebrow">Selections before price</p>
        <h2>Project direction</h2>
        <p class="rh-note">
          Pull library items onto the board, approve the choices that belong to the job, then build the estimate from the same project context.
        </p>
        <div class="rh-design-tabs" role="tablist">
          {TABS.map((tab) => (
            <button class="rh-tab" type="button" data-tab={tab.id} aria-selected={tab.id === 'selections' ? 'true' : 'false'}>
              {tab.label}
            </button>
          ))}
        </div>
      </section>

      <section class="rh-panel" data-panel="selections">
        <div class="rh-design-board">
          <div class="rh-stack">
            <div>
              <div class="kg-pagehead">
                <div>
                  <p class="rh-label">Pull from library</p>
                  <p class="rh-note">Library items become proposed project selections. Approval is a visible review gate.</p>
                </div>
                <a class="rh-btn" href="/library">Open KB</a>
              </div>
            </div>
            <div class="rh-list">
              {libraryItems.length === 0 ? (
                <p class="rh-note">No catalog selections are available.</p>
              ) : null}
              {libraryItems.map((item) => (
                <div class="rh-list-row">
                  <span class="rh-swatch" aria-hidden="true"></span>
                  <div>
                    <strong>{item.label}</strong>
                    <small>{item.line_type} · {fmt(catalogUnitCents(item))}/{item.uom}</small>
                  </div>
                  <button class="rh-btn pull" type="button" data-item={item.id}>Pull</button>
                </div>
              ))}
            </div>
          </div>

          <aside class="kg-card">
            <p class="rh-eyebrow">On this job</p>
            <div class="rh-list">
              {selections.length === 0 ? (
                <p class="rh-note">Nothing pulled yet. Pull a selection from the library before pricing.</p>
              ) : null}
              {selections.map((sel) => (
                <div class="rh-list-row">
                  <div>
                    <strong>{sel.label}</strong>
                    <small>{sel.line_type} · {fmt(sel.amount_cents)} · {sel.lifecycle}</small>
                  </div>
                  {sel.lifecycle === 'proposed' ? (
                    <button class="rh-btn approve" type="button" data-sel={sel.id}>Approve</button>
                  ) : (
                    <span class="rh-status">Approved</span>
                  )}
                </div>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <section class="rh-panel" data-panel="scope" hidden>
        <div class="rh-stack">
          <section class="kg-card">
            <h2>Scope assumptions</h2>
            <p class="rh-note">Use this space for design assumptions that can seed estimate lines after review.</p>
            <div class="rh-chiprow rh-rule">
              <span class="kg-chip green">Client liked</span>
              <span class="kg-chip amber">Needs allowance</span>
            </div>
          </section>
          <section class="kg-card">
            <h2>Kitchenette direction</h2>
            <p class="rh-note">Warm white slab door, quartz top, compact appliance wall.</p>
          </section>
        </div>
      </section>

      <section class="rh-panel" data-panel="questions" hidden>
        <section class="kg-card">
          <h2>Open question</h2>
          <p class="rh-note">Appliance allowance is not priced. Ask only for the missing number before proposal.</p>
          <div class="rh-chiprow rh-rule">
            <span class="kg-chip red">Gap</span>
            <span class="kg-chip">Honest escalation</span>
          </div>
        </section>
      </section>

      <section class="rh-panel" data-panel="model" hidden>
        <section class="kg-card">
          <h2>3D model</h2>
          <p class="rh-note">Room capture and LiDAR context attach here when present. No model is fabricated.</p>
        </section>
      </section>

      <section class="rh-panel" data-panel="integrations" hidden>
        <section class="kg-card">
          <h2>Integrations</h2>
          <p class="rh-note">Bluebeam, RoomPlan, and library connections route through the connections registry.</p>
        </section>
      </section>
    </section>

    <aside class="kg-card kg-span-4">
      <p class="rh-eyebrow">Allowed next</p>
      <dl class="rh-route-list">
        <div>
          <dt>Build estimate</dt>
          <dd>Opens F-EST1 with this project context. Estimate publication still needs operator confirmation.</dd>
        </div>
        <div>
          <dt>Back deal</dt>
          <dd>Returns to the sales/deal face that owns the opportunity.</dd>
        </div>
        <div>
          <dt>Library</dt>
          <dd>Source items come from the knowledge/library surface, then approve into this project.</dd>
        </div>
      </dl>
      <div class="rh-actions">
        <a class="rh-btn primary" href={`/estimate/${projectId}`}>Build estimate</a>
        <a class="rh-btn" href="/right-hand">Ask Right Hand</a>
      </div>
    </aside>
  </article>
</Layout>

<script>
  const root = document.querySelector('.rh-design');
  const projectId = root?.getAttribute('data-project') || '';

  function showTab(id) {
    document.querySelectorAll('.rh-tab').forEach((button) => {
      button.setAttribute('aria-selected', button.getAttribute('data-tab') === id ? 'true' : 'false');
    });
    document.querySelectorAll('.rh-panel').forEach((panel) => {
      panel.hidden = panel.getAttribute('data-panel') !== id;
    });
  }

  document.querySelectorAll('.rh-tab').forEach((button) => {
    button.addEventListener('click', () => showTab(button.getAttribute('data-tab') || 'selections'));
  });

  async function durableWrite(url, confirmMsg) {
    if (!confirm(confirmMsg)) return false;
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ confirmed: true }),
    });
    if (!res.ok) {
      const text = await res.text();
      alert('Write failed (' + res.status + '): ' + text);
      return false;
    }
    return true;
  }

  document.querySelectorAll('.rh-btn.pull').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const itemId = btn.getAttribute('data-item');
      if (!confirm('Pull this Selection onto the job?')) return;
      const res = await fetch(`/api/v1/design/${projectId}/pull`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ confirmed: true, item_id: itemId }),
      });
      if (res.ok) window.location.reload();
      else alert('Pull failed (' + res.status + ').');
    });
  });

  document.querySelectorAll('.rh-btn.approve').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const selId = btn.getAttribute('data-sel');
      const ok = await durableWrite(
        `/api/v1/design/${projectId}/selections/${selId}/approve`,
        'Approve this Selection into the job?',
      );
      if (ok) window.location.reload();
    });
  });
</script>
