---
import Layout from '../layouts/Layout.astro';
import RhSummary from '../components/RhSummary.astro';
import Card from '../components/Card.astro';

const actions = [
  {
    href: '/',
    title: 'Back to Home',
    detail: 'See what Right Hand is holding for you and what needs attention.',
  },
  {
    href: '/field-capture',
    title: 'Add note or media',
    detail: 'Attach photos, videos, typed notes, or a follow-up capture.',
  },
  {
    href: '/projects',
    title: 'Open Projects',
    detail: 'Find the job before reviewing scope, field notes, or audit history.',
  },
  {
    href: '/draft-review',
    title: 'Review draft',
    detail: 'Open the current draft review path when an estimate or proposal is ready.',
  },
] as const;

// D-060 back-button rule + F-RH7 "travels, never parks": if we arrived here from
// a surface (return_to, e.g. the estimate's "Back to conversation"), offer the
// way back so this fallback is never a dead-end. Same-origin local paths only.
const returnToRaw = Astro.url.searchParams.get('return_to') ?? '';
const backHref =
  returnToRaw.startsWith('/') &&
  !returnToRaw.startsWith('//') &&
  !returnToRaw.includes('\\') &&
  !returnToRaw.includes('://')
    ? returnToRaw
    : '';
---

<Layout title="Right Hand" activeHref="/right-hand">
  <section class="rh-fallback" aria-labelledby="rh-fallback-title" data-grammar="canon">
    {backHref ? <a class="rh-fallback__back" href={backHref}>‹ Back</a> : null}
    <RhSummary
      headline="Right Hand"
      detail="Use the bottom mic to talk. This page is the fallback if the voice overlay does not open."
      tone="green"
    />

    <Card eyebrow="Next move" title="Where do you want to go?">
      <p class="rh-fallback__copy">
        Right Hand stays on the bottom mic. If you landed here, pick a surface
        and keep working; nothing has been filed or sent from this page.
      </p>
      <div class="rh-fallback__actions">
        {actions.map((action) => (
          <a class="rh-fallback__action" href={action.href}>
            <span>{action.title}</span>
            <small>{action.detail}</small>
          </a>
        ))}
      </div>
    </Card>
  </section>
</Layout>

<style>
  .rh-fallback {
    display: grid;
    gap: 0.85rem;
  }

  .rh-fallback__back {
    justify-self: start;
    color: var(--text-muted, #5c6670);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .rh-fallback__back:hover {
    color: var(--gold);
  }

  .rh-fallback__copy {
    margin: 0 0 0.85rem;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .rh-fallback__actions {
    display: grid;
    gap: 0.65rem;
  }

  .rh-fallback__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 10px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
  }

  .rh-fallback__action:hover {
    border-color: color-mix(in srgb, var(--gold) 45%, var(--border, #d8dee6));
  }

  .rh-fallback__action span {
    font-weight: 700;
  }

  .rh-fallback__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }
</style>
