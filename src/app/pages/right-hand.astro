---
import Layout from '../layouts/Layout.astro';
import RhSummary from '../components/RhSummary.astro';
import Card from '../components/Card.astro';

const actions = [
  {
    href: '/kb-ingestion',
    title: 'Review staged learning',
    detail: 'Approve or reject the costs, language, and lessons Right Hand wants to remember.',
  },
  {
    href: '/connections',
    title: 'Check sources',
    detail: 'See what Right Hand can use, what is connected, and what still needs setup.',
  },
  {
    href: '/blackboard',
    title: 'Open blackboard',
    detail: 'Review company learning, notes, and the work Right Hand keeps improving.',
  },
  {
    href: '/',
    title: 'Back to work',
    detail: 'Return home. Use the right rail to talk to Right Hand.',
  },
] as const;

// D-060 back-button rule + F-RH7 "travels, never parks": if we arrived here from
// a surface (return_to, e.g. the estimate's "Back to conversation"), offer the
// way back so this fallback is never a dead-end. Same-origin local paths only.
const returnToRaw = Astro.url.searchParams.get('return_to') ?? '';
const backHref =
  returnToRaw.startsWith('/') &&
  !returnToRaw.startsWith('//') &&
  !returnToRaw.includes('\\') &&
  !returnToRaw.includes('://')
    ? returnToRaw
    : '';
---

<Layout title="Right Hand learning" activeHref="/right-hand">
  <section class="rh-fallback" aria-labelledby="rh-fallback-title" data-grammar="canon">
    {backHref ? <a class="rh-fallback__back" href={backHref}>‹ Back</a> : null}
    <RhSummary
      headline="Right Hand"
      detail="On desktop, talk or type in the rail on the right. Capture stays in Camera."
      tone="blue"
    />

    <Card eyebrow="Learning" title="How Right Hand works">
      <p class="rh-fallback__copy">
        Tell Right Hand what happened. It can draft, route, summarize, and prepare
        the work. Sends, money, files, and approvals still come back for your call.
      </p>
      <div class="rh-fallback__actions">
        {actions.map((action) => (
          <a class="rh-fallback__action" href={action.href}>
            <span>{action.title}</span>
            <small>{action.detail}</small>
          </a>
        ))}
      </div>
    </Card>
  </section>
</Layout>

<style>
  .rh-fallback {
    display: grid;
    gap: 0.85rem;
  }

  .rh-fallback__back {
    justify-self: start;
    color: var(--text-muted, #5c6670);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .rh-fallback__back:hover {
    color: var(--gold);
  }

  .rh-fallback__copy {
    margin: 0 0 0.85rem;
    color: var(--text-muted, #5c6670);
    line-height: 1.45;
  }

  .rh-fallback__actions {
    display: grid;
    gap: 0.65rem;
  }

  .rh-fallback__action {
    display: grid;
    gap: 0.15rem;
    padding: 0.85rem;
    border: 1px solid var(--border, #d8dee6);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: var(--surface, #fff);
    box-shadow: 0 10px 24px rgba(24, 23, 19, 0.06);
  }

  .rh-fallback__action:hover {
    border-color: color-mix(in srgb, var(--gold) 45%, var(--border, #d8dee6));
  }

  .rh-fallback__action span {
    font-weight: 700;
  }

  .rh-fallback__action small {
    color: var(--text-muted, #5c6670);
    line-height: 1.35;
  }
</style>
