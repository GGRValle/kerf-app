---
import '../styles/shell.css';
import SpeakFAB from '../components/SpeakFAB.astro';
import { navForRole } from '../lib/nav.js';
import { DEFAULT_ROLE_ROOT_CONTEXT, type LayoutProps } from '../lib/layout-props.js';

export interface Props extends Partial<LayoutProps> {
  title?: string;
  activeHref?: string;
}

const {
  title = 'Kerf',
  activeHref = '/',
  context = DEFAULT_ROLE_ROOT_CONTEXT,
} = Astro.props as Props;

const navItems = navForRole(context.roleRoot);
---

<!doctype html>
<html lang={context.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="kerf-shell" data-role-root={context.roleRoot} data-locale={context.locale} data-tenant={context.tenantId}>
      <header class="kerf-topbar">
        <a class="kerf-brand" href="/">{title === 'Kerf' ? 'Kerf' : `Kerf · ${title}`}</a>
        <nav class="kerf-nav" aria-label="Primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['kerf-nav-link', { active: activeHref === item.href || activeHref.startsWith(item.href + '/') }]}
              data-domain={item.domain}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </header>
      <main class="kerf-main">
        <slot />
      </main>
      <SpeakFAB />
    </div>
  </body>
</html>
