---
import '../styles/shell.css';
// Goal 0 — the canonical surface grammar (tokens + layout primitives extracted
// from the operable canon prototype). Loaded once here; scoped to
// [data-grammar="canon"] so it's inert until a surface opts in. See
// docs/SURFACE_GRAMMAR.md.
import '../styles/surface-grammar.css';
import '../../shell/surfaceCatalog.js';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import RightHandVoiceOverlay from '../components/RightHandVoiceOverlay.astro';
import RightHandConversationDock from '../components/RightHandConversationDock.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { navForContext } from '../lib/nav.js';
import { DEFAULT_ROLE_ROOT_CONTEXT, type LayoutProps, type RoleRoot } from '../lib/layout-props.js';
import { createSurfaceContext, type SurfaceContextInput } from '../lib/surfaceContext.js';
import type { I18nKey } from '../../i18n/keys.js';
import { readBuildStamp } from '../../shell/buildStamp.js';

export interface Props extends Partial<LayoutProps> {
  title?: string;
  titleKey?: I18nKey;
  activeHref?: string;
  surfaceContext?: SurfaceContextInput;
}

const {
  context = DEFAULT_ROLE_ROOT_CONTEXT,
  username,
  title,
  titleKey,
  activeHref = '/',
  surfaceContext,
} = Astro.props as Props;

const { t } = createLayoutContext({ username, locale: context.locale, roleRoot: context.roleRoot });
const navItems = navForContext(context);
const ROLE_LABEL_KEYS: Record<RoleRoot, I18nKey> = {
  owner: 'roleRoot.owner',
  pm: 'roleRoot.pm',
  admin_ops: 'roleRoot.admin_ops',
  field_hand: 'roleRoot.field_hand',
  sub: 'roleRoot.sub',
};
const pageTitle = titleKey ? t(titleKey) : (title ?? t('layout.brand'));
const rawOperatorName =
  username?.trim() ||
  (context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner' ? 'Christian Asdal' : context.roleRoot);
const accountOperatorName =
  context.tenantId === 'tenant_ggr' && /^christian$/i.test(rawOperatorName)
    ? 'Christian Asdal'
    : rawOperatorName;
const operatorName = accountOperatorName
  .replace(/[_-]+/g, ' ')
  .replace(/\b\w/g, (char) => char.toUpperCase());
const conversationOperatorName = operatorName.split(/\s+/).filter(Boolean)[0] ?? operatorName;
const operatorInitials =
  context.tenantId === 'tenant_ggr' && context.roleRoot === 'owner'
    ? 'CA'
    : operatorName
      .split(/\s+/)
      .filter(Boolean)
      .map((part) => part[0])
      .join('')
      .slice(0, 2)
      .toUpperCase() || 'CA';
const buildStamp = readBuildStamp();
const buildCommit = buildStamp.commit;
const buildDirty = String(buildStamp.dirty);
const emittedSurfaceContext = createSurfaceContext(
  context,
  surfaceContext ?? { surface: 'home', phase: 'today' },
);
const emittedSurfaceContextJson = JSON.stringify(emittedSurfaceContext);
---

<!doctype html>
<html lang={context.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="kerf-build-commit" content={buildCommit} />
    <meta name="kerf-build-dirty" content={buildDirty} />
    <title>{pageTitle}</title>
    {/* PWA install (Goal B PR-1): manifest + standalone chrome + home-screen icon. */}
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0A0D11" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Right Hand" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/180.png" />
  </head>
  <body data-active-href={activeHref}>
    <div
      class="kerf-shell kerf-shell--desktop-rh"
      data-role-root={context.roleRoot}
      data-locale={context.locale}
      data-tenant={context.tenantId}
      data-operator-name={conversationOperatorName}
      data-build-commit={buildCommit}
      data-build-dirty={buildDirty}
    >
      <script id="kerf-surface-context" type="application/json" set:html={emittedSurfaceContextJson}></script>
      <header class="kerf-topbar">
        <div class="kerf-topbar-lead">
          <a class="kerf-brand" href="/">
            <span>{t('right_hand.title')}</span>
            <span class="kerf-brand-tagline" data-tagline="From capture to completion.">{t('layout.brand_tagline')}</span>
          </a>
        </div>
        <nav class="kerf-nav" aria-label={t('layout.nav.primary')} id="kerf-primary-nav">
          {navItems.map((item) => {
            const isActive =
              activeHref === item.href ||
              (item.href !== '/' && activeHref.startsWith(item.href + '/'));
            return (
              <a
                href={item.href}
                class:list={['kerf-nav-link', { active: isActive }]}
                aria-current={isActive ? 'page' : undefined}
                data-domain={item.domain}
              >
                {t(item.labelKey)}
              </a>
            );
          })}
        </nav>
        <div class="kerf-role-chip kerf-role-chip--static" aria-label="Current access">
          <span class="kerf-role-chip__label">{t(ROLE_LABEL_KEYS[context.roleRoot])}</span>
        </div>
        <a class="kerf-signout" href="/logout">{t('layout.sign_out')}</a>
        <a class="kerf-topbar-rh" href="/settings/me" aria-label={`${operatorName} settings`}>
          <span aria-hidden="true">{operatorInitials}</span>
        </a>
      </header>
      <div class="kerf-shell__body">
        <main class="kerf-main">
          <slot />
        </main>
        <RightHandConversationDock />
      </div>
      <MobileBottomNav activeHref={activeHref} roleRoot={context.roleRoot} />
      <!-- One Right Hand bubble everywhere: the functional voice overlay
           (unified — the presentation-only F-RH7 .rhb was removed). -->
      <RightHandVoiceOverlay />
    </div>
    <script define:vars={{ emittedSurfaceContext }}>
      const SURFACE_PREVIOUS_KEY = 'kerf.surfaceContext.previous.v1';
      const surfaceContextEl = document.getElementById('kerf-surface-context');

      function parsePreviousSurfaceContext() {
        try {
          const raw = window.sessionStorage.getItem(SURFACE_PREVIOUS_KEY);
          if (!raw) return null;
          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed !== 'object') return null;
          if (typeof parsed.surface !== 'string') return null;
          if (!parsed.ids || typeof parsed.ids !== 'object') return null;
          return { surface: parsed.surface, ids: parsed.ids };
        } catch {
          return null;
        }
      }

      const surfaceContext = {
        ...emittedSurfaceContext,
        previous: parsePreviousSurfaceContext(),
      };

      if (surfaceContextEl) surfaceContextEl.textContent = JSON.stringify(surfaceContext);
      window.__KERF_SURFACE_CONTEXT__ = surfaceContext;
      window.sessionStorage.setItem(
        SURFACE_PREVIOUS_KEY,
        JSON.stringify({
          surface: surfaceContext.surface,
          ids: {
            client_id: surfaceContext.client_id,
            project_id: surfaceContext.project_id,
            estimate_id: surfaceContext.estimate_id,
            proposal_id: surfaceContext.proposal_id,
            invoice_id: surfaceContext.invoice_id,
            line_ids: surfaceContext.line_ids,
          },
        }),
      );
    </script>
    <script>
      const activeNav = document.querySelector('.kerf-nav-link.active');
      activeNav?.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'instant' });
    </script>
    <script is:inline>
      // PWA service-worker registration. Best-effort; install works once
      // /sw.js + /manifest.webmanifest are reachable. The SW cache is
      // build-stamped and never stores money/API responses.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js')
            .then((registration) => registration.update())
            .catch(() => {});
        });
      }
    </script>
  </body>
</html>
