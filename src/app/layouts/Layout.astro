---
import '../styles/shell.css';
import SpeakFAB from '../components/SpeakFAB.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import RightHandVoiceOverlay from '../components/RightHandVoiceOverlay.astro';
import { createLayoutContext } from '../lib/createLayoutContext.js';
import { navForContext } from '../lib/nav.js';
import { DEFAULT_ROLE_ROOT_CONTEXT, type LayoutProps } from '../lib/layout-props.js';
import type { I18nKey } from '../../i18n/keys.js';

export interface Props extends Partial<LayoutProps> {
  title?: string;
  titleKey?: I18nKey;
  activeHref?: string;
}

const {
  context = DEFAULT_ROLE_ROOT_CONTEXT,
  username,
  title,
  titleKey,
  activeHref = '/',
} = Astro.props as Props;

const { t } = createLayoutContext({ username, locale: context.locale });
const navItems = navForContext(context);
const pageTitle = titleKey ? t(titleKey) : (title ?? t('layout.brand'));
---

<!doctype html>
<html lang={context.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="kerf-shell" data-role-root={context.roleRoot} data-locale={context.locale} data-tenant={context.tenantId}>
      <header class="kerf-topbar">
        <div class="kerf-topbar-lead">
          <a class="kerf-brand" href="/">{t('layout.brand')}</a>
        </div>
        <nav class="kerf-nav" aria-label={t('layout.nav.primary')} id="kerf-primary-nav">
          {navItems.map((item) => {
            const isActive =
              activeHref === item.href ||
              (item.href !== '/' && activeHref.startsWith(item.href + '/'));
            return (
              <a
                href={item.href}
                class:list={['kerf-nav-link', { active: isActive }]}
                aria-current={isActive ? 'page' : undefined}
                data-domain={item.domain}
              >
                {t(item.labelKey)}
              </a>
            );
          })}
        </nav>
        <a class="kerf-topbar-rh" href="/right-hand" aria-label={t('layout.speak_fab.label')}>
          <span aria-hidden="true">RH</span>
        </a>
      </header>
      <main class="kerf-main">
        <slot />
      </main>
      <MobileBottomNav activeHref={activeHref} roleRoot={context.roleRoot} />
      <SpeakFAB />
      <RightHandVoiceOverlay />
    </div>
    <script>
      const activeNav = document.querySelector('.kerf-nav-link.active');
      activeNav?.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'instant' });
    </script>
  </body>
</html>
